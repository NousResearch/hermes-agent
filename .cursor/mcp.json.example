{
  "mcpServers": {
    "hermes": {
      "command": "${workspaceFolder}/hermes-mcp-serve",
      "args": [],
      "env": {
        "HERMES_HOME": "${env:HOME}/.hermes",
        "HERMES_REPO": "${workspaceFolder}",
        "HERMES_AGENTS_DIR": "/absolute/path/to/your-fleet/agents"
      }
    }
  }
}
