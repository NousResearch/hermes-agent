# =============================================================================
# Hermes 沙箱环境变量模板
# =============================================================================
# 复制为 .env.sandbox 并填写你的 API keys 和数据库密码。
# 启动命令：source .env.sandbox && docker compose -f docker-compose.sandbox.yml up -d
# =============================================================================

# ---------------------------------------------------------------------------
# 权限映射（可选）
# 默认使用当前用户的 UID/GID，保持容器内文件与宿主机权限一致
# ---------------------------------------------------------------------------
# HERMES_UID=1000
# HERMES_GID=1000

# ---------------------------------------------------------------------------
# 数据库密码（强烈建议修改默认值）
# ---------------------------------------------------------------------------
MySQL_USER=root
MYSQL_PASSWORD=root_password
POSTGRES_USER=mcp_user
POSTGRES_PASSWORD=sugpar-5rygqi-fugwuF

# ---------------------------------------------------------------------------
# LLM API Keys（至少填写一个才能正常使用 Agent）
# ---------------------------------------------------------------------------
# OpenRouter（推荐，支持最多模型）
# OPENROUTER_API_KEY=sk-or-v1-...

# Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI
# OPENAI_API_KEY=sk-...

# Google Gemini
# GOOGLE_API_KEY=...
# GEMINI_API_KEY=...

# 其他 provider keys...
# 完整列表参考 .env.example

# ---------------------------------------------------------------------------
# Gateway / Dashboard（仅在沙箱内运行网关时需要）
# ---------------------------------------------------------------------------
# API_SERVER_KEY=your_secret_api_key_for_gateway

# ---------------------------------------------------------------------------
# 外部已有数据库（如果你不想用 compose 内的数据库）
# 修改 docker-compose.sandbox.yml 中 hermes 服务的 environment 即可
# ---------------------------------------------------------------------------
