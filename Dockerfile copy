FROM debian:13.4

# Disable Python stdout buffering to ensure logs are printed immediately
ENV PYTHONUNBUFFERED=1

ENV USERNAME=hermes
ENV UID=1000

# --- Set up non-root user with given username ---
RUN groupadd -g ${UID} ${USERNAME} && \
    useradd -m -u ${UID} -g ${USERNAME} -s /bin/bash ${USERNAME} && \
    echo "${USERNAME} ALL=(ALL) NOPASSWD: ALL" >> /etc/sudoers

# Install system dependencies in one layer, clear APT cache
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        bash curl git build-essential nodejs npm python3 python3-pip ripgrep ffmpeg gcc python3-dev libffi-dev procps && \
    rm -rf /var/lib/apt/lists/*

#Install ttyd
RUN ARCH=$(uname -m) && \
    curl -sL https://github.com/tsl0922/ttyd/releases/latest/download/ttyd.${ARCH} -o /usr/local/bin/ttyd && \
    chmod +x /usr/local/bin/ttyd

#Copy source to /opt/hermes
COPY . /opt/hermes
WORKDIR /opt/hermes

#Make /root bin folder
RUN mkdir -p /root/.local/bin
ENV PATH="/root/.local/bin:$PATH"

#Get uv prebuilt executable
COPY --from=ghcr.io/astral-sh/uv:0.11.6 /uv /uvx /bin/

#Build
RUN uv venv /opt/hermes/.venv --python 3.11 && \
    . /opt/hermes/.venv/bin/activate && \
    uv pip install -e ".[all]" && \
    npm install --prefer-offline --no-audit && \
    npx playwright install --with-deps chromium --only-shell && \
    cd /opt/hermes/scripts/whatsapp-bridge && \
    npm install --prefer-offline --no-audit && \
    npm cache clean --force
    #uv pip install -e "./tinker-atropos"

WORKDIR /opt/hermes
#Not needed in this setup flow but leftover from main branch
RUN chmod +x /opt/hermes/docker/entrypoint.sh

#RUN mkdir -p /root/
#RUN printf '#!/bin/bash\n. /opt/hermes/.venv/bin/activate\ncd /opt/hermes\nhermes\n' > /root/start-hermes.sh \
#    && chmod +x /root/start-hermes.sh

#Symbolic link to hermes executable
RUN ln -sf "/opt/hermes/.venv/bin/hermes" /root/.local/bin/hermes

ENV HERMES_HOME=/opt/data
VOLUME [ "/opt/data" ]
WORKDIR /opt/data
#CMD ["bin/bash" "-c", "hermes gateway run"]
#ENTRYPOINT [ "/root/.hermes/start-hermes.sh" ]
#CMD ["/bin/bash", "-c", "/root/start-hermes.sh"]
#CMD ["/bin/bash", "-c", "gateway run"]
EXPOSE 7681
