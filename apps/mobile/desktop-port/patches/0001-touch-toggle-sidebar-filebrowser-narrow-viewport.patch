diff --git a/apps/desktop/src/store/layout.ts b/apps/desktop/src/store/layout.ts
index b168e35..c45491b 100644
--- a/apps/desktop/src/store/layout.ts
+++ b/apps/desktop/src/store/layout.ts
@@ -1,5 +1,8 @@
 import { atom, computed, type ReadableAtom } from 'nanostores'
 
+import { SIDEBAR_COLLAPSE_MEDIA_QUERY } from '@/app/layout-constants'
+import { PANE_TOGGLE_REVEAL_EVENT } from '@/components/pane-shell'
+import { matchesQuery } from '@/hooks/use-media-query'
 import { Codecs, persistentAtom } from '@/lib/persisted'
 import { arraysEqual, insertUniqueId } from '@/lib/storage'
 
@@ -187,11 +190,31 @@ export function setSidebarOpen(open: boolean) {
   setPaneOpen(CHAT_SIDEBAR_PANE_ID, open)
 }
 
+// Narrow width (SIDEBAR_COLLAPSE_MEDIA_QUERY, ≤768px): both rails render as
+// force-collapsed hover-reveal overlays (see desktop-controller's
+// `forceCollapsed={narrowViewport}`), so flipping the docked `open` state alone
+// has no visible effect — paneIsOpen() masks it regardless. On a touch device
+// there's no hover to reveal them either, so the titlebar toggle buttons (which
+// call these two functions) would be dead taps. Pin the hover-reveal open via
+// PANE_TOGGLE_REVEAL_EVENT instead, exactly like the review pane's tap path
+// (toggleReview in store/review.ts) and the mod+b/mod+j keybind handlers.
 export function toggleSidebarOpen() {
+  if (matchesQuery(SIDEBAR_COLLAPSE_MEDIA_QUERY)) {
+    window.dispatchEvent(new CustomEvent(PANE_TOGGLE_REVEAL_EVENT, { detail: { id: CHAT_SIDEBAR_PANE_ID } }))
+
+    return
+  }
+
   togglePane(CHAT_SIDEBAR_PANE_ID)
 }
 
 export function toggleFileBrowserOpen() {
+  if (matchesQuery(SIDEBAR_COLLAPSE_MEDIA_QUERY)) {
+    window.dispatchEvent(new CustomEvent(PANE_TOGGLE_REVEAL_EVENT, { detail: { id: FILE_BROWSER_PANE_ID } }))
+
+    return
+  }
+
   togglePane(FILE_BROWSER_PANE_ID)
 }
 
