#!/bin/bash
#
# ARGUS Control Script
# Manages the ARGUS daemon (start, stop, status, restart)
# The Hundred-Eyed Watchman
#
# Uses hermes-native patterns:
#   - PID file management (same as gateway/status.py)
#   - launchd integration (same as gateway.py)
#

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ARGUS_SCRIPT="$SCRIPT_DIR/../argus.py"
LOG_DIR="$HOME/hermes/logs/argus"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Helper functions
log_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

log_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

log_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# Check if running (uses Python PID file check — same as gateway)
is_running() {
    python3 -c "
import sys, os, json
pid_path = os.path.expanduser('~/hermes/data/watcher/argus.pid')
if not os.path.exists(pid_path):
    sys.exit(1)
try:
    record = json.loads(open(pid_path).read().strip())
    pid = int(record.get('pid', 0))
    os.kill(pid, 0)
    sys.exit(0)
except (ValueError, json.JSONDecodeError, ProcessLookupError, OSError):
    sys.exit(1)
" 2>/dev/null
}

# Start Argus
start_argus() {
    log_info "Starting ARGUS..."

    if is_running; then
        log_warning "ARGUS is already running"
        return 0
    fi

    # Run in background
    nohup python3 "$ARGUS_SCRIPT" >> "$LOG_DIR/argus.nohup.log" 2>&1 &
    local pid=$!

    # Wait for PID file to appear
    local attempts=0
    while [ $attempts -lt 10 ]; do
        if is_running; then
            log_success "ARGUS started (PID: $(python3 -c "import json; print(json.load(open(os.path.expanduser('~/hermes/data/watcher/argus.pid')))['pid'])" 2>/dev/null || echo "$pid"))"
            return 0
        fi
        sleep 1
        attempts=$((attempts + 1))
    done

    log_error "ARGUS failed to start (no PID file after 10s)"
    return 1
}

# Stop Argus
stop_argus() {
    log_info "Stopping ARGUS..."

    if ! is_running; then
        log_warning "ARGUS is not running"
        # Clean up stale PID file
        rm -f ~/hermes/data/watcher/argus.pid 2>/dev/null
        return 0
    fi

    # Get PID from file
    local pid
    pid=$(python3 -c "
import json, os
record = json.load(open(os.path.expanduser('~/hermes/data/watcher/argus.pid')))
print(record['pid'])
" 2>/dev/null)

    if [ -n "$pid" ]; then
        kill -TERM "$pid" 2>/dev/null || true

        # Wait for process to exit
        local attempts=0
        while [ $attempts -lt 10 ] && kill -0 "$pid" 2>/dev/null; do
            sleep 1
            attempts=$((attempts + 1))
        done

        # Force kill if still alive
        if kill -0 "$pid" 2>/dev/null; then
            kill -9 "$pid" 2>/dev/null || true
        fi
    fi

    # Clean up PID file
    rm -f ~/hermes/data/watcher/argus.pid 2>/dev/null

    log_success "ARGUS stopped"
}

# Restart Argus
restart_argus() {
    log_info "Restarting ARGUS..."
    stop_argus
    sleep 1
    start_argus
}

# Show status
show_status() {
    echo "=== ARGUS Status ==="
    echo "The Hundred-Eyed Watchman"
    echo ""

    # Use Python status check (same pattern as gateway)
    python3 -c "
import sys, os, json

pid_path = os.path.expanduser('~/hermes/data/watcher/argus.pid')
db_path = os.path.expanduser('~/hermes/data/watcher/argus.db')
log_dir = os.path.expanduser('~/hermes/logs/argus')

# PID status
if os.path.exists(pid_path):
    try:
        record = json.load(open(pid_path))
        pid = record.get('pid', 0)
        try:
            os.kill(pid, 0)
            print(f'  Status:     RUNNING (PID {pid})')
            print(f'  Started:    {record.get(\"start_time\", \"unknown\")}')
        except (ProcessLookupError, OSError):
            print(f'  Status:     STALE PID file (process {pid} not found)')
    except (json.JSONDecodeError, ValueError):
        print('  Status:     CORRUPT PID file')
else:
    print('  Status:     STOPPED')

# Database stats
if os.path.exists(db_path):
    import sqlite3
    conn = sqlite3.connect(db_path)
    cur = conn.cursor()
    try:
        cur.execute('SELECT COUNT(*) FROM sessions WHERE status=\"active\"')
        active = cur.fetchone()[0]
        cur.execute('SELECT COUNT(*) FROM entropy_detections WHERE timestamp > datetime(\"now\", \"-24 hours\")')
        detections_24h = cur.fetchone()[0]
        cur.execute('SELECT COUNT(*) FROM watcher_actions WHERE timestamp > datetime(\"now\", \"-24 hours\")')
        actions_24h = cur.fetchone()[0]
        print(f'  DB:         {db_path}')
        print(f'  Active:     {active} sessions')
        print(f'  Entropy:    {detections_24h} detections (24h)')
        print(f'  Actions:    {actions_24h} actions (24h)')
    except Exception as e:
        print(f'  DB error:   {e}')
    conn.close()
else:
    print('  DB:         not found')

# Log status
argus_log = os.path.join(log_dir, 'argus.log')
if os.path.exists(argus_log):
    size = os.path.getsize(argus_log)
    print(f'  Log:        {argus_log} ({size / 1024:.1f} KB)')
else:
    print(f'  Log:        not found')
"

    echo ""

    # Recent logs
    if [ -f "$LOG_DIR/argus.log" ]; then
        echo "=== Recent Logs (last 5 lines) ==="
        tail -5 "$LOG_DIR/argus.log"
    fi
}

# Show logs
show_logs() {
    if [ -f "$LOG_DIR/argus.log" ]; then
        tail -f "$LOG_DIR/argus.log"
    else
        log_error "Log file not found: $LOG_DIR/argus.log"
    fi
}

# Show database
show_database() {
    local db_path="$HOME/hermes/data/watcher/argus.db"
    if [ -f "$db_path" ]; then
        echo "=== Watcher Database ==="
        echo ""
        echo "Sessions:"
        sqlite3 "$db_path" "SELECT session_id, session_type, status, restart_count, kill_count FROM sessions ORDER BY started_at DESC LIMIT 10;" 2>/dev/null || echo "N/A"
        echo ""
        echo "Recent Actions:"
        sqlite3 "$db_path" "SELECT session_id, action_type, action_reason, timestamp FROM watcher_actions ORDER BY timestamp DESC LIMIT 10;" 2>/dev/null || echo "N/A"
        echo ""
        echo "Entropy Detections:"
        sqlite3 "$db_path" "SELECT session_id, entropy_type, severity, detection_count FROM entropy_detections ORDER BY timestamp DESC LIMIT 10;" 2>/dev/null || echo "N/A"
    else
        log_error "Database not found: $db_path"
    fi
}

# Install Argus (launchd)
install_argus() {
    log_info "Installing ARGUS..."

    # Create directories
    mkdir -p "$LOG_DIR"
    mkdir -p "$HOME/hermes/data/watcher"

    # Initialize database
    local db_path="$HOME/hermes/data/watcher/argus.db"
    if [ ! -f "$db_path" ]; then
        log_info "Initializing database..."
        sqlite3 "$db_path" < "$SCRIPT_DIR/../scripts/watcher/watcher_schema.sql"
        log_success "Database initialized"
    fi

    # Make script executable
    chmod +x "$ARGUS_SCRIPT"

    # Generate and install launchd plist (same pattern as hermes gateway)
    python3 -c "
import sys
sys.path.insert(0, '$SCRIPT_DIR/../scripts/watcher')
from argus import argus_launchd_install
success = argus_launchd_install()
sys.exit(0 if success else 1)
"
    if [ $? -eq 0 ]; then
        log_success "ARGUS installed as launchd service"
    else
        log_error "Failed to install launchd service"
        log_info "Falling back to manual start: argus-control start"
    fi
}

# Uninstall Argus
uninstall_argus() {
    log_info "Uninstalling ARGUS..."

    # Stop first
    stop_argus

    # Remove launchd service
    python3 -c "
import sys
sys.path.insert(0, '$SCRIPT_DIR/../scripts/watcher')
from argus import argus_launchd_uninstall
argus_launchd_uninstall()
" 2>/dev/null

    log_success "ARGUS uninstalled"
    log_warning "Database and logs preserved at: ~/hermes/data/watcher/, ~/hermes/logs/argus/"
}

# Show help
show_help() {
    echo "ARGUS Control Script"
    echo "The Hundred-Eyed Watchman"
    echo ""
    echo "Usage: argus-control [command]"
    echo ""
    echo "Commands:"
    echo "  start      Start ARGUS daemon (background)"
    echo "  stop       Stop ARGUS daemon"
    echo "  restart    Restart ARGUS daemon"
    echo "  status     Show ARGUS status and stats"
    echo "  logs       Tail the ARGUS logs"
    echo "  database   Show database contents"
    echo "  install    Install as launchd service"
    echo "  uninstall  Stop and uninstall launchd service"
    echo "  help       Show this help message"
    echo ""
    echo "Hermes-native patterns:"
    echo "  - PID file: ~/hermes/data/watcher/argus.pid"
    echo "  - launchd:  ~/Library/LaunchAgents/com.hermes.argus.plist"
    echo "  - Logging:  RotatingFileHandler (5MB, 3 backups)"
}

# Main command handler
case "${1:-help}" in
    start)
        start_argus
        ;;
    stop)
        stop_argus
        ;;
    restart)
        restart_argus
        ;;
    status)
        show_status
        ;;
    logs)
        show_logs
        ;;
    database)
        show_database
        ;;
    install)
        install_argus
        ;;
    uninstall)
        uninstall_argus
        ;;
    help|--help|-h)
        show_help
        ;;
    *)
        log_error "Unknown command: $1"
        show_help
        exit 1
        ;;
esac