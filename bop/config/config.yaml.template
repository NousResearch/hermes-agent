# BuiltOnPurpose Hermes v4 guardrails template.
# Secrets belong in ~/.hermes/.env or Hermes auth stores, not in this file.

model:
  provider: "anthropic"
  default: "claude-sonnet-5"

platform_toolsets:
  cli: [hermes-cli]
  # A1 restriction: Telegram stays limited to file, skills, and todo.
  # Add gcal/gmail only during A3/A4 acceptance after MCP tool review.
  telegram: [file, skills, todo]

# Telegram secrets live in ~/.hermes/.env, not config.yaml:
# TELEGRAM_BOT_TOKEN=<bot-token>
# TELEGRAM_ALLOWED_USERS=<comma-separated-user-ids>

# A3/A4 MCP placeholders only. Package choice and OAuth happen with Mike.
# Use `hermes mcp add ...` then `hermes mcp configure <name>` / `hermes tools`.
# tools.include is REQUIRED - an mcp_servers entry with NO tools key registers ALL of that server's tools (update/delete/send included). Never add a server entry without it.
# mcp_servers:
#   gcal:
#     command: "<stdio-command>"
#     args:
#       - "<arg>"
#     env:
#       <ENV_VAR_NAME>: "${<ENV_VAR_NAME>}"
#     tools:
#       include:
#         - list-calendars
#         - list-events
#         - create-event
#   gmail:
#     command: "<stdio-command>"
#     args:
#       - "<arg>"
#     env:
#       <ENV_VAR_NAME>: "${<ENV_VAR_NAME>}"
#     tools:
#       include:
#         - search
#         - read
#         - create_draft
#         - list_labels

approvals:
  mode: manual
  cron_mode: deny

hooks_auto_accept: true

hooks:
  pre_tool_call:
    - matcher: "write_file|patch"
      command: "~/.hermes/agent-hooks/write-fence.sh"
      timeout: 10
    - matcher: "terminal"
      command: "~/.hermes/agent-hooks/repo-guard.sh"
      timeout: 10

auxiliary:
  vision:
    provider: codex
  web_extract:
    provider: codex

delegation:
  provider: openai-codex
  model: gpt-5.4-mini

stt:
  enabled: true
  provider: local
