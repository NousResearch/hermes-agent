# Hermes WebUI ↔ Hermes agent integration (Windows)
# Copy to your hermes-webui checkout as .env (merge with existing values).
# Use forward slashes or escaped backslashes in paths.

HERMES_HOME=C:/Users/<you>/.hermes
HERMES_CONFIG_PATH=C:/Users/<you>/.hermes/config.yaml

# Point WebUI at the Hermes agent repo (must contain run_agent.py)
HERMES_WEBUI_AGENT_DIR=C:/path/to/hermes-agent
HERMES_WEBUI_PYTHON=C:/path/to/hermes-agent/.venv/Scripts/python.exe

HERMES_WEBUI_STATE_DIR=C:/Users/<you>/.hermes/webui
HERMES_WEBUI_HOST=127.0.0.1
HERMES_WEBUI_PORT=8787
HERMES_WEBUI_DEFAULT_WORKSPACE=C:/path/to/hermes-agent

# Leave empty to inherit model.default from ~/.hermes/config.yaml
# HERMES_WEBUI_DEFAULT_MODEL=
