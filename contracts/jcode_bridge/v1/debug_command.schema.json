{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hermes-agent.local/contracts/jcode_bridge/v1/debug_command.schema.json",
  "title": "jcode debug socket command",
  "description": "Newline-JSON request sent by Hermes to a jcode debug socket.",
  "type": "object",
  "x-bridge-contract-version": "jcode-bridge.v1",
  "required": ["type", "id", "command"],
  "properties": {
    "type": {
      "const": "debug_command"
    },
    "id": {
      "type": "integer"
    },
    "command": {
      "type": "string",
      "minLength": 1
    },
    "session_id": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
