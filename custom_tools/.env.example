# ==================================================
# Hermes Web3 Tools - Environment Variables
# ==================================================
# Copy this file to .env and fill in your values
# NEVER commit .env with real keys to git!

# --- Evelyn AI (OpenRouter) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# AI conversation settings
AI_MAX_HISTORY=20
AI_MAX_TOKENS=500

# Personality mode: deep_waifu | degen_operator | cyber_assistant | cold_analyst
AI_PERSONALITY_MODE=deep_waifu

# Custom system prompt (optional - overrides AI_PERSONALITY_MODE if set)
# EVELYN_SYSTEM_PROMPT=Your custom prompt here

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram user IDs allowed to interact
TELEGRAM_ALLOWED_USERS=

# --- Blockchain RPC URLs ---
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
BASE_RPC_URL=https://mainnet.base.org
ARB_RPC_URL=https://arb1.arbitrum.io/rpc
POLYGON_RPC_URL=https://polygon-rpc.com

# --- Block Explorer API Keys ---
ETHERSCAN_API_KEY=

# --- OpenSea API (for /floor command) ---
OPENSEA_API_KEY=

# --- Safety Configuration ---
# IMPORTANT: Keep DRY_RUN=true unless you explicitly want to send transactions
DRY_RUN=true

# --- Batch Execution Config ---
BATCH_CONCURRENCY=3
BATCH_MIN_DELAY=1.0
BATCH_MAX_DELAY=5.0
BATCH_MAX_RETRIES=2

# --- Mint Executor Config ---
MINT_MAX_RETRIES=3
MINT_RETRY_DELAY=5.0

# --- Storage Paths ---
WALLETS_DIR=.wallets
APPROVAL_DB_DIR=.data
