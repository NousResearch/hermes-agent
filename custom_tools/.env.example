# ==================================================
# Hermes Web3 Tools - Environment Variables
# ==================================================
# Copy this file to .env and fill in your values
# NEVER commit .env with real keys to git!

# --- Hermes AI Configuration ---
OPENROUTER_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-4o-mini

# --- Blockchain RPC URLs ---
# Get from: Alchemy, Infura, QuickNode, or public RPCs
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
BASE_RPC_URL=https://mainnet.base.org
ARB_RPC_URL=https://arb1.arbitrum.io/rpc
POLYGON_RPC_URL=https://polygon-rpc.com

# --- Block Explorer API Keys ---
# For ABI fetching and contract verification
ETHERSCAN_API_KEY=

# --- Telegram Approval Bot ---
TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram user IDs allowed to approve transactions
TELEGRAM_ALLOWED_USERS=

# --- Safety Configuration ---
# IMPORTANT: Keep DRY_RUN=true unless you explicitly want to send transactions
DRY_RUN=true

# --- Batch Execution Config ---
BATCH_CONCURRENCY=3
BATCH_MIN_DELAY=1.0
BATCH_MAX_DELAY=5.0
BATCH_MAX_RETRIES=2

# --- Mint Executor Config ---
MINT_MAX_RETRIES=3
MINT_RETRY_DELAY=5.0

# --- Storage Paths ---
WALLETS_DIR=.wallets
APPROVAL_DB_DIR=.data
