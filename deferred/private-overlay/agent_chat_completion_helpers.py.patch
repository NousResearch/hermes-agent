+    headers = copilot_request_headers(
+        is_agent_turn=True, is_vision=is_vision, model=agent.model
+    )
+    session_token = str(getattr(agent, "_copilot_auto_session_token", "") or "").strip()
+    if session_token:
+        headers["Copilot-Session-Token"] = session_token
+    return headers
+
 
