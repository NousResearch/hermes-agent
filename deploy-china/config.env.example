# ============ Hermes Agent 配置模板 ============
# 使用方法：复制为 config.env，填好内容，运行 install.sh 自动读取
# config.env 已被 .gitignore 排除，不会传到 GitHub

# --- 镜像来源（1=魔塔, 2=Docker Hub镜像, 留空安装时手动选）---
# IMAGE_SOURCE=1

# --- Docker Hub 镜像源 ---
# DH_MIRROR="registry.cn-hangzhou.aliyuncs.com"

# --- Dashboard 网页（9119端口）---
# DASH_USER="hermesadmin"
# DASH_PASS="你的密码"

# --- API配置 ---
# PROVIDER="DeepSeek"
# API_KEY="sk-xxx"
# MODEL_NAME="deepseek-chat"

# --- 系统配置 ---
APT_MIRROR="mirrors.aliyun.com"
PIP_MIRROR="https://pypi.tuna.tsinghua.edu.cn/simple"
MODELSCOPE_URL="https://modelscope.cn/datasets/aifengheguai/hermes-agent-v0.18.2"
CONTAINER_NAME="hermes-agent"
HERMES_DATA_DIR="/home/hermes/.hermes"
HERMES_USER="hermes"
