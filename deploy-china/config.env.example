# =============================================================================
# Hermes Agent 中国区部署 - 配置模板
# =============================================================================
# 使用方法：
#   1. 复制本文件为 config.env
#   2. 填入你的真实信息
#   3. 运行 install.sh 会自动读取
#
# 注意：config.env 已被 .gitignore 排除，不会被传到 GitHub
# =============================================================================

APT_MIRROR="mirrors.aliyun.com"
PIP_MIRROR="https://pypi.tuna.tsinghua.edu.cn/simple"
MODELSCOPE_URL="https://modelscope.cn/datasets/aifengheguai/hermes-agent-v0.18.2"

FEISHU_TOKEN=***
DINGTALK_TOKEN=***
WECHAT_TOKEN=***
QQ_TOKEN=***

CONTAINER_NAME="hermes-agent"
HERMES_DATA_DIR="$HOME/.hermes"
DOCKER_IMAGE=