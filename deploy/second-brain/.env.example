SECOND_BRAIN_DOMAIN=second-brain.example.com
PUBLIC_BASE_URL=https://second-brain.example.com
ADMIN_EMAIL=admin@example.com
ADMIN_SSH_TARGET=root@YOUR_SERVER_IP
DEPLOY_ROOT=/opt/second-brain

POSTGRES_DB=second_brain
POSTGRES_USER=second_brain
POSTGRES_PASSWORD=change-me

MINIO_ROOT_USER=secondbrain
MINIO_ROOT_PASSWORD=change-me

HONCHO_API_KEY=

# Ollama Cloud is OpenAI-compatible; fill these before enabling live LLM/RAG.
OLLAMA_CLOUD_API_KEY=
OLLAMA_CLOUD_BASE_URL=https://ollama.com/v1
LLM_MODEL=deepseek-v4-flash
EMBEDDING_MODEL=bge-m3:latest
EMBEDDING_DIM=1024

GATEWAY_API_KEY=change-me
LIGHTRAG_API_KEY=change-me
GATEWAY_TOKEN_SECRET=change-me

# Query and ingest tuning.
QUERY_WORKSPACE_CONCURRENCY=4
INGEST_QUEUE_NAME=second_brain:ingest_jobs
SOURCE_SCAN_QUEUE_NAME=second_brain:source_scan_jobs
INGEST_WORKER_CONCURRENCY=2
SOURCE_SCAN_WORKER_CONCURRENCY=1
SOURCE_SCHEDULER_POLL_SECONDS=60
SOURCE_SCAN_MAX_PAGES=50
SOURCE_MAX_TEXT_BYTES=5242880
NOTION_VERSION=2026-03-11
INGEST_MAX_ATTEMPTS=3
INGEST_RETRY_BACKOFF_SECONDS=10
MAX_TEXT_UPLOAD_BYTES=10485760

# Container resource guardrails. Host swap is configured separately.
LIGHTRAG_CPUS=1.0
LIGHTRAG_MEM_LIMIT=1536m
LIGHTRAG_MEMSWAP_LIMIT=2048m
GATEWAY_CPUS=0.50
GATEWAY_MEM_LIMIT=512m
GATEWAY_MEMSWAP_LIMIT=768m
KNOWLEDGE_API_CPUS=1.0
KNOWLEDGE_API_MEM_LIMIT=512m
KNOWLEDGE_API_MEMSWAP_LIMIT=768m
KNOWLEDGE_WORKER_CPUS=1.0
KNOWLEDGE_WORKER_MEM_LIMIT=512m
KNOWLEDGE_WORKER_MEMSWAP_LIMIT=768m
POSTGRES_CPUS=0.75
POSTGRES_MEM_LIMIT=1024m
POSTGRES_MEMSWAP_LIMIT=1536m
REDIS_CPUS=0.25
REDIS_MEM_LIMIT=256m
REDIS_MEMSWAP_LIMIT=384m
MINIO_CPUS=0.50
MINIO_MEM_LIMIT=512m
MINIO_MEMSWAP_LIMIT=768m
OLLAMA_EMBED_CPUS=1.0
OLLAMA_EMBED_MEM_LIMIT=3072m
OLLAMA_EMBED_MEMSWAP_LIMIT=4096m
