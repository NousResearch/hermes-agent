# Copy to .env on the production host with:
#   umask 077
#   install -m 0600 /dev/null .env
#   $EDITOR .env
# Values here are placeholders only. Never commit production values.

HINDSIGHT_POSTGRES_DB=hindsight
HINDSIGHT_POSTGRES_USER=hindsight
HINDSIGHT_POSTGRES_PASSWORD=replace-with-production-secret
HINDSIGHT_DATABASE_URL=postgresql://hindsight:replace-with-production-secret@db:5432/hindsight
HINDSIGHT_API_KEY=replace-with-production-secret
HINDSIGHT_API_PORT=18080
HINDSIGHT_API_IMAGE=ghcr.io/hindsight-ai/hindsight-api:latest
HINDSIGHT_LOG_LEVEL=info
