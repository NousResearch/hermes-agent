+      },
+      "height": {
+        "$type": "dimension",
+        "$value": "{semantic.dimension.density.controlHeight}"
+      },
+      "radius": {
+        "$type": "dimension",
+        "$value": "{semantic.dimension.radius.control}"
+      }
+    },
+    "table": {
+      "row": {
+        "height": {
+          "$type": "dimension",
+          "$value": "{semantic.dimension.density.rowHeight}"
+        },
+        "background": {
+          "$type": "color",
+          "$value": "{semantic.color.background.surface}"
+        },
+        "backgroundHover": {
+          "$type": "color",
+          "$value": "{semantic.color.background.panel}"
