+            "$type": "color",
+            "$value": "{color.brand.700}"
+          },
+          "backgroundHover": {
+            "$type": "color",
+            "$value": "{color.brand.800}"
+          },
+          "text": {
+            "$type": "color",
+            "$value": "{color.neutral.0}"
+          }
+        },
+        "quiet": {
+          "background": {
+            "$type": "color",
+            "$value": "{color.neutral.0}"
+          },
