+          "$type": "color",
+          "$value": "{color.neutral.300}"
+        },
+        "strong": {
+          "$type": "color",
+          "$value": "{color.neutral.500}"
+        },
+        "focus": {
+          "$type": "color",
+          "$value": "{color.brand.600}"
+        }
