{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clawd-architect.local/docs/ops/schemas/domain_release_evidence_bundle.schema.json",
  "title": "Domain Release Evidence Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "release_id",
    "generated_at",
    "activation_mode",
    "stages",
    "rollback_proof",
    "compatibility_lifecycle",
    "domain_governance",
    "approval_ladder",
    "attribution",
    "internal_release_profile"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "clawd.domain_release_evidence_bundle.v1"
    },
    "release_id": {
      "type": "string",
      "pattern": "^rel_[a-z0-9._-]+$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "activation_mode": {
      "type": "string",
      "enum": [
        "shadow",
        "canary",
        "progressive",
        "broad_activation"
      ]
    },
    "lane_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lane_id", "wave"],
      "properties": {
        "lane_id": { "type": "string", "minLength": 1 },
        "wave": { "type": "string", "minLength": 1 }
      }
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/stage" }
    },
    "rollback_proof": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_rollback_ref",
        "state_rollback_ref",
        "drill_ref",
        "drilled_at",
        "max_age_hours"
      ],
      "properties": {
        "artifact_rollback_ref": { "type": "string", "minLength": 1 },
        "state_rollback_ref": { "type": "string", "minLength": 1 },
        "drill_ref": { "type": "string", "minLength": 1 },
        "drilled_at": { "type": "string", "format": "date-time" },
        "max_age_hours": { "type": "integer", "minimum": 1, "maximum": 720 }
      }
    },
    "compatibility_lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["register_ref", "active_exceptions", "removal_rfc_refs"],
      "properties": {
        "register_ref": { "type": "string", "minLength": 1 },
        "active_exceptions": { "type": "integer", "minimum": 0 },
        "removal_rfc_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "domain_governance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["risk_class", "auth_tier", "route_class", "sensitive_action"],
      "properties": {
        "risk_class": {
          "type": "string",
          "enum": ["RG0_LOW", "RG1_MODERATE", "RG2_HIGH", "RG3_CRITICAL"]
        },
        "auth_tier": {
          "type": "string",
          "enum": ["ADMIN", "OBSERVABILITY", "INTERNAL", "PUBLIC"]
        },
        "route_class": {
          "type": "string",
          "enum": ["advisory", "state_mutation", "sensitive_action"]
        },
        "sensitive_action": { "type": "boolean" }
      }
    },
    "approval_ladder": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "steps"],
      "properties": {
        "required": { "type": "boolean" },
        "steps": {
          "type": "array",
          "items": { "$ref": "#/$defs/approval_step" }
        }
      }
    },
    "attribution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requested_by", "approved_by", "executed_by", "decision_log_ref"],
      "properties": {
        "requested_by": { "type": "string", "minLength": 1 },
        "approved_by": { "type": "string", "minLength": 1 },
        "executed_by": { "type": "string", "minLength": 1 },
        "decision_log_ref": { "type": "string", "minLength": 1 }
      }
    },
    "internal_release_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["public_packaging_in_scope", "benchmark_thresholds", "rollback_readiness"],
      "properties": {
        "public_packaging_in_scope": { "type": "boolean", "const": false },
        "benchmark_thresholds": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/benchmark_threshold" }
        },
        "rollback_readiness": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "proof_refs"],
          "properties": {
            "status": { "type": "string", "enum": ["pass", "block"] },
            "proof_refs": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 },
              "uniqueItems": true
            }
          }
        }
      }
    }
  },
  "$defs": {
    "stage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage", "status", "evidence_refs", "evaluated_at"],
      "properties": {
        "stage": {
          "type": "string",
          "enum": [
            "local_determinism",
            "presubmit",
            "integration_replay",
            "shadow",
            "canary",
            "progressive",
            "broad_activation"
          ]
        },
        "status": { "type": "string", "enum": ["pass", "block"] },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "evaluated_at": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" }
      }
    },
    "approval_step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step", "status", "approver_id", "approved_at", "evidence_ref"],
      "properties": {
        "step": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["pass", "block"] },
        "approver_id": { "type": "string", "minLength": 1 },
        "approved_at": { "type": "string", "format": "date-time" },
        "evidence_ref": { "type": "string", "minLength": 1 }
      }
    },
    "benchmark_threshold": {
      "type": "object",
      "additionalProperties": false,
      "required": ["metric_id", "comparator", "threshold", "observed", "status", "evidence_ref"],
      "properties": {
        "metric_id": { "type": "string", "minLength": 1 },
        "comparator": { "type": "string", "enum": [">=", "<=", "=="] },
        "threshold": { "type": "number" },
        "observed": { "type": "number" },
        "status": { "type": "string", "enum": ["pass", "block"] },
        "evidence_ref": { "type": "string", "minLength": 1 }
      }
    }
  }
}
