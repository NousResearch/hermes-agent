{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clawd-architect.local/docs/ops/schemas/execution_backend_adapter_contract_bundle.schema.json",
  "title": "Execution Backend Adapter Contract Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "slice_id",
    "generated_at",
    "runtime_anchor",
    "transport_boundary",
    "profiles",
    "provider_catalog",
    "selection_matrix",
    "retry_backoff_regression",
    "queue_precondition"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "clawd.xo_909.execution_backend_adapter_contract_pack.v1"
    },
    "slice_id": {
      "type": "string",
      "pattern": "^XO-909$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "runtime_anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slice_id",
        "contract_id",
        "default_transport",
        "disallowed_transports",
        "max_fallback_attempts",
        "default_timeout_seconds",
        "default_max_retries"
      ],
      "properties": {
        "slice_id": { "type": "string" },
        "contract_id": { "type": "string" },
        "objective": { "type": "string" },
        "default_transport": { "type": "string" },
        "disallowed_transports": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "max_fallback_attempts": { "type": "integer", "minimum": 1 },
        "default_timeout_seconds": { "type": "integer", "minimum": 1 },
        "default_max_retries": { "type": "integer", "minimum": 0 },
        "default_backoff_seconds": {
          "type": "array",
          "items": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "selection_defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider_preference": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "transport_preference": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      }
    },
    "transport_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "allow_batch_posture", "state_boundary"],
      "properties": {
        "mode": { "type": "string", "enum": ["bounded", "unbounded"] },
        "allow_batch_posture": { "type": "boolean", "const": false },
        "state_boundary": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "runtime_schema_contract": { "type": "string" },
            "selection_schema_contract": { "type": "string" },
            "retry_schema_contract": { "type": "string" }
          },
          "required": ["runtime_schema_contract", "selection_schema_contract", "retry_schema_contract"]
        }
      }
    },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["profile_id", "provider_preference", "transport_preference", "max_retries"],
        "properties": {
          "profile_id": { "type": "string" },
          "provider_preference": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "transport_preference": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "max_retries": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "provider_catalog": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["provider_id", "provider_label", "task_classes", "transport_modes"],
        "properties": {
          "provider_id": { "type": "string" },
          "provider_label": { "type": "string" },
          "description": { "type": "string" },
          "task_classes": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "transport_modes": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["mode", "timeout_seconds", "supported", "retry"],
              "properties": {
                "mode": { "type": "string" },
                "timeout_seconds": { "type": "integer", "minimum": 1 },
                "supported": { "type": "boolean" },
                "retry": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["max_retries", "backoff_seconds"],
                  "properties": {
                    "max_retries": { "type": "integer", "minimum": 0 },
                    "backoff_seconds": {
                      "type": "array",
                      "items": { "type": "integer", "minimum": 1 },
                      "minItems": 1
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "selection_matrix": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cases", "status"],
      "properties": {
        "status": { "type": "string", "enum": ["PASS", "WARN", "FAIL"] },
        "cases": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "case_id",
              "task_class",
              "task_profile",
              "selection_path",
              "selected_provider",
              "selected_transport",
              "status",
              "fallback_used",
              "attempted_pairs",
              "precedence_chain"
            ],
            "properties": {
              "case_id": { "type": "string" },
              "task_class": { "type": "string" },
              "task_profile": { "type": "string" },
              "selection_path": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["provider_id", "transport", "result"],
                  "properties": {
                    "provider_id": { "type": "string" },
                    "transport": { "type": "string" },
                    "result": { "type": "string", "enum": ["SUPPORTED", "UNSUPPORTED_CLASS", "UNSUPPORTED_TRANSPORT", "DISALLOWED_TRANSPORT"] }
                  }
                }
              },
              "selected_provider": { "type": "string" },
              "selected_transport": { "type": "string" },
              "status": { "type": "string", "enum": ["PASS", "FAIL"] },
              "fallback_used": { "type": "boolean" },
              "selected_by": {
                "type": "object",
                "additionalProperties": false,
                "required": ["precedence", "override_applied"],
                "properties": {
                  "precedence": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "override_applied": { "type": "boolean" }
                }
              },
              "precedence_chain": {
                "type": "array",
                "items": { "type": "string" }
              },
              "attempt_count": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    },
    "retry_backoff_regression": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cases", "status"],
      "properties": {
        "status": { "type": "string", "enum": ["PASS", "WARN", "FAIL"] },
        "cases": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "case_id",
              "provider_id",
              "task_class",
              "transport",
              "failure_scenario",
              "expected_max_retries",
              "computed_retries",
              "computed_delay_seconds"
            ],
            "properties": {
              "case_id": { "type": "string" },
              "provider_id": { "type": "string" },
              "task_class": { "type": "string" },
              "transport": { "type": "string" },
              "failure_scenario": { "type": "string" },
              "expected_max_retries": { "type": "integer", "minimum": 0 },
              "computed_retries": { "type": "integer", "minimum": 0 },
              "computed_delay_seconds": {
                "type": "array",
                "items": { "type": "number", "minimum": 1 }
              },
              "bounded_ok": { "type": "boolean" },
              "result": { "type": "string", "enum": ["PASS", "FAIL"] }
            }
          }
        }
      }
    },
    "queue_precondition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "observed_slice_state",
        "dependency_states",
        "unresolved_dependencies"
      ],
      "properties": {
        "observed_slice_state": { "type": "string" },
        "dependency_states": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "unresolved_dependencies": {
          "type": "array",
          "items": { "type": "string" }
        },
        "validation_state": { "type": "string" }
      }
    },
    "generated_artifacts": {
      "type": "object",
      "additionalProperties": true
    },
    "validation_refs": {
      "type": "object",
      "additionalProperties": false
    },
    "schema_contracts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pack_schema", "selection_schema", "retry_schema", "validation_schema"],
      "properties": {
        "pack_schema": { "type": "string" },
        "selection_schema": { "type": "string" },
        "retry_schema": { "type": "string" },
        "validation_schema": { "type": "string" }
      }
    }
  }
}
