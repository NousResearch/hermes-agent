{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clawd-architect.local/docs/ops/schemas/model_rollout_ring_soak_snapshot.schema.json",
  "title": "Model Rollout Ring Soak Snapshot",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema", "generated_at", "status", "counts", "active"],
  "properties": {
    "schema": {"const": "clawd.model_rollout_ring_soak_snapshot.v1"},
    "generated_at": {"type": "string", "format": "date-time"},
    "status": {"type": "string", "enum": ["idle", "soaking", "ready", "attention", "error"]},
    "counts": {"type": "object"},
    "active": {"type": "array"}
  }
}
