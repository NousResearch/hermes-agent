{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clawd-architect.local/docs/ops/schemas/workflow_task_visibility_scorecard.v1.schema.json",
  "title": "Workflow/Task Visibility Scorecard v1 (LT-02 support contract)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "scope_posture",
    "scorecard_id",
    "generated_at",
    "lane_mapping",
    "surface",
    "system_scorecard",
    "task_scorecards",
    "integration_targets",
    "evidence_refs",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "clawd.b8_workflow_task_visibility_scorecard.v1"
    },
    "scope_posture": {
      "type": "string",
      "const": "support_only"
    },
    "scorecard_id": {
      "type": "string",
      "pattern": "^lt02_[a-z0-9._-]+$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "lane_mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "track",
        "queue_id",
        "board_id",
        "lanes"
      ],
      "properties": {
        "track": {
          "type": "string",
          "const": "SX"
        },
        "queue_id": {
          "type": "string",
          "const": "LT-02"
        },
        "board_id": {
          "type": "string",
          "const": "DSG-05"
        },
        "lanes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["B8", "C1", "XU", "A6", "triage"]
          },
          "uniqueItems": true
        }
      }
    },
    "surface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_id",
        "surface_name",
        "surface_kind",
        "snapshot_at"
      ],
      "properties": {
        "surface_id": {
          "type": "string",
          "minLength": 1
        },
        "surface_name": {
          "type": "string",
          "minLength": 1
        },
        "surface_kind": {
          "type": "string",
          "enum": ["operator_triage", "task_state_board", "layered_health", "other"]
        },
        "snapshot_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "system_scorecard": {
      "$ref": "#/$defs/system_scorecard"
    },
    "task_scorecards": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": {
        "$ref": "#/$defs/task_scorecard"
      }
    },
    "integration_targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/integration_target"
      }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    }
  },
  "$defs": {
    "rating": {
      "type": "string",
      "enum": ["healthy", "degraded", "critical"]
    },
    "dimension_vector": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_freshness",
        "worker_health",
        "blockage_severity",
        "evidence_quality",
        "execution_path_stability"
      ],
      "properties": {
        "task_freshness": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "worker_health": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "blockage_severity": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "evidence_quality": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "execution_path_stability": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        }
      }
    },
    "weight_vector": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_freshness",
        "worker_health",
        "blockage_severity",
        "evidence_quality",
        "execution_path_stability"
      ],
      "properties": {
        "task_freshness": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "worker_health": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "blockage_severity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "evidence_quality": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "execution_path_stability": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "task_scorecard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_id",
        "score",
        "rating",
        "dimensions",
        "suppressed",
        "suppression_reasons"
      ],
      "properties": {
        "task_id": {
          "type": "string",
          "minLength": 1
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "rating": {
          "$ref": "#/$defs/rating"
        },
        "dimensions": {
          "$ref": "#/$defs/dimension_vector"
        },
        "suppressed": {
          "type": "boolean"
        },
        "suppression_reasons": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "system_scorecard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "score",
        "rating",
        "dimensions",
        "weights",
        "thresholds",
        "task_rating_counts",
        "task_count",
        "visible_task_count",
        "suppressed_task_count"
      ],
      "properties": {
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "rating": {
          "$ref": "#/$defs/rating"
        },
        "dimensions": {
          "$ref": "#/$defs/dimension_vector"
        },
        "weights": {
          "$ref": "#/$defs/weight_vector"
        },
        "thresholds": {
          "type": "object",
          "additionalProperties": false,
          "required": ["healthy_min", "degraded_min"],
          "properties": {
            "healthy_min": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "degraded_min": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            }
          }
        },
        "task_rating_counts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["healthy", "degraded", "critical"],
          "properties": {
            "healthy": {
              "type": "integer",
              "minimum": 0
            },
            "degraded": {
              "type": "integer",
              "minimum": 0
            },
            "critical": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "task_count": {
          "type": "integer",
          "minimum": 1
        },
        "visible_task_count": {
          "type": "integer",
          "minimum": 0
        },
        "suppressed_task_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "integration_target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lane", "surface_id", "integration_method", "priority"],
      "properties": {
        "lane": {
          "type": "string",
          "enum": ["C1", "A6", "triage", "B8", "XU"]
        },
        "surface_id": {
          "type": "string",
          "minLength": 1
        },
        "integration_method": {
          "type": "string",
          "minLength": 1
        },
        "priority": {
          "type": "string",
          "enum": ["immediate", "queued", "later"]
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["generated_by", "generated_at", "source_records"],
      "properties": {
        "generated_by": {
          "type": "string",
          "minLength": 1
        },
        "generated_at": {
          "type": "string",
          "format": "date-time"
        },
        "source_records": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
