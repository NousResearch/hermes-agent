  "integration_domains": {
    "checkpoint_handover": {
      "objective": "Require machine-readable checkpoint/handover continuity artifacts as primary resume input.",
      "required_inputs": [
        "state/continuity/checkpoints/*.json",
        "state/continuity/latest/handover_latest.json"
      ],
      "required_outputs": [
        "state/continuity/latest/handover_latest.json",
        "state/continuity/latest/current.json"
      ],
      "fail_closed_on": [
        "missing_checkpoint",
        "invalid_checkpoint_json",
        "checkpoint_pointer_mismatch"
      ]
    },
    "context_overflow_prevention": {
      "objective": "Use volumetric and semantic trigger boundaries to force continuity capture before context degradation causes state loss.",
      "required_inputs": [
        "context utilization telemetry",
        "semantic boundary events"
      ],
      "required_outputs": [
        "continuity checkpoint trigger event",
        "handover refresh artifact"
      ],
      "fail_closed_on": [
        "overflow_trigger_missing",
        "checkpoint_not_written"
      ]
    },
    "ground_truth_capture": {
      "objective": "Anchor continuity decisions to host-captured runtime truth instead of narrative memory.",
      "required_inputs": [
        "gateway status",
        "cron registry",
        "session/process/git state"
      ],
      "required_outputs": [
        "state/continuity/latest/ground_truth_latest.json",
        "state/continuity/latest/current.json"
      ],
      "fail_closed_on": [
        "ground_truth_stale",
        "ground_truth_missing",
        "ground_truth_parse_failure"
      ]
    },
    "verify_gate": {
      "objective": "Mutation-capable paths are blocked until verify-before-resume checks pass with fresh evidence.",
      "required_inputs": [
        "docs/ops/verify_before_resume_gate_checklist_v1.md",
        "state/continuity/latest/verify_last.json"
      ],
      "required_outputs": [
        "verify gate decision",
        "mutation gate posture"
      ],
      "fail_closed_on": [
        "verify_missing",
        "verify_stale",
        "verify_forbidden"
      ]
    },
    "recovery_fail_closed": {
      "objective": "Continuity producer and consumer paths emit typed fail-closed artifacts on invalid/stale/missing upstream state.",
      "required_inputs": [
        "continuity_current runtime artifacts",
        "publish lock diagnostics",
        "reconcile telemetry"
      ],
      "required_outputs": [
        "degraded continuity current artifact",
        "typed blocking reasons"
      ],
      "fail_closed_on": [
        "invalid_continuity_now_payload",
        "publish_lock_timeout_without_owner_hint",
        "recovery_contract_violation"
      ]
    }
  },
  "trigger_policy": {
    "volumetric": {
      "context_utilization_threshold_pct": 85,
      "context_emergency_threshold_pct": 90,
      "buffer_target_pct": 15,
      "notes": "Thresholds reflect archive-mined continuity guidance; implementation-specific guards may use stricter values."
    },
    "semantic": {
      "required_boundaries": [
        "pre_execution",
        "post_mutation",
        "post_scheduling_change",
        "failure_boundary",
        "handover_boundary"
      ]
    }
  },
  "fail_closed_policy": {
