{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "candidate-evaluation-summary.v1",
  "title": "Hermes candidate evaluation summary v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "lane_id", "suite_id", "suite_version", "scorer_id", "scorer_version", "weights_version", "status", "screening_non_confirmatory", "candidate_manifest_id", "incumbent_manifest_id", "case_catalog_digest", "candidate", "incumbent", "dimensions", "paired_hfs_delta", "counts", "n_arm", "n_pair", "hard_gate_failures", "aa_pilot", "archive", "rollback_readiness", "raw_artifacts", "promotion_applied"],
  "properties": {
    "schema_version": {"const": "candidate-evaluation-summary.v1"},
    "lane_id": {"const": "cli-full-v1"},
    "suite_id": {"const": "full-hermes-cli-v1"},
    "suite_version": {"const": 1},
    "scorer_id": {"const": "hermes-fitness-v1"},
    "scorer_version": {"const": 1},
    "weights_version": {"const": "cli-full-v1"},
    "status": {"enum": ["GATE-FAILED", "REJECT", "HOLD", "SCREEN-PASS"]},
    "screening_non_confirmatory": {"const": true},
    "candidate_manifest_id": {"type": ["string", "null"]},
    "incumbent_manifest_id": {"type": ["string", "null"]},
    "case_catalog_digest": {"type": ["string", "null"]},
    "candidate": {"type": "object", "required": ["dimensions", "hfs"]},
    "incumbent": {"type": "object", "required": ["dimensions", "hfs"]},
    "dimensions": {"type": "object", "minProperties": 7},
    "paired_hfs_delta": {"type": ["object", "null"]},
    "counts": {"type": "object", "required": ["wins", "losses", "ties", "complete", "incomplete", "invalid"]},
    "n_arm": {"type": "object", "required": ["candidate", "incumbent"]},
    "n_pair": {"type": "object"},
    "hard_gate_failures": {"type": "array"},
    "aa_pilot": {"type": ["object", "null"]},
    "archive": {"type": ["object", "null"]},
    "rollback_readiness": {"type": "object"},
    "raw_artifacts": {"type": "object"},
    "promotion_applied": {"const": false}
  }
}
