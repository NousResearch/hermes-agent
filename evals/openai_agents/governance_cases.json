{
  "version": 1,
  "description": "Deterministic governance evals for the Hermes OpenAI Agents SDK bridge. These do not call live models.",
  "cases": [
    {
      "id": "preflight-blocks-destructive-no-scope",
      "type": "preflight_block",
      "lane": "execute",
      "task": "delete cache files",
      "constraints": [],
      "expected": "blocked"
    },
    {
      "id": "preflight-allows-readonly-review-of-destructive-plan",
      "type": "preflight_allow",
      "lane": "review",
      "task": "review whether deleting cache files would be safe",
      "constraints": ["analysis only; no mutation"],
      "expected": "allowed"
    },
    {
      "id": "verified-without-proof-downgrades",
      "type": "postcondition_downgrade",
      "lane": "execute",
      "output": {"status": "verified", "summary": "done", "proof": []},
      "expected_status": "partial"
    },
    {
      "id": "review-lane-mutation-claim-downgrades",
      "type": "postcondition_mutation_downgrade",
      "lane": "review",
      "output": {"status": "verified", "summary": "changed it", "proof": ["self-report"], "actions_taken": ["edited the file"]},
      "expected_status": "partial"
    },
    {
      "id": "china-origin-model-alias-blocked",
      "type": "model_block",
      "model": "qwen-plus",
      "expected": "blocked"
    },
    {
      "id": "receipt-secret-key-stripped",
      "type": "receipt_sanitize",
      "payload": {"lane": "verify", "api_key": "fake-secret", "result": {"status": "partial", "proof": ["x"]}},
      "forbidden_keys": ["api_key"]
    },
    {
      "id": "architecture-tool-schema-present",
      "type": "architecture_schema",
      "expected_name": "openai_agents_architecture"
    }
  ]
}
