+    from .models import ActionItem
+
+    return MeetingMinutes(
+        meeting_id=payload["meeting_id"],
+        title=payload["title"],
+        background=payload["background"],
+        agenda=list(payload.get("agenda", [])),
+        discussion_flow=[
