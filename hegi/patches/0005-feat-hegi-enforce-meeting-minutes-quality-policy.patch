+
+def _text(value: Any) -> str:
+    """Return renderer-safe scalar text without coercing containers to repr."""
+    if isinstance(value, str):
+        return value.strip()
+    if isinstance(value, (int, float)) and not isinstance(value, bool):
+        return str(value)
+    return ""
+
 
