# Hermes Back Gate Laminar local defaults.
# Copy to your private environment file; do not commit real keys.

# Laminar app/dashboard and SQL API.
HERMES_LAMINAR_BASE_URL=http://127.0.0.1:5667
HERMES_LAMINAR_API_KEY=

# OTLP HTTP endpoint used by Hermes' fail-open exporter.
HERMES_LAMINAR_EXPORT_ENABLED=false
HERMES_LAMINAR_OTLP_HTTP_ENDPOINT=http://127.0.0.1:8000/v1/traces
HERMES_LAMINAR_SAMPLE_RATE=1.0
HERMES_LAMINAR_RETENTION_DAYS=14

# Back-gate deterministic thresholds.
HERMES_DEV_SIGNAL_WINDOW_DAYS=7
HERMES_DEV_SIGNAL_STATUS_MIN_COUNT=2
HERMES_DEV_SIGNAL_VERIFICATION_MIN_COUNT=2
HERMES_DEV_SIGNAL_CONTRACT_SCORE_THRESHOLD=0.75
HERMES_DEV_SIGNAL_CONTRACT_SCORE_MIN_COUNT=3
HERMES_DEV_SIGNAL_WORKER_CONFIDENCE_THRESHOLD=0.60
HERMES_DEV_SIGNAL_WORKER_CONFIDENCE_MIN_COUNT=3
HERMES_DEV_SIGNAL_OUTLIER_MIN_SAMPLE=5
HERMES_DEV_SIGNAL_OUTLIER_RATIO=2.0
HERMES_DEV_SIGNAL_PROPOSAL_AGING_DAYS=14

# Intentionally absent for v1:
# GOOGLE_GENERATIVE_AI_API_KEY
