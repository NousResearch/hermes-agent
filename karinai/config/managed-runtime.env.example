# Example runtime-manager handoff for one KarinAI agent container.
KARINAI_MANAGED_RUNTIME=true
KARINAI_USER_ID=user_123
KARINAI_WORKSPACE_ID=workspace_123
KARINAI_WORKSPACE_DIR=/workspace
KARINAI_RUNTIME_STATE_DIR=/hermes

# Internal-only API server auth; injected per container by runtime-manager.
API_SERVER_KEY=replace-with-runtime-manager-generated-secret
API_SERVER_HOST=127.0.0.1
API_SERVER_PORT=8000

# Product identity.
KARINAI_ASSISTANT_NAME=KarinAI
KARINAI_PRODUCT_NAME=KarinAI
KARINAI_RUNTIME_NAME=KarinAI agent
KARINAI_BRAND_NAME=KarinAI
KARINAI_POLICY_MODE=beta

# Gateway-mediated access. Raw provider/cloud/SaaS credentials should not live in the user container.
KARINAI_MODEL_GATEWAY_URL=http://karinai-model-gateway.internal/v1
KARINAI_MODEL_GATEWAY_MODEL=karinai/default
KARINAI_MODEL_GATEWAY_API_MODE=chat_completions
# Set when the gateway exposes a Codex Responses-compatible surface backed by OpenAI Codex.
KARINAI_MODEL_GATEWAY_BACKEND_PROVIDER=
KARINAI_IMAGE_GATEWAY_URL=http://karinai-image-gateway.internal
# Backend-side image provider/model hints only; raw provider keys stay in the image gateway service.
KARINAI_IMAGE_GATEWAY_PROVIDER=openai
KARINAI_IMAGE_GATEWAY_MODEL=gpt-image-2
KARINAI_TOOL_GATEWAY_URL=http://karinai-tool-gateway.internal
KARINAI_RUNTIME_TOKEN=replace-with-scoped-runtime-token

# Beta tool policy. Leave unset to use the default in karinai.runtime.tool_policy.
KARINAI_ENABLED_TOOLSETS=file,terminal,code_execution,web,vision,todo,memory,skills,session_search,image_gen,video_gen,tts,kanban,delegation,moa,artifact
KARINAI_DISABLED_TOOLSETS=cronjob,video,homeassistant,computer_use,discord,discord_admin,feishu_doc,feishu_drive,spotify,x_search,yuanbao

# Must remain false in beta; backend owns schedules and plugin lifecycle.
KARINAI_LOCAL_CRON_ENABLED=false
KARINAI_PLUGIN_INSTALL_ENABLED=false
KARINAI_DASHBOARD_ENABLED=false
