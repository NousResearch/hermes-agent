HOST_FILE_PRE_FIELDS = {"state", "sha256", "uid", "gid", "mode"}
HOST_DIRECTORY_FIELDS = {"target_path", "uid", "gid", "mode", "pre"}
HOST_DIRECTORY_PRE_FIELDS = {"state", "uid", "gid", "mode"}
HOST_MANIFEST_FIELDS = {
