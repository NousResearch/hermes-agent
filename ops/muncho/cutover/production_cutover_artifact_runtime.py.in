    "public_mode", "public_key_id",
}
OPERATIONAL_EDGE_KEY_FOUNDATION_FIELDS = {
    "schema", "writer_public_key_id", "keys", "key_count", "keys_distinct",
    "retain_created_keys_on_rollback", "private_content_or_digest_recorded",
    "credential_values_read", "secret_material_recorded",
    "secret_digest_recorded", "receipt_sha256",
}
OPERATIONAL_EDGE_KEY_ROW_FIELDS = {
    "domain", "private_path", "private_uid", "private_gid", "private_mode",
    "public_path", "public_uid", "public_gid", "public_mode",
    "public_key_id", "created",
}
IDENTITY_FOUNDATION_FIELDS = {
    "schema", "users", "groups", "retain_created_dormant_on_rollback",
    "secret_material_recorded", "foundation_sha256",
}
IDENTITY_USER_FIELDS = {
    "name", "uid", "primary_group", "home", "shell",
    "supplementary_groups", "pre",
}
IDENTITY_USER_PRE_FIELDS = {
    "state", "uid", "gid", "home", "shell", "supplementary_group_names",
}
IDENTITY_GROUP_FIELDS = {"name", "gid", "members", "pre"}
IDENTITY_GROUP_PRE_FIELDS = {"state", "gid", "members"}
OPERATIONAL_EDGE_USER_ROLES = tuple(
    f"operational_edge_{domain}" for domain in sorted(OPERATIONAL_EDGE_DOMAINS)
)
OPERATIONAL_EDGE_CLIENT_GROUP_ROLES = tuple(
    f"operational_edge_{domain}_client"
    for domain in sorted(OPERATIONAL_EDGE_DOMAINS)
)
IDENTITY_USER_ROLES = (
    "gateway", "writer", "projector", "routeback", "connector", "mac_ops",
    "browser", "worker",
) + OPERATIONAL_EDGE_USER_ROLES
IDENTITY_GROUP_ROLES = (
    "gateway", "writer", "projector", "writer_client", "routeback",
    "connector", "mac_ops", "browser", "worker", "worker_client",
) + OPERATIONAL_EDGE_USER_ROLES + OPERATIONAL_EDGE_CLIENT_GROUP_ROLES
IDENTITY_USER_NAMES = {
    "gateway": "ai-platform-brain",
    "writer": "muncho-canonical-writer",
    "projector": "muncho-projector",
    "routeback": "muncho-discord-egress",
    "connector": "muncho-discord-connector",
    "mac_ops": "muncho-mac-ops-edge",
    "browser": "muncho-capability-browser",
    "worker": "muncho-worker",
    **{
        f"operational_edge_{domain}": f"muncho-edge-{domain}"
        for domain in sorted(OPERATIONAL_EDGE_DOMAINS)
    },
}
IDENTITY_GROUP_NAMES = {
    **IDENTITY_USER_NAMES,
    "writer_client": "muncho-writer-client",
    "worker_client": "muncho-worker-clients",
    **{
        f"operational_edge_{domain}_client": f"muncho-edge-{domain}-c"
        for domain in sorted(OPERATIONAL_EDGE_DOMAINS)
    },
}
IDENTITY_REQUIRED_GROUP_ROLES = {
    "gateway": [
        "browser", "connector", "mac_ops", "routeback", "worker_client",
        "writer_client", *OPERATIONAL_EDGE_CLIENT_GROUP_ROLES,
    ],
    "writer": ["projector"],
    "projector": [],
    "routeback": [],
    "connector": [],
    "mac_ops": [],
    "browser": [],
    "worker": [],
    **{
        f"operational_edge_{domain}": [
            f"operational_edge_{domain}_client"
        ]
        for domain in sorted(OPERATIONAL_EDGE_DOMAINS)
    },
}
SYSTEM_IDENTITY = re.compile(r"^[a-z_][a-z0-9_-]{0,63}$")
GROUPADD = "/usr/sbin/groupadd"
USERADD = "/usr/sbin/useradd"
GPASSWD = "/usr/bin/gpasswd"
HOST_PATHS = {
    "gateway_unit": GATEWAY_FRAGMENT,
    "writer_unit": WRITER_FRAGMENT,
    "connector_unit": CONNECTOR_FRAGMENT,
    "phase_b_unit": PHASE_B_FRAGMENT,
    "routeback_unit": ROUTEBACK_EDGE_FRAGMENT,
    "mac_ops_unit": MAC_OPS_FRAGMENT,
    "browser_unit": BROWSER_FRAGMENT,
    "browser_config": BROWSER_CONFIG,
    "isolated_worker_socket_unit": ISOLATED_WORKER_SOCKET_FRAGMENT,
    "isolated_worker_service_unit": ISOLATED_WORKER_SERVICE_FRAGMENT,
    "isolated_worker_config": ISOLATED_WORKER_CONFIG,
    "gateway_connector_drop_in": GATEWAY_CONNECTOR_DROP_IN,
    "gateway_config": GATEWAY_CONFIG,
    "writer_config": WRITER_CONFIG,
    "connector_config": CONNECTOR_CONFIG,
    "routeback_config": ROUTEBACK_EDGE_CONFIG,
    "mac_ops_config": MAC_OPS_CONFIG,
    "api_bearer_verifier": API_BEARER_VERIFIER,
    "api_approval_verifier": API_APPROVAL_VERIFIER,
    "operational_edge_client_config": Path(
        "/etc/muncho/operational-edge-client.json"
    ),
    **{
        f"operational_edge_unit_{domain}": Path(
            f"/etc/systemd/system/muncho-operational-edge-{domain}.service"
        )
        for domain in OPERATIONAL_EDGE_DOMAINS
    },
    **{
        f"operational_edge_config_{domain}": Path(
            f"/etc/muncho/operational-edge/{domain}.json"
        )
        for domain in OPERATIONAL_EDGE_DOMAINS
    },
}
SERVICE_PATHS = {
    GATEWAY_UNIT: GATEWAY_FRAGMENT,
    WRITER_UNIT: WRITER_FRAGMENT,
    CONNECTOR_UNIT: CONNECTOR_FRAGMENT,
    PHASE_B_UNIT: Path(f"/etc/systemd/system/{PHASE_B_UNIT}"),
    ROUTEBACK_EDGE_UNIT: Path(f"/etc/systemd/system/{ROUTEBACK_EDGE_UNIT}"),
    MAC_OPS_UNIT: Path(f"/etc/systemd/system/{MAC_OPS_UNIT}"),
    BROWSER_UNIT: Path(f"/etc/systemd/system/{BROWSER_UNIT}"),
    ISOLATED_WORKER_SOCKET_UNIT: ISOLATED_WORKER_SOCKET_FRAGMENT,
    ISOLATED_WORKER_SERVICE_UNIT: ISOLATED_WORKER_SERVICE_FRAGMENT,
    **{
        unit: Path(f"/etc/systemd/system/{unit}")
        for unit in OPERATIONAL_EDGE_UNITS
    },
}


def _systemctl(*arguments: str, timeout: int = 30) -> bytes:
    try:
        result = subprocess.run(
            (SYSTEMCTL, *arguments),
            capture_output=True,
            check=False,
            timeout=timeout,
            env={"LC_ALL": "C.UTF-8", "PATH": "/usr/bin:/bin", "SYSTEMD_PAGER": ""},
            cwd="/",
            close_fds=True,
        )
    except (OSError, subprocess.SubprocessError) as exc:
        raise ArtifactError("artifact_systemd_execution_failed") from exc
    if result.returncode != 0 or result.stderr or len(result.stdout) > 1024 * 1024:
        raise ArtifactError("artifact_systemd_execution_failed")
    return result.stdout


def _systemctl_unit_file(action: str, unit: str) -> None:
    if action not in {"enable", "disable"} or unit not in SERVICE_PATHS:
        raise ArtifactError("artifact_systemd_unit_file_action_invalid")
    try:
        result = subprocess.run(
            (SYSTEMCTL, action, "--", unit),
            capture_output=True,
            check=False,
            timeout=30,
            env={"LC_ALL": "C.UTF-8", "PATH": "/usr/bin:/bin", "SYSTEMD_PAGER": ""},
            cwd="/",
            close_fds=True,
        )
    except (OSError, subprocess.SubprocessError) as exc:
        raise ArtifactError("artifact_systemd_execution_failed") from exc
    if (
        result.returncode != 0
        or len(result.stdout) > 1024 * 1024
        or len(result.stderr) > 1024 * 1024
    ):
        raise ArtifactError("artifact_systemd_execution_failed")


def _service(unit: str) -> Mapping[str, Any]:
    if unit not in SERVICE_PATHS:
        raise ArtifactError("artifact_service_invalid")
    fields = (
        "Names", "FragmentPath", "LoadState", "ActiveState", "SubState",
        "UnitFileState", "MainPID", "DropInPaths", "NeedDaemonReload",
        "TriggeredBy", "Triggers",
    )
    payload = _systemctl("show", "--no-pager", "--property=" + ",".join(fields), "--", unit)
    values: dict[str, str] = {}
    try:
        for line in payload.decode("utf-8", errors="strict").splitlines():
            key, separator, value = line.partition("=")
            if not separator or key in values:
                raise ValueError()
            values[key] = value
    except (UnicodeError, ValueError) as exc:
        raise ArtifactError("artifact_service_observation_invalid") from exc
    missing = set(fields) - set(values)
    if missing == {"MainPID"} and unit == ISOLATED_WORKER_SOCKET_UNIT:
        values["MainPID"] = "0"
    elif missing:
        raise ArtifactError("artifact_service_observation_invalid")
    if set(values) != set(fields) or values["Names"] != unit:
        raise ArtifactError("artifact_service_observation_invalid")
    fragment = values["FragmentPath"]
    fragment_sha: str | None = None
    if values["LoadState"] == "loaded":
        expected = SERVICE_PATHS[unit]
        if fragment != str(expected):
            raise ArtifactError("artifact_service_observation_invalid")
        fragment_sha = hashlib.sha256(
            _read_exact_file(expected, allowed_modes={0o644}, owners={0})
        ).hexdigest()
    elif values["LoadState"] == "not-found" and unit in ({
        WRITER_UNIT,
        CONNECTOR_UNIT,
        PHASE_B_UNIT,
        ROUTEBACK_EDGE_UNIT,
        MAC_OPS_UNIT,
        BROWSER_UNIT,
        ISOLATED_WORKER_SOCKET_UNIT,
        ISOLATED_WORKER_SERVICE_UNIT,
    } | set(OPERATIONAL_EDGE_UNITS)):
        fragment = ""
    else:
        raise ArtifactError("artifact_service_observation_invalid")
    drop_in_paths = (
        [] if not values["DropInPaths"] else sorted(values["DropInPaths"].split())
    )
    if drop_in_paths not in ([], [str(GATEWAY_CONNECTOR_DROP_IN)]) or (
        drop_in_paths and unit != GATEWAY_UNIT
    ):
        raise ArtifactError("artifact_service_observation_invalid")
    drop_in_sha256 = {
        path: hashlib.sha256(
            _read_exact_file(Path(path), allowed_modes={0o644}, owners={0}, groups={0})
        ).hexdigest()
        for path in drop_in_paths
    }
    raw = {
        "schema": SERVICE_SCHEMA,
        "name": unit,
        "fragment_path": fragment,
        "fragment_sha256": fragment_sha,
        "load_state": values["LoadState"],
        "active_state": values["ActiveState"],
        "sub_state": values["SubState"],
        "unit_file_state": values["UnitFileState"],
        "main_pid": int(values["MainPID"]),
        "drop_in_paths": drop_in_paths,
        "drop_in_sha256": drop_in_sha256,
        "need_daemon_reload": values["NeedDaemonReload"] == "yes",
        "triggered_by": [] if not values["TriggeredBy"] else values["TriggeredBy"].split(),
        "triggers": [] if not values["Triggers"] else values["Triggers"].split(),
        "observed_at_unix": int(time.time()),
    }
    return {**raw, "observation_sha256": _sha_json(raw)}


def _stable_service(value: Mapping[str, Any]) -> Mapping[str, Any]:
    return {key: value[key] for key in STABLE_SERVICE_FIELDS}


def _stopped(value: Mapping[str, Any]) -> bool:
    return value["active_state"] == "inactive" and value["sub_state"] == "dead" and value["main_pid"] == 0


def _target_service(
    plan: Mapping[str, Any],
    unit: str,
    *,
    staged_disabled: bool = False,
) -> Mapping[str, Any]:
    key = {
        GATEWAY_UNIT: "gateway_target_identity",
        WRITER_UNIT: "writer_target_identity",
        CONNECTOR_UNIT: "connector_target_identity",
    }.get(unit)
    raw = _exact(plan.get(key), STABLE_SERVICE_FIELDS, "artifact_target_service_invalid")
    expected_drop_ins = (
        [str(GATEWAY_CONNECTOR_DROP_IN)] if unit == GATEWAY_UNIT else []
    )
    if (
        raw["name"] != unit
        or raw["fragment_path"] != str(SERVICE_PATHS[unit])
        or raw["load_state"] != "loaded"
        or SHA256.fullmatch(str(raw["fragment_sha256"])) is None
        or raw["unit_file_state"] != "enabled"
        or raw["drop_in_paths"] != expected_drop_ins
        or not isinstance(raw["drop_in_sha256"], Mapping)
        or set(raw["drop_in_sha256"]) != set(expected_drop_ins)
        or any(SHA256.fullmatch(str(value)) is None for value in raw["drop_in_sha256"].values())
        or raw["need_daemon_reload"] is not False
        or raw["triggered_by"] != []
        or raw["triggers"] != []
    ):
        raise ArtifactError("artifact_target_service_invalid")
    if not staged_disabled:
        return raw
    return {**raw, "unit_file_state": "disabled"}


def _pre_service(plan: Mapping[str, Any], unit: str) -> Mapping[str, Any]:
    key = {
        GATEWAY_UNIT: "gateway_legacy_identity",
        WRITER_UNIT: "writer_pre_identity",
        CONNECTOR_UNIT: "connector_pre_identity",
    }.get(unit)
    raw = _hashed(
        plan.get(key), SERVICE_FIELDS, "observation_sha256",
        "artifact_pre_service_invalid",
    )
    if raw["name"] != unit or not _stopped(raw):
        raise ArtifactError("artifact_pre_service_invalid")
    return raw


def _safe_path(value: Any) -> Path:
    if not isinstance(value, str) or not value.startswith("/") or "\x00" in value:
        raise ArtifactError("artifact_host_path_invalid")
    path = Path(value)
    if ".." in path.parts or os.path.normpath(value) != value:
        raise ArtifactError("artifact_host_path_invalid")
    return path


def _ensure_private_directory(path: Path) -> None:
    if path != EVIDENCE_ROOT and EVIDENCE_ROOT not in path.parents:
        raise ArtifactError("artifact_host_directory_invalid")
    current = EVIDENCE_ROOT
    try:
        os.makedirs(current, mode=0o700, exist_ok=True)
    except OSError as exc:
        raise ArtifactError("artifact_host_directory_invalid") from exc
    for part in path.relative_to(EVIDENCE_ROOT).parts:
        current /= part
        try:
            os.mkdir(current, 0o700)
        except FileExistsError:
            pass
        observed = os.lstat(current)
        if (
            not stat.S_ISDIR(observed.st_mode)
            or stat.S_ISLNK(observed.st_mode)
            or observed.st_uid != 0
            or stat.S_IMODE(observed.st_mode) != 0o700
        ):
            raise ArtifactError("artifact_host_directory_invalid")


def _trusted_parent(path: Path, uid: int) -> None:
    try:
        observed = os.lstat(path.parent)
    except OSError as exc:
        raise ArtifactError("artifact_host_directory_invalid") from exc
    if (
        not stat.S_ISDIR(observed.st_mode)
        or stat.S_ISLNK(observed.st_mode)
        or observed.st_uid not in {0, uid}
        or stat.S_IMODE(observed.st_mode) & 0o022
    ):
        raise ArtifactError("artifact_host_directory_invalid")


def _install(path: Path, payload: bytes, mode: int, *, uid: int = 0, gid: int = 0) -> None:
    if path == EVIDENCE_ROOT or EVIDENCE_ROOT in path.parents:
        _ensure_private_directory(path.parent)
    else:
        _trusted_parent(path, uid)
    if path.exists():
        current = _read_exact_file(
            path, allowed_modes={mode}, owners={uid}, groups={gid}
        )
        if current == payload:
            return
    temporary = path.with_name(f".{path.name}.{os.getpid()}.tmp")
    flags = os.O_WRONLY | os.O_CREAT | os.O_EXCL | getattr(os, "O_CLOEXEC", 0)
    descriptor = os.open(temporary, flags, mode)
    try:
        os.fchmod(descriptor, mode)
        os.fchown(descriptor, uid, gid)
        view = memoryview(payload)
        while view:
            written = os.write(descriptor, view)
            if written <= 0:
                raise ArtifactError("artifact_host_install_failed")
            view = view[written:]
        os.fsync(descriptor)
    finally:
        os.close(descriptor)
    try:
        os.replace(temporary, path)
        parent = os.open(path.parent, os.O_RDONLY | getattr(os, "O_DIRECTORY", 0))
        try:
            os.fsync(parent)
        finally:
            os.close(parent)
    finally:
        try:
            temporary.unlink()
        except FileNotFoundError:
            pass


def _identity_foundation(manifest: Mapping[str, Any]) -> Mapping[str, Any]:
    raw = _hashed(
        manifest.get("identity_foundation"),
        IDENTITY_FOUNDATION_FIELDS,
        "foundation_sha256",
        "artifact_identity_foundation_invalid",
    )
    if (
        raw["schema"] != "muncho-production-host-identity-foundation.v1"
        or raw["retain_created_dormant_on_rollback"] is not True
        or raw["secret_material_recorded"] is not False
    ):
        raise ArtifactError("artifact_identity_foundation_invalid")
    users = _exact(
        raw["users"], set(IDENTITY_USER_ROLES),
        "artifact_identity_foundation_invalid",
    )
    groups = _exact(
        raw["groups"], set(IDENTITY_GROUP_ROLES),
        "artifact_identity_foundation_invalid",
    )
    gids: set[int] = set()
    validated_groups: dict[str, Mapping[str, Any]] = {}
    for role in IDENTITY_GROUP_ROLES:
        item = _exact(
            groups[role], IDENTITY_GROUP_FIELDS,
            "artifact_identity_foundation_invalid",
        )
        pre = _exact(
            item["pre"], IDENTITY_GROUP_PRE_FIELDS,
            "artifact_identity_foundation_invalid",
        )
        if (
            item["name"] != IDENTITY_GROUP_NAMES[role]
            or type(item["gid"]) is not int
            or not 0 < item["gid"] < (1 << 31)
            or item["gid"] in gids
            or not isinstance(item["members"], list)
            or item["members"] != sorted(item["members"])
            or len(set(item["members"])) != len(item["members"])
            or any(
                not isinstance(member, str)
                or SYSTEM_IDENTITY.fullmatch(member) is None
                for member in item["members"]
            )
        ):
            raise ArtifactError("artifact_identity_foundation_invalid")
        gids.add(item["gid"])
        if pre["state"] == "absent":
            if pre != {"state": "absent", "gid": None, "members": None}:
                raise ArtifactError("artifact_identity_foundation_invalid")
        elif pre["state"] == "present":
            if (
                pre["gid"] != item["gid"]
                or not isinstance(pre["members"], list)
                or pre["members"] != sorted(pre["members"])
                or len(set(pre["members"])) != len(pre["members"])
            ):
                raise ArtifactError("artifact_identity_foundation_invalid")
        else:
            raise ArtifactError("artifact_identity_foundation_invalid")
        validated_groups[role] = item
    uids: set[int] = set()
    validated_users: dict[str, Mapping[str, Any]] = {}
    for role in IDENTITY_USER_ROLES:
        item = _exact(
            users[role], IDENTITY_USER_FIELDS,
            "artifact_identity_foundation_invalid",
        )
        pre = _exact(
            item["pre"], IDENTITY_USER_PRE_FIELDS,
            "artifact_identity_foundation_invalid",
        )
        required = {
            IDENTITY_GROUP_NAMES[group_role]
            for group_role in IDENTITY_REQUIRED_GROUP_ROLES[role]
        }
        supplementary = item["supplementary_groups"]
        if (
            item["name"] != IDENTITY_USER_NAMES[role]
            or item["primary_group"] != role
            or type(item["uid"]) is not int
            or not 0 < item["uid"] < (1 << 31)
            or item["uid"] in uids
            or _safe_path(item["home"]) != Path(item["home"])
            or _safe_path(item["shell"]) != Path(item["shell"])
            or not isinstance(supplementary, list)
            or supplementary != sorted(supplementary)
            or len(set(supplementary)) != len(supplementary)
            or supplementary != sorted(required)
        ):
            raise ArtifactError("artifact_identity_foundation_invalid")
        uids.add(item["uid"])
        if role != "gateway" and (
            item["home"] != "/nonexistent"
            or item["shell"] != "/usr/sbin/nologin"
        ):
            raise ArtifactError("artifact_identity_foundation_invalid")
        absent = {
            "state": "absent", "uid": None, "gid": None, "home": None,
            "shell": None, "supplementary_group_names": None,
        }
        if pre["state"] == "absent":
            if pre != absent or supplementary != sorted(required):
                raise ArtifactError("artifact_identity_foundation_invalid")
        elif pre["state"] == "present":
            before = pre["supplementary_group_names"]
            if (
                pre["uid"] != item["uid"]
                or pre["gid"] != validated_groups[role]["gid"]
                or pre["home"] != item["home"]
                or pre["shell"] != item["shell"]
                or not isinstance(before, list)
                or before != sorted(before)
            ):
                raise ArtifactError("artifact_identity_foundation_invalid")
        else:
            raise ArtifactError("artifact_identity_foundation_invalid")
        validated_users[role] = item
    if (
        validated_users["gateway"]["pre"]["state"] != "present"
        or validated_groups["gateway"]["pre"]["state"] != "present"
    ):
        raise ArtifactError("artifact_identity_foundation_invalid")
    derived = {role: set() for role in IDENTITY_GROUP_ROLES}
    for user in validated_users.values():
        for role, group in validated_groups.items():
            if group["name"] in user["supplementary_groups"]:
                derived[role].add(user["name"])
    for role, group in validated_groups.items():
        if group["members"] != sorted(derived[role]):
            raise ArtifactError("artifact_identity_foundation_invalid")
    return raw


def _discord_key_foundation(
    manifest: Mapping[str, Any],
    identity: Mapping[str, Any],
) -> Mapping[str, Any]:
    raw = _hashed(
        manifest.get("discord_key_foundation"),
        DISCORD_KEY_FOUNDATION_FIELDS,
        "foundation_sha256",
        "artifact_discord_key_foundation_invalid",
    )
    writer = _exact(
        raw["writer"],
        DISCORD_KEY_PAIR_FIELDS,
        "artifact_discord_key_foundation_invalid",
    )
    edge = _exact(
        raw["edge"],
        DISCORD_KEY_PAIR_FIELDS,
        "artifact_discord_key_foundation_invalid",
    )
    staged = EVIDENCE_ROOT / "staged" / "keys"
    expected = {
        "writer": {
            "staged_private_path": str(staged / "writer-capability-private.pem"),
            "private_path": str(WRITER_CAPABILITY_PRIVATE_KEY),
            "private_uid": identity["users"]["writer"]["uid"],
            "private_gid": identity["groups"]["writer"]["gid"],
            "private_mode": 0o400,
            "public_path": str(WRITER_CAPABILITY_PUBLIC_KEY),
            "public_uid": 0,
            "public_gid": identity["groups"]["routeback"]["gid"],
            "public_mode": 0o440,
        },
        "edge": {
            "staged_private_path": str(staged / "discord-edge-receipt-private.pem"),
            "private_path": str(EDGE_RECEIPT_PRIVATE_KEY),
            "private_uid": 0,
            "private_gid": 0,
            "private_mode": 0o400,
            "public_path": str(EDGE_RECEIPT_PUBLIC_KEY),
            "public_uid": 0,
            "public_gid": identity["groups"]["writer"]["gid"],
            "public_mode": 0o440,
        },
    }
    for role, item in (("writer", writer), ("edge", edge)):
        if (
            any(item[field] != expected[role][field] for field in expected[role])
            or SHA256.fullmatch(str(item["public_key_id"])) is None
        ):
            raise ArtifactError("artifact_discord_key_foundation_invalid")
    paths = [
        writer["staged_private_path"], writer["private_path"],
        writer["public_path"], edge["staged_private_path"],
        edge["private_path"], edge["public_path"],
    ]
    if (
        raw["schema"] != "muncho-production-discord-key-foundation.v1"
        or raw["pre_state"] != "absent"
        or raw["keys_distinct"] is not True
        or raw["private_content_or_digest_recorded"] is not False
        or raw["secret_material_recorded"] is not False
        or writer["public_key_id"] == edge["public_key_id"]
        or len(set(paths)) != len(paths)
    ):
        raise ArtifactError("artifact_discord_key_foundation_invalid")
    return raw


def _operational_edge_key_foundation(
    manifest: Mapping[str, Any],
    *,
    writer_public_key_id: str,
) -> Mapping[str, Any]:
    raw = _hashed(
        manifest.get("operational_edge_key_foundation"),
        OPERATIONAL_EDGE_KEY_FOUNDATION_FIELDS,
        "receipt_sha256",
        "artifact_operational_edge_key_foundation_invalid",
    )
    rows = raw.get("keys")
    if (
        raw["schema"] != "muncho-operational-edge-key-foundation.v1"
        or raw["writer_public_key_id"] != writer_public_key_id
        or not isinstance(rows, list)
        or len(rows) != len(OPERATIONAL_EDGE_DOMAINS)
        or raw["key_count"] != len(OPERATIONAL_EDGE_DOMAINS)
        or raw["keys_distinct"] is not True
        or raw["retain_created_keys_on_rollback"] is not True
        or raw["private_content_or_digest_recorded"] is not False
        or raw["credential_values_read"] is not False
        or raw["secret_material_recorded"] is not False
        or raw["secret_digest_recorded"] is not False
    ):
        raise ArtifactError(
            "artifact_operational_edge_key_foundation_invalid"
        )
    observed_ids: list[str] = []
    for domain, row in zip(sorted(OPERATIONAL_EDGE_DOMAINS), rows, strict=True):
        item = _exact(
            row,
            OPERATIONAL_EDGE_KEY_ROW_FIELDS,
            "artifact_operational_edge_key_foundation_invalid",
        )
        if (
            item["domain"] != domain
            or item["private_path"] != str(
                OPERATIONAL_EDGE_KEY_STAGING_ROOT
                / f"operational-edge-{domain}-receipt-private.pem"
            )
            or item["public_path"] != str(
                OPERATIONAL_EDGE_KEY_STAGING_ROOT
                / f"{domain}-receipt-public.pem"
            )
            or (item["private_uid"], item["private_gid"], item["private_mode"])
            != (0, 0, "0400")
            or (item["public_uid"], item["public_gid"], item["public_mode"])
            != (0, 0, "0444")
            or SHA256.fullmatch(str(item["public_key_id"])) is None
            or type(item["created"]) is not bool
        ):
            raise ArtifactError(
                "artifact_operational_edge_key_foundation_invalid"
            )
        observed_ids.append(item["public_key_id"])
    if (
        len(set(observed_ids)) != len(observed_ids)
        or writer_public_key_id in set(observed_ids)
    ):
        raise ArtifactError(
            "artifact_operational_edge_key_foundation_invalid"
        )
    return raw


def _nss_group(name: str, gid: int) -> Mapping[str, Any] | None:
    try:
        by_name = grp.getgrnam(name)
    except KeyError:
        by_name = None
    try:
        by_gid = grp.getgrgid(gid)
    except KeyError:
        by_gid = None
    if by_name is None and by_gid is None:
        return None
    if (
        by_name is None
        or by_gid is None
        or by_name.gr_name != by_gid.gr_name
        or by_name.gr_gid != by_gid.gr_gid
        or by_name.gr_name != name
        or by_name.gr_gid != gid
    ):
        raise ArtifactError("artifact_identity_collision")
    return {
        "name": by_name.gr_name,
        "gid": by_name.gr_gid,
        "members": sorted(by_name.gr_mem),
    }


def _nss_user(
    name: str,
    uid: int,
    *,
    groups: Mapping[str, Any],
) -> Mapping[str, Any] | None:
    try:
        by_name = pwd.getpwnam(name)
    except KeyError:
        by_name = None
    try:
        by_uid = pwd.getpwuid(uid)
    except KeyError:
        by_uid = None
    if by_name is None and by_uid is None:
        return None
    if (
        by_name is None
        or by_uid is None
        or by_name.pw_name != by_uid.pw_name
        or by_name.pw_uid != by_uid.pw_uid
        or by_name.pw_name != name
        or by_name.pw_uid != uid
    ):
        raise ArtifactError("artifact_identity_collision")
    primary_name = None
    for role, group in groups.items():
        if group["gid"] == by_name.pw_gid:
            primary_name = role
            break
    if primary_name is None:
        raise ArtifactError("artifact_identity_primary_group_invalid")
    try:
        supplementary = sorted(
            identity.gr_name
            for identity in grp.getgrall()
            if name in identity.gr_mem
        )
    except (KeyError, OSError) as exc:
        raise ArtifactError("artifact_identity_observation_failed") from exc
    return {
        "name": by_name.pw_name,
        "uid": by_name.pw_uid,
        "gid": by_name.pw_gid,
        "primary_group": primary_name,
        "home": by_name.pw_dir,
        "shell": by_name.pw_shell,
        "supplementary_group_names": supplementary,
    }


def _identity_snapshot(foundation: Mapping[str, Any]) -> Mapping[str, Any]:
    groups = {
        role: _nss_group(item["name"], item["gid"])
        for role, item in foundation["groups"].items()
    }
    users = {
        role: _nss_user(
            item["name"], item["uid"], groups=foundation["groups"]
        )
        for role, item in foundation["users"].items()
    }
    return {"users": users, "groups": groups}


def _expected_identity_pre(foundation: Mapping[str, Any]) -> Mapping[str, Any]:
    groups = {}
    for role, item in foundation["groups"].items():
        pre = item["pre"]
        groups[role] = (
            None
            if pre["state"] == "absent"
            else {"name": item["name"], "gid": pre["gid"], "members": pre["members"]}
        )
    users = {}
    for role, item in foundation["users"].items():
        pre = item["pre"]
        users[role] = (
            None
            if pre["state"] == "absent"
            else {
                "name": item["name"],
                "uid": pre["uid"],
                "gid": pre["gid"],
                "primary_group": role,
                "home": pre["home"],
                "shell": pre["shell"],
                "supplementary_group_names": pre[
                    "supplementary_group_names"
                ],
            }
        )
    return {"users": users, "groups": groups}


def _expected_identity_target(foundation: Mapping[str, Any]) -> Mapping[str, Any]:
    groups = {
        role: {"name": item["name"], "gid": item["gid"], "members": item["members"]}
        for role, item in foundation["groups"].items()
    }
    users = {
        role: {
            "name": item["name"],
            "uid": item["uid"],
            "gid": foundation["groups"][item["primary_group"]]["gid"],
            "primary_group": item["primary_group"],
            "home": item["home"],
            "shell": item["shell"],
            "supplementary_group_names": item["supplementary_groups"],
        }
        for role, item in foundation["users"].items()
    }
    return {"users": users, "groups": groups}


def _identity_command(arguments: tuple[str, ...]) -> None:
    try:
        completed = subprocess.run(
            arguments,
            check=False,
            capture_output=True,
            timeout=30,
            env={"PATH": "/usr/sbin:/usr/bin:/sbin:/bin", "LC_ALL": "C"},
            cwd="/",
            close_fds=True,
        )
    except (OSError, subprocess.SubprocessError) as exc:
        raise ArtifactError("artifact_identity_mutation_failed") from exc
    if completed.returncode != 0:
        raise ArtifactError("artifact_identity_mutation_failed")


def _apply_identity_foundation(manifest: Mapping[str, Any]) -> Mapping[str, Any]:
    foundation = _identity_foundation(manifest)
    expected_pre = _expected_identity_pre(foundation)
    expected_target = _expected_identity_target(foundation)
    before = _identity_snapshot(foundation)
    for section in ("groups", "users"):
        for role in before[section]:
            if before[section][role] != expected_pre[section][role] and before[
                section
            ][role] != expected_target[section][role]:
                raise ArtifactError("artifact_identity_precondition_changed")
    created_groups: list[str] = []
    created_users: list[str] = []
    for role in IDENTITY_GROUP_ROLES:
        if before["groups"][role] is None:
            item = foundation["groups"][role]
            _identity_command(
                (GROUPADD, "--system", "--gid", str(item["gid"]), item["name"])
            )
            created_groups.append(item["name"])
    for role in IDENTITY_USER_ROLES:
        if before["users"][role] is None:
            item = foundation["users"][role]
            primary_gid = foundation["groups"][item["primary_group"]]["gid"]
            _identity_command(
                (
                    USERADD,
                    "--system",
                    "--uid",
                    str(item["uid"]),
                    "--gid",
                    str(primary_gid),
                    "--home-dir",
                    item["home"],
                    "--no-create-home",
                    "--shell",
                    item["shell"],
                    item["name"],
                )
            )
            created_users.append(item["name"])
    current = _identity_snapshot(foundation)
    for role in IDENTITY_USER_ROLES:
        item = foundation["users"][role]
        observed = current["users"][role]
        if observed is None:
            raise ArtifactError("artifact_identity_mutation_failed")
        extra = sorted(
            set(observed["supplementary_group_names"])
            - set(item["supplementary_groups"])
        )
        for group_name in extra:
            _identity_command((GPASSWD, "--delete", item["name"], group_name))
        missing = sorted(
            set(item["supplementary_groups"])
            - set(observed["supplementary_group_names"])
        )
        for group_name in missing:
            _identity_command((GPASSWD, "--add", item["name"], group_name))
    after = _identity_snapshot(foundation)
    if after != expected_target:
        raise ArtifactError("artifact_identity_apply_unconfirmed")
    unsigned = {
        "schema": "muncho-production-host-identity-apply.v1",
        "foundation_sha256": foundation["foundation_sha256"],
        "before_sha256": _sha_json(before),
        "after_sha256": _sha_json(after),
        "created_users": sorted(created_users),
        "created_groups": sorted(created_groups),
        "preexisting_memberships_converged_to_allowlist": True,
        "retain_created_dormant_on_rollback": True,
        "secret_material_recorded": False,
    }
    return {**unsigned, "receipt_sha256": _sha_json(unsigned)}


def _rollback_identity_foundation(manifest: Mapping[str, Any]) -> Mapping[str, Any]:
    foundation = _identity_foundation(manifest)
    expected_pre = _expected_identity_pre(foundation)
    current = _identity_snapshot(foundation)
    retained_users: list[str] = []
    retained_groups: list[str] = []
    for role in IDENTITY_USER_ROLES:
        item = foundation["users"][role]
        observed = current["users"][role]
        if observed is None:
            if item["pre"]["state"] == "present":
                raise ArtifactError("artifact_identity_rollback_unconfirmed")
            continue
        target_before = item["pre"]["supplementary_group_names"] or []
        additions = sorted(
            set(observed["supplementary_group_names"]) - set(target_before)
        )
        allowed_additions = set(item["supplementary_groups"]) - set(target_before)
        removals = sorted(
            set(target_before) - set(observed["supplementary_group_names"])
        )
        allowed_removals = set(target_before) - set(
            item["supplementary_groups"]
        )
        if (
            not set(additions).issubset(allowed_additions)
            or not set(removals).issubset(allowed_removals)
        ):
            raise ArtifactError("artifact_identity_rollback_unconfirmed")
        for group_name in additions:
            _identity_command((GPASSWD, "--delete", item["name"], group_name))
        for group_name in removals:
            _identity_command((GPASSWD, "--add", item["name"], group_name))
        if item["pre"]["state"] == "absent":
            retained_users.append(item["name"])
    after = _identity_snapshot(foundation)
    for role in IDENTITY_USER_ROLES:
        if foundation["users"][role]["pre"]["state"] == "present":
            if after["users"][role] != expected_pre["users"][role]:
                raise ArtifactError("artifact_identity_rollback_unconfirmed")
        else:
            expected = _expected_identity_target(foundation)["users"][role]
            expected = {**expected, "supplementary_group_names": []}
            if after["users"][role] is None:
                # The create-only convergence may have crashed before this
                # principal was reached.  Never-created is already the signed
                # pre-state and needs no synthetic rollback mutation.
                continue
            if after["users"][role] != expected:
                raise ArtifactError("artifact_identity_rollback_unconfirmed")
    for role in IDENTITY_GROUP_ROLES:
        group = foundation["groups"][role]
        observed = after["groups"][role]
        if group["pre"]["state"] == "present":
            if observed != expected_pre["groups"][role]:
                raise ArtifactError("artifact_identity_rollback_unconfirmed")
        else:
            if observed is None:
                # As with users, a later planned group may never have been
                # created.  Accept only exact absence; collision checks in the
                # snapshot reject any aliasing by name or gid.
                continue
            if observed != {"name": group["name"], "gid": group["gid"], "members": []}:
                raise ArtifactError("artifact_identity_rollback_unconfirmed")
            retained_groups.append(group["name"])
    unsigned = {
        "schema": "muncho-production-host-identity-rollback.v1",
        "foundation_sha256": foundation["foundation_sha256"],
        "retained_dormant_users": sorted(retained_users),
        "retained_dormant_groups": sorted(retained_groups),
        "preexisting_memberships_restored": True,
        "created_identities_retained_dormant": True,
        "secret_material_recorded": False,
    }
    return {**unsigned, "receipt_sha256": _sha_json(unsigned)}


def _host_manifest(plan: Mapping[str, Any]) -> Mapping[str, Any]:
    raw = _hashed(
        plan.get("host_transition"), HOST_MANIFEST_FIELDS, "manifest_sha256",
        "artifact_host_manifest_invalid",
    )
    if (
        raw["schema"] != "muncho-production-host-transition-manifest.v1"
        or raw["gateway_direct_discord_enabled"] is not False
        or raw["gateway_relay_platforms"] != ["discord"]
        or raw["connector_operation_class"] != "ordinary_guild_acl_session_only"
        or raw["routeback_operation_class"]
        != "canonical_guild_acl_routeback_rest_only"
        or raw["discord_dm_allowed"] is not False
        or raw["secret_material_recorded"] is not False
    ):
        raise ArtifactError("artifact_host_manifest_invalid")
    files = _exact(raw["files"], HOST_FILE_NAMES, "artifact_host_manifest_invalid")
    identity = _identity_foundation(raw)
    key_foundation = _discord_key_foundation(raw, identity)
    operational_key_foundation = _operational_edge_key_foundation(
        raw,
        writer_public_key_id=key_foundation["writer"]["public_key_id"],
    )
    operational_key_ids = raw["operational_edge_receipt_public_key_ids"]
    observed_operational_key_ids = {
        row["domain"]: row["public_key_id"]
        for row in operational_key_foundation["keys"]
    }
    if (
        SHA256.fullmatch(
            str(raw["operational_edge_key_foundation_sha256"])
        )
        is None
        or raw["operational_edge_key_foundation_sha256"]
        != operational_key_foundation["receipt_sha256"]
        or operational_key_ids != observed_operational_key_ids
        or not isinstance(operational_key_ids, Mapping)
        or set(operational_key_ids) != OPERATIONAL_EDGE_DOMAINS
        or any(
            SHA256.fullmatch(str(key_id)) is None
            for key_id in operational_key_ids.values()
        )
        or len(set(operational_key_ids.values())) != len(operational_key_ids)
        or key_foundation["writer"]["public_key_id"]
        in set(operational_key_ids.values())
        or raw["release_owner_uid"] != identity["users"]["gateway"]["uid"]
        or raw["release_owner_gid"] != identity["groups"]["gateway"]["gid"]
    ):
        raise ArtifactError("artifact_operational_edge_key_foundation_invalid")
    service_units = {
        "gateway_unit": GATEWAY_UNIT,
        "writer_unit": WRITER_UNIT,
        "connector_unit": CONNECTOR_UNIT,
    }
    service_digests = {
        name: _target_service(plan, unit)["fragment_sha256"]
        for name, unit in service_units.items()
    }
    topology = _validate_capability_prerequisite_plan(plan)
    if (
        identity["users"]["gateway"]["uid"]
        != topology["gateway_identity"]["uid"]
        or identity["groups"]["gateway"]["gid"]
        != topology["gateway_identity"]["gid"]
        or identity["users"]["worker"]["uid"]
        != topology["isolated_worker"]["server_uid"]
        or identity["groups"]["worker"]["gid"]
        != topology["isolated_worker"]["server_gid"]
        or identity["groups"]["worker_client"]["gid"]
        != topology["isolated_worker"]["socket_gid"]
        or identity["users"]["browser"]["uid"]
        != topology["browser"]["service_uid"]
        or identity["groups"]["browser"]["gid"]
        != topology["browser"]["service_gid"]
        or "docker" in identity["users"]["gateway"]["supplementary_groups"]
    ):
        raise ArtifactError("artifact_host_manifest_invalid")
    service_digests.update(
        {
            "phase_b_unit": topology["phase_b"]["fragment_sha256"],
            "routeback_unit": topology["routeback_edge"][
                "fragment_sha256"
            ],
            "mac_ops_unit": topology["mac_ops"]["fragment_sha256"],
            "browser_unit": topology["browser"]["fragment_sha256"],
            "browser_config": topology["browser"]["config_sha256"],
            "isolated_worker_socket_unit": topology["isolated_worker"][
                "socket_fragment_sha256"
            ],
            "isolated_worker_service_unit": topology["isolated_worker"][
                "service_fragment_sha256"
            ],
            "isolated_worker_config": topology["isolated_worker"][
                "config_sha256"
            ],
            "routeback_config": topology["routeback_edge"]["config_sha256"],
            "mac_ops_config": topology["mac_ops"]["config_sha256"],
        }
    )
    service_digests["gateway_connector_drop_in"] = _target_service(
        plan, GATEWAY_UNIT
    )["drop_in_sha256"][str(GATEWAY_CONNECTOR_DROP_IN)]
    staged_root = EVIDENCE_ROOT / "staged" / "host"
    sealed = _sealed_runtime_artifacts()
    for name in HOST_FILE_NAMES:
        item = _exact(files[name], HOST_FILE_FIELDS, "artifact_host_manifest_invalid")
        target = HOST_PATHS[name]
        pre = _exact(item["pre"], HOST_FILE_PRE_FIELDS, "artifact_host_manifest_invalid")
        if (
            _safe_path(item["staged_path"]) != staged_root / target.name
            or _safe_path(item["target_path"]) != target
            or SHA256.fullmatch(str(item["sha256"])) is None
            or type(item["uid"]) is not int
            or type(item["gid"]) is not int
            or item["uid"] < 0
            or item["gid"] < 0
            or type(item["mode"]) is not int
        ):
            raise ArtifactError("artifact_host_manifest_invalid")
        if name in service_digests and item["sha256"] != service_digests[name]:
            raise ArtifactError("artifact_host_manifest_invalid")
        if name in SEALED_FILE_NAMES and {
            key: item[key]
            for key in ("target_path", "sha256", "uid", "gid", "mode")
        } != sealed["files"][name]:
            raise ArtifactError("artifact_host_manifest_invalid")
        if name in {
            "gateway_unit", "writer_unit", "connector_unit", "phase_b_unit",
            "routeback_unit", "mac_ops_unit", "browser_unit",
            "isolated_worker_socket_unit", "isolated_worker_service_unit",
            "gateway_connector_drop_in",
        } | OPERATIONAL_EDGE_UNIT_FILE_NAMES and (
            item["uid"], item["gid"], item["mode"]
        ) != (0, 0, 0o644):
            raise ArtifactError("artifact_host_manifest_invalid")
        if name == "gateway_config" and (
            item["uid"] <= 0
            or item["gid"] <= 0
            or item["mode"] not in {0o600, 0o640}
        ):
            raise ArtifactError("artifact_host_manifest_invalid")
        if name == "writer_config" and (
            item["uid"] != 0
            or item["gid"] != identity["groups"]["writer"]["gid"]
            or item["mode"] != 0o440
        ):
            raise ArtifactError("artifact_host_manifest_invalid")
        if name in {"connector_config", "routeback_config", "mac_ops_config"} and (
            item["uid"] != 0 or item["gid"] <= 0 or item["mode"] != 0o440
        ):
            raise ArtifactError("artifact_host_manifest_invalid")
        if name == "browser_config" and (
            item["uid"] != 0
            or item["gid"] != identity["groups"]["browser"]["gid"]
            or item["mode"] != 0o440
        ):
            raise ArtifactError("artifact_host_manifest_invalid")
        if name == "isolated_worker_config" and (
            item["uid"] != 0
            or item["gid"] != identity["groups"]["worker"]["gid"]
            or item["mode"] != 0o440
        ):
            raise ArtifactError("artifact_host_manifest_invalid")
        if name in OPERATIONAL_EDGE_CONFIG_FILE_NAMES and (
            item["uid"], item["gid"], item["mode"]
        ) != (0, 0, 0o400):
            raise ArtifactError("artifact_host_manifest_invalid")
        if name == "operational_edge_client_config" and (
            item["uid"], item["gid"], item["mode"]
        ) != (0, 0, 0o444):
            raise ArtifactError("artifact_host_manifest_invalid")
        if name in {"api_bearer_verifier", "api_approval_verifier"} and (
            item["uid"] != 0 or item["gid"] != 0 or item["mode"] != 0o400
        ):
            raise ArtifactError("artifact_host_manifest_invalid")
        if pre["state"] == "absent":
            if any(pre[field] is not None for field in {"sha256", "uid", "gid", "mode"}):
                raise ArtifactError("artifact_host_manifest_invalid")
        elif pre["state"] == "present":
            if (
                SHA256.fullmatch(str(pre["sha256"])) is None
                or type(pre["uid"]) is not int
                or type(pre["gid"]) is not int
                or type(pre["mode"]) is not int
            ):
                raise ArtifactError("artifact_host_manifest_invalid")
        else:
            raise ArtifactError("artifact_host_manifest_invalid")
    for name, unit in service_units.items():
        pre = files[name]["pre"]
        service = _pre_service(plan, unit)
        expected_state = "present" if service["load_state"] == "loaded" else "absent"
        if pre["state"] != expected_state or (
            expected_state == "present" and pre["sha256"] != service["fragment_sha256"]
        ):
            raise ArtifactError("artifact_host_manifest_invalid")
    if any(
        files[name]["pre"]["state"] != "absent"
        for name in ({
            "gateway_connector_drop_in", "writer_config", "connector_config", "phase_b_unit",
            "routeback_unit", "mac_ops_unit", "browser_unit",
            "browser_config", "isolated_worker_socket_unit",
            "isolated_worker_service_unit", "isolated_worker_config",
            "routeback_config", "mac_ops_config", "api_bearer_verifier",
            "api_approval_verifier",
            "operational_edge_client_config",
        } | OPERATIONAL_EDGE_UNIT_FILE_NAMES | OPERATIONAL_EDGE_CONFIG_FILE_NAMES)
    ):
        raise ArtifactError("artifact_host_manifest_invalid")
    directory = _exact(
        raw["isolated_worker_lease_mountpoint"],
        HOST_DIRECTORY_FIELDS,
        "artifact_host_manifest_invalid",
    )
    directory_pre = _exact(
        directory["pre"],
        HOST_DIRECTORY_PRE_FIELDS,
        "artifact_host_manifest_invalid",
    )
    if {
        key: directory[key] for key in ("target_path", "uid", "gid", "mode")
    } != sealed["isolated_worker_lease_mountpoint"]:
        raise ArtifactError("artifact_host_manifest_invalid")
    if directory_pre["state"] == "absent":
        if any(directory_pre[key] is not None for key in ("uid", "gid", "mode")):
            raise ArtifactError("artifact_host_manifest_invalid")
    elif directory_pre["state"] == "present":
        if (
            type(directory_pre["uid"]) is not int
            or type(directory_pre["gid"]) is not int
            or type(directory_pre["mode"]) is not int
        ):
            raise ArtifactError("artifact_host_manifest_invalid")
    else:
        raise ArtifactError("artifact_host_manifest_invalid")
    token = _exact(raw["connector_token"], TOKEN_FIELDS, "artifact_host_manifest_invalid")
    if (
        _safe_path(token["path"]) != CONNECTOR_TOKEN
        or type(token["uid"]) is not int
        or type(token["gid"]) is not int
        or token["uid"] <= 0
        or token["gid"] <= 0
        or token["mode"] != 0o400
        or token["regular_one_link"] is not True
        or token["content_or_digest_recorded"] is not False
        or token["gateway_readable"] is not False
        or token["gid"] != files["connector_config"]["gid"]
        or type(token["source_uid"]) is not int
        or type(token["source_gid"]) is not int
        or token["source_uid"] < 0
        or token["source_gid"] < 0
        or token["source_mode"] != 0o400
        or token["source_uid"] != files["gateway_config"]["uid"]
        or token["uid"] == files["gateway_config"]["uid"]
        or token["uid"] != identity["users"]["connector"]["uid"]
        or token["gid"] != identity["groups"]["connector"]["gid"]
        or files["gateway_config"]["uid"]
        != identity["users"]["gateway"]["uid"]
        or files["gateway_config"]["gid"]
        != identity["groups"]["gateway"]["gid"]
        or files["connector_config"]["gid"]
        != identity["groups"]["connector"]["gid"]
        or files["writer_config"]["gid"]
        != identity["groups"]["writer"]["gid"]
        or files["routeback_config"]["gid"]
        != identity["groups"]["routeback"]["gid"]
        or files["mac_ops_config"]["gid"]
        != identity["groups"]["mac_ops"]["gid"]
    ):
        raise ArtifactError("artifact_host_manifest_invalid")
    source = _safe_path(token["source_path"])
    retired = raw["gateway_retired_token_paths"]
    preserved = raw["routeback_token_paths"]
    if (
        not isinstance(retired, list)
        or not 1 <= len(retired) <= 8
        or len(set(retired)) != len(retired)
        or not isinstance(preserved, list)
        or not 1 <= len(preserved) <= 8
        or len(set(preserved)) != len(preserved)
        or source not in {_safe_path(value) for value in retired}
        or CONNECTOR_TOKEN in {_safe_path(value) for value in retired + preserved}
        or set(retired) & set(preserved)
    ):
        raise ArtifactError("artifact_host_manifest_invalid")
    approval = _exact(
        raw["approval_passkey"],
        APPROVAL_PASSKEY_FIELDS,
        "artifact_host_manifest_invalid",
    )
    approval_source = _safe_path(approval["source_path"])
    approval_retired = raw["retired_approval_passkey_paths"]
    if (
        not isinstance(approval_retired, list)
        or not 1 <= len(approval_retired) <= 8
        or any(not isinstance(path, str) for path in approval_retired)
        or approval_retired != sorted(approval_retired)
        or len(set(approval_retired)) != len(approval_retired)
    ):
        raise ArtifactError("artifact_host_manifest_invalid")
    approval_retired_paths = {_safe_path(value) for value in approval_retired}
    if (
        _safe_path(approval["path"]) != API_APPROVAL_PASSKEY
        or any(
            type(approval[field]) is not int
            for field in (
                "uid", "gid", "mode", "source_uid", "source_gid", "source_mode"
            )
        )
        or (approval["uid"], approval["gid"], approval["mode"])
        != (0, 0, 0o400)
        or approval["regular_one_link"] is not True
        or approval["content_or_digest_recorded"] is not False
        or approval["gateway_readable"] is not False
        or approval_source != STAGED_APPROVAL_PASSKEY
        or (
            approval["source_uid"],
            approval["source_gid"],
            approval["source_mode"],
        ) != (0, 0, 0o400)
        or approval_source not in approval_retired_paths
        or API_APPROVAL_PASSKEY
        in approval_retired_paths
        or approval_source in {_safe_path(value) for value in retired + preserved}
        or API_APPROVAL_PASSKEY
        in {_safe_path(value) for value in retired + preserved}
    ):
        raise ArtifactError("artifact_host_manifest_invalid")
    if key_foundation["writer"]["public_gid"] != files[
        "routeback_config"
    ]["gid"]:
        raise ArtifactError("artifact_host_manifest_invalid")
    return raw


def _file_matches(path: Path, identity: Mapping[str, Any]) -> bool:
    if identity["state"] == "absent":
        return not os.path.lexists(path)
    if not os.path.lexists(path):
        return False
    try:
        payload = _read_exact_file(
            path,
            allowed_modes={identity["mode"]},
            owners={identity["uid"]},
            groups={identity["gid"]},
        )
    except ArtifactError:
        return False
    return hashlib.sha256(payload).hexdigest() == identity["sha256"]


def _directory_matches(path: Path, identity: Mapping[str, Any]) -> bool:
    if identity["state"] == "absent":
        return not os.path.lexists(path)
    try:
        observed = os.lstat(path)
    except OSError:
        return False
    return (
        stat.S_ISDIR(observed.st_mode)
        and not stat.S_ISLNK(observed.st_mode)
        and observed.st_uid == identity["uid"]
        and observed.st_gid == identity["gid"]
        and stat.S_IMODE(observed.st_mode) == identity["mode"]
    )


def _apply_worker_lease_mountpoint(manifest: Mapping[str, Any]) -> None:
    item = manifest["isolated_worker_lease_mountpoint"]
    path = Path(item["target_path"])
    target = {
        "state": "present",
        "uid": item["uid"],
        "gid": item["gid"],
        "mode": item["mode"],
    }
    if _directory_matches(path, target):
        return
    if not _directory_matches(path, item["pre"]):
        raise ArtifactError("artifact_worker_mountpoint_identity_changed")
    if item["pre"]["state"] == "absent":
        try:
            os.mkdir(path, item["mode"])
        except OSError as exc:
            raise ArtifactError("artifact_worker_mountpoint_install_failed") from exc
    try:
        os.chown(path, item["uid"], item["gid"])
        os.chmod(path, item["mode"])
    except OSError as exc:
        raise ArtifactError("artifact_worker_mountpoint_install_failed") from exc
    if not _directory_matches(path, target):
        raise ArtifactError("artifact_worker_mountpoint_install_unconfirmed")


def _rollback_worker_lease_mountpoint(manifest: Mapping[str, Any]) -> None:
    item = manifest["isolated_worker_lease_mountpoint"]
    path = Path(item["target_path"])
    target = {
        "state": "present",
        "uid": item["uid"],
        "gid": item["gid"],
        "mode": item["mode"],
    }
    if _directory_matches(path, item["pre"]):
        return
    if not _directory_matches(path, target):
        raise ArtifactError("artifact_worker_mountpoint_identity_changed")
    try:
        if item["pre"]["state"] == "absent":
            path.rmdir()
        else:
            os.chown(path, item["pre"]["uid"], item["pre"]["gid"])
            os.chmod(path, item["pre"]["mode"])
    except OSError as exc:
        raise ArtifactError("artifact_worker_mountpoint_rollback_failed") from exc
    if not _directory_matches(path, item["pre"]):
        raise ArtifactError("artifact_worker_mountpoint_rollback_unconfirmed")


def _decode_json_object(payload: bytes) -> Mapping[str, Any]:
    def pairs(items: list[tuple[str, Any]]) -> dict[str, Any]:
        result: dict[str, Any] = {}
        for key, value in items:
            if not isinstance(key, str) or not key or key in result:
                raise ValueError()
            result[key] = value
        return result

    try:
        value = json.loads(
            payload.decode("utf-8", errors="strict"),
            object_pairs_hook=pairs,
            parse_constant=lambda _value: (_ for _ in ()).throw(ValueError()),
        )
    except (UnicodeError, ValueError, json.JSONDecodeError) as exc:
        raise ArtifactError("artifact_connector_config_invalid") from exc
    if not isinstance(value, Mapping):
        raise ArtifactError("artifact_connector_config_invalid")
    return value


def _discord_ids(value: Any, *, allow_empty: bool = False) -> bool:
    return (
        isinstance(value, list)
        and (allow_empty or len(value) >= 1)
        and len(value) <= 64
        and len(set(value)) == len(value)
        and all(
            isinstance(item, str)
            and re.fullmatch(r"[1-9][0-9]{4,24}", item) is not None
            for item in value
        )
    )


def _discord_policy_continuity(value: Any) -> Mapping[str, Any]:
    continuity = _hashed(
        value,
        {
            "schema", "source_evidence_sha256", "legacy_policy",
            "target_policy", "exact_membership_preserved",
            "reviewed_reconciliation",
            "secret_material_recorded", "continuity_sha256",
        },
        "continuity_sha256",
        "artifact_discord_policy_continuity_invalid",
    )
    fields = {
        "allowed_guild_ids", "allowed_channel_ids", "allowed_user_ids",
        "allowed_role_ids", "allow_all_users", "allow_bot_authors",
        "require_mention", "auto_thread", "thread_require_mention",
        "discord_dm_allowed", "free_response_channel_ids", "public_only",
        "author_policy",
    }
    legacy = _exact(
        continuity["legacy_policy"],
        fields,
        "artifact_discord_policy_continuity_invalid",
    )
    target = _exact(
        continuity["target_policy"],
        fields,
        "artifact_discord_policy_continuity_invalid",
    )
    if (
        continuity["schema"]
        != "muncho-production-discord-policy-continuity.v2"
        or SHA256.fullmatch(str(continuity["source_evidence_sha256"])) is None
        or legacy == target
        or continuity["exact_membership_preserved"] is not False
        or continuity["reviewed_reconciliation"] is not True
        or continuity["secret_material_recorded"] is not False
        or any(
            not _discord_ids(legacy[field])
            for field in (
                "allowed_guild_ids", "allowed_channel_ids",
                "allowed_user_ids", "allowed_role_ids",
            )
        )
        or not _discord_ids(legacy["free_response_channel_ids"], allow_empty=True)
        or "1279454038731264061" not in legacy["allowed_user_ids"]
        or legacy["author_policy"] != "exact_ids_or_roles"
        or legacy["public_only"] is not False
        or not set(legacy["free_response_channel_ids"]).issubset(
            legacy["allowed_channel_ids"]
        )
        or target["allowed_guild_ids"] != ["1282725267068157972"]
        or target["allowed_channel_ids"] != [
            "1504852355588423801",
            "1504852408227069993",
            "1504852444407140402",
            "1504852485083496561",
            "1504852553031221391",
            "1504852628373373028",
            "1505499746939174993",
            "1507239177350283274",
            "1507239385010016308",
            "1510888721614901358",
        ]
        or target["allowed_user_ids"] != []
        or target["allowed_role_ids"] != []
        or target["free_response_channel_ids"] != [
            "1504852355588423801", "1505499746939174993"
        ]
        or target["public_only"] is not False
        or target["author_policy"] != "guild_acl"
        or target["allow_all_users"] is not False
        or target["allow_bot_authors"] is not False
        or target["require_mention"] is not True
        or target["auto_thread"] is not True
        or target["thread_require_mention"] is not False
        or target["discord_dm_allowed"] is not False
    ):
        raise ArtifactError("artifact_discord_policy_continuity_invalid")
    return target


def _assert_reviewed_connector_boundary(
    plan: Mapping[str, Any], manifest: Mapping[str, Any]
) -> None:
    files = manifest["files"]
    target_policy = _discord_policy_continuity(
        manifest["discord_policy_continuity"]
    )
    connector_unit = _staged_file(files["connector_unit"])
    if (
        CONNECTOR_UNIT_TEMPLATE.count("@EXACT_12_CHAR_SHA@") != 3
        or "/opt/muncho-releases/" in CONNECTOR_UNIT_TEMPLATE
        or "/venv/bin/python" in CONNECTOR_UNIT_TEMPLATE
    ):
        raise ArtifactError("artifact_connector_unit_template_invalid")
    expected_unit = CONNECTOR_UNIT_TEMPLATE.replace(
        "@EXACT_12_CHAR_SHA@", str(plan["release_revision"])[:12]
    ).encode("utf-8", errors="strict")
    if (
        connector_unit != expected_unit
        or b"@EXACT_12_CHAR_SHA@" in connector_unit
        or b"/opt/muncho-releases/" in connector_unit
    ):
        raise ArtifactError("artifact_connector_unit_invalid")
    if _staged_file(files["gateway_connector_drop_in"]) != GATEWAY_CONNECTOR_DROP_IN_BYTES:
        raise ArtifactError("artifact_gateway_connector_drop_in_invalid")
    gateway_unit = _staged_file(files["gateway_unit"])
    gateway_config = _staged_file(files["gateway_config"])
    approval_load = (
        f"LoadCredential=api-approval-passkey-scrypt:{API_APPROVAL_VERIFIER}"
    ).encode("ascii")
    bearer_load = (
        f"LoadCredential=api-server-bearer-sha256:{API_BEARER_VERIFIER}"
    ).encode("ascii")
    approval_source = str(
        _safe_path(manifest["approval_passkey"]["source_path"])
    ).encode("utf-8", errors="strict")
    bearer_source = str(LEGACY_API_BEARER).encode("utf-8", errors="strict")
    approval_inaccessible = b"InaccessiblePaths=-" + approval_source
    bearer_inaccessible = b"InaccessiblePaths=-" + bearer_source
    if any(
        marker in gateway_unit or marker in gateway_config
        for marker in (b"DISCORD_BOT_TOKEN", b"DISCORD_TOKEN")
    ):
        raise ArtifactError("artifact_gateway_discord_credential_survived")
    if (
        any(
            marker in gateway_unit or marker in gateway_config
            for marker in (b"API_SERVER_APPROVAL_PASSKEY",)
        )
        or approval_source in gateway_config
        or bearer_source in gateway_config
        or gateway_unit.count(approval_source) != 1
        or gateway_unit.count(bearer_source) != 1
        or gateway_unit.splitlines().count(approval_inaccessible) != 1
        or gateway_unit.splitlines().count(bearer_inaccessible) != 1
        or gateway_unit.splitlines().count(approval_load) != 1
        or gateway_unit.splitlines().count(bearer_load) != 1
        or b"LoadCredential=api-server.key:" in gateway_unit
        or b"LoadCredential=api-approval-passkey:" in gateway_unit
    ):
        raise ArtifactError("artifact_gateway_credential_boundary_invalid")

    config = _decode_json_object(_staged_file(files["connector_config"]))
    if set(config) != {"service", "discord", "journal"}:
        raise ArtifactError("artifact_connector_config_invalid")
    service = _exact(
        config["service"],
        {
            "socket_path", "gateway_unit", "connector_unit", "gateway_uid",
            "connector_uid", "connector_gid", "connection_timeout_seconds",
        },
        "artifact_connector_config_invalid",
    )
    discord = _exact(
        config["discord"],
        {
            "token_file", "credentials_directory", "allowed_guild_ids",
            "allowed_channel_ids", "allowed_user_ids", "allowed_role_ids",
            "free_response_channel_ids", "public_only", "author_policy",
            "allow_bot_authors", "require_mention", "auto_thread",
            "thread_require_mention",
            "reviewed_cron_history_targets",
            "ready_timeout_seconds", "request_timeout_seconds",
        },
        "artifact_connector_config_invalid",
    )
    journal = _exact(
        config["journal"], {"path", "busy_timeout_ms"},
        "artifact_connector_config_invalid",
    )
    token = manifest["connector_token"]
    if (
        service != {
            "socket_path": "/run/muncho-discord-connector/connector.sock",
            "gateway_unit": GATEWAY_UNIT,
            "connector_unit": CONNECTOR_UNIT,
            "gateway_uid": files["gateway_config"]["uid"],
            "connector_uid": token["uid"],
            "connector_gid": token["gid"],
            "connection_timeout_seconds": 10,
        }
        or discord["token_file"] != str(CONNECTOR_TOKEN)
        or discord["credentials_directory"] != str(CONNECTOR_TOKEN.parent)
        or not _discord_ids(discord["allowed_guild_ids"])
        or not _discord_ids(discord["allowed_channel_ids"])
        or not _discord_ids(discord["allowed_user_ids"], allow_empty=True)
        or not _discord_ids(discord["allowed_role_ids"], allow_empty=True)
        or not _discord_ids(
            discord["free_response_channel_ids"], allow_empty=True
        )
        or discord["allowed_guild_ids"] != target_policy["allowed_guild_ids"]
        or discord["allowed_channel_ids"]
        != target_policy["allowed_channel_ids"]
        or discord["allowed_user_ids"] != target_policy["allowed_user_ids"]
        or discord["allowed_role_ids"] != target_policy["allowed_role_ids"]
        or discord["free_response_channel_ids"]
        != target_policy["free_response_channel_ids"]
        or discord["reviewed_cron_history_targets"] != {
            "06ef64d72891": ["1504852355588423801"],
            "e62f55ca93ca": ["1524321461714681976"],
        }
        or discord["public_only"] is not False
        or discord["author_policy"] != "guild_acl"
        or discord["allow_bot_authors"] is not False
        or discord["require_mention"] is not True
        or discord["auto_thread"] is not True
        or discord["thread_require_mention"] is not False
        or discord["ready_timeout_seconds"] != 30
        or discord["request_timeout_seconds"] != 15
        or journal != {
            "path": "/var/lib/muncho-discord-connector/connector.sqlite3",
            "busy_timeout_ms": 5000,
        }
    ):
        raise ArtifactError("artifact_connector_config_invalid")

    key_foundation = manifest["discord_key_foundation"]
    writer_config = _decode_json_object(_staged_file(files["writer_config"]))
    writer_authority = _exact(
        writer_config.get("discord_edge_authority"),
        {
            "enabled", "capability_private_key_file",
            "edge_receipt_public_key_file", "edge_receipt_public_key_id",
            "request_timeout_seconds",
        },
        "artifact_writer_discord_authority_invalid",
    )
    if writer_authority != {
        "enabled": True,
        "capability_private_key_file": str(WRITER_CAPABILITY_PRIVATE_KEY),
        "edge_receipt_public_key_file": str(EDGE_RECEIPT_PUBLIC_KEY),
        "edge_receipt_public_key_id": key_foundation["edge"]["public_key_id"],
        "request_timeout_seconds": 15,
    }:
        raise ArtifactError("artifact_writer_discord_authority_invalid")

    routeback_config = _decode_json_object(
        _staged_file(files["routeback_config"])
    )
    routeback_keys = _exact(
        routeback_config.get("keys"),
        {
            "writer_capability_public_key_file",
            "writer_capability_public_key_id",
            "edge_receipt_private_key_file",
            "edge_receipt_public_key_id",
        },
        "artifact_routeback_key_binding_invalid",
    )
    credential_private = (
        "/run/credentials/muncho-discord-egress.service/"
        "discord-edge-receipt-private-key"
    )
    if routeback_keys != {
        "writer_capability_public_key_file": str(
            WRITER_CAPABILITY_PUBLIC_KEY
        ),
        "writer_capability_public_key_id": key_foundation["writer"][
            "public_key_id"
        ],
        "edge_receipt_private_key_file": credential_private,
        "edge_receipt_public_key_id": key_foundation["edge"]["public_key_id"],
    }:
        raise ArtifactError("artifact_routeback_key_binding_invalid")


def _target_file_identity(item: Mapping[str, Any]) -> Mapping[str, Any]:
    return {
        "state": "present", "sha256": item["sha256"], "uid": item["uid"],
        "gid": item["gid"], "mode": item["mode"],
    }


def _backup_path(plan: Mapping[str, Any], name: str) -> Path:
    return EVIDENCE_ROOT / "plans" / str(plan["plan_sha256"]) / "host-backup" / f"{name}.json"


def _backup_file(plan: Mapping[str, Any], name: str, item: Mapping[str, Any]) -> None:
    path = _backup_path(plan, name)
    expected = item["pre"]
    if path.exists():
        raw = _strict_json(_read_exact_file(path, allowed_modes={0o400}, owners={0}), "artifact_host_backup_invalid")
        if raw != {"schema": "muncho-production-host-file-backup.v1", "name": name, "pre_identity": expected, "bytes_hex": raw.get("bytes_hex"), "backup_sha256": raw.get("backup_sha256")}:
            raise ArtifactError("artifact_host_backup_invalid")
        unsigned = {key: value for key, value in raw.items() if key != "backup_sha256"}
        if _sha_json(unsigned) != raw["backup_sha256"]:
            raise ArtifactError("artifact_host_backup_invalid")
        return
    target = Path(item["target_path"])
    payload: bytes | None = None
    if expected["state"] == "present":
        payload = _read_exact_file(
            target, allowed_modes={expected["mode"]}, owners={expected["uid"]},
            groups={expected["gid"]},
        )
        if hashlib.sha256(payload).hexdigest() != expected["sha256"]:
            raise ArtifactError("artifact_host_pre_identity_changed")
    elif expected["state"] != "absent" or os.path.lexists(target):
        raise ArtifactError("artifact_host_pre_identity_invalid")
    unsigned = {
        "schema": "muncho-production-host-file-backup.v1",
        "name": name,
        "pre_identity": expected,
        "bytes_hex": None if payload is None else payload.hex(),
    }
    _install(path, _canonical_bytes({**unsigned, "backup_sha256": _sha_json(unsigned)}), 0o400)


def _load_backup(plan: Mapping[str, Any], name: str, item: Mapping[str, Any]) -> bytes | None:
    backup = _backup_path(plan, name)
    if not os.path.lexists(backup):
        # A crash may interrupt the pre-mutation backup loop.  Recover only
        # while the target is still byte-for-byte the signed pre-state; once
        # target bytes appeared, a missing backup is irrecoverable and must
        # fail closed.
        if not _file_matches(Path(item["target_path"]), item["pre"]):
            raise ArtifactError("artifact_host_backup_missing_after_mutation")
        _backup_file(plan, name, item)
    raw = _strict_json(
        _read_exact_file(backup, allowed_modes={0o400}, owners={0}),
        "artifact_host_backup_invalid",
    )
    expected = item["pre"]
    if set(raw) != {"schema", "name", "pre_identity", "bytes_hex", "backup_sha256"} or raw["schema"] != "muncho-production-host-file-backup.v1" or raw["name"] != name or raw["pre_identity"] != expected:
        raise ArtifactError("artifact_host_backup_invalid")
    if _sha_json({key: item for key, item in raw.items() if key != "backup_sha256"}) != raw["backup_sha256"]:
        raise ArtifactError("artifact_host_backup_invalid")
    encoded = raw["bytes_hex"]
    if encoded is None:
        return None
    if not isinstance(encoded, str) or len(encoded) > 2 * MAX_FILE or re.fullmatch(r"[0-9a-f]+", encoded) is None:
        raise ArtifactError("artifact_host_backup_invalid")
    payload = bytes.fromhex(encoded)
    if hashlib.sha256(payload).hexdigest() != expected["sha256"]:
        raise ArtifactError("artifact_host_backup_invalid")
    return payload


def _staged_file(item: Mapping[str, Any]) -> bytes:
    sealed = _sealed_runtime_artifacts()
    for name, identity in sealed["files"].items():
        if item.get("target_path") != identity["target_path"]:
            continue
        if {
            key: item.get(key)
            for key in ("target_path", "sha256", "uid", "gid", "mode")
        } != identity:
            raise ArtifactError("artifact_sealed_runtime_file_invalid")
        return _sealed_file_payload(name)
    payload = _read_exact_file(
        Path(item["staged_path"]), allowed_modes={0o400}, owners={0}, groups={0}
    )
    if hashlib.sha256(payload).hexdigest() != item["sha256"]:
        raise ArtifactError("artifact_staged_file_digest_invalid")
    return payload


def _token_stat(path: Path, *, uid: int, gid: int, mode: int) -> os.stat_result:
    try:
        observed = os.lstat(path)
    except OSError as exc:
        raise ArtifactError("artifact_discord_token_invalid") from exc
    if (
        not stat.S_ISREG(observed.st_mode)
        or stat.S_ISLNK(observed.st_mode)
        or observed.st_nlink != 1
        or observed.st_uid != uid
        or observed.st_gid != gid
        or stat.S_IMODE(observed.st_mode) != mode
        or not 24 <= observed.st_size <= 4096
    ):
        raise ArtifactError("artifact_discord_token_invalid")
    return observed


def _fsync_parent(path: Path) -> None:
    descriptor = os.open(path.parent, os.O_RDONLY | getattr(os, "O_DIRECTORY", 0))
    try:
        os.fsync(descriptor)
    finally:
        os.close(descriptor)


def _assert_routeback_leases(manifest: Mapping[str, Any]) -> None:
    gateway_uid = manifest["files"]["gateway_config"]["uid"]
    for value in manifest["routeback_token_paths"]:
        path = _safe_path(value)
        try:
            observed = os.lstat(path)
        except OSError as exc:
            raise ArtifactError("artifact_routeback_lease_invalid") from exc
        if (
            not stat.S_ISREG(observed.st_mode)
            or stat.S_ISLNK(observed.st_mode)
            or observed.st_nlink != 1
            or stat.S_IMODE(observed.st_mode) != 0o400
            or observed.st_uid == gateway_uid
            or not 24 <= observed.st_size <= 4096
        ):
            raise ArtifactError("artifact_routeback_lease_invalid")


def _move_token_to_connector(manifest: Mapping[str, Any]) -> None:
    token = manifest["connector_token"]
    source = _safe_path(token["source_path"])
    target = CONNECTOR_TOKEN
    retired = [_safe_path(value) for value in manifest["gateway_retired_token_paths"]]
    for path in retired:
        if path != source and os.path.lexists(path):
            raise ArtifactError("artifact_gateway_token_lease_survived")
    source_exists = os.path.lexists(source)
    target_exists = os.path.lexists(target)
    if source_exists:
        _token_stat(
            source, uid=token["source_uid"], gid=token["source_gid"],
            mode=token["source_mode"],
        )
        source_payload = _read_exact_file(
            source, allowed_modes={token["source_mode"]},
            owners={token["source_uid"]}, groups={token["source_gid"]},
            maximum=4096,
        )
        if not target_exists:
            _install(
                target, source_payload, token["mode"], uid=token["uid"],
                gid=token["gid"],
            )
        target_payload = _read_exact_file(
            target, allowed_modes={token["mode"]}, owners={token["uid"]},
            groups={token["gid"]}, maximum=4096,
        )
        if target_payload != source_payload:
            raise ArtifactError("artifact_discord_token_copy_unconfirmed")
        source.unlink()
        _fsync_parent(source)
    elif not target_exists:
        raise ArtifactError("artifact_discord_token_missing")
    _token_stat(
        target, uid=token["uid"], gid=token["gid"], mode=token["mode"]
    )
    if any(os.path.lexists(path) for path in retired):
        raise ArtifactError("artifact_gateway_token_lease_survived")
    _assert_routeback_leases(manifest)


def _restore_token_to_source(manifest: Mapping[str, Any]) -> None:
    token = manifest["connector_token"]
    source = _safe_path(token["source_path"])
    target = CONNECTOR_TOKEN
    source_exists = os.path.lexists(source)
    target_exists = os.path.lexists(target)
    if target_exists:
        target_payload = _read_exact_file(
            target, allowed_modes={token["mode"]}, owners={token["uid"]},
            groups={token["gid"]}, maximum=4096,
        )
        if not source_exists:
            _install(
                source, target_payload, token["source_mode"],
                uid=token["source_uid"], gid=token["source_gid"],
            )
        source_payload = _read_exact_file(
            source, allowed_modes={token["source_mode"]},
            owners={token["source_uid"]}, groups={token["source_gid"]},
            maximum=4096,
        )
        if source_payload != target_payload:
            raise ArtifactError("artifact_discord_token_restore_unconfirmed")
        target.unlink()
        _fsync_parent(target)
    elif not source_exists:
        raise ArtifactError("artifact_discord_token_missing")
    _token_stat(
        source, uid=token["source_uid"], gid=token["source_gid"],
        mode=token["source_mode"],
    )
    if os.path.lexists(target):
        raise ArtifactError("artifact_connector_token_lease_survived")
    _assert_routeback_leases(manifest)


def _approval_passkey_payload(payload: bytes) -> str:
    candidate = payload
    if candidate.endswith(b"\r\n"):
        candidate = candidate[:-2]
    elif candidate.endswith(b"\n"):
        candidate = candidate[:-1]
    try:
        value = candidate.decode("utf-8", errors="strict")
    except UnicodeDecodeError as exc:
        raise ArtifactError("artifact_approval_passkey_invalid") from exc
    if (
        not 32 <= len(candidate) <= 4096
        or not value
        or value != value.strip()
        or any(ord(character) < 0x20 or ord(character) == 0x7F for character in value)
    ):
        raise ArtifactError("artifact_approval_passkey_invalid")
    return value


def _approval_passkey_stat(
    path: Path,
    *,
    uid: int,
    gid: int,
    mode: int,
) -> bytes:
    _trusted_parent(path, uid)
    try:
        observed = os.lstat(path)
    except OSError as exc:
        raise ArtifactError("artifact_approval_passkey_invalid") from exc
    if (
        not stat.S_ISREG(observed.st_mode)
        or stat.S_ISLNK(observed.st_mode)
        or observed.st_nlink != 1
        or observed.st_uid != uid
        or observed.st_gid != gid
        or stat.S_IMODE(observed.st_mode) != mode
        or not 32 <= observed.st_size <= 4098
    ):
        raise ArtifactError("artifact_approval_passkey_invalid")
    payload = _read_exact_file(
        path,
        allowed_modes={mode},
        owners={uid},
        groups={gid},
        maximum=4098,
    )
    _approval_passkey_payload(payload)
    return payload


def _api_verifier(
    payload: bytes,
    *,
    kind: str,
) -> Mapping[str, Any]:
    code = "artifact_api_verifier_invalid"
    raw = _strict_json(payload, code)
    if kind == "bearer":
        expected_fields = {"schema", "algorithm", "domain", "sha256"}
        if (
            set(raw) != expected_fields
            or raw.get("schema") != "hermes.api.bearer-sha256-verifier.v1"
            or raw.get("algorithm") != "sha256"
            or raw.get("domain") != "hermes.api.bearer.v1"
            or not isinstance(raw.get("sha256"), str)
            or SHA256.fullmatch(raw["sha256"]) is None
        ):
            raise ArtifactError(code)
        return raw
    expected_fields = {
        "schema", "algorithm", "domain", "n", "r", "p", "dklen",
        "salt_hex", "verifier_hex",
    }
    if (
        set(raw) != expected_fields
        or raw.get("schema") != "hermes.api.approval-scrypt-verifier.v1"
        or raw.get("algorithm") != "scrypt"
        or raw.get("domain") != "hermes.api.approval-passkey.v1"
        or type(raw.get("n")) is not int
        or raw.get("n") != 16_384
        or type(raw.get("r")) is not int
        or raw.get("r") != 8
        or type(raw.get("p")) is not int
        or raw.get("p") != 1
        or type(raw.get("dklen")) is not int
        or raw.get("dklen") != 32
        or not isinstance(raw.get("salt_hex"), str)
        or re.fullmatch(r"[0-9a-f]{64}", raw["salt_hex"]) is None
        or not isinstance(raw.get("verifier_hex"), str)
        or re.fullmatch(r"[0-9a-f]{64}", raw["verifier_hex"]) is None
    ):
        raise ArtifactError(code)
    return raw


def _validate_api_verifier_foundation(
    manifest: Mapping[str, Any],
) -> Mapping[str, Any]:
    approval = manifest["approval_passkey"]
    approval_source = _safe_path(approval["source_path"])
    retired = [
        _safe_path(value) for value in manifest["retired_approval_passkey_paths"]
    ]
    for path in retired:
        if path != approval_source and os.path.lexists(path):
            raise ArtifactError("artifact_approval_passkey_lease_survived")
    approval_secret = _approval_passkey_payload(
        _approval_passkey_stat(
            approval_source,
            uid=approval["source_uid"],
            gid=approval["source_gid"],
            mode=approval["source_mode"],
        )
    )
    bearer_secret = _approval_passkey_payload(
        _approval_passkey_stat(
            LEGACY_API_BEARER,
            uid=API_SECRET_SOURCE_UID,
            gid=API_SECRET_SOURCE_GID,
            mode=0o400,
        )
    )
    files = manifest["files"]
    bearer_payload = _read_exact_file(
        API_BEARER_VERIFIER,
        allowed_modes={0o400},
        owners={API_VERIFIER_UID},
        groups={API_VERIFIER_GID},
        maximum=8192,
    )
    approval_payload = _read_exact_file(
        API_APPROVAL_VERIFIER,
        allowed_modes={0o400},
        owners={API_VERIFIER_UID},
        groups={API_VERIFIER_GID},
        maximum=8192,
    )
    if (
        hashlib.sha256(bearer_payload).hexdigest()
        != files["api_bearer_verifier"]["sha256"]
        or hashlib.sha256(approval_payload).hexdigest()
        != files["api_approval_verifier"]["sha256"]
    ):
        raise ArtifactError("artifact_api_verifier_identity_invalid")
    bearer = _api_verifier(bearer_payload, kind="bearer")
    approval_verifier = _api_verifier(approval_payload, kind="approval")
    observed_bearer = hashlib.sha256(
        b"hermes.api.bearer.v1\x00" + bearer_secret.encode("utf-8")
    ).hexdigest()
    try:
        observed_approval = hashlib.scrypt(
            b"hermes.api.approval-passkey.v1\x00"
            + approval_secret.encode("utf-8"),
            salt=bytes.fromhex(str(approval_verifier["salt_hex"])),
            n=16_384,
            r=8,
            p=1,
            dklen=32,
            maxmem=64 * 1024 * 1024,
        ).hex()
    except (TypeError, ValueError) as exc:
        raise ArtifactError("artifact_api_verifier_invalid") from exc
    if (
        not hmac.compare_digest(str(bearer["sha256"]), observed_bearer)
        or not hmac.compare_digest(
            str(approval_verifier["verifier_hex"]),
            observed_approval,
        )
    ):
        raise ArtifactError("artifact_api_verifier_secret_mismatch")
    unsigned = {
        "schema": "muncho-production-api-verifier-foundation.v1",
        "bearer_verifier_sha256": files["api_bearer_verifier"]["sha256"],
        "approval_verifier_sha256": files["api_approval_verifier"]["sha256"],
        "source_secrets_root_only": True,
        "source_secrets_loaded_by_gateway": False,
        "secret_material_recorded": False,
    }
    return {**unsigned, "receipt_sha256": _sha_json(unsigned)}


def _move_approval_passkey(manifest: Mapping[str, Any]) -> None:
    """Compatibility wrapper: validate verifier foundation; never copy secret."""

    _validate_api_verifier_foundation(manifest)


def _restore_approval_passkey(manifest: Mapping[str, Any]) -> None:
    """Confirm the root-only source survived; generic host rollback removes verifiers."""

    approval = manifest["approval_passkey"]
    source = _safe_path(approval["source_path"])
    _approval_passkey_stat(
        source,
        uid=approval["source_uid"],
        gid=approval["source_gid"],
        mode=approval["source_mode"],
    )
    _approval_passkey_stat(
        LEGACY_API_BEARER,
        uid=API_SECRET_SOURCE_UID,
        gid=API_SECRET_SOURCE_GID,
        mode=0o400,
    )


def _pem_der(
    payload: bytes,
    *,
    label: str,
    header: bytes,
    footer: bytes,
) -> bytes:
    lines = payload.splitlines()
    if len(lines) < 3 or lines[0] != header or lines[-1] != footer:
        raise ArtifactError(label)
    body = b"".join(lines[1:-1])
    try:
        der = base64.b64decode(body, validate=True)
    except (ValueError, TypeError) as exc:
        raise ArtifactError(label) from exc
    encoded = base64.b64encode(der)
    canonical = (
        header
        + b"\n"
        + b"\n".join(encoded[index:index + 64] for index in range(0, len(encoded), 64))
        + b"\n"
        + footer
        + b"\n"
    )
    if payload != canonical:
        raise ArtifactError(label)
    return der


def _derive_ed25519_public(private_pem: bytes) -> tuple[bytes, str]:
    private_der = _pem_der(
        private_pem,
        label="artifact_discord_private_key_invalid",
        header=b"-----BEGIN PRIVATE KEY-----",
        footer=b"-----END PRIVATE KEY-----",
    )
    private_prefix = bytes.fromhex("302e020100300506032b657004220420")
    if len(private_der) != len(private_prefix) + 32 or not private_der.startswith(
        private_prefix
    ):
        raise ArtifactError("artifact_discord_private_key_invalid")
    try:
        completed = subprocess.run(
            (OPENSSL, "pkey", "-pubout"),
            input=private_pem,
            capture_output=True,
            check=False,
            timeout=10,
            cwd="/",
            env={"LC_ALL": "C", "PATH": "/usr/bin:/bin"},
            close_fds=True,
        )
    except (OSError, subprocess.SubprocessError) as exc:
        raise ArtifactError("artifact_discord_key_derivation_failed") from exc
    if completed.returncode != 0 or completed.stderr:
        raise ArtifactError("artifact_discord_key_derivation_failed")
    public_pem = completed.stdout
    public_der = _pem_der(
        public_pem,
        label="artifact_discord_public_key_invalid",
        header=b"-----BEGIN PUBLIC KEY-----",
        footer=b"-----END PUBLIC KEY-----",
    )
    public_prefix = bytes.fromhex("302a300506032b6570032100")
    if len(public_der) != len(public_prefix) + 32 or not public_der.startswith(
        public_prefix
    ):
        raise ArtifactError("artifact_discord_public_key_invalid")
    raw_public = public_der[len(public_prefix):]
    return public_pem, hashlib.sha256(raw_public).hexdigest()


def _key_private_bytes(path: Path, *, uid: int, gid: int, mode: int) -> bytes:
    return _read_exact_file(
        path,
        allowed_modes={mode},
        owners={uid},
        groups={gid},
        maximum=8 * 1024,
    )


def _provision_discord_keys(manifest: Mapping[str, Any]) -> Mapping[str, Any]:
    foundation = _discord_key_foundation(
        manifest,
        _identity_foundation(manifest),
    )
    receipts: dict[str, Mapping[str, Any]] = {}
    observed_ids: set[str] = set()
    for role in ("writer", "edge"):
        item = foundation[role]
        source = Path(item["staged_private_path"])
        private = Path(item["private_path"])
        public = Path(item["public_path"])
        source_exists = os.path.lexists(source)
        private_exists = os.path.lexists(private)
        if not source_exists and not private_exists:
            raise ArtifactError("artifact_discord_private_key_missing")
        source_payload = (
            None
            if not source_exists
            else _key_private_bytes(source, uid=0, gid=0, mode=0o400)
        )
        target_payload = (
            None
            if not private_exists
            else _key_private_bytes(
                private,
                uid=item["private_uid"],
                gid=item["private_gid"],
                mode=item["private_mode"],
            )
        )
        if source_payload is not None and target_payload is not None and (
            source_payload != target_payload
        ):
            raise ArtifactError("artifact_discord_private_key_conflict")
        payload = source_payload if source_payload is not None else target_payload
        assert payload is not None
        public_payload, key_id = _derive_ed25519_public(payload)
        if key_id != item["public_key_id"] or key_id in observed_ids:
            raise ArtifactError("artifact_discord_key_identity_invalid")
        observed_ids.add(key_id)
        _install(
            private,
            payload,
            item["private_mode"],
            uid=item["private_uid"],
            gid=item["private_gid"],
        )
        _install(
            public,
            public_payload,
            item["public_mode"],
            uid=item["public_uid"],
            gid=item["public_gid"],
        )
        _key_private_bytes(
            private,
            uid=item["private_uid"],
            gid=item["private_gid"],
            mode=item["private_mode"],
        )
        public_observed = _read_exact_file(
            public,
            allowed_modes={item["public_mode"]},
            owners={item["public_uid"]},
            groups={item["public_gid"]},
            maximum=8 * 1024,
        )
        if public_observed != public_payload:
            raise ArtifactError("artifact_discord_public_key_unconfirmed")
        if source_exists:
            source.unlink()
            _fsync_parent(source)
        receipts[role] = {
            "public_key_id": key_id,
            "private_path": str(private),
            "private_uid": item["private_uid"],
            "private_gid": item["private_gid"],
            "private_mode": item["private_mode"],
            "public_path": str(public),
            "public_uid": item["public_uid"],
            "public_gid": item["public_gid"],
            "public_mode": item["public_mode"],
            "staged_private_retired": True,
        }
    unsigned = {
        "schema": "muncho-production-discord-key-provision.v1",
        "foundation_sha256": foundation["foundation_sha256"],
        "writer": receipts["writer"],
        "edge": receipts["edge"],
        "keys_distinct": True,
        "private_content_or_digest_recorded": False,
        "secret_material_recorded": False,
        "secret_digest_recorded": False,
    }
    return {**unsigned, "receipt_sha256": _sha_json(unsigned)}


def _ensure_operational_edge_trust_root() -> None:
    parent = OPERATIONAL_EDGE_TRUST_ROOT.parent
    try:
        parent_state = os.lstat(parent)
    except OSError as exc:
        raise ArtifactError(
            "artifact_operational_edge_trust_parent_invalid"
        ) from exc
    if (
        stat.S_ISLNK(parent_state.st_mode)
        or not stat.S_ISDIR(parent_state.st_mode)
        or parent_state.st_uid != 0
        or parent_state.st_gid != 0
        or stat.S_IMODE(parent_state.st_mode) & 0o022
    ):
        raise ArtifactError("artifact_operational_edge_trust_parent_invalid")
    if not os.path.lexists(OPERATIONAL_EDGE_TRUST_ROOT):
        try:
            os.mkdir(OPERATIONAL_EDGE_TRUST_ROOT, 0o755)
            os.chown(OPERATIONAL_EDGE_TRUST_ROOT, 0, 0)
            os.chmod(OPERATIONAL_EDGE_TRUST_ROOT, 0o755)
            _fsync_parent(OPERATIONAL_EDGE_TRUST_ROOT)
        except OSError as exc:
            raise ArtifactError(
                "artifact_operational_edge_trust_root_invalid"
            ) from exc
    try:
        observed = os.lstat(OPERATIONAL_EDGE_TRUST_ROOT)
    except OSError as exc:
        raise ArtifactError(
            "artifact_operational_edge_trust_root_invalid"
        ) from exc
    if (
        stat.S_ISLNK(observed.st_mode)
        or not stat.S_ISDIR(observed.st_mode)
        or observed.st_uid != 0
        or observed.st_gid != 0
        or stat.S_IMODE(observed.st_mode) != 0o755
    ):
        raise ArtifactError("artifact_operational_edge_trust_root_invalid")


def _operational_edge_key_targets(
    manifest: Mapping[str, Any],
    *,
    install: bool,
) -> tuple[Mapping[str, Any], list[Mapping[str, Any]]]:
    discord = _discord_key_foundation(
        manifest,
        _identity_foundation(manifest),
    )
    foundation = _operational_edge_key_foundation(
        manifest,
        writer_public_key_id=discord["writer"]["public_key_id"],
    )
    expected_ids = manifest["operational_edge_receipt_public_key_ids"]
    if install:
        _ensure_operational_edge_trust_root()
    receipts: list[Mapping[str, Any]] = []
    observed_ids: set[str] = set()
    for item in foundation["keys"]:
        domain = item["domain"]
        staged_private = Path(item["private_path"])
        staged_public = Path(item["public_path"])
        private_payload = _key_private_bytes(
            staged_private,
            uid=0,
            gid=0,
            mode=0o400,
        )
        public_payload = _read_exact_file(
            staged_public,
            allowed_modes={0o444},
            owners={0},
            groups={0},
            maximum=8 * 1024,
        )
        derived_public, key_id = _derive_ed25519_public(private_payload)
        if (
            public_payload != derived_public
            or key_id != item["public_key_id"]
            or expected_ids.get(domain) != key_id
            or key_id in observed_ids
        ):
            raise ArtifactError(
                "artifact_operational_edge_key_identity_invalid"
            )
        observed_ids.add(key_id)
        private = (
            OPERATIONAL_EDGE_KEY_ROOT
            / f"operational-edge-{domain}-receipt-private.pem"
        )
        public = OPERATIONAL_EDGE_TRUST_ROOT / f"{domain}-receipt-public.pem"
        if install:
            if os.path.lexists(private) and _key_private_bytes(
                private,
                uid=0,
                gid=0,
                mode=0o400,
            ) != private_payload:
                raise ArtifactError(
                    "artifact_operational_edge_private_key_conflict"
                )
            if os.path.lexists(public) and _read_exact_file(
                public,
                allowed_modes={0o444},
                owners={0},
                groups={0},
                maximum=8 * 1024,
            ) != public_payload:
                raise ArtifactError(
                    "artifact_operational_edge_public_key_conflict"
                )
            _install(private, private_payload, 0o400, uid=0, gid=0)
            _install(public, public_payload, 0o444, uid=0, gid=0)
        final_private = _key_private_bytes(
            private,
            uid=0,
            gid=0,
            mode=0o400,
        )
        final_public = _read_exact_file(
            public,
            allowed_modes={0o444},
            owners={0},
            groups={0},
            maximum=8 * 1024,
        )
        final_derived, final_key_id = _derive_ed25519_public(final_private)
        if (
            final_private != private_payload
            or final_public != public_payload
            or final_derived != final_public
            or final_key_id != key_id
        ):
            raise ArtifactError(
                "artifact_operational_edge_key_install_unconfirmed"
            )
        receipts.append(
            {
                "domain": domain,
                "public_key_id": key_id,
                "private_path": str(private),
                "private_uid": 0,
                "private_gid": 0,
                "private_mode": 0o400,
                "public_path": str(public),
                "public_uid": 0,
                "public_gid": 0,
                "public_mode": 0o444,
                "private_key_verified": True,
                "public_key_verified": True,
                "staged_key_copy_retained": True,
            }
        )
    if len(observed_ids) != len(OPERATIONAL_EDGE_DOMAINS):
        raise ArtifactError("artifact_operational_edge_key_identity_invalid")
    return foundation, receipts


def _provision_operational_edge_keys(
    manifest: Mapping[str, Any],
) -> Mapping[str, Any]:
    stopped = {unit: _service(unit) for unit in OPERATIONAL_EDGE_UNITS}
    if any(not _stopped(value) for value in stopped.values()):
        raise ArtifactError("artifact_operational_edge_services_not_stopped")
    foundation, keys = _operational_edge_key_targets(manifest, install=True)
    unsigned = {
        "schema": "muncho-production-operational-edge-key-provision.v1",
        "key_foundation_sha256": foundation["receipt_sha256"],
        "receipt_public_key_ids": dict(
            manifest["operational_edge_receipt_public_key_ids"]
        ),
        "keys": keys,
        "key_count": len(keys),
        "all_keys_verified": True,
        "all_operational_edge_services_stopped": True,
        "staged_key_copies_retained_for_crash_recovery": True,
        "retain_final_keys_dormant_on_rollback": True,
        "private_content_or_digest_recorded": False,
        "secret_material_recorded": False,
        "secret_digest_recorded": False,
    }
    return {**unsigned, "receipt_sha256": _sha_json(unsigned)}


def _retain_operational_edge_keys_on_rollback(
    manifest: Mapping[str, Any],
) -> Mapping[str, Any]:
    stopped = {unit: _service(unit) for unit in OPERATIONAL_EDGE_UNITS}
    if any(not _stopped(value) for value in stopped.values()):
        raise ArtifactError("artifact_operational_edge_services_not_stopped")
    # A crash may reach rollback after staging but before the forward install.
    # Converge the already-attested identities into their final dormant paths;
    # never generate, replace, or delete a key during rollback.
    foundation, keys = _operational_edge_key_targets(manifest, install=True)
    unsigned = {
        "schema": "muncho-production-operational-edge-key-retention.v1",
        "key_foundation_sha256": foundation["receipt_sha256"],
        "receipt_public_key_ids": dict(
            manifest["operational_edge_receipt_public_key_ids"]
        ),
        "keys": keys,
        "key_count": len(keys),
        "all_keys_verified": True,
        "stopped_operational_edge_units": list(OPERATIONAL_EDGE_UNITS),
        "all_operational_edge_services_stopped": True,
        "final_private_keys_retained": True,
        "final_public_keys_retained": True,
        "final_keys_retained_dormant": True,
        "staged_key_copies_retained": True,
        "private_content_or_digest_recorded": False,
        "secret_material_recorded": False,
        "secret_digest_recorded": False,
    }
    return {**unsigned, "receipt_sha256": _sha_json(unsigned)}


def _ensure_state_directory(path: Path, *, uid: int, gid: int) -> None:
    if not os.path.lexists(path):
        try:
            os.mkdir(path, 0o700)
            os.chown(path, uid, gid)
            os.chmod(path, 0o700)
            _fsync_parent(path)
        except OSError as exc:
            raise ArtifactError("artifact_discord_state_directory_invalid") from exc
    try:
        observed = os.lstat(path)
    except OSError as exc:
        raise ArtifactError("artifact_discord_state_directory_invalid") from exc
    if (
        stat.S_ISLNK(observed.st_mode)
        or not stat.S_ISDIR(observed.st_mode)
        or observed.st_uid != uid
        or observed.st_gid != gid
        or stat.S_IMODE(observed.st_mode) != 0o700
    ):
        raise ArtifactError("artifact_discord_state_directory_invalid")


def _bootstrap_discord_journal(
    plan: Mapping[str, Any],
    manifest: Mapping[str, Any],
    *,
    kind: str,
) -> Mapping[str, Any]:
    identity = _identity_foundation(manifest)
    role = "connector" if kind == "connector" else "routeback"
    user = identity["users"][role]
    group = identity["groups"][role]
    state = CONNECTOR_STATE_DIRECTORY if kind == "connector" else ROUTEBACK_STATE_DIRECTORY
    journal = CONNECTOR_JOURNAL if kind == "connector" else ROUTEBACK_JOURNAL
    _ensure_state_directory(state, uid=user["uid"], gid=group["gid"])
    release = Path(
        "/opt/adventico-ai-platform/hermes-agent-releases"
    ) / f"hermes-agent-{str(plan['release_revision'])[:12]}"
    interpreter = release / ".venv/bin/python"
    arguments = (
        RUNUSER,
        "--user", user["name"],
        "--group", group["name"],
        "--",
        str(interpreter),
        "-B", "-I", "-m", "gateway.production_discord_journal_bootstrap",
        "--kind", kind,
        "--intent-sha256", str(plan["plan_sha256"]),
        "--busy-timeout-ms", "5000",
    )
    try:
        completed = subprocess.run(
            arguments,
            cwd=release,
            env={
                "LC_ALL": "C.UTF-8",
                "PATH": "/usr/bin:/bin",
                "PYTHONNOUSERSITE": "1",
                "HOME": user["home"],
            },
            check=False,
            capture_output=True,
            timeout=60,
            close_fds=True,
        )
    except (OSError, subprocess.SubprocessError) as exc:
        raise ArtifactError("artifact_discord_journal_bootstrap_failed") from exc
    if completed.returncode != 0 or completed.stderr:
        raise ArtifactError("artifact_discord_journal_bootstrap_failed")
    raw = _strict_json(
        completed.stdout,
        "artifact_discord_journal_bootstrap_receipt_invalid",
    )
    digest = raw.get("receipt_sha256")
    if (
        raw.get("schema") != "muncho-production-discord-journal-bootstrap.v1"
        or raw.get("kind") != kind
        or raw.get("path") != str(journal)
        or raw.get("uid") != user["uid"]
        or raw.get("gid") != group["gid"]
        or raw.get("mode") != "0600"
        or raw.get("bootstrap_intent_sha256") != plan["plan_sha256"]
        or raw.get("clean") is not True
        or raw.get("secret_material_recorded") is not False
        or raw.get("secret_digest_recorded") is not False
        or not isinstance(digest, str)
        or SHA256.fullmatch(digest) is None
        or _sha_json({key: value for key, value in raw.items() if key != "receipt_sha256"})
        != digest
    ):
        raise ArtifactError("artifact_discord_journal_bootstrap_receipt_invalid")
    return raw


def _bootstrap_discord_foundation(
    plan: Mapping[str, Any], manifest: Mapping[str, Any]
) -> Mapping[str, Any]:
    keys = _provision_discord_keys(manifest)
    connector = _bootstrap_discord_journal(
        plan, manifest, kind="connector"
    )
    routeback = _bootstrap_discord_journal(
        plan, manifest, kind="routeback"
    )
    unsigned = {
        "schema": "muncho-production-discord-foundation-bootstrap.v1",
        "plan_sha256": plan["plan_sha256"],
        "key_foundation_sha256": manifest["discord_key_foundation"][
            "foundation_sha256"
        ],
        "key_provision_receipt_sha256": keys["receipt_sha256"],
        "writer_public_key_id": keys["writer"]["public_key_id"],
        "edge_public_key_id": keys["edge"]["public_key_id"],
        "connector_journal_receipt_sha256": connector["receipt_sha256"],
        "routeback_journal_receipt_sha256": routeback["receipt_sha256"],
        "journals_clean_before_service_start": True,
        "normal_startup_creation_disabled": True,
        "private_content_or_digest_recorded": False,
        "secret_material_recorded": False,
        "secret_digest_recorded": False,
    }
    return {**unsigned, "receipt_sha256": _sha_json(unsigned)}


def _operational_edge_bundle(
    manifest: Mapping[str, Any],
) -> Mapping[str, Any]:
    raw = _hashed(
        _sealed_runtime_artifacts().get("operational_edge_bundle"),
        {
            "schema", "release_revision", "release_root",
            "release_owner_uid", "release_owner_gid", "catalog_sha256",
            "domains", "operation_count", "all_operations_implemented",
            "credentials_by_domain", "credential_count",
            "credential_values_read", "receipt_public_key_ids",
            "identity_contract", "units", "configs",
            "client_config_path", "client_config_sha256",
            "secret_material_recorded", "secret_digest_recorded",
            "bundle_sha256",
        },
        "bundle_sha256",
        "artifact_operational_edge_bundle_invalid",
    )
    revision = str(raw["release_revision"])
    expected_release = (
        Path("/opt/adventico-ai-platform/hermes-agent-releases")
        / f"hermes-agent-{revision[:12]}"
    )
    identity = _identity_foundation(manifest)
    service_users = {
        domain: identity["users"][f"operational_edge_{domain}"]
        for domain in sorted(OPERATIONAL_EDGE_DOMAINS)
    }
    service_groups = {
        domain: identity["groups"][f"operational_edge_{domain}"]
        for domain in sorted(OPERATIONAL_EDGE_DOMAINS)
    }
    socket_groups = {
        domain: identity["groups"][f"operational_edge_{domain}_client"]
        for domain in sorted(OPERATIONAL_EDGE_DOMAINS)
    }
    mutation_user = identity["users"]["gateway"]
    contract = _exact(
        raw["identity_contract"],
        {
            "services", "probe_runner", "sockets", "mutation_peer",
            "allowed_read_peer_uids_by_domain",
            "cross_domain_service_access", "root_socket_peer_allowed",
        },
        "artifact_operational_edge_bundle_invalid",
    )
    expected_units = {
        unit: manifest["files"][f"operational_edge_unit_{domain}"]["sha256"]
        for domain, unit in (
            (domain, f"muncho-operational-edge-{domain}.service")
            for domain in sorted(OPERATIONAL_EDGE_DOMAINS)
        )
    }
    expected_configs = {
        str(Path("/etc/muncho/operational-edge") / f"{domain}.json"):
        manifest["files"][f"operational_edge_config_{domain}"]["sha256"]
        for domain in sorted(OPERATIONAL_EDGE_DOMAINS)
    }
    if (
        raw["schema"] != "muncho-operational-edge-unit-bundle.v2"
        or revision != _sealed_runtime_artifacts()["release_revision"]
        or raw["release_root"] != str(expected_release)
        or raw["release_owner_uid"] != manifest["release_owner_uid"]
        or raw["release_owner_gid"] != manifest["release_owner_gid"]
        or SHA256.fullmatch(str(raw["catalog_sha256"])) is None
        or raw["domains"] != sorted(OPERATIONAL_EDGE_DOMAINS)
        or type(raw["operation_count"]) is not int
        or raw["operation_count"] < len(OPERATIONAL_EDGE_DOMAINS)
        or raw["all_operations_implemented"] is not True
        or not isinstance(raw["credentials_by_domain"], Mapping)
        or set(raw["credentials_by_domain"]) != OPERATIONAL_EDGE_DOMAINS
        or type(raw["credential_count"]) is not int
        or raw["credential_count"] < 1
        or raw["credential_values_read"] is not False
        or raw["receipt_public_key_ids"]
        != manifest["operational_edge_receipt_public_key_ids"]
        or raw["units"] != expected_units
        or raw["configs"] != expected_configs
        or raw["client_config_path"]
        != str(HOST_PATHS["operational_edge_client_config"])
        or raw["client_config_sha256"]
        != manifest["files"]["operational_edge_client_config"]["sha256"]
        or contract["services"] != {
            domain: {
                "user": service_users[domain]["name"],
                "group": service_groups[domain]["name"],
                "uid": service_users[domain]["uid"],
                "gid": service_groups[domain]["gid"],
            }
            for domain in sorted(OPERATIONAL_EDGE_DOMAINS)
        }
        or contract["probe_runner"] != {
            "user": mutation_user["name"],
            "uid": mutation_user["uid"],
            "gid": identity["groups"]["gateway"]["gid"],
            "supplementary_gids": sorted(
                group["gid"] for group in socket_groups.values()
            ),
            "root_allowed": False,
        }
        or contract["sockets"] != {
            domain: {
                "group": socket_groups[domain]["name"],
                "gid": socket_groups[domain]["gid"],
                "mode": "0660",
            }
            for domain in sorted(OPERATIONAL_EDGE_DOMAINS)
        }
        or contract["mutation_peer"] != {
            "user": mutation_user["name"],
            "uid": mutation_user["uid"],
            "gid": identity["groups"]["gateway"]["gid"],
            "distinct_from_services": True,
        }
        or contract["allowed_read_peer_uids_by_domain"] != {
            domain: [mutation_user["uid"]]
            for domain in sorted(OPERATIONAL_EDGE_DOMAINS)
        }
        or contract["cross_domain_service_access"] is not False
        or contract["root_socket_peer_allowed"] is not False
        or raw["secret_material_recorded"] is not False
        or raw["secret_digest_recorded"] is not False
    ):
        raise ArtifactError("artifact_operational_edge_bundle_invalid")
    return raw


def _operational_asset_readback(
    manifest: Mapping[str, Any],
) -> Mapping[str, Any]:
    bundle = _operational_edge_bundle(manifest)
    verification = _hashed(
        _sealed_runtime_artifacts().get("operational_asset_verification"),
        {
            "schema", "release_revision", "manifest_sha256",
            "expected_uid", "expected_gid", "files", "file_count",
            "all_payloads_verified", "credential_values_read",
            "secret_material_recorded", "secret_digest_recorded",
            "verification_sha256",
        },
        "verification_sha256",
        "artifact_operational_asset_verification_invalid",
    )
    release = Path(bundle["release_root"])
    rows = verification["files"]
    if (
        verification["schema"]
        != "muncho-operational-edge-assets-verification.v1"
        or verification["release_revision"] != bundle["release_revision"]
        or verification["expected_uid"] != bundle["release_owner_uid"]
        or verification["expected_gid"] != bundle["release_owner_gid"]
        or not isinstance(rows, list)
        or verification["file_count"] != len(rows)
        or len(rows) < len(OPERATIONAL_EDGE_DOMAINS)
        or verification["all_payloads_verified"] is not True
        or verification["credential_values_read"] is not False
        or verification["secret_material_recorded"] is not False
        or verification["secret_digest_recorded"] is not False
    ):
        raise ArtifactError("artifact_operational_asset_verification_invalid")
    observed: dict[str, Mapping[str, Any]] = {}
    for item in rows:
        row = _exact(
            item,
            {"asset_id", "path", "uid", "gid", "mode", "size", "sha256"},
            "artifact_operational_asset_verification_invalid",
        )
        path = _safe_path(row["path"])
        try:
            relative = path.relative_to(release)
        except ValueError as exc:
            raise ArtifactError(
                "artifact_operational_asset_verification_invalid"
            ) from exc
        if (
            not isinstance(row["asset_id"], str)
            or not row["asset_id"]
            or row["asset_id"] in observed
            or not relative.parts
            or row["uid"] != bundle["release_owner_uid"]
            or row["gid"] != bundle["release_owner_gid"]
            or row["mode"] != "0555"
            or type(row["size"]) is not int
            or not 0 < row["size"] <= 16 * 1024 * 1024
            or SHA256.fullmatch(str(row["sha256"])) is None
        ):
            raise ArtifactError(
                "artifact_operational_asset_verification_invalid"
            )
        payload = _read_exact_file(
            path,
            allowed_modes={0o555},
            owners={bundle["release_owner_uid"]},
            groups={bundle["release_owner_gid"]},
            maximum=16 * 1024 * 1024,
        )
        if len(payload) != row["size"] or hashlib.sha256(payload).hexdigest() != row["sha256"]:
            raise ArtifactError("artifact_operational_asset_readback_drifted")
        observed[row["asset_id"]] = row
    asset_manifest_path = (
        release / "ops/muncho/runtime/operational-assets/manifest.json"
    )
    manifest_payload = _read_exact_file(
        asset_manifest_path,
        allowed_modes={0o444},
        owners={bundle["release_owner_uid"]},
        groups={bundle["release_owner_gid"]},
        maximum=16 * 1024 * 1024,
    )
    if not manifest_payload.endswith(b"\n") or manifest_payload.endswith(b"\n\n"):
        raise ArtifactError("artifact_operational_asset_manifest_invalid")
    asset_manifest = _hashed(
        _strict_json(
            manifest_payload[:-1],
            "artifact_operational_asset_manifest_invalid",
        ),
        {
            "schema", "release_revision", "catalog_sha256", "assets",
            "asset_count", "operation_count", "all_operations_implemented",
            "credential_material_packaged", "secret_digest_recorded",
            "manifest_sha256",
        },
        "manifest_sha256",
        "artifact_operational_asset_manifest_invalid",
    )
    asset_rows = asset_manifest["assets"]
    if (
        asset_manifest["schema"] != "muncho-operational-edge-assets.v1"
        or asset_manifest["release_revision"] != bundle["release_revision"]
        or asset_manifest["catalog_sha256"] != bundle["catalog_sha256"]
        or asset_manifest["manifest_sha256"]
        != verification["manifest_sha256"]
        or not isinstance(asset_rows, list)
        or asset_manifest["asset_count"] != len(asset_rows)
        or len(asset_rows) != len(observed)
        or asset_manifest["operation_count"] != bundle["operation_count"]
        or asset_manifest["all_operations_implemented"] is not True
        or asset_manifest["credential_material_packaged"] is not False
        or asset_manifest["secret_digest_recorded"] is not False
    ):
        raise ArtifactError("artifact_operational_asset_manifest_invalid")
    seen: set[str] = set()
    for item in asset_rows:
        row = _exact(
            item,
            {
                "asset_id", "source_path", "source_uid", "source_gid",
                "source_mode", "packaged_relative", "packaged_mode",
                "size", "sha256",
            },
            "artifact_operational_asset_manifest_invalid",
        )
        verified = observed.get(row["asset_id"])
        packaged_relative = Path(str(row["packaged_relative"]))
        if (
            verified is None
            or row["asset_id"] in seen
            or row["packaged_mode"] != "0555"
            or packaged_relative.is_absolute()
            or ".." in packaged_relative.parts
            or not packaged_relative.parts
            or release / packaged_relative
            != Path(verified["path"])
            or row["size"] != verified["size"]
            or row["sha256"] != verified["sha256"]
        ):
            raise ArtifactError("artifact_operational_asset_manifest_invalid")
        seen.add(row["asset_id"])
    if seen != set(observed):
        raise ArtifactError("artifact_operational_asset_manifest_invalid")
    unsigned = {
        "schema": "muncho-production-operational-assets-host-readback.v1",
        "verification_sha256": verification["verification_sha256"],
        "asset_manifest_sha256": asset_manifest["manifest_sha256"],
        "file_count": len(observed),
        "all_payloads_verified": True,
        "credential_values_read": False,
        "secret_material_recorded": False,
        "secret_digest_recorded": False,
    }
    return {**unsigned, "receipt_sha256": _sha_json(unsigned)}


def _operational_process_identity(
    pid: int,
    *,
    expected_uid: int,
    expected_gid: int,
) -> None:
    if type(pid) is not int or pid < 1:
        raise ArtifactError("artifact_operational_edge_process_invalid")
    try:
        payload = (Path("/proc") / str(pid) / "status").read_bytes()
        text = payload.decode("ascii", errors="strict")
    except (OSError, UnicodeError) as exc:
        raise ArtifactError(
            "artifact_operational_edge_process_unavailable"
        ) from exc
    if not 0 < len(payload) <= 256 * 1024:
        raise ArtifactError("artifact_operational_edge_process_invalid")
    fields: dict[str, list[str]] = {}
    for line in text.splitlines():
        name, separator, value = line.partition(":")
        if separator and name in {"Uid", "Gid"}:
            fields[name] = value.split()
    try:
        uids = [int(value) for value in fields["Uid"]]
        gids = [int(value) for value in fields["Gid"]]
    except (KeyError, ValueError) as exc:
        raise ArtifactError("artifact_operational_edge_process_invalid") from exc
    if (
        len(uids) != 4
        or len(gids) != 4
        or any(value != expected_uid for value in uids)
        or any(value != expected_gid for value in gids)
    ):
        raise ArtifactError("artifact_operational_edge_process_invalid")


def _operational_edge_runtime(
    manifest: Mapping[str, Any],
    *,
    allowed_unit_file_states: set[str] | None = None,
) -> Mapping[str, Any]:
    allowed_states = (
        {"disabled"}
        if allowed_unit_file_states is None
        else set(allowed_unit_file_states)
    )
    if not allowed_states or not allowed_states <= {"disabled", "enabled"}:
        raise ArtifactError("artifact_operational_edge_service_invalid")
    identity = _identity_foundation(manifest)
    result: dict[str, Any] = {}
    for domain in sorted(OPERATIONAL_EDGE_DOMAINS):
        service_role = f"operational_edge_{domain}"
        socket_role = f"operational_edge_{domain}_client"
        service_uid = identity["users"][service_role]["uid"]
        service_gid = identity["groups"][service_role]["gid"]
        socket_gid = identity["groups"][socket_role]["gid"]
        unit = f"muncho-operational-edge-{domain}.service"
        before = _service(unit)
        if (
            before["active_state"] != "active"
            or before["sub_state"] != "running"
            or before["main_pid"] <= 0
            or before["unit_file_state"] not in allowed_states
            or before["fragment_sha256"]
            != manifest["files"][f"operational_edge_unit_{domain}"]["sha256"]
        ):
            raise ArtifactError("artifact_operational_edge_service_invalid")
        _operational_process_identity(
            before["main_pid"],
            expected_uid=service_uid,
            expected_gid=service_gid,
        )
        socket_path = OPERATIONAL_EDGE_SOCKET_ROOT / domain / "edge.sock"
        try:
            socket_before = os.lstat(socket_path)
        except OSError as exc:
            raise ArtifactError(
                "artifact_operational_edge_socket_unavailable"
            ) from exc
        after = _service(unit)
        try:
            socket_after = os.lstat(socket_path)
        except OSError as exc:
            raise ArtifactError(
                "artifact_operational_edge_socket_unavailable"
            ) from exc
        socket_identity = lambda item: (
            item.st_dev, item.st_ino, item.st_mode, item.st_uid,
            item.st_gid, item.st_nlink, item.st_mtime_ns, item.st_ctime_ns,
        )
        if (
            _stable_service(before) != _stable_service(after)
            or (
                before["active_state"], before["sub_state"],
                before["main_pid"],
            ) != (
                after["active_state"], after["sub_state"],
                after["main_pid"],
            )
            or socket_identity(socket_before) != socket_identity(socket_after)
            or not stat.S_ISSOCK(socket_before.st_mode)
            or socket_before.st_uid != service_uid
            or socket_before.st_gid != socket_gid
            or stat.S_IMODE(socket_before.st_mode) != 0o660
        ):
            raise ArtifactError("artifact_operational_edge_socket_invalid")
        result[domain] = {
            "service": before,
            "process_uid": service_uid,
            "process_gid": service_gid,
            "socket_path": str(socket_path),
            "socket_uid": socket_before.st_uid,
            "socket_gid": socket_before.st_gid,
            "socket_mode": "0660",
            "socket_device": socket_before.st_dev,
            "socket_inode": socket_before.st_ino,
            "ready": True,
        }
    return result


def _operational_required_jobs(plan: Mapping[str, Any]) -> list[Mapping[str, Any]]:
    continuity = plan.get("cron_continuity_plan")
    prior = (
        continuity.get("operational_edge_readiness")
        if isinstance(continuity, Mapping)
        else None
    )
    rows = prior.get("required_jobs") if isinstance(prior, Mapping) else None
    if (
        not isinstance(rows, list)
        or len(rows) != 14
        or any(
            not isinstance(row, Mapping)
            or set(row) != {"source_job_id", "operation_id"}
            for row in rows
        )
        or [row["source_job_id"] for row in rows]
        != sorted(row["source_job_id"] for row in rows)
        or len({row["source_job_id"] for row in rows}) != len(rows)
    ):
        raise ArtifactError("artifact_operational_edge_required_jobs_invalid")
    return [dict(row) for row in rows]


def _validate_operational_edge_readiness(
    value: Mapping[str, Any],
    *,
    plan: Mapping[str, Any],
    runtime: Mapping[str, Any],
) -> Mapping[str, Any]:
    raw = _hashed(
        value,
        {
            "schema", "release_revision", "boot_id_sha256",
            "observed_at_unix", "maximum_age_seconds", "collector_nonce",
            "catalog_sha256", "required_jobs", "required_job_count",
            "jobs", "job_count", "all_required_jobs_ready",
            "credential_values_read", "permissions_widened",
            "secret_material_recorded", "secret_digest_recorded",
            "receipt_sha256",
        },
        "receipt_sha256",
        "artifact_operational_edge_readiness_invalid",
    )
    expected_jobs = _operational_required_jobs(plan)
    expected_pairs = [
        (row["source_job_id"], row["operation_id"])
        for row in expected_jobs
    ]
    try:
        boot_text = Path("/proc/sys/kernel/random/boot_id").read_text(
            encoding="ascii", errors="strict"
        ).strip()
    except (OSError, UnicodeError) as exc:
        raise ArtifactError(
            "artifact_operational_edge_boot_unavailable"
        ) from exc
    if UUID_TEXT.fullmatch(boot_text) is None:
        raise ArtifactError("artifact_operational_edge_boot_invalid")
    boot_sha256 = hashlib.sha256((boot_text + "\n").encode("ascii")).hexdigest()
    current = int(time.time())
    jobs = raw["jobs"]
    if (
        raw["schema"] != "muncho-operational-edge-readiness.v2"
        or raw["release_revision"] != plan["release_revision"]
        or raw["boot_id_sha256"] != boot_sha256
        or type(raw["observed_at_unix"]) is not int
        or not 0 <= current - raw["observed_at_unix"]
        <= OPERATIONAL_EDGE_READINESS_MAXIMUM_AGE_SECONDS
        or raw["maximum_age_seconds"]
        != OPERATIONAL_EDGE_READINESS_MAXIMUM_AGE_SECONDS
        or UUID4_TEXT.fullmatch(str(raw["collector_nonce"])) is None
        or raw["catalog_sha256"]
        != _operational_edge_bundle(_host_manifest(plan))["catalog_sha256"]
        or raw["required_jobs"] != expected_jobs
        or raw["required_job_count"] != len(expected_jobs)
        or not isinstance(jobs, list)
        or raw["job_count"] != len(jobs)
        or len(jobs) != len(expected_jobs)
        or raw["all_required_jobs_ready"] is not True
        or raw["credential_values_read"] is not False
        or raw["permissions_widened"] is not False
        or raw["secret_material_recorded"] is not False
        or raw["secret_digest_recorded"] is not False
    ):
        raise ArtifactError("artifact_operational_edge_readiness_invalid")
    observed_pairs: list[tuple[Any, Any]] = []
    for item in jobs:
        row = _exact(
            item,
            {
                "source_job_id", "operation_id", "domain", "service_unit",
                "service_uid", "service_gid", "socket_path", "socket_uid",
                "socket_gid", "socket_mode", "main_pid", "peer_round_trip",
                "probe_operation_id", "probe_return_code",
                "probe_packet_schema", "probe_packet_sha256",
                "meaningful_packet", "error_only_packet",
            },
            "artifact_operational_edge_readiness_invalid",
        )
        live = runtime.get(row["domain"])
        service = live.get("service") if isinstance(live, Mapping) else None
        if (
            not isinstance(live, Mapping)
            or not isinstance(service, Mapping)
            or row["service_unit"] != service["name"]
            or row["service_uid"] != live["process_uid"]
            or row["service_gid"] != live["process_gid"]
            or row["socket_path"] != live["socket_path"]
            or row["socket_uid"] != live["socket_uid"]
            or row["socket_gid"] != live["socket_gid"]
            or row["socket_mode"] != live["socket_mode"]
            or row["main_pid"] != service["main_pid"]
            or row["peer_round_trip"] is not True
            or not isinstance(row["probe_operation_id"], str)
            or not row["probe_operation_id"]
            or row["probe_return_code"] != 0
            or row["probe_packet_schema"]
            != "muncho-operational-edge-probe-packet.v1"
            or SHA256.fullmatch(str(row["probe_packet_sha256"])) is None
            or row["meaningful_packet"] is not True
            or row["error_only_packet"] is not False
        ):
            raise ArtifactError("artifact_operational_edge_readiness_invalid")
        observed_pairs.append((row["source_job_id"], row["operation_id"]))
    if observed_pairs != expected_pairs:
        raise ArtifactError("artifact_operational_edge_readiness_invalid")
    return raw


def _publish_operational_edge_readiness(
    plan: Mapping[str, Any],
    *,
    runtime: Mapping[str, Any],
) -> Mapping[str, Any]:
    manifest = _host_manifest(plan)
    bundle = _operational_edge_bundle(manifest)
    release = Path(bundle["release_root"])
    interpreter = release / ".venv/bin/python"
    if os.geteuid() != 0:
        raise ArtifactError("artifact_operational_edge_publisher_unauthorized")
    try:
        completed = subprocess.run(
            (
                str(interpreter), "-I", "-B", "-m",
                "gateway.operational_edge_readiness", "--publish",
                "--revision", str(plan["release_revision"]),
            ),
            cwd=str(release),
            env={
                "HOME": "/root",
                "LANG": "C.UTF-8",
                "LC_ALL": "C.UTF-8",
                "PATH": "/usr/bin:/bin",
                "PYTHONDONTWRITEBYTECODE": "1",
                "PYTHONNOUSERSITE": "1",
                "TZ": "UTC",
            },
            stdin=subprocess.DEVNULL,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            check=False,
            timeout=OPERATIONAL_EDGE_READINESS_TIMEOUT_SECONDS,
            close_fds=True,
            start_new_session=True,
        )
    except (OSError, subprocess.SubprocessError) as exc:
        raise ArtifactError(
            "artifact_operational_edge_readiness_failed"
        ) from exc
    if (
        completed.returncode != 0
        or completed.stderr
        or not isinstance(completed.stdout, bytes)
        or not 0 < len(completed.stdout) <= MAX_JSON + 1
        or not completed.stdout.endswith(b"\n")
        or completed.stdout.endswith(b"\n\n")
    ):
        raise ArtifactError("artifact_operational_edge_readiness_failed")
    published = _read_exact_file(
        OPERATIONAL_EDGE_READINESS_PATH,
        allowed_modes={0o400},
        owners={0},
        groups={0},
        maximum=MAX_JSON,
    )
    if published != completed.stdout:
        raise ArtifactError("artifact_operational_edge_readiness_unpublished")
    value = _strict_json(
        completed.stdout[:-1],
        "artifact_operational_edge_readiness_invalid",
    )
    return _validate_operational_edge_readiness(
        value,
        plan=plan,
        runtime=runtime,
    )


def _remove_operational_edge_readiness() -> None:
    if not os.path.lexists(OPERATIONAL_EDGE_READINESS_PATH):
        return
    _read_exact_file(
        OPERATIONAL_EDGE_READINESS_PATH,
        allowed_modes={0o400},
        owners={0},
        groups={0},
        maximum=MAX_JSON,
    )
    try:
        OPERATIONAL_EDGE_READINESS_PATH.unlink()
        _fsync_parent(OPERATIONAL_EDGE_READINESS_PATH)
    except OSError as exc:
        raise ArtifactError(
            "artifact_operational_edge_readiness_remove_failed"
        ) from exc
    if os.path.lexists(OPERATIONAL_EDGE_READINESS_PATH):
        raise ArtifactError(
            "artifact_operational_edge_readiness_remove_unconfirmed"
        )


def _host_apply(plan: Mapping[str, Any]) -> Mapping[str, Any]:
    manifest = _host_manifest(plan)
    _assert_reviewed_connector_boundary(plan, manifest)
    gateway = _service(GATEWAY_UNIT)
    writer = _service(WRITER_UNIT)
    connector = _service(CONNECTOR_UNIT)
    if not _stopped(gateway) or not _stopped(writer) or not _stopped(connector):
        raise ArtifactError("artifact_host_services_not_stopped")
    # Establish the reboot fence before installing any target bytes.  A crash
    # anywhere in the stopped transition must not make a partially installed
    # target start through multi-user.target.
    for unit, current in (
        (GATEWAY_UNIT, gateway),
        (WRITER_UNIT, writer),
        (CONNECTOR_UNIT, connector),
    ):
        if current["load_state"] == "loaded" and current["unit_file_state"] == "enabled":
            _systemctl_unit_file("disable", unit)
    files = manifest["files"]
    for name in sorted(HOST_FILE_NAMES):
        _backup_file(plan, name, files[name])
    identity_receipt = _apply_identity_foundation(manifest)
    _apply_worker_lease_mountpoint(manifest)
    for name in sorted(HOST_FILE_NAMES):
        item = files[name]
        path = Path(item["target_path"])
        target = _target_file_identity(item)
        if _file_matches(path, target):
            continue
        if not _file_matches(path, item["pre"]):
            raise ArtifactError("artifact_host_identity_changed")
        _install(
            path, _staged_file(item), item["mode"], uid=item["uid"],
            gid=item["gid"],
        )
    _move_token_to_connector(manifest)
    api_foundation = _validate_api_verifier_foundation(manifest)
    discord_foundation = _bootstrap_discord_foundation(plan, manifest)
    operational_asset_readback = _operational_asset_readback(manifest)
    operational_edge_keys = _provision_operational_edge_keys(manifest)
    _systemctl("daemon-reload")
    for unit in BOOT_ENABLE_UNITS:
        _systemctl_unit_file("disable", unit)
    for unit in OPERATIONAL_EDGE_UNITS:
        current = _service(unit)
        if _stopped(current):
            _systemctl("start", "--", unit, timeout=180)
    operational_edge_runtime = _operational_edge_runtime(manifest)
    operational_edge_readiness = _publish_operational_edge_readiness(
        plan,
        runtime=operational_edge_runtime,
    )
    gateway = _service(GATEWAY_UNIT)
    writer = _service(WRITER_UNIT)
    connector = _service(CONNECTOR_UNIT)
    phase_b = _service(PHASE_B_UNIT)
    routeback = _service(ROUTEBACK_EDGE_UNIT)
    mac_ops = _service(MAC_OPS_UNIT)
    browser = _service(BROWSER_UNIT)
    worker_socket = _service(ISOLATED_WORKER_SOCKET_UNIT)
    worker_service = _service(ISOLATED_WORKER_SERVICE_UNIT)
    topology = _validate_capability_prerequisite_plan(plan)
    if (
        not _stopped(gateway) or not _stopped(writer) or not _stopped(connector)
        or not _stopped(phase_b) or not _stopped(routeback)
        or not _stopped(mac_ops) or not _stopped(browser)
        or not _stopped(worker_socket) or not _stopped(worker_service)
        or any(
            service["unit_file_state"] != "disabled"
            for service in (
                gateway, writer, connector, phase_b, routeback, mac_ops,
                browser, worker_socket,
            )
        )
        or worker_service["unit_file_state"] != "static"
        or _stable_service(gateway)
        != _target_service(plan, GATEWAY_UNIT, staged_disabled=True)
        or _stable_service(writer)
        != _target_service(plan, WRITER_UNIT, staged_disabled=True)
        or _stable_service(connector)
        != _target_service(plan, CONNECTOR_UNIT, staged_disabled=True)
        or phase_b["fragment_sha256"]
        != topology["phase_b"]["fragment_sha256"]
        or routeback["fragment_sha256"]
        != topology["routeback_edge"]["fragment_sha256"]
        or mac_ops["fragment_sha256"]
        != topology["mac_ops"]["fragment_sha256"]
        or browser["fragment_sha256"]
        != topology["browser"]["fragment_sha256"]
        or worker_socket["fragment_sha256"]
        != topology["isolated_worker"]["socket_fragment_sha256"]
        or worker_service["fragment_sha256"]
        != topology["isolated_worker"]["service_fragment_sha256"]
    ):
        raise ArtifactError("artifact_host_apply_unconfirmed")
    return _receipt({
        "schema": "muncho-production-writer-host-apply.v2",
        "plan_sha256": plan["plan_sha256"],
        "artifact_sha256": plan["artifacts"]["host_activation"]["sha256"],
        "gateway_stopped": gateway,
        "writer_stopped": writer,
        "connector_stopped": connector,
        "phase_b_stopped": phase_b,
        "routeback_stopped": routeback,
        "mac_ops_stopped": mac_ops,
        "browser_stopped": browser,
        "isolated_worker_socket_stopped": worker_socket,
        "isolated_worker_service_stopped": worker_service,
        "isolated_worker_lease_mountpoint_prepared": True,
        "identity_foundation_sha256": manifest["identity_foundation"][
            "foundation_sha256"
        ],
        "identity_apply_receipt_sha256": identity_receipt["receipt_sha256"],
        "discord_key_foundation_sha256": manifest["discord_key_foundation"][
            "foundation_sha256"
        ],
        "discord_foundation_receipt_sha256": discord_foundation[
            "receipt_sha256"
        ],
        "writer_public_key_id": discord_foundation["writer_public_key_id"],
        "edge_public_key_id": discord_foundation["edge_public_key_id"],
        "operational_edge_key_foundation_sha256": operational_edge_keys[
            "key_foundation_sha256"
        ],
        "operational_edge_key_provision_receipt_sha256": (
            operational_edge_keys["receipt_sha256"]
        ),
        "operational_edge_receipt_public_key_ids": operational_edge_keys[
            "receipt_public_key_ids"
        ],
        "operational_edge_staged_key_copies_retained": True,
        "operational_edge_keys_ready": True,
        "operational_edge_runtime": operational_edge_runtime,
        "operational_edge_asset_readback_receipt_sha256": (
            operational_asset_readback["receipt_sha256"]
        ),
        "operational_edge_readiness": operational_edge_readiness,
        "only_operational_edge_services_started": True,
        "normal_services_remained_stopped": True,
        "discord_journals_clean_before_service_start": True,
        "normal_startup_journal_creation_disabled": True,
        "preexisting_memberships_converged_to_allowlist": True,
        "direct_discord_disabled": True,
        "discord_dm_allowed": False,
        "api_verifier_foundation_receipt_sha256": api_foundation[
            "receipt_sha256"
        ],
        "api_bearer_verifier_installed": True,
        "api_approval_verifier_installed": True,
        "api_source_secrets_root_only": True,
        "api_source_secrets_loaded_by_gateway": False,
        "ok": True,
        "secret_material_recorded": False,
        "secret_digest_recorded": False,
    })


def _host_start_writer(plan: Mapping[str, Any]) -> Mapping[str, Any]:
    manifest = _host_manifest(plan)
    gateway = _service(GATEWAY_UNIT)
    writer = _service(WRITER_UNIT)
    connector = _service(CONNECTOR_UNIT)
    if (
        not _stopped(gateway)
        or _stable_service(gateway)
        != _target_service(plan, GATEWAY_UNIT, staged_disabled=True)
        or _stable_service(writer)
        != _target_service(plan, WRITER_UNIT, staged_disabled=True)
        or _stable_service(connector)
        != _target_service(plan, CONNECTOR_UNIT, staged_disabled=True)
    ):
        raise ArtifactError("artifact_host_start_precondition_invalid")
    if (
        connector["active_state"] != "active"
        or connector["sub_state"] != "running"
        or connector["main_pid"] <= 0
    ):
        raise ArtifactError("artifact_connector_prerequisite_not_ready")
    _operational_edge_runtime(manifest)
    if _stopped(writer):
        _systemctl("start", "--", WRITER_UNIT, timeout=60)
        writer = _service(WRITER_UNIT)
    if writer["active_state"] != "active" or writer["sub_state"] != "running" or writer["main_pid"] <= 0:
        raise ArtifactError("artifact_writer_start_unconfirmed")
    return _receipt({
        "schema": "muncho-production-writer-start.v1",
        "plan_sha256": plan["plan_sha256"],
        "artifact_sha256": plan["artifacts"]["host_activation"]["sha256"],
        "ok": True,
        "secret_material_recorded": False,
    })


def _host_start_prerequisites(plan: Mapping[str, Any]) -> Mapping[str, Any]:
    manifest = _host_manifest(plan)
    gateway = _service(GATEWAY_UNIT)
    writer = _service(WRITER_UNIT)
    connector = _service(CONNECTOR_UNIT)
    if (
        not _stopped(gateway)
        or not _stopped(writer)
        or not _stopped(connector)
        or _stable_service(gateway)
        != _target_service(plan, GATEWAY_UNIT, staged_disabled=True)
        or _stable_service(writer)
        != _target_service(plan, WRITER_UNIT, staged_disabled=True)
        or _stable_service(connector)
        != _target_service(plan, CONNECTOR_UNIT, staged_disabled=True)
    ):
        raise ArtifactError("artifact_prerequisite_start_precondition_invalid")
    for unit in PREREQUISITE_UNITS:
        current = _service(unit)
        if _stopped(current):
            _systemctl("start", "--", unit, timeout=180)
    expected = {
        ISOLATED_WORKER_SOCKET_UNIT: ("active", "listening", 0),
        PHASE_B_UNIT: ("active", "exited", 0),
        ROUTEBACK_EDGE_UNIT: ("active", "running", 1),
        CONNECTOR_UNIT: ("active", "running", 1),
        MAC_OPS_UNIT: ("active", "running", 1),
        BROWSER_UNIT: ("active", "running", 1),
    }
    for unit, (active, sub, minimum_pid) in expected.items():
        current = _service(unit)
        if (
            current["active_state"] != active
            or current["sub_state"] != sub
            or current["main_pid"] < minimum_pid
            or current["unit_file_state"] != "disabled"
        ):
            raise ArtifactError("artifact_prerequisite_start_unconfirmed")
    worker_service = _service(ISOLATED_WORKER_SERVICE_UNIT)
    if not (
        worker_service["unit_file_state"] == "static"
        and (
            _stopped(worker_service)
            or (
                worker_service["active_state"] == "active"
                and worker_service["sub_state"] == "running"
                and worker_service["main_pid"] > 0
            )
        )
    ):
        raise ArtifactError("artifact_prerequisite_start_unconfirmed")
    if (
        not _stopped(_service(GATEWAY_UNIT))
        or not _stopped(_service(WRITER_UNIT))
    ):
        raise ArtifactError("artifact_prerequisite_started_forbidden_service")
    _operational_edge_runtime(manifest)
    return _receipt({
        "schema": "muncho-production-prerequisite-services-start.v1",
        "plan_sha256": plan["plan_sha256"],
        "artifact_sha256": plan["artifacts"]["host_activation"]["sha256"],
        "ok": True,
        "secret_material_recorded": False,
    })


def _host_commit_boot(plan: Mapping[str, Any]) -> Mapping[str, Any]:
    """Idempotently converge the post-intent stack to boot persistence."""

    manifest = _host_manifest(plan)
    topology = _validate_capability_prerequisite_plan(plan)
    units = ALL_TARGET_UNITS
    before = {unit: _service(unit) for unit in units}

    def expected(unit: str, item: Mapping[str, Any]) -> Mapping[str, Any]:
        return _target_service(
            plan,
            unit,
            staged_disabled=item["unit_file_state"] == "disabled",
        )

    if (
        any(
            before[unit]["unit_file_state"] not in {"disabled", "enabled"}
            for unit in BOOT_ENABLE_UNITS
        )
        or before[ISOLATED_WORKER_SERVICE_UNIT]["unit_file_state"] != "static"
        or any(
            _stable_service(before[unit]) != expected(unit, before[unit])
            for unit in (GATEWAY_UNIT, WRITER_UNIT, CONNECTOR_UNIT)
        )
        or before[PHASE_B_UNIT]["fragment_sha256"]
        != topology["phase_b"]["fragment_sha256"]
        or before[ROUTEBACK_EDGE_UNIT]["fragment_sha256"]
        != topology["routeback_edge"]["fragment_sha256"]
        or before[MAC_OPS_UNIT]["fragment_sha256"]
        != topology["mac_ops"]["fragment_sha256"]
        or before[BROWSER_UNIT]["fragment_sha256"]
        != topology["browser"]["fragment_sha256"]
        or before[ISOLATED_WORKER_SOCKET_UNIT]["fragment_sha256"]
        != topology["isolated_worker"]["socket_fragment_sha256"]
        or before[ISOLATED_WORKER_SERVICE_UNIT]["fragment_sha256"]
        != topology["isolated_worker"]["service_fragment_sha256"]
        or any(
            before[f"muncho-operational-edge-{domain}.service"][
                "fragment_sha256"
            ]
            != manifest["files"][f"operational_edge_unit_{domain}"][
                "sha256"
            ]
            for domain in OPERATIONAL_EDGE_DOMAINS
        )
    ):
        raise ArtifactError("artifact_host_boot_commit_precondition_invalid")
    _operational_edge_runtime(
        manifest,
        allowed_unit_file_states={"disabled", "enabled"},
    )

    for unit in BOOT_ENABLE_UNITS:
        _systemctl_unit_file("enable", unit)
    for unit in PREREQUISITE_UNITS:
        if _stopped(_service(unit)):
            _systemctl("start", "--", unit, timeout=180)
    if _stopped(_service(WRITER_UNIT)):
        _systemctl("start", "--", WRITER_UNIT, timeout=60)

    after = {unit: _service(unit) for unit in units}
    running = (
        WRITER_UNIT,
        CONNECTOR_UNIT,
        ROUTEBACK_EDGE_UNIT,
        MAC_OPS_UNIT,
        BROWSER_UNIT,
        ISOLATED_WORKER_SERVICE_UNIT,
        *OPERATIONAL_EDGE_UNITS,
    )
    gateway_ready = _stopped(after[GATEWAY_UNIT]) or (
        after[GATEWAY_UNIT]["active_state"] == "active"
        and after[GATEWAY_UNIT]["sub_state"] == "running"
        and after[GATEWAY_UNIT]["main_pid"] > 0
    )
    if (
        any(after[unit]["unit_file_state"] != "enabled" for unit in BOOT_ENABLE_UNITS)
        or after[ISOLATED_WORKER_SERVICE_UNIT]["unit_file_state"] != "static"
        or not gateway_ready
        or any(
            after[unit]["active_state"] != "active"
            or after[unit]["sub_state"] != "running"
            or after[unit]["main_pid"] <= 0
            for unit in running
        )
        or after[PHASE_B_UNIT]["active_state"] != "active"
        or after[PHASE_B_UNIT]["sub_state"] != "exited"
        or after[PHASE_B_UNIT]["main_pid"] != 0
        or _stable_service(after[GATEWAY_UNIT])
        != _target_service(plan, GATEWAY_UNIT)
        or _stable_service(after[WRITER_UNIT])
        != _target_service(plan, WRITER_UNIT)
        or _stable_service(after[CONNECTOR_UNIT])
        != _target_service(plan, CONNECTOR_UNIT)
        or after[PHASE_B_UNIT]["fragment_sha256"]
        != topology["phase_b"]["fragment_sha256"]
        or after[ROUTEBACK_EDGE_UNIT]["fragment_sha256"]
        != topology["routeback_edge"]["fragment_sha256"]
        or after[MAC_OPS_UNIT]["fragment_sha256"]
        != topology["mac_ops"]["fragment_sha256"]
        or after[BROWSER_UNIT]["fragment_sha256"]
        != topology["browser"]["fragment_sha256"]
        or after[ISOLATED_WORKER_SOCKET_UNIT]["active_state"] != "active"
        or after[ISOLATED_WORKER_SOCKET_UNIT]["sub_state"] != "listening"
        or after[ISOLATED_WORKER_SOCKET_UNIT]["main_pid"] != 0
        or after[ISOLATED_WORKER_SOCKET_UNIT]["fragment_sha256"]
        != topology["isolated_worker"]["socket_fragment_sha256"]
        or after[ISOLATED_WORKER_SERVICE_UNIT]["fragment_sha256"]
        != topology["isolated_worker"]["service_fragment_sha256"]
        or any(
            after[f"muncho-operational-edge-{domain}.service"][
                "fragment_sha256"
            ]
            != manifest["files"][f"operational_edge_unit_{domain}"][
                "sha256"
            ]
            for domain in OPERATIONAL_EDGE_DOMAINS
        )
    ):
        raise ArtifactError("artifact_host_boot_commit_unconfirmed")
    operational_edge_runtime = _operational_edge_runtime(
        manifest,
        allowed_unit_file_states={"enabled"},
    )
    return _receipt({
        "schema": "muncho-production-host-boot-commit.v2",
        "plan_sha256": plan["plan_sha256"],
        "artifact_sha256": plan["artifacts"]["host_activation"]["sha256"],
        "gateway_observed": after[GATEWAY_UNIT],
        "writer_active": after[WRITER_UNIT],
        "connector_active": after[CONNECTOR_UNIT],
        "phase_b_active": after[PHASE_B_UNIT],
        "routeback_active": after[ROUTEBACK_EDGE_UNIT],
        "mac_ops_active": after[MAC_OPS_UNIT],
        "browser_active": after[BROWSER_UNIT],
        "isolated_worker_socket_active": after[ISOLATED_WORKER_SOCKET_UNIT],
        "isolated_worker_service_active": after[ISOLATED_WORKER_SERVICE_UNIT],
        "operational_edge_runtime": operational_edge_runtime,
        "boot_fence_released": True,
        "ok": True,
        "secret_material_recorded": False,
        "secret_digest_recorded": False,
    })


def _restore_discord_keys(manifest: Mapping[str, Any]) -> Mapping[str, Any]:
    foundation = _discord_key_foundation(
        manifest,
        _identity_foundation(manifest),
    )
    restored: list[str] = []
    for role in ("writer", "edge"):
        item = foundation[role]
        source = Path(item["staged_private_path"])
        private = Path(item["private_path"])
        public = Path(item["public_path"])
        source_payload = (
            _key_private_bytes(source, uid=0, gid=0, mode=0o400)
            if os.path.lexists(source)
            else None
        )
        private_payload = (
            _key_private_bytes(
                private,
                uid=item["private_uid"],
                gid=item["private_gid"],
                mode=item["private_mode"],
            )
            if os.path.lexists(private)
            else None
        )
        if source_payload is None and private_payload is None:
            raise ArtifactError("artifact_discord_private_key_restore_missing")
        if (
            source_payload is not None
            and private_payload is not None
            and source_payload != private_payload
        ):
            raise ArtifactError("artifact_discord_private_key_restore_conflict")
        payload = source_payload if source_payload is not None else private_payload
        assert payload is not None
        public_payload, key_id = _derive_ed25519_public(payload)
        if key_id != item["public_key_id"]:
            raise ArtifactError("artifact_discord_key_restore_invalid")
        if os.path.lexists(public) and _read_exact_file(
            public,
            allowed_modes={item["public_mode"]},
            owners={item["public_uid"]},
            groups={item["public_gid"]},
            maximum=8 * 1024,
        ) != public_payload:
            raise ArtifactError("artifact_discord_public_key_restore_conflict")
        if source_payload is None:
            _install(source, payload, 0o400, uid=0, gid=0)
        _key_private_bytes(source, uid=0, gid=0, mode=0o400)
        for target in (public, private):
            try:
                target.unlink()
            except FileNotFoundError:
                pass
            else:
                _fsync_parent(target)
        restored.append(role)
    unsigned = {
        "schema": "muncho-production-discord-key-rollback.v1",
        "foundation_sha256": foundation["foundation_sha256"],
        "staged_private_keys_restored": sorted(restored),
        "target_private_keys_removed": True,
        "target_public_keys_removed": True,
        "private_content_or_digest_recorded": False,
        "secret_material_recorded": False,
        "secret_digest_recorded": False,
    }
    return {**unsigned, "receipt_sha256": _sha_json(unsigned)}


def _remove_discord_journals(
    plan: Mapping[str, Any],
    manifest: Mapping[str, Any],
    *,
    nonclean_removal_authorized: bool,
) -> Mapping[str, Any]:
    identity = _identity_foundation(manifest)
    removed: list[str] = []
    for kind in ("connector", "routeback"):
        role = "connector" if kind == "connector" else "routeback"
        uid = identity["users"][role]["uid"]
        gid = identity["groups"][role]["gid"]
        journal = CONNECTOR_JOURNAL if kind == "connector" else ROUTEBACK_JOURNAL
        if not nonclean_removal_authorized and os.path.lexists(journal):
            _bootstrap_discord_journal(plan, manifest, kind=kind)
        paths = [
            Path(f"{journal}-wal"),
            Path(f"{journal}-shm"),
            Path(f"{journal}.initialized"),
            Path(f"{journal}.bootstrap-intent"),
            journal,
        ]
        for path in paths:
            if not os.path.lexists(path):
                continue
            try:
                observed = os.lstat(path)
            except OSError as exc:
                raise ArtifactError("artifact_discord_journal_remove_invalid") from exc
            if (
                stat.S_ISLNK(observed.st_mode)
                or not stat.S_ISREG(observed.st_mode)
                or observed.st_nlink != 1
                or observed.st_uid != uid
                or observed.st_gid != gid
                or stat.S_IMODE(observed.st_mode) != 0o600
            ):
                raise ArtifactError("artifact_discord_journal_remove_invalid")
            path.unlink()
            _fsync_parent(path)
        if any(os.path.lexists(path) for path in paths):
            raise ArtifactError("artifact_discord_journal_remove_unconfirmed")
        removed.append(kind)
    unsigned = {
        "schema": "muncho-production-discord-journal-rollback.v1",
        "plan_sha256": plan["plan_sha256"],
        "removed_journals": sorted(removed),
        "nonclean_removal_authorized_by_host_apply_receipt": (
            nonclean_removal_authorized
        ),
        "state_directories_retained_dormant": True,
        "secret_material_recorded": False,
        "secret_digest_recorded": False,
    }
    return {**unsigned, "receipt_sha256": _sha_json(unsigned)}


def _host_rollback(plan: Mapping[str, Any], apply_receipt: Mapping[str, Any] | None) -> Mapping[str, Any]:
    _validate_apply_receipt(apply_receipt, plan, "host_activation")
    manifest = _host_manifest(plan)
    for unit in (
        GATEWAY_UNIT,
        WRITER_UNIT,
        *reversed(PREREQUISITE_UNITS),
        *reversed(OPERATIONAL_EDGE_UNITS),
        ISOLATED_WORKER_SERVICE_UNIT,
    ):
        current = _service(unit)
        if not _stopped(current):
            _systemctl("stop", "--", unit, timeout=180)
    for unit in reversed(BOOT_ENABLE_UNITS):
        _systemctl_unit_file("disable", unit)
    gateway = _service(GATEWAY_UNIT)
    writer = _service(WRITER_UNIT)
    connector = _service(CONNECTOR_UNIT)
    if not _stopped(gateway) or not _stopped(writer) or not _stopped(connector):
        raise ArtifactError("artifact_host_services_not_stopped")
    _remove_operational_edge_readiness()
    operational_edge_key_retention = (
        _retain_operational_edge_keys_on_rollback(manifest)
    )
    journal_rollback = _remove_discord_journals(
        plan,
        manifest,
        nonclean_removal_authorized=apply_receipt is not None,
    )
    key_rollback = _restore_discord_keys(manifest)
    files = manifest["files"]
    for name in sorted(HOST_FILE_NAMES):
        item = files[name]
        path = Path(item["target_path"])
        if not _file_matches(path, item["pre"]) and not _file_matches(
            path, _target_file_identity(item)
        ):
            raise ArtifactError("artifact_host_identity_changed")
        payload = _load_backup(plan, name, item)
        if payload is None:
            try:
                path.unlink()
            except FileNotFoundError:
                pass
        else:
            pre = item["pre"]
            _install(
                path, payload, pre["mode"], uid=pre["uid"], gid=pre["gid"]
            )
    _rollback_worker_lease_mountpoint(manifest)
    _restore_token_to_source(manifest)
    _restore_approval_passkey(manifest)
    identity_rollback = _rollback_identity_foundation(manifest)
    _systemctl("daemon-reload")
    for unit in (GATEWAY_UNIT, WRITER_UNIT, CONNECTOR_UNIT):
        pre = _pre_service(plan, unit)
        if pre["load_state"] == "loaded" and pre["unit_file_state"] == "enabled":
            _systemctl_unit_file("enable", unit)
    gateway = _service(GATEWAY_UNIT)
    writer = _service(WRITER_UNIT)
    connector = _service(CONNECTOR_UNIT)
    removed_prerequisites = {
        unit: _service(unit)
        for unit in (
            PHASE_B_UNIT,
            ROUTEBACK_EDGE_UNIT,
            MAC_OPS_UNIT,
            BROWSER_UNIT,
            ISOLATED_WORKER_SOCKET_UNIT,
            ISOLATED_WORKER_SERVICE_UNIT,
            *OPERATIONAL_EDGE_UNITS,
        )
    }
    if (
        not _stopped(gateway) or not _stopped(writer) or not _stopped(connector)
        or _stable_service(gateway) != _stable_service(_pre_service(plan, GATEWAY_UNIT))
        or _stable_service(writer) != _stable_service(_pre_service(plan, WRITER_UNIT))
        or _stable_service(connector) != _stable_service(_pre_service(plan, CONNECTOR_UNIT))
        or any(
            service["load_state"] != "not-found" or not _stopped(service)
            for service in removed_prerequisites.values()
        )
    ):
        raise ArtifactError("artifact_host_rollback_unconfirmed")
    return _receipt({
        "schema": "muncho-production-writer-host-rollback.v2",
        "plan_sha256": plan["plan_sha256"],
        "artifact_sha256": plan["artifacts"]["host_rollback"]["sha256"],
        "api_verifiers_removed": True,
        "api_source_secrets_preserved": True,
        "phase_b_removed": True,
        "routeback_removed": True,
        "mac_ops_removed": True,
        "browser_removed": True,
        "isolated_worker_socket_removed": True,
        "isolated_worker_service_removed": True,
        "isolated_worker_lease_mountpoint_restored": True,
        "identity_foundation_sha256": manifest["identity_foundation"][
            "foundation_sha256"
        ],
        "identity_rollback_receipt_sha256": identity_rollback[
            "receipt_sha256"
        ],
        "discord_key_rollback_receipt_sha256": key_rollback[
            "receipt_sha256"
        ],
        "operational_edge_key_retention_receipt_sha256": (
            operational_edge_key_retention["receipt_sha256"]
        ),
        "operational_edge_keys_retained_dormant": True,
        "operational_edge_staged_key_copies_retained": True,
        "operational_edge_units_removed": list(OPERATIONAL_EDGE_UNITS),
        "operational_edge_readiness_removed": True,
        "discord_journal_rollback_receipt_sha256": journal_rollback[
            "receipt_sha256"
        ],
        "staged_private_keys_restored": True,
        "discord_journals_removed": True,
        "created_identities_retained_dormant": True,
        "preexisting_memberships_restored": True,
        "ok": True,
        "secret_material_recorded": False,
        "secret_digest_recorded": False,
    })


def execute(action: str, plan: Mapping[str, Any], apply_receipt: Mapping[str, Any] | None) -> Mapping[str, Any]:
    if action == "observe_initial":
        return _observe_initial(plan)
    if action == "observe_final_tail":
        return _observe(plan, before_apply=False)
    if action == "observe_before_apply":
        return _observe(plan, before_apply=True)
    if action == "database_preflight":
        return _database_preflight(plan)
    if action == "database_apply":
        return _database_apply(plan)
    if action == "database_terminal":
        if _database_state(plan) != "target":
            raise ArtifactError("artifact_database_terminal_state_invalid")
        return _database_receipt(plan, schema="muncho-production-legacy-cutover-postflight.v1", artifact_name="database_postflight", legacy=False)
    if action == "database_rollback":
        return _database_rollback(plan, apply_receipt)
    if action == "host_apply_stopped":
        return _host_apply(plan)
    if action == "host_start_prerequisites":
        return _host_start_prerequisites(plan)
    if action == "host_start_writer":
        return _host_start_writer(plan)
    if action == "host_commit_boot":
        return _host_commit_boot(plan)
    if action == "host_rollback":
        return _host_rollback(plan, apply_receipt)
    raise ArtifactError("artifact_action_invalid")


def main() -> int:
    try:
        if len(sys.argv) != 2:
            raise ArtifactError("artifact_action_invalid")
        _require_runtime()
        action, plan, apply_receipt = _validate_request(_read_stdin())
        if sys.argv[1] != action:
            raise ArtifactError("artifact_action_mismatch")
        result = execute(action, plan, apply_receipt)
        sys.stdout.buffer.write(_canonical_bytes(result) + b"\n")
        sys.stdout.buffer.flush()
        return 0
    except BaseException:
        # The parent coordinator emits the stable public failure.  Artifacts
        # never serialize exception text, subprocess output, SQL, or secrets.
        return 2


if __name__ == "__main__":
    raise SystemExit(main())
