class ArtifactError(RuntimeError):
    """Stable failure with no secret-bearing details."""


def _canonical_bytes(value: Any) -> bytes:
    try:
        payload = json.dumps(
            value,
            ensure_ascii=False,
            sort_keys=True,
            separators=(",", ":"),
            allow_nan=False,
        ).encode("utf-8", errors="strict")
    except (TypeError, ValueError, UnicodeError) as exc:
        raise ArtifactError("artifact_noncanonical_value") from exc
    if len(payload) > MAX_JSON:
        raise ArtifactError("artifact_value_oversized")
    return payload


def _sha_json(value: Any) -> str:
    return hashlib.sha256(_canonical_bytes(value)).hexdigest()


OPERATIONAL_EDGE_UNIT_FILE_NAMES = {
    f"operational_edge_unit_{domain}" for domain in OPERATIONAL_EDGE_DOMAINS
}
OPERATIONAL_EDGE_CONFIG_FILE_NAMES = {
    f"operational_edge_config_{domain}" for domain in OPERATIONAL_EDGE_DOMAINS
}
SEALED_FILE_NAMES = {
    "phase_b_unit",
    "routeback_unit",
    "mac_ops_unit",
    "browser_unit",
    "browser_config",
    "isolated_worker_socket_unit",
    "isolated_worker_service_unit",
    "isolated_worker_config",
    "operational_edge_client_config",
} | OPERATIONAL_EDGE_UNIT_FILE_NAMES | OPERATIONAL_EDGE_CONFIG_FILE_NAMES
SEALED_REQUEST_FIELDS = {
    "schema",
    "release_revision",
    "target",
    "files",
    "isolated_worker_lease_mountpoint",
    "topology_fragments",
    "capability_bundle",
    "isolated_worker_bundle",
    "operational_edge_bundle",
    "operational_asset_verification",
    "secret_material_recorded",
    "secret_digest_recorded",
    "request_sha256",
    "payloads",
}


def _sealed_runtime_artifacts() -> Mapping[str, Any]:
    raw = _exact(
        SEALED_RUNTIME_ARTIFACT_REQUEST,
        SEALED_REQUEST_FIELDS,
        "artifact_sealed_runtime_request_invalid",
    )
    payloads = _exact(
        raw["payloads"],
        SEALED_FILE_NAMES,
        "artifact_sealed_runtime_request_invalid",
    )
    files = _exact(
        raw["files"],
        SEALED_FILE_NAMES,
        "artifact_sealed_runtime_request_invalid",
    )
    descriptor = {
        key: value
        for key, value in raw.items()
        if key not in {"payloads", "request_sha256"}
    }
    target = _validate_target(raw["target"])
    if (
        raw["schema"]
        != "muncho-production-cutover-sealed-runtime-artifacts.v1"
        or REVISION.fullmatch(str(raw["release_revision"])) is None
        or target["project"] != "adventico-ai-platform"
        or target["zone"] != "europe-west3-a"
        or target["vm"] != "ai-platform-runtime-01"
        or raw["secret_material_recorded"] is not False
        or raw["secret_digest_recorded"] is not False
        or raw["request_sha256"] != _sha_json(descriptor)
        or not isinstance(raw["capability_bundle"], Mapping)
        or raw["capability_bundle"].get("secret_material_recorded") is not False
        or raw["capability_bundle"].get("secret_digest_recorded") is not False
        or not isinstance(raw["isolated_worker_bundle"], Mapping)
        or raw["isolated_worker_bundle"].get("secret_material_recorded") is not False
        or raw["isolated_worker_bundle"].get("secret_digest_recorded") is not False
        or not isinstance(raw["operational_edge_bundle"], Mapping)
        or raw["operational_edge_bundle"].get("credential_values_read") is not False
        or raw["operational_edge_bundle"].get("secret_material_recorded") is not False
        or raw["operational_edge_bundle"].get("secret_digest_recorded") is not False
        or not isinstance(raw["operational_asset_verification"], Mapping)
        or raw["operational_asset_verification"].get("credential_values_read") is not False
        or raw["operational_asset_verification"].get("secret_material_recorded") is not False
        or raw["operational_asset_verification"].get("secret_digest_recorded") is not False
        or any(
            marker in _canonical_bytes(descriptor).lower()
            for marker in (b'"docker"', b'"cdp_url"')
        )
    ):
        raise ArtifactError("artifact_sealed_runtime_request_invalid")
    for name in SEALED_FILE_NAMES:
        item = _exact(
            files[name],
            {"target_path", "sha256", "uid", "gid", "mode"},
            "artifact_sealed_runtime_request_invalid",
        )
        payload = payloads[name]
        if (
            not isinstance(payload, bytes)
            or not 0 < len(payload) <= MAX_FILE
            or hashlib.sha256(payload).hexdigest() != item["sha256"]
            or type(item["uid"]) is not int
            or type(item["gid"]) is not int
            or type(item["mode"]) is not int
            or item["uid"] != 0
            or item["gid"] < 0
        ):
            raise ArtifactError("artifact_sealed_runtime_request_invalid")
        if name in {"browser_config", "isolated_worker_config"}:
            valid_identity = item["mode"] == 0o440
        elif name in OPERATIONAL_EDGE_CONFIG_FILE_NAMES:
            valid_identity = (item["gid"], item["mode"]) == (0, 0o400)
        elif name == "operational_edge_client_config":
            valid_identity = (item["gid"], item["mode"]) == (0, 0o444)
        else:
            valid_identity = (item["gid"], item["mode"]) == (0, 0o644)
        if not valid_identity:
            raise ArtifactError("artifact_sealed_runtime_request_invalid")
    mountpoint = _exact(
        raw["isolated_worker_lease_mountpoint"],
        {"target_path", "uid", "gid", "mode"},
        "artifact_sealed_runtime_request_invalid",
    )
    if mountpoint != {
        "target_path": str(ISOLATED_WORKER_LEASE_BASE),
        "uid": 0,
        "gid": 0,
        "mode": 0o700,
    }:
        raise ArtifactError("artifact_sealed_runtime_request_invalid")
    topology = _exact(
        raw["topology_fragments"],
        {"isolated_worker", "browser", "operational_edge"},
        "artifact_sealed_runtime_request_invalid",
    )
    if not all(isinstance(topology[name], Mapping) for name in topology):
        raise ArtifactError("artifact_sealed_runtime_request_invalid")
    return raw


def _sealed_file_payload(name: str) -> bytes:
    if name not in SEALED_FILE_NAMES:
        raise ArtifactError("artifact_sealed_runtime_file_invalid")
    return bytes(_sealed_runtime_artifacts()["payloads"][name])


def _exact(value: Any, fields: set[str], code: str) -> dict[str, Any]:
    if not isinstance(value, Mapping) or set(value) != fields:
        raise ArtifactError(code)
    return dict(value)


def _hashed(value: Any, fields: set[str], digest_field: str, code: str) -> dict[str, Any]:
    raw = _exact(value, fields, code)
    digest = raw.get(digest_field)
    if not isinstance(digest, str) or SHA256.fullmatch(digest) is None:
        raise ArtifactError(code)
    unsigned = {key: item for key, item in raw.items() if key != digest_field}
    if _sha_json(unsigned) != digest:
        raise ArtifactError(code)
    return raw


def _strict_json(payload: bytes, code: str) -> Mapping[str, Any]:
    if not payload or len(payload) > MAX_JSON or b"\x00" in payload:
        raise ArtifactError(code)

    def pairs(items: list[tuple[str, Any]]) -> dict[str, Any]:
        result: dict[str, Any] = {}
        for key, value in items:
            if key in result:
                raise ValueError("duplicate key")
            result[key] = value
        return result

    try:
        value = json.loads(
            payload.decode("utf-8", errors="strict"),
            object_pairs_hook=pairs,
            parse_constant=lambda _value: (_ for _ in ()).throw(ValueError()),
        )
    except (UnicodeError, ValueError, json.JSONDecodeError) as exc:
        raise ArtifactError(code) from exc
    if not isinstance(value, Mapping) or _canonical_bytes(value) != payload:
        raise ArtifactError(code)
    return value


def _read_stdin() -> Mapping[str, Any]:
    payload = sys.stdin.buffer.read(MAX_JSON + 2)
    if not payload.endswith(b"\n") or payload.endswith(b"\n\n"):
        raise ArtifactError("artifact_request_invalid")
    return _strict_json(payload[:-1], "artifact_request_invalid")


def _read_exact_file(
    path: Path,
    *,
    allowed_modes: set[int],
    owners: set[int],
    groups: set[int] | None = None,
    maximum: int = MAX_FILE,
) -> bytes:
    try:
        before = os.lstat(path)
    except OSError as exc:
        raise ArtifactError("artifact_file_unavailable") from exc
    if (
        stat.S_ISLNK(before.st_mode)
        or not stat.S_ISREG(before.st_mode)
        or before.st_nlink != 1
        or before.st_uid not in owners
        or (groups is not None and before.st_gid not in groups)
        or stat.S_IMODE(before.st_mode) not in allowed_modes
        or not 0 < before.st_size <= maximum
    ):
        raise ArtifactError("artifact_file_identity_invalid")
    flags = os.O_RDONLY | getattr(os, "O_CLOEXEC", 0) | getattr(os, "O_NOFOLLOW", 0)
    try:
        descriptor = os.open(path, flags)
        try:
            opened = os.fstat(descriptor)
            if (opened.st_dev, opened.st_ino) != (before.st_dev, before.st_ino):
                raise ArtifactError("artifact_file_raced")
            chunks: list[bytes] = []
            remaining = maximum + 1
            while remaining:
                chunk = os.read(descriptor, min(remaining, 64 * 1024))
                if not chunk:
                    break
                chunks.append(chunk)
                remaining -= len(chunk)
            payload = b"".join(chunks)
            after = os.fstat(descriptor)
        finally:
            os.close(descriptor)
    except ArtifactError:
        raise
    except OSError as exc:
        raise ArtifactError("artifact_file_read_failed") from exc
    if (
        (after.st_dev, after.st_ino, after.st_size, after.st_mtime_ns, after.st_ctime_ns)
        != (before.st_dev, before.st_ino, before.st_size, before.st_mtime_ns, before.st_ctime_ns)
        or len(payload) != before.st_size
        or len(payload) > maximum
    ):
        raise ArtifactError("artifact_file_raced")
    return payload


def _self_sha256() -> str:
    path = Path(__file__)
    payload = _read_exact_file(path, allowed_modes={0o500}, owners={0})
    return hashlib.sha256(payload).hexdigest()


def _validate_target(value: Any) -> dict[str, Any]:
    fields = {
        "project", "zone", "vm", "database", "sql_instance", "sql_host",
        "tls_server_name", "port", "writer_login",
    }
    raw = _exact(value, fields, "artifact_target_invalid")
    textual = ("project", "zone", "vm", "sql_instance", "sql_host", "tls_server_name")
    if (
        raw["database"] != DATABASE
        or raw["port"] != 5432
        or any(not isinstance(raw[field], str) or not raw[field] for field in textual)
        or ROLE.fullmatch(str(raw["writer_login"])) is None
        or any(any(ord(char) < 32 for char in str(raw[field])) for field in textual)
    ):
        raise ArtifactError("artifact_target_invalid")
    try:
        ipaddress.ip_address(str(raw["sql_host"]))
    except ValueError as exc:
        raise ArtifactError("artifact_target_invalid") from exc
    tls_name = str(raw["tls_server_name"])
    if len(tls_name) > 253 or re.fullmatch(r"[A-Za-z0-9.-]+", tls_name) is None:
        raise ArtifactError("artifact_target_invalid")
    return raw


def _initial_observation_request(value: Any) -> dict[str, Any]:
    raw = _hashed(
        value,
        {
            "schema", "action", "release_revision", "target", "artifact",
            "secret_material_recorded", "secret_digest_recorded",
            "request_sha256",
        },
        "request_sha256",
        "artifact_initial_request_invalid",
    )
    revision = raw["release_revision"]
    artifact = _exact(
        raw["artifact"],
        {"path", "sha256"},
        "artifact_initial_request_invalid",
    )
    release_root = (
        "/opt/adventico-ai-platform/hermes-agent-releases/"
        f"hermes-agent-{str(revision)[:12]}/"
    )
    if (
        raw["schema"] != INITIAL_OBSERVATION_REQUEST_SCHEMA
        or raw["action"] != "observe_initial"
        or raw["action"] not in ALLOWED_ACTIONS
        or not isinstance(revision, str)
        or REVISION.fullmatch(revision) is None
        or raw["secret_material_recorded"] is not False
        or raw["secret_digest_recorded"] is not False
        or not isinstance(artifact["path"], str)
        or artifact["path"]
        != release_root + "ops/muncho/cutover/artifacts/production-observe"
        or SHA256.fullmatch(str(artifact["sha256"])) is None
        or artifact["sha256"] != _self_sha256()
    ):
        raise ArtifactError("artifact_initial_request_invalid")
    target = _validate_target(raw["target"])
    if (
        target["project"] != "adventico-ai-platform"
        or target["zone"] != "europe-west3-a"
        or target["vm"] != "ai-platform-runtime-01"
        or target != _sealed_runtime_artifacts()["target"]
    ):
        raise ArtifactError("artifact_initial_request_invalid")
    return raw


SNAPSHOT_FIELDS = {
    "schema", "database", "shape", "source_owner", "relation_oid",
    "source_row_count", "canonical14_sha256", "extended19_sha256",
    "occurred_at_cutoff", "inserted_at_cutoff", "relation_identity_sha256",
    "acl_identity_sha256", "index_identity_sha256", "observed_at_unix",
    "snapshot_sha256",
}


def _validate_snapshot(value: Any) -> dict[str, Any]:
    raw = _hashed(value, SNAPSHOT_FIELDS, "snapshot_sha256", "artifact_snapshot_invalid")
    if (
        raw["schema"] != SNAPSHOT_SCHEMA
        or raw["database"] != DATABASE
        or raw["shape"] != "legacy19"
        or ROLE.fullmatch(str(raw["source_owner"])) is None
        or re.fullmatch(r"[1-9][0-9]*", str(raw["relation_oid"])) is None
        or type(raw["source_row_count"]) is not int
        or raw["source_row_count"] <= 0
        or type(raw["observed_at_unix"]) is not int
        or raw["observed_at_unix"] <= 0
        or not isinstance(raw["occurred_at_cutoff"], str)
        or not isinstance(raw["inserted_at_cutoff"], str)
    ):
        raise ArtifactError("artifact_snapshot_invalid")
    for field in (
        "canonical14_sha256", "extended19_sha256", "relation_identity_sha256",
        "acl_identity_sha256", "index_identity_sha256",
    ):
        if SHA256.fullmatch(str(raw[field])) is None:
            raise ArtifactError("artifact_snapshot_invalid")
    return raw


def _validate_legacy_truth_decision(
    value: Any,
    *,
    snapshot: Mapping[str, Any] | None = None,
    owner_subject_sha256: str | None = None,
) -> dict[str, Any]:
    fields = {
        "schema", "mode", "decision_id", "decision_event_id",
        "owner_subject_sha256", "reviewed_snapshot_sha256",
        "accepted_event_ids", "accepted_event_receipts",
        "reseed_manifest_sha256", "truth_epoch_id",
        "truth_epoch_sha256", "decision_sha256",
    }
    raw = _hashed(
        value,
        fields,
        "decision_sha256",
        "artifact_legacy_truth_decision_invalid",
    )
    mode = raw["mode"]
    event_ids = raw["accepted_event_ids"]
    receipts = raw["accepted_event_receipts"]
    if (
        raw["schema"] != "muncho-production-legacy-truth-decision.v1"
        or mode not in {"reseed_accepted_events", "start_new_truth_epoch"}
        or not isinstance(raw["decision_id"], str)
        or re.fullmatch(
            r"legacy-truth-decision:[0-9a-f]{8}-[0-9a-f]{4}-"
            r"[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}",
            raw["decision_id"],
        ) is None
        or not isinstance(raw["decision_event_id"], str)
        or UUID_TEXT.fullmatch(raw["decision_event_id"]) is None
        or SHA256.fullmatch(str(raw["owner_subject_sha256"])) is None
        or SHA256.fullmatch(str(raw["reviewed_snapshot_sha256"])) is None
        or not isinstance(event_ids, list)
        or not isinstance(receipts, list)
        or len(event_ids) != len(receipts)
        or len(event_ids) > MAX_ACCEPTED_LEGACY_EVENTS
        or len(set(event_ids)) != len(event_ids)
        or event_ids != sorted(event_ids)
        or raw["decision_event_id"] in event_ids
    ):
        raise ArtifactError("artifact_legacy_truth_decision_invalid")
    if (
        snapshot is not None
        and raw["reviewed_snapshot_sha256"] != snapshot.get("snapshot_sha256")
    ) or (
        owner_subject_sha256 is not None
        and raw["owner_subject_sha256"] != owner_subject_sha256
    ):
        raise ArtifactError("artifact_legacy_truth_decision_invalid")
    normalized_receipts = []
    for index, item in enumerate(receipts):
        receipt = _exact(
            item,
            {"event_id", "canonical14_row_sha256"},
            "artifact_legacy_truth_decision_invalid",
        )
        if (
            not isinstance(receipt["event_id"], str)
            or UUID_TEXT.fullmatch(receipt["event_id"]) is None
            or receipt["event_id"] != event_ids[index]
            or SHA256.fullmatch(str(receipt["canonical14_row_sha256"])) is None
        ):
            raise ArtifactError("artifact_legacy_truth_decision_invalid")
        normalized_receipts.append(receipt)
    if snapshot is not None and len(event_ids) > int(snapshot["source_row_count"]):
        raise ArtifactError("artifact_legacy_truth_decision_invalid")
    if mode == "reseed_accepted_events":
        manifest = {
            "schema": "muncho-production-legacy-reseed-manifest.v1",
            "reviewed_snapshot_sha256": raw["reviewed_snapshot_sha256"],
            "accepted_event_ids": event_ids,
            "accepted_event_receipts": normalized_receipts,
        }
        if (
            not event_ids
            or raw["reseed_manifest_sha256"] != _sha_json(manifest)
            or raw["truth_epoch_id"] is not None
            or raw["truth_epoch_sha256"] is not None
        ):
            raise ArtifactError("artifact_legacy_truth_decision_invalid")
    else:
        epoch = {
            "schema": "muncho-production-new-truth-epoch.v1",
            "reviewed_snapshot_sha256": raw["reviewed_snapshot_sha256"],
            "truth_epoch_id": raw["truth_epoch_id"],
        }
        if (
            event_ids
            or receipts
            or raw["reseed_manifest_sha256"] is not None
            or not isinstance(raw["truth_epoch_id"], str)
            or re.fullmatch(
                r"truth-epoch:[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-"
                r"[0-9a-f]{4}-[0-9a-f]{12}",
                raw["truth_epoch_id"],
            ) is None
            or raw["truth_epoch_sha256"] != _sha_json(epoch)
        ):
            raise ArtifactError("artifact_legacy_truth_decision_invalid")
    return raw


def _validate_cron_continuity_authority(
    authority: Mapping[str, Any],
    *,
    revision: str,
) -> None:
    inventory = _hashed(
        authority.get("cron_inventory"),
        {
            "schema", "created_at", "source_store_sha256", "job_count",
            "enabled_count", "compatible_enabled_count",
            "incompatible_enabled_count", "disabled_count",
            "compatible_enabled_records", "incompatible_enabled_records",
            "disabled_records", "legacy_auto_sync",
            "migration_required_for_gateway_startup", "migration_plan_payload",
            "migration_plan_sha256", "prompt_or_script_content_recorded",
            "job_executed", "inventory_sha256",
        },
        "inventory_sha256",
        "artifact_plan_invalid",
    )
    host_facts = _hashed(
        authority.get("mechanical_job_host_facts"),
        {
            "schema", "collected_at", "github_cli", "git",
            "github_credential", "provider_or_model_credential_observed",
            "discord_credential_observed", "host_facts_sha256",
        },
        "host_facts_sha256",
        "artifact_plan_invalid",
    )
    package = _hashed(
        authority.get("mechanical_job_package"),
        {
            "schema", "rail_schema", "release_revision", "release_root",
            "job_allowlist", "rail_sha256", "host_facts_sha256",
            "host_binaries", "units", "credential_name",
            "credential_value_recorded", "provider_or_model_dependency",
            "discord_dependency", "timer_started_by_package",
            "manifest_sha256",
        },
        "manifest_sha256",
        "artifact_plan_invalid",
    )
    plan_value = authority.get("cron_continuity_plan")
    packaged_plan = (
        isinstance(plan_value, Mapping)
        and plan_value.get("schema")
        == "muncho-production-cron-packaged-continuity-plan.v3"
    )
    collector_package = None
    collector_execution_readiness = None
    operational_edge_readiness = None
    if packaged_plan:
        plan = _hashed(
            plan_value,
            {
                "schema", "source_store_sha256", "observation_sha256",
                "review_plan_sha256", "inventory_sha256",
                "collector_package_manifest_sha256",
                "trusted_collector_package",
                "collector_execution_readiness",
                "operational_edge_readiness",
                "mechanical_job_package_manifest_sha256",
                "cutover_runtime_sha256", "cutover_entrypoint_sha256",
                "replacement_bundle_sha256", "replacement_record_count",
                "enabled_count", "records", "disposition_counts",
                "owner_input_required_job_ids",
                "post_cutover_owner_followups", "catalog_complete",
                "review_complete", "cutover_executable",
                "blanket_inert_migration_allowed",
                "byte_exact_source_archive_required",
                "execute_job_during_packaging",
                "prompt_or_script_content_recorded", "plan_sha256",
            },
            "plan_sha256",
            "artifact_plan_invalid",
        )
        collector_package = _hashed(
            plan.get("trusted_collector_package"),
            {
                "schema", "rail_schema", "release_revision", "release_root",
                "rail_path", "rail_sha256", "package_binding_sha256",
                "collector_contract", "dependency_sha256", "units",
                "service_user", "service_group", "reader_group", "packet_root",
                "provider_or_model_dependency", "gateway_credential_dependency",
                "discord_credential_dependency", "semantic_judgment_allowed",
                "direct_delivery_allowed", "timer_enabled_by_package",
                "timer_started_by_package", "manifest_sha256",
            },
            "manifest_sha256",
            "artifact_plan_invalid",
        )
        collector_execution_readiness = _hashed(
            plan.get("collector_execution_readiness"),
            {
                "schema", "release_revision",
                "collector_manifest_sha256", "service_user", "service_uid",
                "service_group", "service_gid", "checked_path_count",
                "blocked_paths", "blocked_path_count",
                "direct_dependencies_ready",
                "scoped_execution_edge_required_job_ids",
                "scoped_execution_edge_required_count",
                "scoped_execution_edge_packaged",
                "scoped_execution_edge_receipt_sha256",
                "scoped_execution_edge_meaningful_packet_count",
                "activation_ready", "permissions_widened",
                "credential_content_read", "secret_material_recorded",
                "readiness_sha256",
            },
            "readiness_sha256",
            "artifact_plan_invalid",
        )
        operational_edge_readiness = _hashed(
            plan.get("operational_edge_readiness"),
            {
                "schema", "release_revision", "boot_id_sha256",
                "observed_at_unix", "maximum_age_seconds",
                "collector_nonce", "catalog_sha256",
                "required_jobs", "required_job_count", "jobs", "job_count",
                "all_required_jobs_ready", "credential_values_read",
                "permissions_widened", "secret_material_recorded",
                "secret_digest_recorded", "receipt_sha256",
            },
            "receipt_sha256",
            "artifact_plan_invalid",
        )
    else:
        plan = _hashed(
            plan_value,
            {
                "schema", "source_store_sha256", "inventory_sha256",
                "inventory_plan_template_sha256", "continuity_dispositions",
                "review_complete", "cutover_executable",
                "blanket_inert_migration_allowed", "execute_job_during_migration",
                "approval_id", "approved_by", "owner_approved_plan_sha256",
            },
            "owner_approved_plan_sha256",
            "artifact_plan_invalid",
        )
    credential = host_facts.get("github_credential")
    expected_release = (
        "/opt/adventico-ai-platform/hermes-agent-releases/"
        f"hermes-agent-{revision[:12]}"
    )
    if packaged_plan:
        records = plan.get("records")
        dispositions = plan.get("disposition_counts")
        followups = plan.get("post_cutover_owner_followups")
        preserved = [
            row for row in records
            if isinstance(row, Mapping)
            and row.get("job_id") == "fecd0675f91e"
        ] if isinstance(records, list) else []
        owner_target = preserved[0].get("target") if len(preserved) == 1 else None
        collector_rows = [
            row for row in records
            if isinstance(row, Mapping)
            and row.get("disposition") == "migrate_trusted_collector"
        ] if isinstance(records, list) else []
        required_edges = operational_edge_readiness.get(
            "required_jobs"
        ) if operational_edge_readiness is not None else None
        edge_jobs = operational_edge_readiness.get(
            "jobs"
        ) if operational_edge_readiness is not None else None
        required_edge_ids = [
            row.get("source_job_id")
            for row in required_edges
            if isinstance(row, Mapping)
        ] if isinstance(required_edges, list) else []
        required_edge_pairs = [
            (row.get("source_job_id"), row.get("operation_id"))
            for row in required_edges
            if isinstance(row, Mapping)
        ] if isinstance(required_edges, list) else []
        edge_job_pairs = [
            (row.get("source_job_id"), row.get("operation_id"))
            for row in edge_jobs
            if isinstance(row, Mapping)
        ] if isinstance(edge_jobs, list) else []
        execution_edge_ids = (
            collector_execution_readiness.get(
                "scoped_execution_edge_required_job_ids"
            )
            if collector_execution_readiness is not None
            else None
        )
        packaged_invalid = (
            collector_package is None
            or collector_execution_readiness is None
            or operational_edge_readiness is None
            or collector_package.get("schema")
            != "muncho-trusted-cron-collector-package.v1"
            or collector_package.get("rail_schema")
            != "muncho-trusted-cron-collector-rail.v1"
            or collector_package.get("release_revision") != revision
            or collector_package.get("release_root") != expected_release
            or collector_package.get("provider_or_model_dependency") is not False
            or collector_package.get("gateway_credential_dependency") is not False
            or collector_package.get("discord_credential_dependency") is not False
            or collector_package.get("semantic_judgment_allowed") is not False
            or collector_package.get("direct_delivery_allowed") is not False
            or collector_package.get("timer_enabled_by_package") is not False
            or collector_package.get("timer_started_by_package") is not False
            or collector_execution_readiness.get("schema")
            != "muncho-trusted-cron-execution-readiness.v1"
            or collector_execution_readiness.get("release_revision") != revision
            or collector_execution_readiness.get("collector_manifest_sha256")
            != collector_package.get("manifest_sha256")
            or collector_execution_readiness.get("blocked_paths") != []
            or collector_execution_readiness.get("blocked_path_count") != 0
            or collector_execution_readiness.get("direct_dependencies_ready")
            is not True
            or collector_execution_readiness.get(
                "scoped_execution_edge_required_count"
            ) != 14
            or collector_execution_readiness.get(
                "scoped_execution_edge_packaged"
            ) is not True
            or collector_execution_readiness.get(
                "scoped_execution_edge_receipt_sha256"
            ) != operational_edge_readiness.get("receipt_sha256")
            or collector_execution_readiness.get(
                "scoped_execution_edge_meaningful_packet_count"
            ) != 14
            or collector_execution_readiness.get("activation_ready") is not True
            or collector_execution_readiness.get("permissions_widened")
            is not False
            or collector_execution_readiness.get("credential_content_read")
            is not False
            or collector_execution_readiness.get("secret_material_recorded")
            is not False
            or operational_edge_readiness.get("schema")
            != "muncho-operational-edge-readiness.v2"
            or operational_edge_readiness.get("release_revision") != revision
            or SHA256.fullmatch(str(
                operational_edge_readiness.get("boot_id_sha256") or ""
            )) is None
            or type(operational_edge_readiness.get("observed_at_unix")) is not int
            or operational_edge_readiness.get("observed_at_unix", 0) < 1
            or operational_edge_readiness.get("maximum_age_seconds") != 120
            or UUID4_TEXT.fullmatch(str(
                operational_edge_readiness.get("collector_nonce") or ""
            )) is None
            or SHA256.fullmatch(str(
                operational_edge_readiness.get("catalog_sha256") or ""
            )) is None
            or operational_edge_readiness.get("required_job_count") != 14
            or operational_edge_readiness.get("job_count") != 14
            or operational_edge_readiness.get("all_required_jobs_ready")
            is not True
            or operational_edge_readiness.get("credential_values_read")
            is not False
            or operational_edge_readiness.get("permissions_widened") is not False
            or operational_edge_readiness.get("secret_material_recorded")
            is not False
            or operational_edge_readiness.get("secret_digest_recorded")
            is not False
            or len(required_edge_ids) != 14
            or len(set(required_edge_ids)) != 14
            or required_edge_ids != sorted(required_edge_ids)
            or edge_job_pairs != required_edge_pairs
            or execution_edge_ids != required_edge_ids
            or not isinstance(edge_jobs, list)
            or len(edge_jobs) != 14
            or [
                row.get("source_job_id")
                for row in edge_jobs
                if isinstance(row, Mapping)
            ] != required_edge_ids
            or any(
                not isinstance(row, Mapping)
                or set(row) != {
                    "source_job_id", "operation_id", "domain",
                    "service_unit", "service_uid", "service_gid",
                    "socket_path", "socket_uid", "socket_gid",
                    "socket_mode", "main_pid", "peer_round_trip",
                    "probe_operation_id", "probe_return_code",
                    "probe_packet_schema", "probe_packet_sha256",
                    "meaningful_packet", "error_only_packet",
                }
                or row.get("peer_round_trip") is not True
                or row.get("probe_return_code") != 0
                or row.get("probe_packet_schema")
                != "muncho-operational-edge-probe-packet.v1"
                or SHA256.fullmatch(str(row.get("probe_packet_sha256") or ""))
                is None
                or row.get("meaningful_packet") is not True
                or row.get("error_only_packet") is not False
                for row in edge_jobs
            )
            or not isinstance(collector_package.get("units"), Mapping)
            or len(collector_package["units"]) != 21
            or plan.get("collector_package_manifest_sha256")
            != collector_package.get("manifest_sha256")
            or plan.get("mechanical_job_package_manifest_sha256")
            != package.get("manifest_sha256")
            or SHA256.fullmatch(str(plan.get("cutover_runtime_sha256") or ""))
            is None
            or SHA256.fullmatch(str(plan.get("cutover_entrypoint_sha256") or ""))
            is None
            or plan.get("source_store_sha256")
            != inventory.get("source_store_sha256")
            or plan.get("inventory_sha256") != inventory.get("inventory_sha256")
            or plan.get("enabled_count") != 28
            or plan.get("replacement_record_count") != 24
            or not isinstance(records, list)
            or len(records) != 28
            or len({row.get("job_id") for row in records if isinstance(row, Mapping)})
            != 28
            or any(
                not isinstance(row, Mapping)
                or row.get("owner_input_required") is not False
                for row in records
            )
            or dispositions
            != {
                "keep_compatible": 1,
                "migrate_primary_agent": 5,
                "migrate_trusted_collector": 21,
                "preserve_inert": 1,
            }
            or len(collector_rows) != 21
            or any(
                not isinstance(row.get("target"), Mapping)
                or row["target"].get("semantic_judgment_allowed_in_collector")
                is not False
                or row["target"].get("provider_or_model_allowed_in_collector")
                is not False
                or row["target"].get("direct_discord_allowed_in_collector")
                is not False
                for row in collector_rows
            )
            or len(preserved) != 1
            or preserved[0].get("disposition") != "preserve_inert"
            or not isinstance(owner_target, Mapping)
            or owner_target.get("archive_byte_exact_required") is not True
            or owner_target.get("archive_source_store_sha256")
            != inventory.get("source_store_sha256")
            or owner_target.get("live_record_enabled") is not False
            or owner_target.get("live_record_state") != "paused"
            or owner_target.get("delete_allowed") is not False
            or owner_target.get("claimed_discontinued") is not False
            or owner_target.get("owner_followup_blocks_cutover") is not False
            or plan.get("owner_input_required_job_ids") != []
            or followups
            != [{
                "job_id": "fecd0675f91e",
                "followup_code": "rebuild_local_mac_agent_or_retire_preserved_record",
                "current_disposition": "preserve_inert",
                "blocks_cutover": False,
            }]
            or plan.get("catalog_complete") is not True
            or plan.get("review_complete") is not True
            or plan.get("cutover_executable") is not True
            or plan.get("blanket_inert_migration_allowed") is not False
            or plan.get("byte_exact_source_archive_required") is not True
            or plan.get("execute_job_during_packaging") is not False
            or plan.get("prompt_or_script_content_recorded") is not False
        )
    else:
        packaged_invalid = (
            plan.get("schema") != "muncho-production-cron-continuity-plan.v2"
            or plan.get("source_store_sha256")
            != inventory.get("source_store_sha256")
            or plan.get("inventory_sha256") != inventory.get("inventory_sha256")
            or plan.get("inventory_plan_template_sha256")
            != inventory.get("migration_plan_sha256")
            or not isinstance(plan.get("continuity_dispositions"), list)
            or plan.get("review_complete") is not True
            or plan.get("cutover_executable") is not True
            or plan.get("blanket_inert_migration_allowed") is not False
            or plan.get("execute_job_during_migration") is not False
            or plan.get("approved_by") != "owner"
        )
    if (
        inventory.get("schema")
        != "muncho-production-cron-migration-inventory.v2"
        or inventory.get("prompt_or_script_content_recorded") is not False
        or inventory.get("job_executed") is not False
        or _sha_json(inventory.get("migration_plan_payload"))
        != inventory.get("migration_plan_sha256")
        or host_facts.get("schema") != "muncho-mechanical-job-host-facts.v1"
        or host_facts.get("provider_or_model_credential_observed") is not False
        or host_facts.get("discord_credential_observed") is not False
        or not isinstance(credential, Mapping)
        or credential.get("content_recorded") is not False
        or credential.get("size_recorded") is not False
        or credential.get("digest_recorded") is not False
        or package.get("schema") != "muncho-mechanical-job-package.v1"
        or package.get("rail_schema") != "muncho-mechanical-job-rail.v1"
        or package.get("release_revision") != revision
        or package.get("release_root") != expected_release
        or package.get("host_facts_sha256")
        != host_facts.get("host_facts_sha256")
        or package.get("credential_value_recorded") is not False
        or package.get("provider_or_model_dependency") is not False
        or package.get("discord_dependency") is not False
        or package.get("timer_started_by_package") is not False
        or packaged_invalid
    ):
        raise ArtifactError("artifact_plan_invalid")


def _plan_digest(raw: Mapping[str, Any]) -> str:
    digest = raw.get("plan_sha256")
    if not isinstance(digest, str) or SHA256.fullmatch(digest) is None:
        raise ArtifactError("artifact_plan_invalid")
    unsigned = {key: item for key, item in raw.items() if key != "plan_sha256"}
    if _sha_json(unsigned) != digest:
        raise ArtifactError("artifact_plan_invalid")
    revision = raw.get("release_revision")
    if not isinstance(revision, str) or REVISION.fullmatch(revision) is None:
        raise ArtifactError("artifact_plan_invalid")
    _validate_target(raw.get("target"))
    schema = raw.get("schema")
    freeze_fields = {
        "schema", "release_revision", "target", "owner_subject_sha256",
        "owner_public_key_ed25519_hex", "owner_key_id", "gateway_before",
        "writer_before", "connector_before", "initial_snapshot",
        "owner_runtime_attestation", "observe_artifact", "cutover_authority", "states",
        "secret_material_recorded", "plan_sha256",
    }
    cutover_fields = {
        "schema", "release_revision", "target", "owner_subject_sha256",
        "owner_public_key_ed25519_hex", "owner_key_id", "freeze_plan",
        "freeze_plan_sha256", "freeze_approval_sha256", "final_tail_receipt",
        "final_tail_receipt_sha256", "artifacts", "gateway_legacy_identity",
        "writer_pre_identity", "connector_pre_identity",
        "gateway_target_identity", "writer_target_identity",
        "connector_target_identity", "host_transition", "rollback_contract",
        "capability_topology", "cron_inventory", "cron_continuity_plan",
        "mechanical_job_host_facts", "mechanical_job_package",
        "legacy_truth_decision", "owner_runtime_attestation",
        "states", "secret_material_recorded", "plan_sha256",
    }
    runtime_attestation = _hashed(
        raw.get("owner_runtime_attestation"),
        {
            "schema", "revision", "manifest_sha256", "tree_sha256",
            "interpreter_sha256", "pyvenv_cfg_sha256", "sys_path_sha256",
            "required_modules_sha256", "module_origins_release_local",
            "ambient_python_environment_present", "secret_material_recorded",
            "secret_digest_recorded", "attestation_sha256",
        },
        "attestation_sha256",
        "artifact_plan_invalid",
    )
    if (
        runtime_attestation.get("schema")
        != "muncho-production-owner-runtime-attestation.v1"
        or runtime_attestation.get("revision") != revision
        or any(
            SHA256.fullmatch(str(runtime_attestation.get(name))) is None
            for name in (
                "manifest_sha256", "tree_sha256", "interpreter_sha256",
                "pyvenv_cfg_sha256", "sys_path_sha256",
                "required_modules_sha256",
            )
        )
        or runtime_attestation.get("module_origins_release_local") is not True
        or runtime_attestation.get("ambient_python_environment_present")
        is not False
        or runtime_attestation.get("secret_material_recorded") is not False
        or runtime_attestation.get("secret_digest_recorded") is not False
    ):
        raise ArtifactError("artifact_plan_invalid")
    if schema == "muncho-production-legacy-freeze-plan.v2":
        if set(raw) != freeze_fields or raw.get("states") != [
            "authority", "gateway_stopped", "final_tail_captured"
        ]:
            raise ArtifactError("artifact_plan_invalid")
        initial_snapshot = _validate_snapshot(raw.get("initial_snapshot"))
        authority = _hashed(
            raw.get("cutover_authority"),
            {
                "schema", "release_revision", "artifacts",
                "gateway_target_identity", "writer_target_identity",
                "connector_target_identity", "host_transition",
                "capability_topology", "cron_inventory",
                "cron_continuity_plan", "mechanical_job_host_facts",
                "mechanical_job_package", "legacy_truth_decision",
                "final_tail_bounds",
                "rollback_contract", "secret_material_recorded",
                "authority_sha256",
            },
            "authority_sha256",
            "artifact_plan_invalid",
        )
        artifacts = authority.get("artifacts")
        bounds = authority.get("final_tail_bounds")
        rollback = authority.get("rollback_contract")
        _validate_legacy_truth_decision(
            authority.get("legacy_truth_decision"),
            snapshot=initial_snapshot,
            owner_subject_sha256=str(raw.get("owner_subject_sha256") or ""),
        )
        _validate_cron_continuity_authority(authority, revision=revision)
        if (
            authority.get("schema") != "muncho-production-cutover-authority.v1"
            or authority.get("release_revision") != revision
            or authority.get("secret_material_recorded") is not False
            or not isinstance(artifacts, Mapping)
            or set(artifacts) != {
                "observe", "database_apply", "database_rollback",
                "database_postflight", "host_activation", "host_rollback",
            }
            or raw.get("observe_artifact") != artifacts.get("observe")
            or not isinstance(bounds, Mapping)
            or set(bounds) != {
                "max_appended_rows", "max_capture_delay_seconds"
            }
            or type(bounds.get("max_appended_rows")) is not int
            or not 0 <= bounds["max_appended_rows"] <= 10_000_000
            or type(bounds.get("max_capture_delay_seconds")) is not int
            or not 1 <= bounds["max_capture_delay_seconds"] <= 3600
            or not isinstance(rollback, Mapping)
            or set(rollback) != {
                "database_rollback_sha256", "host_rollback_sha256",
                "requires_gateway_stopped", "requires_writer_stopped",
                "requires_connector_stopped",
                "requires_zero_canonical_writer_writes",
                "restart_legacy_gateway",
            }
            or rollback.get("database_rollback_sha256")
            != artifacts["database_rollback"].get("sha256")
            or rollback.get("host_rollback_sha256")
            != artifacts["host_rollback"].get("sha256")
            or rollback.get("requires_gateway_stopped") is not True
            or rollback.get("requires_writer_stopped") is not True
            or rollback.get("requires_connector_stopped") is not True
            or rollback.get("requires_zero_canonical_writer_writes") is not True
            or rollback.get("restart_legacy_gateway") is not True
        ):
            raise ArtifactError("artifact_plan_invalid")
    elif schema == "muncho-production-legacy-cutover-plan.v2":
        if set(raw) != cutover_fields or raw.get("states") != [
            "authority", "host_applied", "prerequisites_started",
            "capability_prerequisites_validated", "final_tail_reobserved",
            "preflight", "database_applied", "writer_started",
            "database_terminal_validated", "activation_commit_intent",
            "boot_committed", "gateway_started", "terminal",
        ]:
            raise ArtifactError("artifact_plan_invalid")
        freeze = raw.get("freeze_plan")
        if not isinstance(freeze, Mapping):
            raise ArtifactError("artifact_plan_invalid")
        freeze_digest = _plan_digest(freeze)
        authority = freeze.get("cutover_authority")
        rollback = raw.get("rollback_contract")
        artifacts = raw.get("artifacts")
        if (
            raw.get("freeze_plan_sha256") != freeze_digest
            or raw.get("release_revision") != freeze.get("release_revision")
            or raw.get("target") != freeze.get("target")
            or raw.get("owner_subject_sha256")
            != freeze.get("owner_subject_sha256")
            or raw.get("owner_public_key_ed25519_hex")
            != freeze.get("owner_public_key_ed25519_hex")
            or raw.get("owner_key_id") != freeze.get("owner_key_id")
            or raw.get("owner_runtime_attestation")
            != freeze.get("owner_runtime_attestation")
            or not isinstance(authority, Mapping)
            or not isinstance(artifacts, Mapping)
            or not isinstance(rollback, Mapping)
            or set(rollback) != {
                "database_rollback_sha256", "host_rollback_sha256",
                "requires_gateway_stopped", "requires_writer_stopped",
                "requires_connector_stopped",
                "requires_zero_canonical_writer_writes",
                "restart_legacy_gateway",
            }
            or rollback.get("requires_gateway_stopped") is not True
            or rollback.get("requires_writer_stopped") is not True
            or rollback.get("requires_connector_stopped") is not True
            or rollback.get("requires_zero_canonical_writer_writes") is not True
            or rollback.get("restart_legacy_gateway") is not True
            or artifacts != authority.get("artifacts")
            or raw.get("gateway_target_identity")
            != authority.get("gateway_target_identity")
            or raw.get("writer_target_identity")
            != authority.get("writer_target_identity")
            or raw.get("connector_target_identity")
            != authority.get("connector_target_identity")
            or raw.get("host_transition") != authority.get("host_transition")
            or raw.get("capability_topology")
            != authority.get("capability_topology")
            or raw.get("cron_inventory") != authority.get("cron_inventory")
            or raw.get("cron_continuity_plan")
            != authority.get("cron_continuity_plan")
            or raw.get("mechanical_job_host_facts")
            != authority.get("mechanical_job_host_facts")
            or raw.get("mechanical_job_package")
            != authority.get("mechanical_job_package")
            or raw.get("legacy_truth_decision")
            != authority.get("legacy_truth_decision")
            or rollback != authority.get("rollback_contract")
        ):
            raise ArtifactError("artifact_plan_invalid")
        _validate_legacy_truth_decision(
            raw.get("legacy_truth_decision"),
            snapshot=_validate_snapshot(freeze.get("initial_snapshot")),
            owner_subject_sha256=str(raw.get("owner_subject_sha256") or ""),
        )
        database_rollback = artifacts.get("database_rollback")
        host_rollback = artifacts.get("host_rollback")
        if (
            not isinstance(database_rollback, Mapping)
            or not isinstance(host_rollback, Mapping)
            or rollback.get("database_rollback_sha256")
            != database_rollback.get("sha256")
            or rollback.get("host_rollback_sha256")
            != host_rollback.get("sha256")
            or SHA256.fullmatch(str(raw.get("freeze_approval_sha256"))) is None
        ):
            raise ArtifactError("artifact_plan_invalid")
    else:
        raise ArtifactError("artifact_plan_invalid")
    public = raw.get("owner_public_key_ed25519_hex")
    if (
        raw.get("secret_material_recorded") is not False
        or SHA256.fullmatch(str(raw.get("owner_subject_sha256"))) is None
        or not isinstance(public, str)
        or re.fullmatch(r"[0-9a-f]{64}", public) is None
        or raw.get("owner_key_id") != hashlib.sha256(bytes.fromhex(public)).hexdigest()
    ):
        raise ArtifactError("artifact_plan_invalid")
    return digest


def _binding(plan: Mapping[str, Any], action: str) -> Mapping[str, Any]:
    artifact_name = ACTION_ARTIFACT[action]
    if action == "observe_final_tail":
        value = plan.get("observe_artifact")
    else:
        artifacts = plan.get("artifacts")
        if not isinstance(artifacts, Mapping) or set(artifacts) != {
            "observe", "database_apply", "database_rollback", "database_postflight",
            "host_activation", "host_rollback",
        }:
            raise ArtifactError("artifact_plan_invalid")
        value = artifacts.get(artifact_name)
    raw = _exact(value, {"path", "sha256"}, "artifact_binding_invalid")
    release_root = f"/opt/adventico-ai-platform/hermes-agent-releases/hermes-agent-{str(plan['release_revision'])[:12]}/"
    if (
        not isinstance(raw["path"], str)
        or not raw["path"].startswith(release_root)
        or "/../" in raw["path"]
        or raw["path"].endswith("/..")
        or SHA256.fullmatch(str(raw["sha256"])) is None
    ):
        raise ArtifactError("artifact_binding_invalid")
    if raw["sha256"] != _self_sha256():
        raise ArtifactError("artifact_self_binding_invalid")
    return raw


def _final_snapshot(plan: Mapping[str, Any]) -> dict[str, Any]:
    tail = plan.get("final_tail_receipt")
    fields = {
        "schema", "freeze_plan_sha256", "approval_sha256", "gateway_stopped",
        "writer_stopped", "final_snapshot", "initial_row_count", "final_row_count",
        "append_only_row_floor_preserved", "captured_at_unix", "receipt_sha256",
    }
    tail = _hashed(tail, fields, "receipt_sha256", "artifact_plan_invalid")
    snapshot = _validate_snapshot(tail.get("final_snapshot"))
    freeze = plan.get("freeze_plan")
    if not isinstance(freeze, Mapping):
        raise ArtifactError("artifact_plan_invalid")
    initial = _validate_snapshot(freeze.get("initial_snapshot"))
    authority = freeze.get("cutover_authority")
    if not isinstance(authority, Mapping):
        raise ArtifactError("artifact_plan_invalid")
    bounds = authority.get("final_tail_bounds")
    if not isinstance(bounds, Mapping):
        raise ArtifactError("artifact_plan_invalid")
    if (
        tail.get("schema") != "muncho-production-final-tail-receipt.v1"
        or plan.get("final_tail_receipt_sha256") != tail.get("receipt_sha256")
        or tail.get("gateway_stopped") is not True
        or tail.get("writer_stopped") is not True
        or tail.get("append_only_row_floor_preserved") is not True
        or tail.get("final_row_count") != snapshot["source_row_count"]
        or type(tail.get("initial_row_count")) is not int
        or tail["initial_row_count"] > tail["final_row_count"]
        or type(tail.get("captured_at_unix")) is not int
        or SHA256.fullmatch(str(tail.get("freeze_plan_sha256"))) is None
        or SHA256.fullmatch(str(tail.get("approval_sha256"))) is None
        or tail.get("freeze_plan_sha256") != plan.get("freeze_plan_sha256")
        or tail.get("approval_sha256") != plan.get("freeze_approval_sha256")
        or tail.get("initial_row_count") != initial["source_row_count"]
        or tail["final_row_count"] - tail["initial_row_count"]
        > bounds.get("max_appended_rows", -1)
        or tail["captured_at_unix"] < initial["observed_at_unix"]
        or tail["captured_at_unix"] - initial["observed_at_unix"]
        > bounds.get("max_capture_delay_seconds", -1)
        or any(
            snapshot[field] != initial[field]
            for field in (
                "database", "shape", "source_owner", "relation_oid",
                "relation_identity_sha256", "acl_identity_sha256",
                "index_identity_sha256",
            )
        )
    ):
        raise ArtifactError("artifact_plan_invalid")
    return snapshot


def _legacy_truth_decision_for_plan(plan: Mapping[str, Any]) -> dict[str, Any]:
    freeze = plan.get("freeze_plan")
    if not isinstance(freeze, Mapping):
        raise ArtifactError("artifact_legacy_truth_decision_invalid")
    return _validate_legacy_truth_decision(
        plan.get("legacy_truth_decision"),
        snapshot=_validate_snapshot(freeze.get("initial_snapshot")),
        owner_subject_sha256=str(plan.get("owner_subject_sha256") or ""),
    )


def _accepted_event_set_sha256(decision: Mapping[str, Any]) -> str:
    return _sha_json(decision["accepted_event_ids"])


def _validate_capability_prerequisite_plan(
    plan: Mapping[str, Any],
) -> dict[str, Any]:
    contract = _exact(
        PRODUCTION_CAPABILITY_PREREQUISITE_CONTRACT,
        {
            "schema", "topology_schema", "path", "boot_id_path", "uid", "gid",
            "mode", "maximum_bytes", "maximum_age_seconds", "lifecycle_phases",
            "fields",
            "topology_fields", "isolated_worker_topology_fields",
            "browser_topology_fields", "isolated_worker_receipt_fields",
            "browser_receipt_fields", "collector_entrypoint", "dynamic_receipt",
            "owner_approval_binds_collector_criteria",
            "live_reobservation_required", "atomic_root_install",
            "secret_material_recorded", "secret_digest_recorded",
        },
        "artifact_prerequisite_contract_invalid",
    )
    if (
        contract["schema"] != "muncho-production-capability-prerequisite.v3"
        or contract["topology_schema"]
        != "muncho-production-capability-topology.v3"
        or contract["path"]
        != "/var/lib/muncho-production-capability/prerequisite-receipt.json"
        or contract["boot_id_path"] != "/proc/sys/kernel/random/boot_id"
        or contract["uid"] != 0
        or contract["gid"] != 0
        or contract["mode"] != 0o444
        or type(contract["maximum_bytes"]) is not int
        or not 0 < contract["maximum_bytes"] <= MAX_JSON
        or contract["maximum_age_seconds"] != 900
        or contract["lifecycle_phases"] != ["committed", "staged"]
        or contract["collector_entrypoint"]
        != "gateway.production_capability_prerequisites:collect"
        or contract["dynamic_receipt"] is not True
        or contract["owner_approval_binds_collector_criteria"] is not True
        or contract["live_reobservation_required"] is not True
        or contract["atomic_root_install"] is not True
        or contract["secret_material_recorded"] is not False
        or contract["secret_digest_recorded"] is not False
        or not isinstance(contract["fields"], list)
        or not isinstance(contract["topology_fields"], list)
        or not isinstance(contract["isolated_worker_topology_fields"], list)
        or not isinstance(contract["browser_topology_fields"], list)
        or not isinstance(contract["isolated_worker_receipt_fields"], list)
        or not isinstance(contract["browser_receipt_fields"], list)
        or any(
            "docker" in field.lower() or "cdp" in field.lower()
            for key in (
                "fields",
                "topology_fields",
                "isolated_worker_topology_fields",
                "browser_topology_fields",
                "isolated_worker_receipt_fields",
                "browser_receipt_fields",
            )
            for field in contract[key]
        )
    ):
        raise ArtifactError("artifact_prerequisite_contract_invalid")
    topology = plan.get("capability_topology")
    if not isinstance(topology, Mapping):
        raise ArtifactError("artifact_prerequisite_plan_invalid")
    topology = dict(topology)
    sealed = _sealed_runtime_artifacts()["topology_fragments"]
    worker = topology.get("isolated_worker")
    browser = topology.get("browser")
    if (
        set(topology) != set(contract["topology_fields"])
        or topology.get("schema") != contract["topology_schema"]
        or topology.get("prerequisite_receipt_path") != contract["path"]
        or topology.get("collector_contract_sha256") != _sha_json(contract)
        or not isinstance(worker, Mapping)
        or set(worker) != set(contract["isolated_worker_topology_fields"])
        or not isinstance(browser, Mapping)
        or set(browser) != set(contract["browser_topology_fields"])
        or dict(worker) != dict(sealed["isolated_worker"])
        or dict(browser) != dict(sealed["browser"])
        or "docker" in topology
        or "cdp_url" in browser
    ):
        raise ArtifactError("artifact_prerequisite_plan_invalid")
    return topology


def _assert_current_capability_prerequisite(plan: Mapping[str, Any]) -> None:
    topology = _validate_capability_prerequisite_plan(plan)
    contract = PRODUCTION_CAPABILITY_PREREQUISITE_CONTRACT
    payload = _read_exact_file(
        Path(contract["path"]),
        allowed_modes={contract["mode"]},
        owners={contract["uid"]},
        groups={contract["gid"]},
        maximum=contract["maximum_bytes"],
    )
    receipt = dict(_strict_json(payload, "artifact_prerequisite_invalid"))
    current = int(time.time())
    receipt_worker = receipt.get("isolated_worker")
    receipt_browser = receipt.get("browser")
    if (
        set(receipt) != set(contract["fields"])
        or receipt.get("schema") != contract["schema"]
        or receipt.get("release_revision") != plan.get("release_revision")
        or receipt.get("lifecycle_phase") != "staged"
        or receipt.get("topology_identity_sha256") != _sha_json(topology)
        or receipt.get("secret_material_recorded") is not False
        or receipt.get("secret_digest_recorded") is not False
        or type(receipt.get("observed_at_unix")) is not int
        or receipt["observed_at_unix"] > current + 30
        or current - receipt["observed_at_unix"]
        > contract["maximum_age_seconds"]
        or SHA256.fullmatch(str(receipt.get("receipt_sha256"))) is None
        or receipt["receipt_sha256"]
        != _sha_json({
            key: item
            for key, item in receipt.items()
            if key != "receipt_sha256"
        })
        or SHA256.fullmatch(str(receipt.get("boot_id_sha256"))) is None
        or not isinstance(receipt_worker, Mapping)
        or set(receipt_worker) != set(contract["isolated_worker_receipt_fields"])
        or not isinstance(receipt_browser, Mapping)
        or set(receipt_browser) != set(contract["browser_receipt_fields"])
        or any(
            receipt_worker.get(field) != topology["isolated_worker"][field]
            for field in contract["isolated_worker_topology_fields"]
            if field in receipt_worker
        )
        or any(
            receipt_browser.get(field) != topology["browser"][field]
            for field in contract["browser_topology_fields"]
            if field in receipt_browser
        )
        or receipt_worker.get("socket_mode") != "0660"
        or type(receipt_worker.get("socket_device")) is not int
        or receipt_worker["socket_device"] <= 0
        or type(receipt_worker.get("socket_inode")) is not int
        or receipt_worker["socket_inode"] <= 0
        or receipt_worker.get("ready") is not True
        or receipt_browser.get("socket_mode") != "0660"
        or type(receipt_browser.get("socket_device")) is not int
        or receipt_browser["socket_device"] <= 0
        or type(receipt_browser.get("socket_inode")) is not int
        or receipt_browser["socket_inode"] <= 0
        or receipt_browser.get("ready") is not True
    ):
        raise ArtifactError("artifact_prerequisite_invalid")
    try:
        boot_id = Path(contract["boot_id_path"]).read_bytes()
    except OSError as exc:
        raise ArtifactError("artifact_prerequisite_boot_unavailable") from exc
    if (
        not 0 < len(boot_id) <= 256
        or hashlib.sha256(boot_id.strip()).hexdigest()
        != receipt["boot_id_sha256"]
    ):
        raise ArtifactError("artifact_prerequisite_boot_drifted")


def _validate_request(value: Mapping[str, Any]) -> tuple[str, dict[str, Any], Mapping[str, Any] | None]:
    if value.get("schema") == INITIAL_OBSERVATION_REQUEST_SCHEMA:
        initial = _initial_observation_request(value)
        return "observe_initial", initial, None
    fields = {
        "schema", "action", "plan", "apply_receipt", "secret_material_recorded",
        "request_sha256",
    }
    raw = _hashed(value, fields, "request_sha256", "artifact_request_invalid")
    action = raw["action"]
    if (
        raw["schema"] != REQUEST_SCHEMA
        or not isinstance(action, str)
        or action not in ALLOWED_ACTIONS
        or action not in ACTION_ARTIFACT
        or raw["secret_material_recorded"] is not False
        or not isinstance(raw["plan"], Mapping)
    ):
        raise ArtifactError("artifact_request_invalid")
    plan = dict(raw["plan"])
    _plan_digest(plan)
    if plan.get("schema") == "muncho-production-legacy-cutover-plan.v2":
        _host_manifest(plan)
    _binding(plan, action)
    apply_receipt = raw["apply_receipt"]
    if action not in {"database_rollback", "host_rollback"} and apply_receipt is not None:
        raise ArtifactError("artifact_request_invalid")
    if apply_receipt is not None and not isinstance(apply_receipt, Mapping):
        raise ArtifactError("artifact_request_invalid")
    if action != "observe_final_tail":
        _final_snapshot(plan)
    if action in FORWARD_ACTIONS:
        _assert_current_capability_prerequisite(plan)
    return action, plan, apply_receipt


def _require_runtime() -> None:
    if not sys.platform.startswith("linux") or not hasattr(os, "geteuid") or os.geteuid() != 0:
        raise ArtifactError("artifact_runtime_identity_invalid")
    expected = {"LC_ALL": "C.UTF-8", "PATH": "/usr/bin:/bin", "PYTHONNOUSERSITE": "1"}
    if dict(os.environ) != expected:
        raise ArtifactError("artifact_environment_not_sealed")


def _sql_literal(value: Any) -> str:
    if not isinstance(value, str) or not value or len(value.encode("utf-8")) > 4096:
        raise ArtifactError("artifact_sql_value_invalid")
    if "\x00" in value or any(ord(char) < 32 for char in value):
        raise ArtifactError("artifact_sql_value_invalid")
    return "'" + value.replace("'", "''") + "'"


def _pgpass_user(target: Mapping[str, Any]) -> str:
    payload = bytearray(
        _read_exact_file(
            PGPASS_PATH,
            allowed_modes={0o400},
            owners={0},
            maximum=4096,
        )
    )
    try:
        if payload.endswith(b"\n"):
            del payload[-1]
        if not payload or b"\n" in payload or b"\r" in payload:
            raise ArtifactError("artifact_pgpass_identity_invalid")
        fields: list[bytearray] = []
        current = bytearray()
        escaped = False
        index = 0
        while index < len(payload) and len(fields) < 4:
            byte = payload[index]
            if escaped:
                current.append(byte)
                escaped = False
            elif byte == 0x5C:
                escaped = True
            elif byte == 0x3A:
                fields.append(current)
                current = bytearray()
            else:
                current.append(byte)
            index += 1
        if escaped or len(fields) != 4 or index >= len(payload):
            raise ArtifactError("artifact_pgpass_identity_invalid")
        host, port, database, user = (
            bytes(field).decode("utf-8", errors="strict") for field in fields
        )
        if (
            host != target["tls_server_name"]
            or port != str(target["port"])
            or database != target["database"]
            or ROLE.fullmatch(user) is None
            or not payload[index:]
        ):
            raise ArtifactError("artifact_pgpass_identity_invalid")
        return user
    except UnicodeError as exc:
        raise ArtifactError("artifact_pgpass_identity_invalid") from exc
    finally:
        payload[:] = b"\x00" * len(payload)


def _postgres_env(plan: Mapping[str, Any], *, database: str | None = None) -> dict[str, str]:
    target = _validate_target(plan["target"])
    source_owner = (
        _pgpass_user(target)
        if plan.get("schema") == INITIAL_OBSERVATION_REQUEST_SCHEMA
        else str(
            (
                _validate_snapshot(plan["initial_snapshot"])
                if "initial_snapshot" in plan
                else _final_snapshot(plan)
            )["source_owner"]
        )
    )
    _read_exact_file(CA_PATH, allowed_modes={0o400, 0o444}, owners={0}, maximum=1024 * 1024)
    return {
        "LC_ALL": "C.UTF-8",
        "PATH": "/usr/bin:/bin",
        "HOME": "/",
        "PGAPPNAME": "muncho-production-cutover-artifact",
        "PGCHANNELBINDING": "require",
        "PGCONNECT_TIMEOUT": "5",
        "PGDATABASE": DATABASE if database is None else database,
        "PGHOST": str(target["tls_server_name"]),
        "PGHOSTADDR": str(target["sql_host"]),
        "PGPASSFILE": str(PGPASS_PATH),
        "PGPORT": str(target["port"]),
        "PGSSLMODE": "verify-full",
        "PGSSLROOTCERT": str(CA_PATH),
        "PGUSER": source_owner,
    }


def _run_psql(plan: Mapping[str, Any], sql: str, *, read_only: bool) -> bytes:
    if not isinstance(sql, str) or not sql or len(sql.encode("utf-8")) > 4 * MAX_FILE:
        raise ArtifactError("artifact_sql_invalid")
    prefix = (
        "SET default_transaction_read_only = on;\n"
        if read_only
        else "SET default_transaction_read_only = off;\n"
    )
    try:
        result = subprocess.run(
            (PSQL, "-X", "-qAt", "--no-password", "--set=ON_ERROR_STOP=1"),
            input=(prefix + sql).encode("utf-8"),
            capture_output=True,
            check=False,
            timeout=840,
            env=_postgres_env(plan),
            cwd="/",
            close_fds=True,
        )
    except (OSError, subprocess.SubprocessError) as exc:
        raise ArtifactError("artifact_database_execution_failed") from exc
    if result.returncode != 0 or result.stderr or len(result.stdout) > MAX_JSON + 1:
        raise ArtifactError("artifact_database_execution_failed")
    return result.stdout.rstrip(b"\n")


def _psql_json(plan: Mapping[str, Any], sql: str, *, read_only: bool = True) -> Mapping[str, Any]:
    payload = _run_psql(plan, sql, read_only=read_only)
    return _strict_json(payload, "artifact_database_observation_invalid")


STATE_SQL = r"""
BEGIN TRANSACTION ISOLATION LEVEL SERIALIZABLE READ ONLY;
SET LOCAL TimeZone = 'UTC';
SET LOCAL DateStyle = 'ISO, YMD';
SET LOCAL lock_timeout = '15s';
SET LOCAL statement_timeout = '2min';
SELECT pg_catalog.pg_advisory_xact_lock_shared(4841739663211427921);
SELECT pg_catalog.jsonb_build_object(
    'public_oid', pg_catalog.to_regclass('public.canonical_event_log')::oid,
    'archive_oid', pg_catalog.to_regclass(
        'canonical_brain_legacy_quarantine.canonical_event_log_legacy_v1'
    )::oid,
    'public_columns', COALESCE((
        SELECT pg_catalog.count(*)::integer FROM pg_catalog.pg_attribute
         WHERE attrelid = pg_catalog.to_regclass('public.canonical_event_log')
           AND attnum > 0 AND NOT attisdropped
    ), 0),
    'archive_columns', COALESCE((
        SELECT pg_catalog.count(*)::integer FROM pg_catalog.pg_attribute
         WHERE attrelid = pg_catalog.to_regclass(
            'canonical_brain_legacy_quarantine.canonical_event_log_legacy_v1'
         ) AND attnum > 0 AND NOT attisdropped
    ), 0),
    'canonical_schema', pg_catalog.to_regnamespace('canonical_brain') IS NOT NULL,
    'writer_contract_ready', pg_catalog.to_regprocedure(
        'canonical_brain.writer_ping(jsonb,jsonb)'
    ) IS NOT NULL
)::text;
COMMIT;
"""


def _database_state(plan: Mapping[str, Any]) -> str:
    raw = _exact(
        _psql_json(plan, STATE_SQL),
        {"public_oid", "archive_oid", "public_columns", "archive_columns", "canonical_schema", "writer_contract_ready"},
        "artifact_database_state_invalid",
    )
    if raw["public_oid"] is not None and raw["archive_oid"] is None and raw["public_columns"] == 19 and raw["archive_columns"] == 0 and raw["canonical_schema"] is False:
        return "legacy"
    if raw["public_oid"] is not None and raw["archive_oid"] is not None and raw["public_columns"] == 14 and raw["archive_columns"] == 19:
        if raw["writer_contract_ready"] is True:
            return "target" if _writer_membership_ready(plan) else "migrated"
        if raw["canonical_schema"] is False:
            return "reconciled"
    raise ArtifactError("artifact_database_state_invalid")


def _observation_sql(relation: str) -> str:
    if relation not in {
        "public.canonical_event_log",
        "canonical_brain_legacy_quarantine.canonical_event_log_legacy_v1",
    }:
        raise ArtifactError("artifact_relation_invalid")
    return rf"""
BEGIN TRANSACTION ISOLATION LEVEL SERIALIZABLE READ ONLY;
SET LOCAL TimeZone = 'UTC';
SET LOCAL DateStyle = 'ISO, YMD';
SET LOCAL lock_timeout = '15s';
SET LOCAL statement_timeout = '5min';
SELECT pg_catalog.pg_advisory_xact_lock_shared(4841739663211427921);
LOCK TABLE {relation} IN ACCESS SHARE MODE;
WITH row_receipts AS (
    SELECT event.event_id,
           pg_catalog.encode(pg_catalog.sha256(pg_catalog.convert_to(
               pg_catalog.jsonb_build_object(
                   'event_id', pg_catalog.to_jsonb(event)->'event_id',
                   'schema_version', pg_catalog.to_jsonb(event)->'schema_version',
                   'event_type', pg_catalog.to_jsonb(event)->'event_type',
                   'occurred_at', pg_catalog.to_jsonb(event)->'occurred_at',
                   'case_id', pg_catalog.to_jsonb(event)->'case_id',
                   'source', pg_catalog.to_jsonb(event)->'source',
                   'actor', pg_catalog.to_jsonb(event)->'actor',
                   'subject', pg_catalog.to_jsonb(event)->'subject',
                   'evidence', pg_catalog.to_jsonb(event)->'evidence',
                   'decision', pg_catalog.to_jsonb(event)->'decision',
                   'status', pg_catalog.to_jsonb(event)->'status',
                   'next_action', pg_catalog.to_jsonb(event)->'next_action',
                   'safety', pg_catalog.to_jsonb(event)->'safety',
                   'payload', pg_catalog.to_jsonb(event)->'payload'
               )::text, 'UTF8')), 'hex') AS canonical14_row_sha256,
           pg_catalog.encode(pg_catalog.sha256(pg_catalog.convert_to(
               pg_catalog.to_jsonb(event)::text, 'UTF8')), 'hex')
               AS extended19_row_sha256
      FROM {relation} AS event
), content AS (
    SELECT pg_catalog.count(*)::bigint AS source_row_count,
           pg_catalog.encode(pg_catalog.sha256(pg_catalog.convert_to(
               'canonical-writer-legacy-reconcile-v1:canonical14' || E'\\n'
               || COALESCE(pg_catalog.string_agg(
                    event_id::text || ':' || canonical14_row_sha256,
                    E'\\n' ORDER BY event_id), ''), 'UTF8')), 'hex')
               AS canonical14_sha256,
           pg_catalog.encode(pg_catalog.sha256(pg_catalog.convert_to(
               'canonical-writer-legacy-reconcile-v1:extended19' || E'\\n'
               || COALESCE(pg_catalog.string_agg(
                    event_id::text || ':' || extended19_row_sha256,
                    E'\\n' ORDER BY event_id), ''), 'UTF8')), 'hex')
               AS extended19_sha256
      FROM row_receipts
), relation_projection AS (
    SELECT class.oid::text AS relation_oid,
           pg_catalog.pg_get_userbyid(class.relowner) AS source_owner,
           pg_catalog.jsonb_build_object(
             'oid', class.oid::text,
             'owner', pg_catalog.pg_get_userbyid(class.relowner),
             'kind', class.relkind, 'persistence', class.relpersistence,
             'partition', class.relispartition,
             'access_method', access_method.amname,
             'tablespace', class.reltablespace,
             'row_security', class.relrowsecurity,
             'force_row_security', class.relforcerowsecurity,
             'replica_identity', class.relreplident,
             'options', class.reloptions,
             'columns', COALESCE((
                SELECT pg_catalog.jsonb_agg(pg_catalog.jsonb_build_array(
                    attribute.attnum, attribute.attname,
                    pg_catalog.format_type(attribute.atttypid, attribute.atttypmod),
                    attribute.attnotnull, attribute.atthasdef,
                    pg_catalog.pg_get_expr(default_row.adbin, default_row.adrelid),
                    attribute.attidentity, attribute.attgenerated,
                    attribute.attstorage, attribute.attcompression,
                    attribute.attstattarget, attribute.attoptions
                ) ORDER BY attribute.attnum)
                  FROM pg_catalog.pg_attribute AS attribute
                  LEFT JOIN pg_catalog.pg_attrdef AS default_row
                    ON default_row.adrelid = attribute.attrelid
                   AND default_row.adnum = attribute.attnum
                 WHERE attribute.attrelid = class.oid
                   AND attribute.attnum > 0 AND NOT attribute.attisdropped
             ), '[]'::jsonb),
             'constraints', COALESCE((
                SELECT pg_catalog.jsonb_agg(pg_catalog.jsonb_build_array(
                    constraint_row.conname, constraint_row.contype,
                    constraint_row.condeferrable, constraint_row.condeferred,
                    constraint_row.convalidated,
                    pg_catalog.pg_get_constraintdef(constraint_row.oid, true)
                ) ORDER BY constraint_row.conname, constraint_row.oid)
                  FROM pg_catalog.pg_constraint AS constraint_row
                 WHERE constraint_row.conrelid = class.oid
             ), '[]'::jsonb),
             'triggers', COALESCE((
                SELECT pg_catalog.jsonb_agg(pg_catalog.pg_get_triggerdef(trigger_row.oid, true)
                    ORDER BY trigger_row.tgname)
                  FROM pg_catalog.pg_trigger AS trigger_row
                 WHERE trigger_row.tgrelid = class.oid AND NOT trigger_row.tgisinternal
             ), '[]'::jsonb),
             'rules', COALESCE((
                SELECT pg_catalog.jsonb_agg(pg_catalog.pg_get_ruledef(rewrite.oid, true)
                    ORDER BY rewrite.rulename)
                  FROM pg_catalog.pg_rewrite AS rewrite
                 WHERE rewrite.ev_class = class.oid
             ), '[]'::jsonb),
             'policies', COALESCE((
                SELECT pg_catalog.jsonb_agg(pg_catalog.jsonb_build_array(
                    policy.polname, policy.polcmd, policy.polpermissive,
                    policy.polroles, pg_catalog.pg_get_expr(policy.polqual, policy.polrelid),
                    pg_catalog.pg_get_expr(policy.polwithcheck, policy.polrelid)
                ) ORDER BY policy.polname)
                  FROM pg_catalog.pg_policy AS policy
                 WHERE policy.polrelid = class.oid
             ), '[]'::jsonb)
           ) AS identity
      FROM pg_catalog.pg_class AS class
      JOIN pg_catalog.pg_am AS access_method ON access_method.oid = class.relam
     WHERE class.oid = '{relation}'::regclass
), acl_projection AS (
    SELECT pg_catalog.jsonb_build_object(
      'table', COALESCE((
        SELECT pg_catalog.jsonb_agg(pg_catalog.jsonb_build_array(
            acl.grantor, acl.grantee, acl.privilege_type, acl.is_grantable
        ) ORDER BY acl.grantor, acl.grantee, acl.privilege_type, acl.is_grantable)
          FROM pg_catalog.pg_class AS class
          CROSS JOIN LATERAL pg_catalog.aclexplode(
            COALESCE(class.relacl, pg_catalog.acldefault('r', class.relowner))
          ) AS acl WHERE class.oid = '{relation}'::regclass
      ), '[]'::jsonb),
      'columns', COALESCE((
        SELECT pg_catalog.jsonb_agg(pg_catalog.jsonb_build_array(
            attribute.attnum, acl.grantor, acl.grantee,
            acl.privilege_type, acl.is_grantable
        ) ORDER BY attribute.attnum, acl.grantor, acl.grantee,
                   acl.privilege_type, acl.is_grantable)
          FROM pg_catalog.pg_attribute AS attribute
          CROSS JOIN LATERAL pg_catalog.aclexplode(attribute.attacl) AS acl
         WHERE attribute.attrelid = '{relation}'::regclass
           AND attribute.attnum > 0 AND NOT attribute.attisdropped
      ), '[]'::jsonb)
    ) AS identity
), index_projection AS (
    SELECT COALESCE(pg_catalog.jsonb_agg(pg_catalog.jsonb_build_object(
        'name', index_class.relname, 'owner', pg_catalog.pg_get_userbyid(index_class.relowner),
        'access_method', access_method.amname, 'unique', index.indisunique,
        'primary', index.indisprimary, 'exclusion', index.indisexclusion,
        'immediate', index.indimmediate, 'valid', index.indisvalid,
        'ready', index.indisready, 'live', index.indislive,
        'keys', index.indnkeyatts, 'attributes', index.indnatts,
        'expressions', pg_catalog.pg_get_expr(index.indexprs, index.indrelid),
        'predicate', pg_catalog.pg_get_expr(index.indpred, index.indrelid),
        'key_definitions', (SELECT pg_catalog.jsonb_agg(
            pg_catalog.pg_get_indexdef(index.indexrelid, key_number, true)
            ORDER BY key_number
        ) FROM pg_catalog.generate_series(1, index.indnatts) AS key_number)
    ) ORDER BY index_class.relname, index.indexrelid), '[]'::jsonb) AS identity
      FROM pg_catalog.pg_index AS index
      JOIN pg_catalog.pg_class AS index_class ON index_class.oid = index.indexrelid
      JOIN pg_catalog.pg_am AS access_method ON access_method.oid = index_class.relam
     WHERE index.indrelid = '{relation}'::regclass
), cutoffs AS (
    SELECT max(occurred_at) AS occurred_at_cutoff,
           max(inserted_at) AS inserted_at_cutoff FROM {relation}
)
SELECT pg_catalog.jsonb_build_object(
    'source_owner', relation_projection.source_owner,
    'relation_oid', relation_projection.relation_oid,
    'source_row_count', content.source_row_count,
    'canonical14_sha256', content.canonical14_sha256,
    'extended19_sha256', content.extended19_sha256,
    'occurred_at_cutoff', cutoffs.occurred_at_cutoff,
    'inserted_at_cutoff', cutoffs.inserted_at_cutoff,
    'relation_identity_sha256', pg_catalog.encode(pg_catalog.sha256(
        pg_catalog.convert_to(relation_projection.identity::text, 'UTF8')), 'hex'),
    'acl_identity_sha256', pg_catalog.encode(pg_catalog.sha256(
        pg_catalog.convert_to(acl_projection.identity::text, 'UTF8')), 'hex'),
    'index_identity_sha256', pg_catalog.encode(pg_catalog.sha256(
        pg_catalog.convert_to(index_projection.identity::text, 'UTF8')), 'hex'),
    'observed_at_unix', pg_catalog.floor(pg_catalog.extract(
        epoch FROM pg_catalog.clock_timestamp()))::bigint
)::text
FROM content CROSS JOIN relation_projection CROSS JOIN acl_projection
CROSS JOIN index_projection CROSS JOIN cutoffs;
COMMIT;
"""


OBSERVATION_FIELDS = {
    "source_owner", "relation_oid", "source_row_count", "canonical14_sha256",
    "extended19_sha256", "occurred_at_cutoff", "inserted_at_cutoff",
    "relation_identity_sha256", "acl_identity_sha256", "index_identity_sha256",
    "observed_at_unix",
}


def _legacy_observation(plan: Mapping[str, Any], *, archived: bool) -> dict[str, Any]:
    relation = (
        "canonical_brain_legacy_quarantine.canonical_event_log_legacy_v1"
        if archived else "public.canonical_event_log"
    )
    raw = _exact(
        _psql_json(plan, _observation_sql(relation)),
        OBSERVATION_FIELDS,
        "artifact_legacy_observation_invalid",
    )
    if (
        ROLE.fullmatch(str(raw["source_owner"])) is None
        or re.fullmatch(r"[1-9][0-9]*", str(raw["relation_oid"])) is None
        or type(raw["source_row_count"]) is not int
        or raw["source_row_count"] <= 0
        or type(raw["observed_at_unix"]) is not int
        or raw["observed_at_unix"] <= 0
    ):
        raise ArtifactError("artifact_legacy_observation_invalid")
    for field in (
        "canonical14_sha256", "extended19_sha256", "relation_identity_sha256",
        "acl_identity_sha256", "index_identity_sha256",
    ):
        if SHA256.fullmatch(str(raw[field])) is None:
            raise ArtifactError("artifact_legacy_observation_invalid")
    return raw


def _snapshot_from_observation(observed: Mapping[str, Any]) -> dict[str, Any]:
    unsigned = {
        "schema": SNAPSHOT_SCHEMA,
        "database": DATABASE,
        "shape": "legacy19",
        **dict(observed),
    }
    return _validate_snapshot({**unsigned, "snapshot_sha256": _sha_json(unsigned)})


def _same_frozen_snapshot(expected: Mapping[str, Any], observed: Mapping[str, Any]) -> bool:
    projected = {
        "database": DATABASE,
        "shape": "legacy19",
        **{key: item for key, item in observed.items() if key != "observed_at_unix"},
    }
    return projected == {
        key: item for key, item in expected.items()
        if key not in {"schema", "observed_at_unix", "snapshot_sha256"}
    }


def _observe(plan: Mapping[str, Any], *, before_apply: bool) -> Mapping[str, Any]:
    if _database_state(plan) != "legacy":
        raise ArtifactError("artifact_legacy_state_required")
    observed = _legacy_observation(plan, archived=False)
    expected = (
        _validate_snapshot(plan["initial_snapshot"])
        if not before_apply else _final_snapshot(plan)
    )
    if observed["source_owner"] != expected["source_owner"]:
        raise ArtifactError("artifact_source_owner_changed")
    snapshot = _snapshot_from_observation(observed)
    if before_apply and not _same_frozen_snapshot(expected, observed):
        raise ArtifactError("artifact_final_tail_changed")
    return snapshot


def _observe_initial(request: Mapping[str, Any]) -> Mapping[str, Any]:
    if request.get("schema") != INITIAL_OBSERVATION_REQUEST_SCHEMA:
        raise ArtifactError("artifact_initial_request_invalid")
    if _database_state(request) != "legacy":
        raise ArtifactError("artifact_legacy_state_required")
    observed = _legacy_observation(request, archived=False)
    if observed["source_owner"] != _pgpass_user(
        _validate_target(request["target"])
    ):
        raise ArtifactError("artifact_source_owner_changed")
    return _snapshot_from_observation(observed)


ROLE_PROJECTION_SQL = r"""
BEGIN TRANSACTION ISOLATION LEVEL SERIALIZABLE READ ONLY;
SET LOCAL TimeZone = 'UTC';
SELECT pg_catalog.pg_advisory_xact_lock_shared(4841739663211427921);
WITH roles AS (
  SELECT COALESCE(pg_catalog.jsonb_agg(pg_catalog.to_jsonb(role_row)
      ORDER BY role_row.rolname), '[]'::jsonb) AS value
    FROM (SELECT rolname, rolcanlogin, rolinherit, rolsuper, rolcreatedb,
                 rolcreaterole, rolreplication, rolbypassrls, rolconnlimit,
                 rolvaliduntil, rolconfig
            FROM pg_catalog.pg_roles
           WHERE rolname IN ('canonical_brain_migration_owner',
                             'canonical_brain_writer', :'writer_login')) AS role_row
), memberships AS (
  SELECT COALESCE(pg_catalog.jsonb_agg(pg_catalog.jsonb_build_array(
      granted.rolname, member.rolname, membership.admin_option,
      membership.inherit_option, membership.set_option
  ) ORDER BY granted.rolname, member.rolname), '[]'::jsonb) AS value
    FROM pg_catalog.pg_auth_members AS membership
    JOIN pg_catalog.pg_roles AS granted ON granted.oid = membership.roleid
    JOIN pg_catalog.pg_roles AS member ON member.oid = membership.member
   WHERE granted.rolname IN ('canonical_brain_migration_owner', 'canonical_brain_writer')
      OR member.rolname IN ('canonical_brain_migration_owner', 'canonical_brain_writer', :'writer_login')
), acl AS (
  SELECT COALESCE(pg_catalog.jsonb_agg(pg_catalog.jsonb_build_array(
      namespace.nspname, class.relname, acl.grantor, acl.grantee,
      acl.privilege_type, acl.is_grantable
  ) ORDER BY namespace.nspname, class.relname, acl.grantor, acl.grantee,
             acl.privilege_type, acl.is_grantable), '[]'::jsonb) AS value
    FROM pg_catalog.pg_class AS class
    JOIN pg_catalog.pg_namespace AS namespace ON namespace.oid = class.relnamespace
    CROSS JOIN LATERAL pg_catalog.aclexplode(class.relacl) AS acl
   WHERE namespace.nspname IN ('public', 'canonical_brain',
                               'canonical_brain_legacy_quarantine')
)
SELECT pg_catalog.jsonb_build_object(
  'roles_acl_sha256', pg_catalog.encode(pg_catalog.sha256(pg_catalog.convert_to(
      pg_catalog.jsonb_build_object('roles', roles.value,
                                    'memberships', memberships.value,
                                    'acl', acl.value)::text, 'UTF8')), 'hex')
)::text FROM roles CROSS JOIN memberships CROSS JOIN acl;
COMMIT;
"""


def _writer_membership_ready(plan: Mapping[str, Any]) -> bool:
    login = str(_validate_target(plan["target"])["writer_login"])
    sql = f"""
BEGIN TRANSACTION ISOLATION LEVEL SERIALIZABLE READ ONLY;
SELECT pg_catalog.pg_advisory_xact_lock_shared(4841739663211427921);
SELECT pg_catalog.jsonb_build_object('ready', (
  SELECT pg_catalog.count(*) = 1
    FROM pg_catalog.pg_auth_members AS membership
    JOIN pg_catalog.pg_roles AS granted ON granted.oid = membership.roleid
    JOIN pg_catalog.pg_roles AS member ON member.oid = membership.member
   WHERE granted.rolname = 'canonical_brain_writer'
     AND member.rolname = {_sql_literal(login)}
     AND NOT membership.admin_option AND membership.inherit_option
     AND NOT membership.set_option
))::text;
COMMIT;
"""
    raw = _exact(
        _psql_json(plan, sql),
        {"ready"},
        "artifact_writer_membership_observation_invalid",
    )
    if type(raw["ready"]) is not bool:
        raise ArtifactError("artifact_writer_membership_observation_invalid")
    return raw["ready"]


def _role_projection(plan: Mapping[str, Any]) -> str:
    login = str(_validate_target(plan["target"])["writer_login"])
    sql = ROLE_PROJECTION_SQL.replace(":'writer_login'", _sql_literal(login))
    raw = _exact(_psql_json(plan, sql), {"roles_acl_sha256"}, "artifact_role_projection_invalid")
    digest = raw["roles_acl_sha256"]
    if not isinstance(digest, str) or SHA256.fullmatch(digest) is None:
        raise ArtifactError("artifact_role_projection_invalid")
    return digest


CANONICAL_CONTENT_SQL = r"""
WITH row_receipts AS (
  SELECT event.event_id,
         pg_catalog.encode(pg_catalog.sha256(pg_catalog.convert_to(
           pg_catalog.to_jsonb(event)::text, 'UTF8')), 'hex') AS row_sha
    FROM public.canonical_event_log AS event
    JOIN canonical_brain_legacy_quarantine.canonical_event_log_legacy_v1
      AS legacy USING (event_id)
), content AS (
  SELECT pg_catalog.count(*)::bigint AS legacy_row_count,
         pg_catalog.encode(pg_catalog.sha256(pg_catalog.convert_to(
           'canonical-writer-legacy-reconcile-v1:canonical14' || E'\n'
           || COALESCE(pg_catalog.string_agg(event_id::text || ':' || row_sha,
              E'\n' ORDER BY event_id), ''), 'UTF8')), 'hex') AS canonical14_sha256
    FROM row_receipts
)
SELECT pg_catalog.jsonb_build_object(
  'canonical_row_count', (
    SELECT pg_catalog.count(*)::bigint FROM public.canonical_event_log
  ),
  'legacy_row_count', legacy_row_count,
  'canonical14_sha256', canonical14_sha256
)::text FROM content;
"""


def _privileged_projection_sql(plan: Mapping[str, Any], query: str) -> str:
    """Run an exact read through a transaction-scoped SET-only owner bridge."""

    if not isinstance(query, str) or not query.strip():
        raise ArtifactError("artifact_database_observation_invalid")
    owner = str(_final_snapshot(plan)["source_owner"])
    return f"""
BEGIN TRANSACTION ISOLATION LEVEL SERIALIZABLE;
SET LOCAL TimeZone = 'UTC';
SET LOCAL lock_timeout = '15s';
SET LOCAL statement_timeout = '5min';
SELECT pg_catalog.pg_advisory_xact_lock_shared(4841739663211427921);
DO $projection_authority$
BEGIN
  IF SESSION_USER <> {_sql_literal(owner)} OR CURRENT_USER <> SESSION_USER
     OR pg_catalog.current_database() <> {_sql_literal(DATABASE)} THEN
    RAISE EXCEPTION 'canonical projection authority is invalid';
  END IF;
  EXECUTE pg_catalog.format(
    'GRANT canonical_brain_migration_owner TO %I '
    'WITH ADMIN FALSE, INHERIT FALSE, SET TRUE', SESSION_USER
  );
END
$projection_authority$;
GRANT USAGE ON SCHEMA canonical_brain_legacy_quarantine
  TO canonical_brain_migration_owner;
GRANT SELECT ON TABLE
  canonical_brain_legacy_quarantine.canonical_event_log_legacy_v1
  TO canonical_brain_migration_owner;
SET LOCAL ROLE canonical_brain_migration_owner;
LOCK TABLE canonical_brain_legacy_quarantine.canonical_event_log_legacy_v1,
           public.canonical_event_log IN ACCESS SHARE MODE;
{query}
RESET ROLE;
REVOKE SELECT ON TABLE
  canonical_brain_legacy_quarantine.canonical_event_log_legacy_v1
  FROM canonical_brain_migration_owner;
REVOKE USAGE ON SCHEMA canonical_brain_legacy_quarantine
  FROM canonical_brain_migration_owner;
DO $projection_authority_retired$
BEGIN
  EXECUTE pg_catalog.format(
    'REVOKE canonical_brain_migration_owner FROM %I', SESSION_USER
  );
  IF EXISTS (
    SELECT 1 FROM pg_catalog.pg_auth_members AS membership
    JOIN pg_catalog.pg_roles AS granted ON granted.oid = membership.roleid
    JOIN pg_catalog.pg_roles AS member ON member.oid = membership.member
    WHERE granted.rolname = 'canonical_brain_migration_owner'
      AND member.rolname = SESSION_USER
  ) OR pg_catalog.has_schema_privilege(
    'canonical_brain_migration_owner',
    'canonical_brain_legacy_quarantine', 'USAGE'
  ) OR pg_catalog.has_table_privilege(
    'canonical_brain_migration_owner',
    'canonical_brain_legacy_quarantine.canonical_event_log_legacy_v1',
    'SELECT'
  ) THEN
    RAISE EXCEPTION 'canonical projection authority survived';
  END IF;
END
$projection_authority_retired$;
COMMIT;
"""


def _legacy_truth_projection_sql(plan: Mapping[str, Any]) -> str:
    decision = _legacy_truth_decision_for_plan(plan)
    accepted = list(decision["accepted_event_receipts"])
    accepted_values = ",\n".join(
        "(" + _sql_literal(item["event_id"]) + "::uuid,"
        + _sql_literal(item["canonical14_row_sha256"]) + ")"
        for item in accepted
    )
    accepted_cte = (
        "VALUES\n" + accepted_values
        if accepted_values
        else "SELECT NULL::uuid, NULL::text WHERE false"
    )
    event_type = (
        "legacy.truth.reseeded"
        if decision["mode"] == "reseed_accepted_events"
        else "truth.epoch.started"
    )
    return f"""WITH accepted(event_id, row_sha256) AS ({accepted_cte})
SELECT pg_catalog.jsonb_build_object(
  'decision_event_count', (
    SELECT pg_catalog.count(*) FROM public.canonical_event_log AS event
    JOIN canonical_brain.writer_event_provenance AS provenance USING (event_id)
    WHERE event.event_id = {_sql_literal(decision['decision_event_id'])}::uuid
      AND event.event_type = {_sql_literal(event_type)}
      AND event.payload->>'cutover_plan_sha256' = {_sql_literal(plan['plan_sha256'])}
      AND event.payload->>'legacy_truth_decision_sha256'
          = {_sql_literal(decision['decision_sha256'])}
      AND provenance.canonical_content_sha256
          = {_sql_literal(decision['decision_sha256'])}
      AND provenance.origin = 'owner_approved_legacy_truth_decision'
  ),
  'trusted_legacy_event_count', (
    SELECT pg_catalog.count(*) FROM accepted
    JOIN canonical_brain.writer_event_provenance AS provenance USING (event_id)
    WHERE provenance.canonical_content_sha256 = accepted.row_sha256
      AND provenance.origin = 'owner_approved_legacy_reseed'
  ),
  'unexpected_provenance_count', (
    SELECT pg_catalog.count(*)
      FROM canonical_brain.writer_event_provenance AS provenance
     WHERE provenance.event_id
           <> {_sql_literal(decision['decision_event_id'])}::uuid
       AND NOT EXISTS (
         SELECT 1 FROM accepted WHERE accepted.event_id = provenance.event_id
       )
  )
)::text;
"""


def _database_projection(plan: Mapping[str, Any], *, legacy: bool) -> Mapping[str, Any]:
    expected = _final_snapshot(plan)
    observed = _legacy_observation(plan, archived=not legacy)
    if not _same_frozen_snapshot(expected, observed):
        raise ArtifactError("artifact_final_tail_changed")
    canonical_count = 0
    canonical_hash = observed["canonical14_sha256"]
    trusted_legacy_event_count = 0
    zero_writes = True
    if not legacy:
        content = _exact(
            _psql_json(
                plan,
                _privileged_projection_sql(plan, CANONICAL_CONTENT_SQL),
                read_only=False,
            ),
            {"canonical_row_count", "legacy_row_count", "canonical14_sha256"},
            "artifact_canonical_content_invalid",
        )
        canonical_count = content["canonical_row_count"]
        canonical_hash = content["canonical14_sha256"]
        state = _database_state(plan)
        decision_state = state in {"migrated", "target"}
        if decision_state:
            truth = _exact(
                _psql_json(
                    plan,
                    _privileged_projection_sql(
                        plan,
                        _legacy_truth_projection_sql(plan),
                    ),
                    read_only=False,
                ),
                {
                    "decision_event_count",
                    "trusted_legacy_event_count",
                    "unexpected_provenance_count",
                },
                "artifact_writer_write_observation_invalid",
            )
            trusted_legacy_event_count = truth["trusted_legacy_event_count"]
            zero_writes = truth["unexpected_provenance_count"] == 0
            decision = _legacy_truth_decision_for_plan(plan)
            if (
                truth["decision_event_count"] != 1
                or trusted_legacy_event_count
                != len(decision["accepted_event_ids"])
            ):
                raise ArtifactError("artifact_legacy_truth_decision_unverified")
        if (
            canonical_count
            != expected["source_row_count"] + (1 if decision_state else 0)
            or content["legacy_row_count"] != expected["source_row_count"]
            or canonical_hash != expected["canonical14_sha256"]
        ):
            raise ArtifactError("artifact_canonical_content_changed")
    if not zero_writes:
        raise ArtifactError("artifact_writer_writes_present")
    return {
        "source_row_count": expected["source_row_count"],
        "archive_row_count": observed["source_row_count"],
        "canonical_row_count": canonical_count,
        "archive_extended19_sha256": observed["extended19_sha256"],
        "canonical14_sha256": canonical_hash,
        "relation_identity_sha256": observed["relation_identity_sha256"],
        "acl_identity_sha256": observed["acl_identity_sha256"],
        "index_identity_sha256": observed["index_identity_sha256"],
        "roles_acl_sha256": _role_projection(plan),
        "zero_canonical_writer_writes": True,
        "trusted_legacy_event_count": trusted_legacy_event_count,
    }


def _receipt(value: Mapping[str, Any]) -> Mapping[str, Any]:
    unsigned = dict(value)
    return {**unsigned, "receipt_sha256": _sha_json(unsigned)}


def _database_receipt(plan: Mapping[str, Any], *, schema: str, artifact_name: str, legacy: bool) -> Mapping[str, Any]:
    projection = _database_projection(plan, legacy=legacy)
    decision = _legacy_truth_decision_for_plan(plan)
    return _receipt({
        "schema": schema,
        "plan_sha256": plan["plan_sha256"],
        "artifact_sha256": plan["artifacts"][artifact_name]["sha256"],
        "final_snapshot_sha256": _final_snapshot(plan)["snapshot_sha256"],
        **projection,
        "legacy_truth_mode": decision["mode"],
        "legacy_truth_decision_sha256": decision["decision_sha256"],
        "legacy_truth_decision_event_id": decision["decision_event_id"],
        "accepted_event_set_sha256": _accepted_event_set_sha256(decision),
        "truth_epoch_sha256": decision["truth_epoch_sha256"],
        "legacy_shape_restored": legacy,
        "ok": True,
        "secret_material_recorded": False,
    })


def _probe_hba(plan: Mapping[str, Any]) -> str:
    target = _validate_target(plan["target"])
    source_owner = str(_final_snapshot(plan)["source_owner"])
    _read_exact_file(CA_PATH, allowed_modes={0o400, 0o444}, owners={0}, maximum=1024 * 1024)
    _read_exact_file(PGPASS_PATH, allowed_modes={0o400}, owners={0}, maximum=4096)
    context = ssl.create_default_context(cafile=str(CA_PATH))
    context.minimum_version = ssl.TLSVersion.TLSv1_2
    raw: socket.socket | None = None
    protected: ssl.SSLSocket | None = None
    try:
        raw = socket.create_connection((str(target["sql_host"]), int(target["port"])), timeout=5.0)
        raw.sendall(struct.pack("!II", 8, 80877103))
        if raw.recv(1) != b"S":
            raise ArtifactError("artifact_hba_probe_tls_refused")
        protected = context.wrap_socket(raw, server_hostname=str(target["tls_server_name"]))
        raw = None
        startup = {
            "user": source_owner,
            "database": "cloudsqladmin",
            "application_name": "muncho-production-cutover-hba-probe",
            "client_encoding": "UTF8",
        }
        body = struct.pack("!I", 196608) + b"".join(
            key.encode("ascii") + b"\x00" + value.encode("utf-8") + b"\x00"
            for key, value in startup.items()
        ) + b"\x00"
        protected.sendall(struct.pack("!I", len(body) + 4) + body)
        protected.settimeout(5.0)
        kind = protected.recv(1)
        if kind != b"E":
            raise ArtifactError("artifact_hba_probe_not_rejected")
        length_raw = protected.recv(4)
        if len(length_raw) != 4:
            raise ArtifactError("artifact_hba_probe_invalid")
        length = struct.unpack("!I", length_raw)[0]
        if not 5 <= length <= 8192:
            raise ArtifactError("artifact_hba_probe_invalid")
        payload = b""
        while len(payload) < length - 4:
            chunk = protected.recv(length - 4 - len(payload))
            if not chunk:
                raise ArtifactError("artifact_hba_probe_invalid")
            payload += chunk
        fields: dict[str, str] = {}
        for item in payload[:-1].split(b"\x00"):
            if len(item) < 2:
                continue
            fields[item[:1].decode("ascii")] = item[1:].decode("utf-8", errors="strict")
        message = fields.get("M", "")
        suffix = f'\", user \"{source_owner}\", database \"cloudsqladmin\", SSL encryption'
        prefixes = ('no pg_hba.conf entry for host \"', 'pg_hba.conf rejects connection for host \"')
        prefix = next((item for item in prefixes if message.startswith(item)), None)
        if fields.get("C") != "28000" or prefix is None or not message.endswith(suffix):
            raise ArtifactError("artifact_hba_probe_rejection_invalid")
        remote = message[len(prefix):-len(suffix)]
        ipaddress.ip_address(remote)
        peer = protected.getpeercert(binary_form=True)
        if not peer:
            raise ArtifactError("artifact_hba_probe_invalid")
        unsigned = {
            "schema": "muncho-production-cloudsqladmin-hba-rejection.v1",
            "host": target["sql_host"],
            "tls_server_name": target["tls_server_name"],
            "port": target["port"],
            "server_certificate_sha256": hashlib.sha256(peer).hexdigest(),
            "database": "cloudsqladmin",
            "user": source_owner,
            "sqlstate": "28000",
            "result": "pg_hba_rejected",
            "tls_peer_verified": True,
        }
        return _sha_json(unsigned)
    except (OSError, ssl.SSLError, UnicodeError, ValueError) as exc:
        raise ArtifactError("artifact_hba_probe_failed") from exc
    finally:
        if protected is not None:
            try:
                protected.close()
            except OSError:
                pass
        if raw is not None:
            try:
                raw.close()
            except OSError:
                pass


def _settings(values: Mapping[str, str]) -> str:
    if not values or any(re.fullmatch(r"muncho\.[a-z0-9_.]+", key) is None for key in values):
        raise ArtifactError("artifact_setting_invalid")
    return "\n".join(f"SET {key} = {_sql_literal(value)};" for key, value in sorted(values.items())) + "\n"


def _membership_sql(plan: Mapping[str, Any]) -> str:
    login = str(_validate_target(plan["target"])["writer_login"])
    owner = str(_final_snapshot(plan)["source_owner"])
    return f"""
BEGIN TRANSACTION ISOLATION LEVEL SERIALIZABLE;
SET LOCAL lock_timeout = '15s';
SET LOCAL statement_timeout = '2min';
SELECT pg_catalog.pg_advisory_xact_lock(4841739663211427921);
DO $membership$
BEGIN
  IF pg_catalog.current_database() <> {_sql_literal(DATABASE)}
     OR SESSION_USER <> {_sql_literal(owner)} OR CURRENT_USER <> SESSION_USER
     OR pg_catalog.to_regprocedure('canonical_brain.writer_ping(jsonb,jsonb)') IS NULL
     OR NOT EXISTS (SELECT 1 FROM pg_catalog.pg_roles WHERE rolname = {_sql_literal(login)}
         AND rolcanlogin AND rolinherit AND NOT rolsuper AND NOT rolcreatedb
         AND NOT rolcreaterole AND NOT rolreplication AND NOT rolbypassrls)
     OR EXISTS (SELECT 1 FROM pg_catalog.pg_auth_members AS membership
          JOIN pg_catalog.pg_roles AS member ON member.oid = membership.member
         WHERE member.rolname = {_sql_literal(login)}
           AND NOT EXISTS (SELECT 1 FROM pg_catalog.pg_roles AS granted
             WHERE granted.oid = membership.roleid
               AND granted.rolname = 'canonical_brain_writer')) THEN
    RAISE EXCEPTION 'production writer membership prerequisite drifted';
  END IF;
  EXECUTE pg_catalog.format(
    'GRANT canonical_brain_writer TO %I WITH ADMIN FALSE, INHERIT TRUE, SET FALSE',
    {_sql_literal(login)}
  );
  IF (SELECT pg_catalog.count(*) FROM pg_catalog.pg_auth_members AS membership
       JOIN pg_catalog.pg_roles AS granted ON granted.oid = membership.roleid
       JOIN pg_catalog.pg_roles AS member ON member.oid = membership.member
      WHERE granted.rolname = 'canonical_brain_writer'
        AND member.rolname = {_sql_literal(login)}
        AND NOT membership.admin_option AND membership.inherit_option
        AND NOT membership.set_option) <> 1 THEN
    RAISE EXCEPTION 'production writer membership did not become exact';
  END IF;
END
$membership$;
COMMIT;
"""


def _legacy_truth_decision_sql(plan: Mapping[str, Any]) -> str:
    """Build the exact owner-bound reseed/new-epoch transaction.

    This code never selects events by type, text, case meaning, or keywords.
    The only legacy rows promoted into operational reads are the UUIDs and row
    receipts explicitly present in the signed decision manifest.
    """

    decision = _legacy_truth_decision_for_plan(plan)
    owner = str(_final_snapshot(plan)["source_owner"])
    accepted = list(decision["accepted_event_receipts"])
    values = ",\n".join(
        "(" + _sql_literal(item["event_id"]) + "::uuid,"
        + _sql_literal(item["canonical14_row_sha256"]) + ")"
        for item in accepted
    )
    accepted_insert = (
        "INSERT INTO pg_temp._cw_accepted_legacy_event "
        "(event_id, canonical14_row_sha256) VALUES\n" + values + ";"
        if values
        else ""
    )
    decision_type = (
        "legacy.truth.reseeded"
        if decision["mode"] == "reseed_accepted_events"
        else "truth.epoch.started"
    )
    decision_case_id = "case:legacy-truth:" + decision["decision_sha256"][:32]
    accepted_set_sha256 = _accepted_event_set_sha256(decision)
    source_doc = {
        "system": "owner_approved_cutover",
        "component": "legacy_truth_decision",
        "cutover_plan_sha256": plan["plan_sha256"],
    }
    actor_doc = {
        "type": "authenticated_owner",
        "id_sha256": decision["owner_subject_sha256"],
    }
    subject_doc = {
        "type": "canonical_truth_epoch",
        "id": decision["truth_epoch_id"] or decision["decision_id"],
    }
    evidence_doc = {
        "reviewed_snapshot_sha256": decision["reviewed_snapshot_sha256"],
        "reseed_manifest_sha256": decision["reseed_manifest_sha256"],
        "accepted_event_set_sha256": accepted_set_sha256,
        "accepted_event_count": len(accepted),
        "truth_epoch_sha256": decision["truth_epoch_sha256"],
    }
    decision_doc = {
        "kind": "owner_approved_legacy_truth_decision",
        "mode": decision["mode"],
        "decision_id": decision["decision_id"],
        "decision_sha256": decision["decision_sha256"],
    }
    status_doc = {
        "state": (
            "accepted_legacy_events_reseeded"
            if accepted
            else "new_truth_epoch_started"
        )
    }
    next_action_doc: dict[str, Any] = {}
    safety_doc = {
        "secret_value_recorded": False,
        "payment_credential_recorded": False,
        "business_mutation": False,
        "outbound": False,
    }
    payload_doc = {
        "cutover_plan_sha256": plan["plan_sha256"],
        "legacy_truth_decision_sha256": decision["decision_sha256"],
        "accepted_event_set_sha256": accepted_set_sha256,
        "reseed_manifest_sha256": decision["reseed_manifest_sha256"],
        "truth_epoch_id": decision["truth_epoch_id"],
        "truth_epoch_sha256": decision["truth_epoch_sha256"],
        "canonical_content_sha256": decision["decision_sha256"],
    }
    decision_runtime = {
        "service_internal": True,
        "legacy_truth_decision_sha256": decision["decision_sha256"],
        "cutover_plan_sha256": plan["plan_sha256"],
    }

    literals = {
        "decision_event_id": _sql_literal(decision["decision_event_id"]),
        "decision_event_type": _sql_literal(decision_type),
        "decision_case_id": _sql_literal(decision_case_id),
        "decision_sha256": _sql_literal(decision["decision_sha256"]),
        "manifest_sha256": _sql_literal(
            decision["reseed_manifest_sha256"] or "none"
        ),
        "owner_subject_sha256": _sql_literal(decision["owner_subject_sha256"]),
        "plan_sha256": _sql_literal(plan["plan_sha256"]),
        "source": _sql_literal(json.dumps(source_doc, sort_keys=True, separators=(",", ":"))),
        "actor": _sql_literal(json.dumps(actor_doc, sort_keys=True, separators=(",", ":"))),
        "subject": _sql_literal(json.dumps(subject_doc, sort_keys=True, separators=(",", ":"))),
        "evidence": _sql_literal(json.dumps(evidence_doc, sort_keys=True, separators=(",", ":"))),
        "decision": _sql_literal(json.dumps(decision_doc, sort_keys=True, separators=(",", ":"))),
        "status": _sql_literal(json.dumps(status_doc, sort_keys=True, separators=(",", ":"))),
        "next_action": _sql_literal(json.dumps(next_action_doc, sort_keys=True, separators=(",", ":"))),
        "safety": _sql_literal(json.dumps(safety_doc, sort_keys=True, separators=(",", ":"))),
        "payload": _sql_literal(json.dumps(payload_doc, sort_keys=True, separators=(",", ":"))),
        "decision_runtime": _sql_literal(json.dumps(decision_runtime, sort_keys=True, separators=(",", ":"))),
    }
    routing_runtime = f"""
pg_catalog.jsonb_strip_nulls(pg_catalog.jsonb_build_object(
  'platform', NULLIF(COALESCE(
      event.source#>>'{{observed_session,platform}}',
      event.source#>>'{{source_refs,platform}}', ''), ''),
  'thread_id', NULLIF(COALESCE(
      event.source#>>'{{observed_session,thread_id}}',
      event.source#>>'{{source_refs,thread_id}}', ''), ''),
  'chat_id', NULLIF(COALESCE(
      event.source#>>'{{observed_session,chat_id}}',
      event.source#>>'{{source_refs,chat_id}}', ''), ''),
  'session_key_sha256', CASE
      WHEN COALESCE(event.source#>>'{{observed_session,session_key_sha256}}','')
           ~ '^[0-9a-f]{{64}}$'
        THEN event.source#>>'{{observed_session,session_key_sha256}}'
      WHEN COALESCE(event.source#>>'{{source_refs,session_key_sha256}}','')
           ~ '^[0-9a-f]{{64}}$'
        THEN event.source#>>'{{source_refs,session_key_sha256}}'
      WHEN COALESCE(event.source#>>'{{source_refs,session_key}}','') <> ''
        THEN pg_catalog.encode(pg_catalog.sha256(pg_catalog.convert_to(
          event.source#>>'{{source_refs,session_key}}', 'UTF8')), 'hex')
      ELSE NULL END,
  'legacy_truth_decision_sha256', {literals['decision_sha256']},
  'reseed_manifest_sha256', {literals['manifest_sha256']},
  'owner_subject_sha256', {literals['owner_subject_sha256']},
  'cutover_plan_sha256', {literals['plan_sha256']}
))
""".strip()

    return f"""
BEGIN TRANSACTION ISOLATION LEVEL SERIALIZABLE;
SET LOCAL TimeZone = 'UTC';
SET LOCAL lock_timeout = '15s';
SET LOCAL statement_timeout = '5min';
SELECT pg_catalog.pg_advisory_xact_lock(4841739663211427921);
CREATE TEMP TABLE _cw_accepted_legacy_event (
  event_id uuid PRIMARY KEY,
  canonical14_row_sha256 text NOT NULL
    CHECK (canonical14_row_sha256 ~ '^[0-9a-f]{{64}}$')
) ON COMMIT DROP;
{accepted_insert}
GRANT SELECT ON TABLE pg_temp._cw_accepted_legacy_event
  TO canonical_brain_migration_owner;
DO $legacy_truth_authority$
BEGIN
  IF SESSION_USER <> {_sql_literal(owner)} OR CURRENT_USER <> SESSION_USER
     OR pg_catalog.current_database() <> {_sql_literal(DATABASE)}
     OR pg_catalog.to_regprocedure(
          'canonical_brain.writer_ping(jsonb,jsonb)') IS NULL THEN
    RAISE EXCEPTION 'legacy truth decision authority is invalid';
  END IF;
  EXECUTE pg_catalog.format(
    'GRANT canonical_brain_migration_owner TO %I '
    'WITH ADMIN FALSE, INHERIT FALSE, SET TRUE', SESSION_USER
  );
END
$legacy_truth_authority$;
GRANT USAGE ON SCHEMA canonical_brain_legacy_quarantine
  TO canonical_brain_migration_owner;
GRANT SELECT ON TABLE
  canonical_brain_legacy_quarantine.canonical_event_log_legacy_v1
  TO canonical_brain_migration_owner;
SET LOCAL ROLE canonical_brain_migration_owner;
LOCK TABLE canonical_brain_legacy_quarantine.canonical_event_log_legacy_v1,
           public.canonical_event_log,
           canonical_brain.writer_event_provenance
  IN ACCESS EXCLUSIVE MODE;
DO $legacy_truth_receipts$
DECLARE invalid_count bigint;
BEGIN
  SELECT pg_catalog.count(*) INTO invalid_count
    FROM pg_temp._cw_accepted_legacy_event AS accepted
    LEFT JOIN public.canonical_event_log AS event
      ON event.event_id = accepted.event_id
    LEFT JOIN canonical_brain_legacy_quarantine.canonical_event_log_legacy_v1
      AS legacy ON legacy.event_id = accepted.event_id
   WHERE event.event_id IS NULL OR legacy.event_id IS NULL
      OR pg_catalog.encode(pg_catalog.sha256(pg_catalog.convert_to(
           pg_catalog.to_jsonb(event)::text, 'UTF8')), 'hex')
         <> accepted.canonical14_row_sha256;
  IF invalid_count <> 0 OR (
      SELECT pg_catalog.count(*) FROM pg_temp._cw_accepted_legacy_event
  ) <> {len(accepted)} THEN
    RAISE EXCEPTION 'legacy truth accepted event receipt mismatch';
  END IF;
END
$legacy_truth_receipts$;

INSERT INTO canonical_brain.writer_event_provenance (
  event_id, canonical_content_sha256, origin, trusted_runtime, appended_at
)
SELECT event.event_id, accepted.canonical14_row_sha256,
       'owner_approved_legacy_reseed', {routing_runtime},
       pg_catalog.clock_timestamp()
  FROM public.canonical_event_log AS event
  JOIN pg_temp._cw_accepted_legacy_event AS accepted
    ON accepted.event_id = event.event_id
ON CONFLICT (event_id) DO NOTHING;

INSERT INTO public.canonical_event_log (
  event_id, schema_version, event_type, occurred_at, case_id, source, actor,
  subject, evidence, decision, status, next_action, safety, payload
)
SELECT {literals['decision_event_id']}::uuid, 'canonical_event.v1',
       {literals['decision_event_type']}, pg_catalog.clock_timestamp(),
       {literals['decision_case_id']}, {literals['source']}::jsonb,
       {literals['actor']}::jsonb, {literals['subject']}::jsonb,
       {literals['evidence']}::jsonb, {literals['decision']}::jsonb,
       {literals['status']}::jsonb, {literals['next_action']}::jsonb,
       {literals['safety']}::jsonb, {literals['payload']}::jsonb
 WHERE NOT EXISTS (
   SELECT 1 FROM public.canonical_event_log
    WHERE event_id = {literals['decision_event_id']}::uuid
 );
INSERT INTO canonical_brain.writer_event_provenance (
  event_id, canonical_content_sha256, origin, trusted_runtime, appended_at
)
SELECT event.event_id, {literals['decision_sha256']},
       'owner_approved_legacy_truth_decision',
       {literals['decision_runtime']}::jsonb, event.occurred_at
  FROM public.canonical_event_log AS event
 WHERE event.event_id = {literals['decision_event_id']}::uuid
ON CONFLICT (event_id) DO NOTHING;

DO $legacy_truth_terminal$
DECLARE invalid_count bigint;
BEGIN
  IF (
    SELECT pg_catalog.count(*) FROM public.canonical_event_log AS event
     WHERE event.event_id = {literals['decision_event_id']}::uuid
       AND event.schema_version = 'canonical_event.v1'
       AND event.event_type = {literals['decision_event_type']}
       AND event.case_id = {literals['decision_case_id']}
       AND event.source = {literals['source']}::jsonb
       AND event.actor = {literals['actor']}::jsonb
       AND event.subject = {literals['subject']}::jsonb
       AND event.evidence = {literals['evidence']}::jsonb
       AND event.decision = {literals['decision']}::jsonb
       AND event.status = {literals['status']}::jsonb
       AND event.next_action = {literals['next_action']}::jsonb
       AND event.safety = {literals['safety']}::jsonb
       AND event.payload = {literals['payload']}::jsonb
  ) <> 1 THEN
    RAISE EXCEPTION 'legacy truth decision event replay or tamper detected';
  END IF;
  IF (
    SELECT pg_catalog.count(*)
      FROM canonical_brain.writer_event_provenance AS provenance
      JOIN public.canonical_event_log AS event USING (event_id)
     WHERE provenance.event_id = {literals['decision_event_id']}::uuid
       AND provenance.canonical_content_sha256 = {literals['decision_sha256']}
       AND provenance.origin = 'owner_approved_legacy_truth_decision'
       AND provenance.trusted_runtime = {literals['decision_runtime']}::jsonb
  ) <> 1 THEN
    RAISE EXCEPTION 'legacy truth decision provenance is invalid';
  END IF;
  SELECT pg_catalog.count(*) INTO invalid_count
    FROM pg_temp._cw_accepted_legacy_event AS accepted
    JOIN public.canonical_event_log AS event USING (event_id)
    LEFT JOIN canonical_brain.writer_event_provenance AS provenance
      USING (event_id)
   WHERE provenance.event_id IS NULL
      OR provenance.canonical_content_sha256
         <> accepted.canonical14_row_sha256
      OR provenance.origin <> 'owner_approved_legacy_reseed'
      OR provenance.trusted_runtime <> {routing_runtime};
  IF invalid_count <> 0 OR EXISTS (
    SELECT 1 FROM canonical_brain.writer_event_provenance AS provenance
     WHERE provenance.event_id <> {literals['decision_event_id']}::uuid
       AND NOT EXISTS (
         SELECT 1 FROM pg_temp._cw_accepted_legacy_event AS accepted
          WHERE accepted.event_id = provenance.event_id
       )
  ) THEN
    RAISE EXCEPTION 'legacy truth provenance set is not exact';
  END IF;
END
$legacy_truth_terminal$;
RESET ROLE;
REVOKE SELECT ON TABLE
  canonical_brain_legacy_quarantine.canonical_event_log_legacy_v1
  FROM canonical_brain_migration_owner;
REVOKE USAGE ON SCHEMA canonical_brain_legacy_quarantine
  FROM canonical_brain_migration_owner;
DO $retire_legacy_truth_authority$
BEGIN
  EXECUTE pg_catalog.format(
    'REVOKE canonical_brain_migration_owner FROM %I', SESSION_USER
  );
  IF EXISTS (
    SELECT 1 FROM pg_catalog.pg_auth_members AS membership
    JOIN pg_catalog.pg_roles AS granted ON granted.oid = membership.roleid
    JOIN pg_catalog.pg_roles AS member ON member.oid = membership.member
    WHERE granted.rolname = 'canonical_brain_migration_owner'
      AND member.rolname = SESSION_USER
  ) OR pg_catalog.has_schema_privilege(
    'canonical_brain_migration_owner',
    'canonical_brain_legacy_quarantine', 'USAGE'
  ) OR pg_catalog.has_table_privilege(
    'canonical_brain_migration_owner',
    'canonical_brain_legacy_quarantine.canonical_event_log_legacy_v1',
    'SELECT'
  ) THEN
    RAISE EXCEPTION 'legacy truth temporary authority survived';
  END IF;
END
$retire_legacy_truth_authority$;
COMMIT;
"""


def _database_preflight(plan: Mapping[str, Any]) -> Mapping[str, Any]:
    if _database_state(plan) != "legacy":
        raise ArtifactError("artifact_database_preflight_state_invalid")
    _database_projection(plan, legacy=True)
    _probe_hba(plan)
    return _database_receipt(
        plan,
        schema="muncho-production-legacy-cutover-preflight.v1",
        artifact_name="database_postflight",
        legacy=True,
    )


def _database_apply(plan: Mapping[str, Any]) -> Mapping[str, Any]:
    state = _database_state(plan)
    snapshot = _final_snapshot(plan)
    if state == "target":
        _database_projection(plan, legacy=False)
        return _database_receipt(
            plan,
            schema="muncho-production-legacy-database-apply.v1",
            artifact_name="database_apply",
            legacy=False,
        )
    if state == "legacy":
        _database_projection(plan, legacy=True)
        reconcile_settings = {
            "muncho.canonical_writer_reconcile_scope": "owner_approved_cutover",
            "muncho.canonical_writer_reconcile_database": DATABASE,
            "muncho.canonical_writer_reconcile_server_identity_sha256": plan["plan_sha256"],
            "muncho.canonical_writer_reconcile_source_owner": snapshot["source_owner"],
            "muncho.canonical_writer_reconcile_expected_row_count": str(snapshot["source_row_count"]),
            "muncho.canonical_writer_reconcile_expected_canonical14_sha256": snapshot["canonical14_sha256"],
            "muncho.canonical_writer_reconcile_expected_extended19_sha256": snapshot["extended19_sha256"],
            "muncho.canonical_writer_reconcile_expected_occurred_at_cutoff": snapshot["occurred_at_cutoff"],
            "muncho.canonical_writer_reconcile_approval_receipt_sha256": plan["plan_sha256"],
        }
        _run_psql(plan, _settings(reconcile_settings) + LEGACY_RECONCILE_SQL, read_only=False)
        state = _database_state(plan)
    if state not in {"reconciled", "migrated", "target"}:
        raise ArtifactError("artifact_database_apply_state_invalid")
    if state == "reconciled":
        _database_projection(plan, legacy=False)
        hba_digest = _probe_hba(plan)
        migration_settings = {
            "muncho.canonical_writer_migration_scope": "owner_approved_cutover",
            "muncho.canonical_writer_migration_database": DATABASE,
            "muncho.canonical_writer_migration_approval_receipt_sha256": plan["plan_sha256"],
            "muncho.canonical_writer_cloudsqladmin_hba_rejection_sha256": hba_digest,
        }
        _run_psql(plan, _settings(migration_settings) + WRITER_MIGRATION_SQL, read_only=False)
        state = _database_state(plan)
    if state == "migrated":
        _run_psql(plan, _legacy_truth_decision_sql(plan), read_only=False)
        _database_projection(plan, legacy=False)
        _run_psql(plan, _membership_sql(plan), read_only=False)
    if _database_state(plan) != "target":
        raise ArtifactError("artifact_database_apply_state_invalid")
    return _database_receipt(
        plan,
        schema="muncho-production-legacy-database-apply.v1",
        artifact_name="database_apply",
        legacy=False,
    )


def _rollback_sql(plan: Mapping[str, Any], state: str) -> str:
    if state not in {"reconciled", "migrated", "target"}:
        raise ArtifactError("artifact_database_rollback_state_invalid")
    snapshot = _final_snapshot(plan)
    decision = _legacy_truth_decision_for_plan(plan)
    login = str(_validate_target(plan["target"])["writer_login"])
    owner = str(snapshot["source_owner"])
    drop_schema = "" if state == "reconciled" else "DROP SCHEMA canonical_brain CASCADE;"
    accepted = list(decision["accepted_event_receipts"])
    accepted_values = ",\n".join(
        "(" + _sql_literal(item["event_id"]) + "::uuid,"
        + _sql_literal(item["canonical14_row_sha256"]) + ")"
        for item in accepted
    )
    accepted_cte = (
        "VALUES\n" + accepted_values
        if accepted_values
        else "SELECT NULL::uuid, NULL::text WHERE false"
    )
    decision_type = (
        "legacy.truth.reseeded"
        if decision["mode"] == "reseed_accepted_events"
        else "truth.epoch.started"
    )
    decision_case_id = "case:legacy-truth:" + decision["decision_sha256"][:32]
    accepted_set_sha256 = _accepted_event_set_sha256(decision)
    source_doc = {
        "system": "owner_approved_cutover",
        "component": "legacy_truth_decision",
        "cutover_plan_sha256": plan["plan_sha256"],
    }
    actor_doc = {
        "type": "authenticated_owner",
        "id_sha256": decision["owner_subject_sha256"],
    }
    subject_doc = {
        "type": "canonical_truth_epoch",
        "id": decision["truth_epoch_id"] or decision["decision_id"],
    }
    evidence_doc = {
        "reviewed_snapshot_sha256": decision["reviewed_snapshot_sha256"],
        "reseed_manifest_sha256": decision["reseed_manifest_sha256"],
        "accepted_event_set_sha256": accepted_set_sha256,
        "accepted_event_count": len(accepted),
        "truth_epoch_sha256": decision["truth_epoch_sha256"],
    }
    decision_doc = {
        "kind": "owner_approved_legacy_truth_decision",
        "mode": decision["mode"],
        "decision_id": decision["decision_id"],
        "decision_sha256": decision["decision_sha256"],
    }
    status_doc = {
        "state": (
            "accepted_legacy_events_reseeded"
            if accepted
            else "new_truth_epoch_started"
        )
    }
    payload_doc = {
        "cutover_plan_sha256": plan["plan_sha256"],
        "legacy_truth_decision_sha256": decision["decision_sha256"],
        "accepted_event_set_sha256": accepted_set_sha256,
        "reseed_manifest_sha256": decision["reseed_manifest_sha256"],
        "truth_epoch_id": decision["truth_epoch_id"],
        "truth_epoch_sha256": decision["truth_epoch_sha256"],
        "canonical_content_sha256": decision["decision_sha256"],
    }
    decision_runtime = {
        "service_internal": True,
        "legacy_truth_decision_sha256": decision["decision_sha256"],
        "cutover_plan_sha256": plan["plan_sha256"],
    }

    def json_literal(value: Mapping[str, Any]) -> str:
        return _sql_literal(
            json.dumps(value, sort_keys=True, separators=(",", ":"))
        )

    routing_runtime = f"""
pg_catalog.jsonb_strip_nulls(pg_catalog.jsonb_build_object(
  'platform', NULLIF(COALESCE(
      event.source#>>'{{observed_session,platform}}',
      event.source#>>'{{source_refs,platform}}', ''), ''),
  'thread_id', NULLIF(COALESCE(
      event.source#>>'{{observed_session,thread_id}}',
      event.source#>>'{{source_refs,thread_id}}', ''), ''),
  'chat_id', NULLIF(COALESCE(
      event.source#>>'{{observed_session,chat_id}}',
      event.source#>>'{{source_refs,chat_id}}', ''), ''),
  'session_key_sha256', CASE
      WHEN COALESCE(event.source#>>'{{observed_session,session_key_sha256}}','')
           ~ '^[0-9a-f]{{64}}$'
        THEN event.source#>>'{{observed_session,session_key_sha256}}'
      WHEN COALESCE(event.source#>>'{{source_refs,session_key_sha256}}','')
           ~ '^[0-9a-f]{{64}}$'
        THEN event.source#>>'{{source_refs,session_key_sha256}}'
      WHEN COALESCE(event.source#>>'{{source_refs,session_key}}','') <> ''
        THEN pg_catalog.encode(pg_catalog.sha256(pg_catalog.convert_to(
          event.source#>>'{{source_refs,session_key}}', 'UTF8')), 'hex')
      ELSE NULL END,
  'legacy_truth_decision_sha256', {_sql_literal(decision['decision_sha256'])},
  'reseed_manifest_sha256', {_sql_literal(decision['reseed_manifest_sha256'] or 'none')},
  'owner_subject_sha256', {_sql_literal(decision['owner_subject_sha256'])},
  'cutover_plan_sha256', {_sql_literal(plan['plan_sha256'])}
))
""".strip()
    return f"""
BEGIN TRANSACTION ISOLATION LEVEL SERIALIZABLE;
SET LOCAL TimeZone = 'UTC';
SET LOCAL lock_timeout = '15s';
SET LOCAL statement_timeout = '5min';
SELECT pg_catalog.pg_advisory_xact_lock(4841739663211427921);
DO $rollback_authority$
BEGIN
  IF SESSION_USER <> {_sql_literal(owner)} OR CURRENT_USER <> SESSION_USER
     OR pg_catalog.current_database() <> {_sql_literal(DATABASE)} THEN
    RAISE EXCEPTION 'production rollback authority or zero-write guard failed';
  END IF;
  IF EXISTS (SELECT 1 FROM pg_catalog.pg_auth_members AS membership
      JOIN pg_catalog.pg_roles AS granted ON granted.oid = membership.roleid
      JOIN pg_catalog.pg_roles AS member ON member.oid = membership.member
     WHERE granted.rolname = 'canonical_brain_writer'
       AND member.rolname = {_sql_literal(login)}) THEN
    EXECUTE pg_catalog.format(
      'REVOKE canonical_brain_writer FROM %I', {_sql_literal(login)}
    );
  END IF;
  EXECUTE pg_catalog.format(
    'GRANT canonical_brain_migration_owner TO %I '
    'WITH ADMIN FALSE, INHERIT FALSE, SET TRUE', SESSION_USER
  );
END
$rollback_authority$;
GRANT USAGE ON SCHEMA canonical_brain_legacy_quarantine
  TO canonical_brain_migration_owner;
GRANT SELECT ON TABLE
  canonical_brain_legacy_quarantine.canonical_event_log_legacy_v1
  TO canonical_brain_migration_owner;
SET LOCAL ROLE canonical_brain_migration_owner;
LOCK TABLE canonical_brain_legacy_quarantine.canonical_event_log_legacy_v1,
           public.canonical_event_log IN ACCESS EXCLUSIVE MODE;
DO $rollback_guard$
DECLARE archive_count bigint; canonical_count bigint; legacy_count bigint;
        canonical_hash text; decision_present boolean := false;
        provenance_count bigint := 0; invalid_count bigint := 0;
BEGIN
  SELECT pg_catalog.count(*) INTO archive_count
    FROM canonical_brain_legacy_quarantine.canonical_event_log_legacy_v1;
  SELECT pg_catalog.count(*) INTO canonical_count FROM public.canonical_event_log;
  WITH receipts AS (
    SELECT event.event_id,
           pg_catalog.encode(pg_catalog.sha256(pg_catalog.convert_to(
             pg_catalog.to_jsonb(event)::text, 'UTF8')), 'hex') AS row_sha
      FROM public.canonical_event_log AS event
      JOIN canonical_brain_legacy_quarantine.canonical_event_log_legacy_v1
        AS legacy USING (event_id)
  ) SELECT pg_catalog.count(*),
      pg_catalog.encode(pg_catalog.sha256(pg_catalog.convert_to(
      'canonical-writer-legacy-reconcile-v1:canonical14' || E'\\n'
      || COALESCE(pg_catalog.string_agg(event_id::text || ':' || row_sha,
         E'\\n' ORDER BY event_id), ''), 'UTF8')), 'hex')
    INTO legacy_count, canonical_hash FROM receipts;
  SELECT EXISTS (
    SELECT 1 FROM public.canonical_event_log
     WHERE event_id = {_sql_literal(decision['decision_event_id'])}::uuid
  ) INTO decision_present;
  IF archive_count <> {int(snapshot['source_row_count'])}
     OR legacy_count <> {int(snapshot['source_row_count'])}
     OR canonical_hash <> {_sql_literal(snapshot['canonical14_sha256'])} THEN
    RAISE EXCEPTION 'production rollback frozen truth changed';
  END IF;
  IF canonical_count <> {int(snapshot['source_row_count'])}
                         + CASE WHEN decision_present THEN 1 ELSE 0 END
     OR EXISTS (
       SELECT 1 FROM public.canonical_event_log AS event
        WHERE NOT EXISTS (
          SELECT 1
            FROM canonical_brain_legacy_quarantine.canonical_event_log_legacy_v1
              AS legacy
           WHERE legacy.event_id = event.event_id
        )
          AND event.event_id
              <> {_sql_literal(decision['decision_event_id'])}::uuid
     ) THEN
    RAISE EXCEPTION 'production rollback canonical row set changed';
  END IF;
  IF pg_catalog.to_regclass(
       'canonical_brain.writer_event_provenance') IS NOT NULL THEN
    SELECT pg_catalog.count(*) INTO provenance_count
      FROM canonical_brain.writer_event_provenance;
  END IF;
  IF NOT decision_present THEN
    IF provenance_count <> 0 THEN
      RAISE EXCEPTION 'production rollback partial legacy truth state';
    END IF;
  ELSE
    IF pg_catalog.to_regclass(
         'canonical_brain.writer_event_provenance') IS NULL
       OR provenance_count <> {len(accepted) + 1} THEN
      RAISE EXCEPTION 'production rollback partial legacy truth state';
    END IF;
    IF (
      SELECT pg_catalog.count(*) FROM public.canonical_event_log AS event
       WHERE event.event_id = {_sql_literal(decision['decision_event_id'])}::uuid
         AND event.schema_version = 'canonical_event.v1'
         AND event.event_type = {_sql_literal(decision_type)}
         AND event.case_id = {_sql_literal(decision_case_id)}
         AND event.source = {json_literal(source_doc)}::jsonb
         AND event.actor = {json_literal(actor_doc)}::jsonb
         AND event.subject = {json_literal(subject_doc)}::jsonb
         AND event.evidence = {json_literal(evidence_doc)}::jsonb
         AND event.decision = {json_literal(decision_doc)}::jsonb
         AND event.status = {json_literal(status_doc)}::jsonb
         AND event.next_action = '{{}}'::jsonb
         AND event.safety = '{{"business_mutation":false,"outbound":false,"payment_credential_recorded":false,"secret_value_recorded":false}}'::jsonb
         AND event.payload = {json_literal(payload_doc)}::jsonb
    ) <> 1 OR (
      SELECT pg_catalog.count(*)
        FROM canonical_brain.writer_event_provenance AS provenance
       WHERE provenance.event_id
             = {_sql_literal(decision['decision_event_id'])}::uuid
         AND provenance.canonical_content_sha256
             = {_sql_literal(decision['decision_sha256'])}
         AND provenance.origin = 'owner_approved_legacy_truth_decision'
         AND provenance.trusted_runtime = {json_literal(decision_runtime)}::jsonb
    ) <> 1 THEN
      RAISE EXCEPTION 'production rollback decision binding invalid';
    END IF;
    WITH accepted(event_id, row_sha256) AS ({accepted_cte})
    SELECT pg_catalog.count(*) INTO invalid_count
      FROM accepted
      LEFT JOIN public.canonical_event_log AS event USING (event_id)
      LEFT JOIN canonical_brain.writer_event_provenance AS provenance
        USING (event_id)
     WHERE event.event_id IS NULL OR provenance.event_id IS NULL
        OR pg_catalog.encode(pg_catalog.sha256(pg_catalog.convert_to(
             pg_catalog.to_jsonb(event)::text, 'UTF8')), 'hex')
           <> accepted.row_sha256
        OR provenance.canonical_content_sha256 <> accepted.row_sha256
        OR provenance.origin <> 'owner_approved_legacy_reseed'
        OR provenance.trusted_runtime <> {routing_runtime};
    IF invalid_count <> 0 OR EXISTS (
      WITH accepted(event_id, row_sha256) AS ({accepted_cte})
      SELECT 1 FROM canonical_brain.writer_event_provenance AS provenance
       WHERE provenance.event_id
             <> {_sql_literal(decision['decision_event_id'])}::uuid
         AND NOT EXISTS (
           SELECT 1 FROM accepted WHERE accepted.event_id = provenance.event_id
         )
    ) THEN
      RAISE EXCEPTION 'production rollback legacy truth provenance invalid';
    END IF;
  END IF;
END
$rollback_guard$;
{drop_schema}
DROP TABLE public.canonical_event_log;
RESET ROLE;
REVOKE SELECT ON TABLE
  canonical_brain_legacy_quarantine.canonical_event_log_legacy_v1
  FROM canonical_brain_migration_owner;
REVOKE USAGE ON SCHEMA canonical_brain_legacy_quarantine
  FROM canonical_brain_migration_owner;
ALTER TABLE canonical_brain_legacy_quarantine.canonical_event_log_legacy_v1
  SET SCHEMA public;
ALTER TABLE public.canonical_event_log_legacy_v1 RENAME TO canonical_event_log;
DROP TABLE canonical_brain_legacy_quarantine.reconciliation_receipts;
DROP SCHEMA canonical_brain_legacy_quarantine;
DO $retire_rollback_bridge$
BEGIN
  EXECUTE pg_catalog.format('REVOKE canonical_brain_migration_owner FROM %I', SESSION_USER);
  IF EXISTS (SELECT 1 FROM pg_catalog.pg_auth_members AS membership
      JOIN pg_catalog.pg_roles AS granted ON granted.oid = membership.roleid
      JOIN pg_catalog.pg_roles AS member ON member.oid = membership.member
     WHERE granted.rolname = 'canonical_brain_migration_owner'
       AND member.rolname = SESSION_USER)
     OR pg_catalog.has_table_privilege(
       'canonical_brain_migration_owner',
       'public.canonical_event_log',
       'SELECT'
     ) THEN
    RAISE EXCEPTION 'production rollback bridge survived';
  END IF;
END
$retire_rollback_bridge$;
COMMIT;
"""


def _validate_apply_receipt(value: Mapping[str, Any] | None, plan: Mapping[str, Any], artifact: str) -> None:
    if value is None:
        return
    raw = dict(value)
    digest = raw.get("receipt_sha256")
    if (
        not isinstance(digest, str)
        or SHA256.fullmatch(digest) is None
        or _sha_json({key: item for key, item in raw.items() if key != "receipt_sha256"}) != digest
        or raw.get("plan_sha256") != plan["plan_sha256"]
        or raw.get("artifact_sha256") != plan["artifacts"][artifact]["sha256"]
        or raw.get("ok") is not True
        or raw.get("secret_material_recorded") is not False
    ):
        raise ArtifactError("artifact_apply_receipt_invalid")
    if artifact == "database_apply":
        fields = {
            "schema", "plan_sha256", "artifact_sha256",
            "final_snapshot_sha256", "source_row_count",
            "archive_row_count", "canonical_row_count",
            "archive_extended19_sha256", "canonical14_sha256",
            "relation_identity_sha256", "acl_identity_sha256",
            "index_identity_sha256", "roles_acl_sha256",
            "zero_canonical_writer_writes", "trusted_legacy_event_count",
            "legacy_truth_mode", "legacy_truth_decision_sha256",
            "legacy_truth_decision_event_id", "accepted_event_set_sha256",
            "truth_epoch_sha256", "legacy_shape_restored", "ok",
            "secret_material_recorded", "receipt_sha256",
        }
        if set(raw) != fields:
            raise ArtifactError("artifact_apply_receipt_invalid")
        snapshot = _final_snapshot(plan)
        decision = _legacy_truth_decision_for_plan(plan)
        if (
            raw["schema"]
            != "muncho-production-legacy-database-apply.v1"
            or raw["final_snapshot_sha256"] != snapshot["snapshot_sha256"]
            or raw["source_row_count"] != snapshot["source_row_count"]
            or raw["archive_row_count"] != snapshot["source_row_count"]
            or raw["canonical_row_count"] != snapshot["source_row_count"] + 1
            or raw["archive_extended19_sha256"]
            != snapshot["extended19_sha256"]
            or raw["canonical14_sha256"] != snapshot["canonical14_sha256"]
            or raw["relation_identity_sha256"]
            != snapshot["relation_identity_sha256"]
            or raw["acl_identity_sha256"] != snapshot["acl_identity_sha256"]
            or raw["index_identity_sha256"]
            != snapshot["index_identity_sha256"]
            or SHA256.fullmatch(str(raw["roles_acl_sha256"])) is None
            or raw["zero_canonical_writer_writes"] is not True
            or raw["trusted_legacy_event_count"]
            != len(decision["accepted_event_ids"])
            or raw["legacy_truth_mode"] != decision["mode"]
            or raw["legacy_truth_decision_sha256"]
            != decision["decision_sha256"]
            or raw["legacy_truth_decision_event_id"]
            != decision["decision_event_id"]
            or raw["accepted_event_set_sha256"]
            != _accepted_event_set_sha256(decision)
            or raw["truth_epoch_sha256"] != decision["truth_epoch_sha256"]
            or raw["legacy_shape_restored"] is not False
        ):
            raise ArtifactError("artifact_apply_receipt_invalid")


def _database_rollback(plan: Mapping[str, Any], apply_receipt: Mapping[str, Any] | None) -> Mapping[str, Any]:
    _validate_apply_receipt(apply_receipt, plan, "database_apply")
    state = _database_state(plan)
    if state != "legacy":
        _run_psql(plan, _rollback_sql(plan, state), read_only=False)
    if _database_state(plan) != "legacy":
        raise ArtifactError("artifact_database_rollback_state_invalid")
    return _database_receipt(
        plan,
        schema="muncho-production-legacy-database-rollback.v1",
        artifact_name="database_rollback",
        legacy=True,
    )


SERVICE_FIELDS = {
    "schema", "name", "fragment_path", "fragment_sha256", "load_state",
    "active_state", "sub_state", "unit_file_state", "main_pid", "drop_in_paths",
    "drop_in_sha256", "need_daemon_reload", "triggered_by", "triggers",
    "observed_at_unix", "observation_sha256",
}
STABLE_SERVICE_FIELDS = {
    "name", "fragment_path", "fragment_sha256", "load_state",
    "unit_file_state", "drop_in_paths", "drop_in_sha256",
    "need_daemon_reload", "triggered_by", "triggers",
}
HOST_FILE_NAMES = {
