[Unit]
Description=Muncho passkey v2 web to authority socket

[Socket]
ListenStream=/run/muncho-owner-gate/passkey-authority.sock
FileDescriptorName=passkey-authority
SocketUser=muncho-passkey-authority
SocketGroup=muncho-passkey-web
SocketMode=0660
RemoveOnStop=yes
DirectoryMode=0755

[Install]
WantedBy=sockets.target
