#!/usr/bin/env bash
set -euo pipefail

OWNER="ai-platform-brain"
REPO_URL="https://github.com/lomliev/hermes-agent.git"
RELEASES="/opt/adventico-ai-platform/hermes-agent-releases"
ACTIVE_LINK="/opt/adventico-ai-platform/hermes-agent"
SERVICE="hermes-cloud-gateway.service"
GATEWAY_FRAGMENT="/etc/systemd/system/hermes-cloud-gateway.service"
GATEWAY_CONNECTOR_DROP_IN="/etc/systemd/system/hermes-cloud-gateway.service.d/20-discord-connector.conf"
CUTOVER_PLAN_PATH="/var/lib/muncho-production-legacy-cutover/staged/cutover-plan.json"
CUTOVER_UNIT_INPUT_PLAN_PATH="/var/lib/muncho-production-legacy-cutover/staged/unit-input-plan.json"
CUTOVER_UNIT_INPUT_APPROVAL_PATH="/var/lib/muncho-production-legacy-cutover/staged/unit-input-approval.json"
CUTOVER_UNIT_INPUTS_PATH="/var/lib/muncho-production-legacy-cutover/staged/production-unit-inputs.json"
CUTOVER_STAGED_TRUSTED_UID=0
CUTOVER_STAGED_TRUSTED_GID=0
GATEWAY_FRAGMENT_TRUSTED_UID=0
GATEWAY_FRAGMENT_TRUSTED_GID=0
SYSTEMCTL="/usr/bin/systemctl"
SYSTEM_PYTHON="/usr/bin/python3"
SYSTEM_GIT="/usr/bin/git"
SYSTEM_ID="/usr/bin/id"
CUTOVER_BOOTSTRAP_RUNTIME_DIR="/run"
CUTOVER_BOOTSTRAP_REPOSITORY_PATH="ops/muncho/cutover/production_unit_input_bootstrap.py"
AGENT_BROWSER_CONFIG_RELATIVE_PATH="ops/muncho/runtime/dependencies/agent-browser.json"
RUNTIME_CONFIG_ROOT_UID=0
RUNTIME_CONFIG_ROOT_GID=0
HERMES_HOME="/opt/adventico-ai-platform/hermes-home"
PLANNED_RESTART_HELPER="$HERMES_HOME/scripts/planned_gateway_restart.sh"
STATE_DIR="/opt/adventico-ai-platform/canonical-brain/state/private/upstream_sync_monitor"
REPORT_DIR="/opt/adventico-ai-platform/canonical-brain/state/reports"
KEEP_RELEASES="${MUNCHO_AUTO_DEPLOY_KEEP_RELEASES:-8}"
VOICE_CALL_GUARD_PATH="${MUNCHO_VOICE_CALL_GUARD_PATH:-/opt/adventico-ai-platform/canonical-brain/state/runtime/voice-skyai-active-calls.json}"
VOICE_CALL_LEASE_TOOL="${MUNCHO_VOICE_CALL_LEASE_TOOL:-/opt/adventico-ai-platform/hermes-home/bin/voice-skyai-call-lease}"
VOICE_CALL_GUARD_BYPASS="${MUNCHO_IGNORE_ACTIVE_VOICE_CALLS:-0}"
DEPLOY_HEALTH_WAIT_SECONDS="${MUNCHO_DEPLOY_HEALTH_WAIT_SECONDS:-8}"

usage() {
  cat >&2 <<'EOF'
Usage:
  muncho-auto-deploy-release start <40-char-sha> <pr-number>
  muncho-auto-deploy-release run <40-char-sha> <pr-number>
  muncho-auto-deploy-release check-voice-guard
EOF
}

json_escape() {
  python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))'
}

write_status() {
  local status="$1"
  local sha="$2"
  local pr="$3"
  local extra_json="${4:-}"
  if [ -z "$extra_json" ]; then
    extra_json="{}"
  fi
  mkdir -p "$STATE_DIR" "$REPORT_DIR"
  local now
  now="$(date -Iseconds)"
  local status_file="$STATE_DIR/auto-sync-deploy-latest.json"
  python3 - "$status_file" "$status" "$sha" "$pr" "$now" "$extra_json" <<'PY'
import json
import os
import sys
from pathlib import Path

path = Path(sys.argv[1])
status, sha, pr, now = sys.argv[2:6]
extra = json.loads(sys.argv[6])
payload = {
    "schema": "muncho-auto-deploy-release.v1",
    "status": status,
    "target_commit": sha,
    "pr_number": int(pr),
    "updated_at": now,
}
payload.update(extra)
tmp = path.with_name(f".{path.name}.{os.getpid()}.tmp")
tmp.write_text(json.dumps(payload, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")
os.replace(tmp, path)
archive = path.with_name(f"auto-sync-deploy-{now.replace(':', '').replace('-', '')}.json")
archive_tmp = archive.with_name(f".{archive.name}.{os.getpid()}.tmp")
archive_tmp.write_text(json.dumps(payload, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")
os.replace(archive_tmp, archive)
PY
  cat >"$REPORT_DIR/fork-upstream-auto-sync-deploy-latest-public-summary.md" <<EOF
# Fork upstream auto-sync deploy

Status: \`$status\`

Time: \`$now\`

Target commit: \`$sha\`

PR: #$pr
EOF
}

voice_call_guard_json() {
  if [ "$VOICE_CALL_GUARD_BYPASS" = "1" ]; then
    printf '{"schema":"voice-skyai-active-calls-status.v1","path":%s,"active":false,"active_count":0,"bypassed":true}\n' \
      "$(python3 -c 'import json,sys; print(json.dumps(sys.argv[1]))' "$VOICE_CALL_GUARD_PATH")"
    return 0
  fi
  if [ -x "$VOICE_CALL_LEASE_TOOL" ]; then
    local lease_output
    local lease_rc=0
    lease_output="$("$VOICE_CALL_LEASE_TOOL" --path "$VOICE_CALL_GUARD_PATH" status --json)" || lease_rc=$?
    if [ "$lease_rc" -eq 0 ] || [ "$lease_rc" -eq 7 ]; then
      printf '%s\n' "$lease_output"
      return 0
    fi
  fi
  python3 - "$VOICE_CALL_GUARD_PATH" <<'PY'
import json
import time
from datetime import datetime, timezone
from pathlib import Path
import sys

path = Path(sys.argv[1])
ttl_default = 180
ended = {"ended", "completed", "closed", "inactive", "hangup", "hung_up"}

def parse_ts(value):
    if not isinstance(value, str) or not value.strip():
        return None
    text = value.strip()
    if text.endswith("Z"):
        text = text[:-1] + "+00:00"
    try:
        return datetime.fromisoformat(text).timestamp()
    except ValueError:
        return None

payload = {}
if path.exists():
    try:
        payload = json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        payload = {"unreadable": True}
if not isinstance(payload, dict):
    payload = {"unreadable": True}
ttl = int(payload.get("ttl_seconds") or ttl_default)
now = time.time()
fallback_ts = path.stat().st_mtime if path.exists() else None
active = []
stale_count = 0
calls = payload.get("calls") if isinstance(payload.get("calls"), list) else []
for call in calls:
    if not isinstance(call, dict):
        continue
    status = str(call.get("status") or "active").lower()
    ts = parse_ts(call.get("last_seen_at")) or parse_ts(call.get("updated_at")) or parse_ts(call.get("started_at")) or fallback_ts
    if status not in ended and call.get("active") is not False and ts is not None and now - ts <= ttl:
        active.append(call)
    else:
        stale_count += 1
if not active and payload.get("active") is True:
    ts = parse_ts(payload.get("last_seen_at")) or parse_ts(payload.get("updated_at")) or fallback_ts
    if ts is not None and now - ts <= ttl:
        active.append({"call_id": payload.get("call_id") or "single-marker"})
print(json.dumps({
    "schema": "voice-skyai-active-calls-status.v1",
    "path": str(path),
    "active": bool(active),
    "active_count": len(active),
    "stale_count": stale_count,
    "ttl_seconds": ttl,
    "updated_at": payload.get("updated_at"),
    "checked_at": datetime.now(timezone.utc).isoformat().replace("+00:00", "Z"),
}, ensure_ascii=False, sort_keys=True))
PY
}

voice_call_guard_active() {
  python3 -c 'import json,sys; print("true" if json.load(sys.stdin).get("active") else "false")'
}

voice_call_guard_extra_json() {
  local stage="$1"
  local status_json="$2"
  python3 - "$stage" "$status_json" <<'PY'
import json
import sys

stage = sys.argv[1]
status = json.loads(sys.argv[2])
print(json.dumps({"stage": stage, "voice_call_guard": status}, ensure_ascii=False, sort_keys=True))
PY
}

require_no_active_voice_call() {
  local sha="$1"
  local pr="$2"
  local stage="$3"
  local status_json
  status_json="$(voice_call_guard_json)"
  echo "voice_call_guard_${stage}=$status_json"
  if [ "$(printf '%s' "$status_json" | voice_call_guard_active)" = "true" ]; then
    write_status "blocked_active_voice_call" "$sha" "$pr" "$(voice_call_guard_extra_json "$stage" "$status_json")"
    echo "BLOCKED_ACTIVE_VOICE_CALL: Voice SkyAI/PBX call lease is active; refusing to restart $SERVICE." >&2
    exit 7
  fi
}

validate_args() {
  local sha="${1:-}"
  local pr="${2:-}"
  if [[ ! "$sha" =~ ^[0-9a-f]{40}$ ]]; then
    echo "BLOCKED: target SHA must be a 40-char lowercase git SHA." >&2
    exit 2
  fi
  if [[ ! "$pr" =~ ^[0-9]+$ ]]; then
    echo "BLOCKED: PR number must be numeric." >&2
    exit 2
  fi
  if [[ ! "$KEEP_RELEASES" =~ ^[0-9]{1,3}$ ]] \
    || [ "$KEEP_RELEASES" -lt 2 ] \
    || [ "$KEEP_RELEASES" -gt 100 ]; then
    echo "BLOCKED: release retention must be an integer from 2 through 100." >&2
    exit 2
  fi
  if [[ ! "$DEPLOY_HEALTH_WAIT_SECONDS" =~ ^[0-9]{1,3}$ ]] \
    || [ "$DEPLOY_HEALTH_WAIT_SECONDS" -gt 300 ]; then
    echo "BLOCKED: deploy health wait must be an integer from 0 through 300 seconds." >&2
    exit 2
  fi
}

gateway_deploy_topology_json() {
  local observation=""
  observation="$($SYSTEMCTL show --no-pager \
    --property=Names,FragmentPath,LoadState,UnitFileState,DropInPaths,NeedDaemonReload,TriggeredBy,Triggers \
    -- "$SERVICE" 2>/dev/null || true)"
  python3 - \
    "$GATEWAY_FRAGMENT" \
    "$GATEWAY_CONNECTOR_DROP_IN" \
    "$CUTOVER_PLAN_PATH" \
    "$ACTIVE_LINK" \
    "$RELEASES" \
    "$SERVICE" \
    "$GATEWAY_FRAGMENT_TRUSTED_UID" \
    "$GATEWAY_FRAGMENT_TRUSTED_GID" \
    "$observation" <<'PY'
import hashlib
import json
import os
import re
import stat
import sys
from pathlib import Path

SCHEMA = "muncho-legacy-auto-deploy-topology.v1"
PINNED_HEADER = "# Exact SHA-bound Cloud Muncho production gateway; do not edit."
PLAN_SCHEMA = "muncho-production-legacy-cutover-plan.v3"
CONFIG_PATH = "/opt/adventico-ai-platform/hermes-home/config.yaml"
STARTUP_FLAG = "--require-production-model-sovereignty"
REVISION = re.compile(r"^[0-9a-f]{40}$")
SHA256 = re.compile(r"^[0-9a-f]{64}$")
MAX_UNIT_BYTES = 1024 * 1024
MAX_PLAN_BYTES = 8 * 1024 * 1024
MAX_SYSTEMD_BYTES = 64 * 1024

fragment = Path(sys.argv[1])
drop_in = Path(sys.argv[2])
plan_path = Path(sys.argv[3])
active_link = Path(sys.argv[4])
releases = Path(sys.argv[5])
service = sys.argv[6]
trusted_uid = int(sys.argv[7])
trusted_gid = int(sys.argv[8])
systemd_raw = sys.argv[9]


class GateError(RuntimeError):
    pass


def emit(classification, reason_code, **extra):
    value = {
        "schema": SCHEMA,
        "classification": classification,
        "reason_code": reason_code,
        "fragment_path": str(fragment),
        "secret_material_recorded": False,
        "secret_digest_recorded": False,
        **extra,
    }
    print(json.dumps(value, ensure_ascii=True, sort_keys=True, separators=(",", ":")))


def identity(item):
    return (
        item.st_dev,
        item.st_ino,
        item.st_mode,
        item.st_uid,
        item.st_gid,
        item.st_nlink,
        item.st_size,
        item.st_mtime_ns,
        item.st_ctime_ns,
    )


def read_exact(path, *, modes, owners, groups, maximum):
    try:
        before = path.lstat()
        resolved = path.resolve(strict=True)
    except OSError as exc:
        raise GateError("trusted_file_unavailable") from exc
    if (
        resolved != path
        or not stat.S_ISREG(before.st_mode)
        or stat.S_ISLNK(before.st_mode)
        or before.st_nlink != 1
        or stat.S_IMODE(before.st_mode) not in modes
        or before.st_uid not in owners
        or before.st_gid not in groups
        or not 0 < before.st_size <= maximum
    ):
        raise GateError("trusted_file_identity_invalid")
    flags = os.O_RDONLY | getattr(os, "O_CLOEXEC", 0) | getattr(os, "O_NOFOLLOW", 0)
    try:
        descriptor = os.open(path, flags)
    except OSError as exc:
        raise GateError("trusted_file_open_failed") from exc
    try:
        opened = os.fstat(descriptor)
        raw = bytearray()
        while len(raw) <= maximum:
            chunk = os.read(descriptor, min(64 * 1024, maximum + 1 - len(raw)))
            if not chunk:
                break
            raw.extend(chunk)
        after = os.fstat(descriptor)
    finally:
        os.close(descriptor)
    try:
        reachable = path.lstat()
    except OSError as exc:
        raise GateError("trusted_file_replaced") from exc
    if (
        len(raw) != before.st_size
        or len(raw) > maximum
        or identity(before) != identity(opened)
        or identity(before) != identity(after)
        or identity(before) != identity(reachable)
    ):
        raise GateError("trusted_file_changed")
    return bytes(raw)


def parse_systemd(raw):
    if not raw or len(raw.encode("utf-8", errors="strict")) > MAX_SYSTEMD_BYTES:
        raise GateError("systemd_observation_unavailable")
    expected = {
        "Names",
        "FragmentPath",
        "LoadState",
        "UnitFileState",
        "DropInPaths",
        "NeedDaemonReload",
        "TriggeredBy",
        "Triggers",
    }
    values = {}
    for line in raw.splitlines():
        name, separator, value = line.partition("=")
        if not separator or name in values:
            raise GateError("systemd_observation_invalid")
        values[name] = value
    if set(values) != expected:
        raise GateError("systemd_observation_invalid")
    if (
        values["Names"] != service
        or values["FragmentPath"] != str(fragment)
        or values["LoadState"] != "loaded"
        or values["UnitFileState"] != "enabled"
        or values["NeedDaemonReload"] != "no"
        or values["TriggeredBy"]
        or values["Triggers"]
    ):
        raise GateError("systemd_identity_drifted")
    values["drop_in_paths"] = (
        [] if not values["DropInPaths"] else sorted(values["DropInPaths"].split())
    )
    return values


def decode_plan(raw):
    def pairs(items):
        value = {}
        for name, item in items:
            if name in value:
                raise GateError("cutover_plan_duplicate_key")
            value[name] = item
        return value

    def constant(_value):
        raise GateError("cutover_plan_nonfinite_number")

    try:
        value = json.loads(
            raw.decode("utf-8", errors="strict"),
            object_pairs_hook=pairs,
            parse_constant=constant,
        )
    except (UnicodeError, ValueError, json.JSONDecodeError) as exc:
        raise GateError("cutover_plan_invalid") from exc
    if not isinstance(value, dict):
        raise GateError("cutover_plan_invalid")
    try:
        canonical = json.dumps(
            value,
            ensure_ascii=False,
            sort_keys=True,
            separators=(",", ":"),
            allow_nan=False,
        ).encode("utf-8", errors="strict")
    except (TypeError, ValueError, UnicodeError) as exc:
        raise GateError("cutover_plan_invalid") from exc
    if canonical != raw:
        raise GateError("cutover_plan_not_canonical")
    plan_sha256 = value.get("plan_sha256")
    unsigned = {name: item for name, item in value.items() if name != "plan_sha256"}
    if (
        not isinstance(plan_sha256, str)
        or SHA256.fullmatch(plan_sha256) is None
        or hashlib.sha256(
            json.dumps(
                unsigned,
                ensure_ascii=False,
                sort_keys=True,
                separators=(",", ":"),
                allow_nan=False,
            ).encode("utf-8", errors="strict")
        ).hexdigest()
        != plan_sha256
    ):
        raise GateError("cutover_plan_digest_invalid")
    return value


try:
    systemd = parse_systemd(systemd_raw)
    fragment_raw = read_exact(
        fragment,
        modes={0o644},
        owners={trusted_uid},
        groups={trusted_gid},
        maximum=MAX_UNIT_BYTES,
    )
    try:
        fragment_text = fragment_raw.decode("utf-8", errors="strict")
    except UnicodeError as exc:
        raise GateError("gateway_fragment_not_utf8") from exc
    lines = fragment_text.splitlines()
    pinned_signal = (
        os.path.lexists(plan_path)
        or PINNED_HEADER in lines
        or any(line.startswith("# ReleaseRevision=") for line in lines)
        or STARTUP_FLAG in fragment_text
        or str(releases) + "/hermes-agent-" in fragment_text
        or bool(systemd["drop_in_paths"])
    )
    if not pinned_signal:
        legacy_working_directory = [
            line for line in lines if line.startswith("WorkingDirectory=")
        ]
        legacy_exec_start = [
            line for line in lines if line.startswith("ExecStart=")
        ]
        if (
            legacy_working_directory != [f"WorkingDirectory={active_link}"]
            or len(legacy_exec_start) != 1
            or not legacy_exec_start[0].startswith(
                f"ExecStart={active_link}/.venv/bin/python "
            )
        ):
            raise GateError("legacy_topology_not_symlink_bound")
        emit(
            "legacy",
            "trusted_legacy_symlink_topology",
            fragment_sha256=hashlib.sha256(fragment_raw).hexdigest(),
        )
        raise SystemExit(0)
    if not os.path.lexists(plan_path):
        raise GateError("pinned_topology_cutover_plan_missing")
    plan_raw = read_exact(
        plan_path,
        modes={0o400},
        owners={trusted_uid},
        groups={trusted_gid},
        maximum=MAX_PLAN_BYTES,
    )
    plan = decode_plan(plan_raw)
    revision = plan.get("release_revision")
    runtime_attestation = plan.get("owner_runtime_attestation")
    runtime_fields = {
        "schema", "revision", "manifest_sha256", "tree_sha256",
        "interpreter_sha256", "pyvenv_cfg_sha256", "sys_path_sha256",
        "required_modules_sha256", "module_origins_release_local",
        "ambient_python_environment_present", "secret_material_recorded",
        "secret_digest_recorded", "attestation_sha256",
    }
    runtime_unsigned = (
        {
            name: item
            for name, item in runtime_attestation.items()
            if name != "attestation_sha256"
        }
        if isinstance(runtime_attestation, dict)
        else {}
    )
    runtime_digest = hashlib.sha256(
        json.dumps(
            runtime_unsigned,
            ensure_ascii=False,
            sort_keys=True,
            separators=(",", ":"),
            allow_nan=False,
        ).encode("utf-8", errors="strict")
    ).hexdigest()
    if (
        plan.get("schema") != PLAN_SCHEMA
        or not isinstance(revision, str)
        or REVISION.fullmatch(revision) is None
        or plan.get("secret_material_recorded") is not False
        or not isinstance(runtime_attestation, dict)
        or set(runtime_attestation) != runtime_fields
        or runtime_attestation.get("schema")
        != "muncho-production-owner-runtime-attestation.v1"
        or runtime_attestation.get("revision") != revision
        or runtime_attestation.get("attestation_sha256") != runtime_digest
        or any(
            SHA256.fullmatch(str(runtime_attestation.get(name))) is None
            for name in (
                "manifest_sha256", "tree_sha256", "interpreter_sha256",
                "pyvenv_cfg_sha256", "sys_path_sha256",
                "required_modules_sha256",
            )
        )
        or runtime_attestation.get("module_origins_release_local") is not True
        or runtime_attestation.get("ambient_python_environment_present")
        is not False
        or runtime_attestation.get("secret_material_recorded") is not False
        or runtime_attestation.get("secret_digest_recorded") is not False
    ):
        raise GateError("cutover_plan_revision_invalid")
    target = plan.get("gateway_target_identity")
    target_fields = {
        "name",
        "fragment_path",
        "fragment_sha256",
        "load_state",
        "unit_file_state",
        "drop_in_paths",
        "drop_in_sha256",
        "need_daemon_reload",
        "triggered_by",
        "triggers",
    }
    if not isinstance(target, dict) or set(target) != target_fields:
        raise GateError("cutover_gateway_target_invalid")
    fragment_sha256 = hashlib.sha256(fragment_raw).hexdigest()
    if (
        target["name"] != service
        or target["fragment_path"] != str(fragment)
        or target["fragment_sha256"] != fragment_sha256
        or target["load_state"] != "loaded"
        or target["unit_file_state"] != "enabled"
        or target["drop_in_paths"] != [str(drop_in)]
        or not isinstance(target["drop_in_sha256"], dict)
        or set(target["drop_in_sha256"]) != {str(drop_in)}
        or target["need_daemon_reload"] is not False
        or target["triggered_by"] != []
        or target["triggers"] != []
        or systemd["drop_in_paths"] != [str(drop_in)]
    ):
        raise GateError("cutover_gateway_target_drifted")
    drop_in_raw = read_exact(
        drop_in,
        modes={0o644},
        owners={trusted_uid},
        groups={trusted_gid},
        maximum=MAX_UNIT_BYTES,
    )
    drop_in_sha256 = hashlib.sha256(drop_in_raw).hexdigest()
    if target["drop_in_sha256"][str(drop_in)] != drop_in_sha256:
        raise GateError("cutover_gateway_drop_in_drifted")
    release = releases / f"hermes-agent-{revision[:12]}"
    interpreter = release / ".venv/bin/python"
    marker = release / ".codex-source-commit"
    config_matches = [
        line.removeprefix("# ConfigSHA256=")
        for line in lines
        if line.startswith("# ConfigSHA256=")
    ]
    revision_lines = [line for line in lines if line.startswith("# ReleaseRevision=")]
    if len(config_matches) != 1 or SHA256.fullmatch(config_matches[0]) is None:
        raise GateError("gateway_fragment_config_identity_invalid")
    config_sha256 = config_matches[0]
    expected_exec = (
        f"ExecStart={interpreter} -B -P -s -m gateway.run "
        f"--config {CONFIG_PATH} {STARTUP_FLAG} "
        f"--production-release-revision {revision} "
        f"--production-config-sha256 {config_sha256}"
    )
    expected_pre = (
        f"ExecStartPre=+{interpreter} -B -P -s -m "
        "gateway.production_capability_prerequisites collect "
        f"--revision {revision} --config-sha256 {config_sha256} "
        "--lifecycle-phase committed"
    )
    required_once = {
        PINNED_HEADER,
        f"# ReleaseRevision={revision}",
        f"# ConfigSHA256={config_sha256}",
        f"AssertPathExists={interpreter}",
        f"AssertPathExists={marker}",
        f"WorkingDirectory={release}",
        f"Environment=PYTHONPATH={release}",
        expected_pre,
        expected_exec,
        f"ReadOnlyPaths={release}",
    }
    if revision_lines != [f"# ReleaseRevision={revision}"] or any(
        lines.count(item) != 1 for item in required_once
    ):
        raise GateError("gateway_fragment_revision_contract_drifted")
    marker_raw = read_exact(
        marker,
        modes={0o400, 0o440, 0o444, 0o600, 0o640, 0o644},
        owners={trusted_uid, marker.lstat().st_uid},
        groups={trusted_gid, marker.lstat().st_gid},
        maximum=128,
    )
    if marker_raw != (revision + "\n").encode("ascii"):
        raise GateError("release_source_commit_drifted")
    emit(
        "sha_pinned",
        "signed_sha_pinned_topology",
        release_revision=revision,
        release_root=str(release),
        fragment_sha256=fragment_sha256,
        connector_drop_in_sha256=drop_in_sha256,
        cutover_plan_sha256=plan["plan_sha256"],
    )
except SystemExit:
    raise
except GateError as exc:
    emit("ambiguous", str(exc))
except BaseException:
    emit("ambiguous", "topology_gate_failed")
PY
}

