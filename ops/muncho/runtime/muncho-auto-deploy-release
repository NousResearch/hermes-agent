validate_cutover_unit_inputs() {
  local expected_revision="$1"
  python3 - \
    "$CUTOVER_UNIT_INPUTS_PATH" \
    "$CUTOVER_UNIT_INPUT_PLAN_PATH" \
    "$CUTOVER_UNIT_INPUT_APPROVAL_PATH" \
    "$CUTOVER_STAGED_TRUSTED_UID" \
    "$CUTOVER_STAGED_TRUSTED_GID" \
    "$expected_revision" <<'PY'
import hashlib
import ipaddress
import json
import os
import re
import stat
import sys
from pathlib import Path

UNIT_SCHEMA = "muncho-production-cutover-unit-inputs.v2"
PLAN_SCHEMA = "muncho-production-cutover-unit-input-plan.v2"
PAYLOAD_SCHEMA = "muncho-production-cutover-unit-input-payload.v2"
APPROVAL_SCHEMA = "muncho-production-cutover-unit-input-approval.v2"
REVISION = re.compile(r"^[0-9a-f]{40}$")
SHA256 = re.compile(r"^[0-9a-f]{64}$")
UNIT_FIELDS = {
    "schema", "release_revision", "authority_plan_sha256",
    "authority_approval_sha256", "database_ip", "target", "gateway", "routeback",
    "mac_ops", "browser", "worker", "worker_client_group",
    "worker_client_gid", "operational_edge_identities",
    "operational_edge_socket_groups", "writer_capability_public_key_id",
    "operational_edge_key_foundation_sha256",
    "operational_edge_receipt_public_key_ids", "release_owner_uid",
    "release_owner_gid", "bwrap_sha256", "shell_sha256",
    "secret_material_recorded", "secret_digest_recorded",
}
IDENTITY_FIELDS = {"user", "group", "uid", "gid"}
APPROVAL_FIELDS = {
    "schema", "purpose", "plan_sha256", "release_revision",
    "owner_subject_sha256",
    "owner_public_key_ed25519_hex", "owner_key_id", "nonce_sha256",
    "issued_at_unix", "expires_at_unix", "approved",
    "signature_ed25519_hex", "approval_sha256",
}
PLAN_FIELDS = {
    "schema", "release_revision", "unit_inputs", "owner_subject_sha256",
    "owner_public_key_ed25519_hex", "owner_key_id", "owner_runtime_attestation",
    "created_at_unix",
    "secret_material_recorded", "secret_digest_recorded", "plan_sha256",
}
RUNTIME_ATTESTATION_FIELDS = {
    "schema", "revision", "manifest_sha256", "tree_sha256",
    "interpreter_sha256", "pyvenv_cfg_sha256", "sys_path_sha256",
    "required_modules_sha256", "module_origins_release_local",
    "ambient_python_environment_present", "secret_material_recorded",
    "secret_digest_recorded", "attestation_sha256",
}
PAYLOAD_FIELDS = {
    "schema", "database_ip", "target", "gateway", "routeback", "mac_ops",
    "browser", "worker", "worker_client_group", "worker_client_gid",
    "operational_edge_identities", "operational_edge_socket_groups",
    "writer_capability_public_key_id",
    "operational_edge_key_foundation_sha256",
    "operational_edge_receipt_public_key_ids",
    "release_owner_uid", "release_owner_gid", "bwrap_sha256", "shell_sha256",
    "secret_material_recorded",
    "secret_digest_recorded",
}
IDENTITY = re.compile(r"^[a-z_][a-z0-9_-]{0,63}$")
TARGET_FIELDS = {
    "project", "zone", "vm", "database", "sql_instance", "sql_host",
    "tls_server_name", "port", "writer_login",
}
OPERATIONAL_EDGE_DOMAINS = {
    "adventico_email", "bitrix", "canonical", "github", "infrastructure",
    "skyvision_db", "skyvision_email", "skyvision_gitlab", "skyvision_panel",
}

unit_path = Path(sys.argv[1])
plan_path = Path(sys.argv[2])
approval_path = Path(sys.argv[3])
trusted_uid = int(sys.argv[4])
trusted_gid = int(sys.argv[5])
expected_revision = sys.argv[6]


class GateError(RuntimeError):
    pass


def identity(item):
    return (
        item.st_dev, item.st_ino, item.st_mode, item.st_nlink,
        item.st_uid, item.st_gid, item.st_size, item.st_mtime_ns,
        item.st_ctime_ns,
    )


def read_exact(path, *, mode, maximum):
    descriptor = None
    try:
        before = path.lstat()
        if (
            path.resolve(strict=True) != path
            or not stat.S_ISREG(before.st_mode)
            or stat.S_ISLNK(before.st_mode)
            or before.st_nlink != 1
            or before.st_uid != trusted_uid
            or before.st_gid != trusted_gid
            or stat.S_IMODE(before.st_mode) != mode
            or not 0 < before.st_size <= maximum
        ):
            raise GateError("trusted_staged_identity_invalid")
        flags = os.O_RDONLY | getattr(os, "O_CLOEXEC", 0)
        flags |= getattr(os, "O_NOFOLLOW", 0)
        descriptor = os.open(path, flags)
        opened = os.fstat(descriptor)
        raw = bytearray()
        while len(raw) <= maximum:
            chunk = os.read(
                descriptor,
                min(64 * 1024, maximum + 1 - len(raw)),
            )
            if not chunk:
                break
            raw.extend(chunk)
        after = os.fstat(descriptor)
        reachable = path.lstat()
    except GateError:
        raise
    except OSError as exc:
        raise GateError("trusted_staged_unavailable") from exc
    finally:
        if descriptor is not None:
            os.close(descriptor)
    if (
        len(raw) != before.st_size
        or len(raw) > maximum
        or identity(before) != identity(opened)
        or identity(before) != identity(after)
        or identity(before) != identity(reachable)
    ):
        raise GateError("trusted_staged_changed")
    return bytes(raw)


def canonical(value):
    return json.dumps(
        value,
        ensure_ascii=False,
        sort_keys=True,
        separators=(",", ":"),
        allow_nan=False,
    ).encode("utf-8", errors="strict")


def decode(raw, *, newline):
    def pairs(items):
        value = {}
        for name, item in items:
            if name in value:
                raise GateError("trusted_staged_duplicate_key")
            value[name] = item
        return value

    def constant(_value):
        raise GateError("trusted_staged_nonfinite_number")

    try:
        value = json.loads(
            raw.decode("utf-8", errors="strict"),
            object_pairs_hook=pairs,
            parse_constant=constant,
        )
    except GateError:
        raise
    except (UnicodeError, ValueError, json.JSONDecodeError) as exc:
        raise GateError("trusted_staged_json_invalid") from exc
    if not isinstance(value, dict) or raw != canonical(value) + (b"\n" if newline else b""):
        raise GateError("trusted_staged_json_not_canonical")
    return value


def self_digest(value, field):
    digest = value.get(field)
    if SHA256.fullmatch(str(digest)) is None:
        raise GateError("trusted_staged_digest_invalid")
    unsigned = {name: item for name, item in value.items() if name != field}
    if hashlib.sha256(canonical(unsigned)).hexdigest() != digest:
        raise GateError("trusted_staged_digest_invalid")
    return digest


if REVISION.fullmatch(expected_revision) is None:
    raise GateError("expected_revision_invalid")
unit_raw = read_exact(unit_path, mode=0o444, maximum=128 * 1024)
plan_raw = read_exact(plan_path, mode=0o400, maximum=1024 * 1024)
approval_raw = read_exact(approval_path, mode=0o400, maximum=1024 * 1024)
unit = decode(unit_raw, newline=True)
plan = decode(plan_raw, newline=False)
approval = decode(approval_raw, newline=False)
plan_sha256 = self_digest(plan, "plan_sha256")
approval_sha256 = self_digest(approval, "approval_sha256")
runtime_attestation = plan.get("owner_runtime_attestation")
if not isinstance(runtime_attestation, dict):
    raise GateError("cutover_unit_inputs_owner_runtime_invalid")
self_digest(runtime_attestation, "attestation_sha256")

if set(unit) != UNIT_FIELDS or unit.get("schema") != UNIT_SCHEMA:
    raise GateError("cutover_unit_inputs_fields_invalid")
identities = []
for name in ("gateway", "routeback", "mac_ops", "browser", "worker"):
    item = unit.get(name)
    if (
        not isinstance(item, dict)
        or set(item) != IDENTITY_FIELDS
        or IDENTITY.fullmatch(str(item.get("user"))) is None
        or IDENTITY.fullmatch(str(item.get("group"))) is None
        or type(item.get("uid")) is not int
        or type(item.get("gid")) is not int
        or item["uid"] <= 0
        or item["gid"] <= 0
    ):
        raise GateError("cutover_unit_inputs_identity_invalid")
    identities.append(item)
operational_identities = unit.get("operational_edge_identities")
operational_socket_groups = unit.get("operational_edge_socket_groups")
if (
    not isinstance(operational_identities, dict)
    or set(operational_identities) != OPERATIONAL_EDGE_DOMAINS
    or not isinstance(operational_socket_groups, dict)
    or set(operational_socket_groups) != OPERATIONAL_EDGE_DOMAINS
):
    raise GateError("cutover_unit_inputs_identity_invalid")
socket_gids = set()
for domain in sorted(OPERATIONAL_EDGE_DOMAINS):
    item = operational_identities[domain]
    socket = operational_socket_groups[domain]
    expected_name = f"muncho-edge-{domain}"
    expected_socket_group = f"muncho-edge-{domain}-c"
    if (
        not isinstance(item, dict)
        or set(item) != IDENTITY_FIELDS
        or item.get("user") != expected_name
        or item.get("group") != expected_name
        or type(item.get("uid")) is not int
        or type(item.get("gid")) is not int
        or item["uid"] <= 0
        or item["gid"] <= 0
        or not isinstance(socket, dict)
        or set(socket) != {"group", "gid"}
        or socket.get("group") != expected_socket_group
        or type(socket.get("gid")) is not int
        or socket["gid"] <= 0
    ):
        raise GateError("cutover_unit_inputs_identity_invalid")
    identities.append(item)
    socket_gids.add(socket["gid"])
target = unit.get("target")
receipt_key_ids = unit.get("operational_edge_receipt_public_key_ids")
try:
    target_address = ipaddress.ip_address(str(target.get("sql_host")))
except (AttributeError, ValueError) as exc:
    raise GateError("cutover_unit_inputs_target_invalid") from exc
if (
    not isinstance(target, dict)
    or set(target) != TARGET_FIELDS
    or target.get("project") != "adventico-ai-platform"
    or target.get("zone") != "europe-west3-a"
    or target.get("vm") != "ai-platform-runtime-01"
    or target.get("database") != "ai_platform_brain"
    or target.get("port") != 5432
    or str(target_address) != target.get("sql_host")
    or target.get("sql_host") != unit.get("database_ip")
    or re.fullmatch(r"[a-z][a-z0-9-]{0,62}", str(target.get("sql_instance")))
    is None
    or not isinstance(target.get("tls_server_name"), str)
    or len(target["tls_server_name"]) > 253
    or re.fullmatch(r"[A-Za-z0-9.-]+", target["tls_server_name"]) is None
    or IDENTITY.fullmatch(str(target.get("writer_login"))) is None
):
    raise GateError("cutover_unit_inputs_target_invalid")
if (
    unit["release_revision"] != expected_revision
    or unit["authority_plan_sha256"] != plan_sha256
    or unit["authority_approval_sha256"] != approval_sha256
    or unit["secret_material_recorded"] is not False
    or unit["secret_digest_recorded"] is not False
    or SHA256.fullmatch(str(unit["bwrap_sha256"])) is None
    or SHA256.fullmatch(str(unit["shell_sha256"])) is None
    or type(unit["worker_client_gid"]) is not int
    or unit["worker_client_gid"] <= 0
    or unit["worker_client_group"] != "muncho-worker-clients"
    or SHA256.fullmatch(str(unit["writer_capability_public_key_id"])) is None
    or SHA256.fullmatch(
        str(unit["operational_edge_key_foundation_sha256"])
    ) is None
    or not isinstance(receipt_key_ids, dict)
    or set(receipt_key_ids) != OPERATIONAL_EDGE_DOMAINS
    or any(
        SHA256.fullmatch(str(key_id)) is None
        for key_id in receipt_key_ids.values()
    )
    or len(set(receipt_key_ids.values())) != len(receipt_key_ids)
    or unit["writer_capability_public_key_id"]
    in set(receipt_key_ids.values())
    or type(unit["release_owner_uid"]) is not int
    or type(unit["release_owner_gid"]) is not int
    or unit["release_owner_uid"] != unit["gateway"]["uid"]
    or unit["release_owner_gid"] != unit["gateway"]["gid"]
    or len({item["uid"] for item in identities}) != len(identities)
    or len(
        {item["gid"] for item in identities}
        | {unit["worker_client_gid"]}
        | socket_gids
    )
    != len(identities) + 1 + len(OPERATIONAL_EDGE_DOMAINS)
):
    raise GateError("cutover_unit_inputs_policy_invalid")
if (
    set(plan) != PLAN_FIELDS
    or plan.get("schema") != PLAN_SCHEMA
    or plan.get("release_revision") != expected_revision
    or SHA256.fullmatch(str(plan.get("owner_subject_sha256"))) is None
    or re.fullmatch(
        r"[0-9a-f]{64}",
        str(plan.get("owner_public_key_ed25519_hex")),
    ) is None
    or plan.get("owner_key_id") != hashlib.sha256(
        bytes.fromhex(plan["owner_public_key_ed25519_hex"])
    ).hexdigest()
    or type(plan.get("created_at_unix")) is not int
    or plan["created_at_unix"] <= 0
    or plan.get("secret_material_recorded") is not False
    or plan.get("secret_digest_recorded") is not False
    or set(runtime_attestation) != RUNTIME_ATTESTATION_FIELDS
    or runtime_attestation.get("schema")
    != "muncho-production-owner-runtime-attestation.v1"
    or runtime_attestation.get("revision") != expected_revision
    or any(
        SHA256.fullmatch(str(runtime_attestation.get(name))) is None
        for name in (
            "manifest_sha256", "tree_sha256", "interpreter_sha256",
            "pyvenv_cfg_sha256", "sys_path_sha256",
            "required_modules_sha256",
        )
    )
    or runtime_attestation.get("module_origins_release_local") is not True
    or runtime_attestation.get("ambient_python_environment_present") is not False
    or runtime_attestation.get("secret_material_recorded") is not False
    or runtime_attestation.get("secret_digest_recorded") is not False
    or not isinstance(plan.get("unit_inputs"), dict)
    or set(plan["unit_inputs"]) != PAYLOAD_FIELDS
    or plan["unit_inputs"].get("schema") != PAYLOAD_SCHEMA
    or plan["unit_inputs"].get("secret_material_recorded") is not False
    or plan["unit_inputs"].get("secret_digest_recorded") is not False
):
    raise GateError("cutover_unit_input_plan_invalid")
if set(approval) != APPROVAL_FIELDS or (
    approval.get("schema") != APPROVAL_SCHEMA
    or approval.get("purpose") != "production_cutover_unit_inputs"
    or approval.get("plan_sha256") != plan_sha256
    or approval.get("release_revision") != expected_revision
    or approval.get("owner_subject_sha256") != plan.get("owner_subject_sha256")
    or approval.get("owner_public_key_ed25519_hex")
    != plan.get("owner_public_key_ed25519_hex")
    or approval.get("owner_key_id") != plan.get("owner_key_id")
    or SHA256.fullmatch(str(approval.get("nonce_sha256"))) is None
    or type(approval.get("issued_at_unix")) is not int
    or type(approval.get("expires_at_unix")) is not int
    or not 1 <= approval["expires_at_unix"] - approval["issued_at_unix"] <= 3600
    or re.fullmatch(
        r"[0-9a-f]{128}", str(approval.get("signature_ed25519_hex"))
    ) is None
    or approval.get("approved") is not True
):
    raise GateError("cutover_unit_inputs_owner_approval_invalid")
expected = {
    "schema": UNIT_SCHEMA,
    "release_revision": plan["release_revision"],
    "authority_plan_sha256": plan_sha256,
    "authority_approval_sha256": approval_sha256,
    **{
        name: item
        for name, item in plan["unit_inputs"].items()
        if name != "schema"
    },
}
if unit != expected:
    raise GateError("cutover_unit_inputs_authority_drifted")
print(json.dumps({
    "schema": "muncho-auto-deploy-cutover-unit-inputs.v1",
    "release_revision": expected_revision,
    "unit_inputs_path": str(unit_path),
    "unit_inputs_sha256": hashlib.sha256(unit_raw).hexdigest(),
    "authority_plan_sha256": plan_sha256,
    "authority_approval_sha256": approval_sha256,
    "ok": True,
    "secret_material_recorded": False,
    "secret_digest_recorded": False,
}, ensure_ascii=True, sort_keys=True, separators=(",", ":")))
PY
}

require_cutover_unit_inputs() {
