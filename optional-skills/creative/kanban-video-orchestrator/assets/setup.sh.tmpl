#!/usr/bin/env bash
# ═══════════════════════════════════════════════════════════════════════
# Video Pipeline Setup — {{TITLE}}
# Generated at: {{GENERATED_AT}}
# Slug: {{SLUG}}
# Tenant: {{TENANT}}
# ═══════════════════════════════════════════════════════════════════════
set -euo pipefail

PROJECT_SLUG="{{SLUG}}"
WORKSPACE="$HOME/projects/video-pipeline/${PROJECT_SLUG}"
TENANT="{{TENANT}}"

# ─────────────────────────────────────────────────────────────────────
# 1. Verify required API keys
# ─────────────────────────────────────────────────────────────────────
echo "═══ Checking required API keys ═══"

check_key() {
    local var="$1"
    local kc_account="${2:-hermes}"
    local kc_service="${3:-$1}"
    local _hermes_env="${HERMES_HOME:-$HOME/.hermes}/.env"
    if grep -q "^${var}=" "$_hermes_env" 2>/dev/null && [ -n "$(grep "^${var}=" "$_hermes_env" | cut -d= -f2-)" ]; then
        echo " ✓ ${var} (env)"
        return 0
    fi
    if command -v security >/dev/null 2>&1 && security find-generic-password -a "${kc_account}" -s "${kc_service}" -w >/dev/null 2>&1; then
        echo " ✓ ${var} (Keychain ${kc_account}/${kc_service})"
        return 0
    fi
    echo " ✗ ${var} not set in ${_hermes_env} or Keychain (${kc_account}/${kc_service})"
    return 1
}

{{KEY_CHECKS}}

python3 -c "import yaml" 2>/dev/null || { echo "PyYAML missing; install with pip install pyyaml" >&2; exit 1; }

# ─────────────────────────────────────────────────────────────────────
# 2. Create project workspace
# ─────────────────────────────────────────────────────────────────────
echo "═══ Creating project workspace ═══"
mkdir -p \
  "$WORKSPACE/taste/style-frames" \
  "$WORKSPACE/audio/voiceover" \
  "$WORKSPACE/audio/sfx" \
  "$WORKSPACE/assets/logos" \
  "$WORKSPACE/assets/fonts" \
  "$WORKSPACE/assets/existing-footage" \
  "$WORKSPACE/scenes" \
  "$WORKSPACE/checkpoints" \
  "$WORKSPACE/tools" \
  "$WORKSPACE/output"
{{SCENE_DIRS}}
echo " ✓ $WORKSPACE"

# ─────────────────────────────────────────────────────────────────────
# 3. Create Hermes profiles
# ─────────────────────────────────────────────────────────────────────
echo "═══ Creating Hermes profiles ═══"

create_profile() {
    local profile="$1"
    local description="$2"
    local dir="$HOME/.hermes/profiles/$profile"
    local marker="$dir/.kanban-video-orchestrator-owner"

    if [ -d "$dir" ]; then
        if [ ! -f "$marker" ]; then
            echo " ✗ Profile already exists and is not owned by this pipeline: $profile" >&2
            echo "   Rename this profile in the plan (recommended: ${PROJECT_SLUG}-$profile) or back it up manually." >&2
            exit 1
        fi
        if [ "$(cat "$marker")" != "$PROJECT_SLUG" ]; then
            echo " ✗ Profile $profile belongs to a different video pipeline: $(cat "$marker")" >&2
            exit 1
        fi
        echo " ↻ profile exists: $profile"
    else
        hermes profile create "$profile" --clone --description "$description"
    fi

    local cfg_path="$dir/config.yaml"
    if [ ! -f "$cfg_path" ]; then
        printf '{}\n' > "$cfg_path"
    fi

    printf '%s\n' "$PROJECT_SLUG" > "$marker"
    hermes profile describe "$profile" --text "$description" >/dev/null
}

{{PROFILE_CREATE_COMMANDS}}

# ─────────────────────────────────────────────────────────────────────
# 4. Configure profiles (toolsets + always_load skills only)
# ─────────────────────────────────────────────────────────────────────
echo "═══ Configuring profiles ═══"

configure_profile() {
    local profile="$1"
    local toolsets_json="$2"
    local skills_json="$3"
    python3 - "$profile" "$toolsets_json" "$skills_json" <<'PY'
import json
import os
import sys
import yaml

profile, toolsets_json, skills_json = sys.argv[1:4]
toolsets = json.loads(toolsets_json)
skills = json.loads(skills_json)
path = os.path.expanduser(f"~/.hermes/profiles/{profile}/config.yaml")
if not os.path.exists(path):
    print(f"profile config not found: {path}", file=sys.stderr)
    sys.exit(1)

with open(path, encoding="utf-8") as fh:
    cfg = yaml.safe_load(fh) or {}

cfg["toolsets"] = toolsets
cfg.setdefault("skills", {})["always_load"] = skills
platform_toolsets = cfg.setdefault("platform_toolsets", {})
platform_toolsets["cli"] = toolsets

with open(path, "w", encoding="utf-8") as fh:
    yaml.safe_dump(cfg, fh, sort_keys=False, allow_unicode=True)

with open(path, encoding="utf-8") as fh:
    after = yaml.safe_load(fh) or {}

assert after.get("toolsets") == toolsets, f"toolsets mismatch for {profile}"
assert after.get("platform_toolsets", {}).get("cli") == toolsets, f"platform_toolsets.cli mismatch for {profile}"
assert after.get("skills", {}).get("always_load") == skills, f"skills.always_load mismatch for {profile}"
print(f" ✓ {profile}")
PY
}

{{PROFILE_CONFIG_COMMANDS}}

# ─────────────────────────────────────────────────────────────────────
# 5. Write SOUL.md per profile
# ─────────────────────────────────────────────────────────────────────
echo "═══ Writing profile personalities ═══"
{{SOUL_WRITES}}

# ─────────────────────────────────────────────────────────────────────
# 6. Write project files and copy assets
# ─────────────────────────────────────────────────────────────────────
echo "═══ Writing brief + TEAM + taste ═══"

cat > "$WORKSPACE/brief.md" <<'BRIEF_EOF'
{{BRIEF_CONTENTS}}
BRIEF_EOF

cat > "$WORKSPACE/TEAM.md" <<'TEAM_EOF'
{{TEAM_CONTENTS}}
TEAM_EOF

{{TASTE_WRITES}}

{{ASSET_COPIES}}

# ─────────────────────────────────────────────────────────────────────
# 7. Verify required artifacts
# ─────────────────────────────────────────────────────────────────────
echo "═══ Verifying setup artifacts ═══"
for p in "$WORKSPACE/brief.md" "$WORKSPACE/TEAM.md" "$WORKSPACE/taste/brand-guide.md" "$WORKSPACE/taste/emotional-dna.md"; do
    [ -f "$p" ] || { echo " ✗ missing $p" >&2; exit 1; }
done
for profile in {{PROFILE_NAMES}}; do
    [ -f "$HOME/.hermes/profiles/$profile/SOUL.md" ] || { echo " ✗ missing SOUL.md for $profile" >&2; exit 1; }
done

hermes kanban init 2>/dev/null || true

# ─────────────────────────────────────────────────────────────────────
# 8. Fire the initial kanban task
# ─────────────────────────────────────────────────────────────────────
echo "═══ Firing initial kanban task ═══"

hermes kanban create "Direct production of {{TITLE}}" \
  --assignee {{DIRECTOR_PROFILE}} \
  --workspace dir:"$WORKSPACE" \
  --tenant "$TENANT" \
  --priority 2 \
  --max-runtime 4h \
  --body "$(cat <<EOF
Read brief.md, TEAM.md, and taste/.
Decompose into the team graph defined in TEAM.md.
Do not execute the work yourself. Route every concrete subtask via kanban create.

All child tasks MUST use the Hermes CLI flags:
  --workspace dir:"$WORKSPACE"
  --tenant "$TENANT"

Runtime defaults:
  renderer: 1800s
  editor: 600s
  voice-talent: 300s
  image-to-video-generator: 900s

Tasks longer than 5 minutes should emit periodic heartbeats with progress.
EOF
)"

echo
echo "Setup complete"
echo "Monitor with: hermes kanban watch --tenant $TENANT"
echo "Board snapshot: hermes kanban list --tenant $TENANT"
echo "Workspace: $WORKSPACE"
