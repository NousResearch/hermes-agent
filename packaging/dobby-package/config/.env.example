# Dobby package environment template.
# Copy to .env for a local install. Keep real .env files out of support bundles.
# Copy these names exactly, then replace every angle-bracket placeholder in the
# real .env file. Do not paste real values into this example.

# BYO OpenAI-compatible model endpoint.
# Use your provider's endpoint and model; do not paste real keys into examples.
HERMES_INFERENCE_PROVIDER=custom
OPENAI_BASE_URL=<MODEL_ENDPOINT_URL>
OPENAI_API_KEY=<MODEL_API_KEY>
HERMES_MODEL=<MODEL_ID>

# BYO Discord application.
# Create an app/bot in the Discord Developer Portal, then replace these values.
DISCORD_CLIENT_ID=<DISCORD_CLIENT_ID>
DISCORD_BOT_TOKEN=<DISCORD_BOT_TOKEN>
DISCORD_HOME_CHANNEL=<DISCORD_CHANNEL_ID>
DISCORD_ALLOWED_USERS=<DISCORD_USER_ID_LIST>
DISCORD_ALLOWED_CHANNELS=<DISCORD_CHANNEL_ID_LIST>

# Safe gateway defaults: explicit allowlists, mention-required channels, no allow-all.
DISCORD_REQUIRE_MENTION=true
DISCORD_FREE_RESPONSE_CHANNELS=
DISCORD_ALLOW_ALL_USERS=false
GATEWAY_ALLOW_ALL_USERS=false

# Local safety defaults.
HERMES_HOME=<FRESH_HERMES_HOME>
HERMES_REDACT_SECRETS=true
HERMES_WRITE_SAFE_ROOT=<LOCAL_WORKSPACE_ROOT>

# Signed webhook inbox.
WEBHOOK_SECRET=<WEBHOOK_HMAC_SECRET_MIN_32_CHARS>
