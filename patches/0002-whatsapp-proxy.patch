@@ -570,7 +575,10 @@ class WhatsAppAdapter(BasePlatformAdapter):
             if bridge_ok:
                 try:
                     import aiohttp
-                    async with aiohttp.ClientSession() as session:
+                    proxy_url = resolve_proxy_url(platform_env_var="WHATSAPP_PROXY")
+                    sess_kw, req_kw = proxy_kwargs_for_aiohttp(proxy_url)
+                    async with aiohttp.ClientSession(**sess_kw) as session:
                         async with session.get(
                             f"http://127.0.0.1:{self._bridge_port}/health",
                         ) as resp:
@@ -594,7 +602,10 @@ class WhatsAppAdapter(BasePlatformAdapter):
                                     print(f"[{self.name}] Using existing bridge (status: {bridge_status})")
