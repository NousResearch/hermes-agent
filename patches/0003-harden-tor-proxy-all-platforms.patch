diff --git a/plugins/platforms/slack/adapter.py b/plugins/platforms/slack/adapter.py
index bf76bd8502..8fc5874e5f 100644
--- a/plugins/platforms/slack/adapter.py
+++ b/plugins/platforms/slack/adapter.py
@@ -495,10 +495,21 @@ def _resolve_slack_proxy_url() -> Optional[str]:
 
     normalized = proxy_url.lower()
     if not normalized.startswith(("http://", "https://")):
-        logger.info(
-            "[Slack] Ignoring unsupported proxy scheme for Slack transport: %s",
-            safe_url_for_log(proxy_url),
-        )
+        # HARDENING: if ALL_PROXY=socks5:// is set, user intended Tor routing.
+        # Slack SDK rejects SOCKS5 — warn prominently that Slack will leak.
+        _all_proxy = os.environ.get("ALL_PROXY") or ""
+        if "socks5://" in _all_proxy.lower():
+            logger.warning(
+                "[Slack] SOCKS5 proxy detected (ALL_PROXY=%s) but Slack SDK only supports HTTP proxies. "
+                "Slack connections will NOT route through Tor. To fix: run a local HTTP->SOCKS5 proxy "
+                "(e.g. privoxy) and set ALL_PROXY=http://127.0.0.1:8118 instead.",
+                safe_url_for_log(_all_proxy),
+            )
+        else:
+            logger.info(
+                "[Slack] Ignoring unsupported proxy scheme for Slack transport: %s",
+                safe_url_for_log(proxy_url),
+            )
         return None
 
     if any(is_host_excluded_by_no_proxy(host) for host in _SLACK_PROXY_HOSTS):
