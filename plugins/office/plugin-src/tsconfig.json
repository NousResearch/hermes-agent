{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "../dashboard/dist",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "types": ["react", "three"]
  },
  "include": ["src"]
}
