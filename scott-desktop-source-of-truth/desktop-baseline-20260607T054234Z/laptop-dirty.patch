+  // to main when the pinned branch no longer exists on origin).
+  let branchArgs = []
+  try {
+    const head = await runGit(['rev-parse', '--abbrev-ref', 'HEAD'], { cwd: updateRoot })
+    const current = (head.stdout || '').trim()
