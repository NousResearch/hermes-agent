+
+        err_str = str(first_err)
+        # ZAI vision models (glm-4v-flash etc.) return error code 1210
+        # ("API Φ░âτö¿σÅéµò░µ£ëΦ»»") when max_tokens is passed on multimodal
+        # calls.  The error message does NOT contain "max_tokens" so the
