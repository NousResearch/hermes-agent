+  return {
+    binary: metadata.binary,
+    byteSize: metadata.byteSize,
+    kind: 'file',
+    large: metadata.large,
+    label: path.basename(resolved),
+    language: PREVIEW_LANGUAGE_BY_EXT[ext] || 'text',
+    mimeType,
+    path: resolved,
+    previewKind,
+    source: raw,
+    url: pathToFileURL(resolved).toString()
