-class ModelAssignment(BaseModel):
-    """Payload for POST /api/model/set ΓÇö assign a provider/model to a slot.
-
-    scope="main"        ΓåÆ writes model.provider + model.default
-    scope="auxiliary"   ΓåÆ writes auxiliary.<task>.provider + auxiliary.<task>.model
-    scope="auxiliary" with task=""  ΓåÆ applied to every auxiliary.* slot
-    scope="auxiliary" with task="__reset__"  ΓåÆ resets every slot to provider="auto"
-    """
-    scope: str
-    provider: str
-    model: str
-    task: str = ""
-    # Optional OpenAI-compatible endpoint URL. Only honored for custom/local
-    # providers on the main slot ΓÇö lets the GUI configure a self-hosted endpoint
-    # (vLLM, llama.cpp, Ollama, ΓÇª) that needs no API key. The runtime resolver
-    # reads model.base_url from config (it ignores OPENAI_BASE_URL), so this is
-    # the path that actually wires a local endpoint into resolution.
-    base_url: str = ""
