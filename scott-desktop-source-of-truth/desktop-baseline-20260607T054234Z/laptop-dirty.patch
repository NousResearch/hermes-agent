+    const readTitle = () => window?.webContents?.getTitle?.() || ''
+    const scheduleGrace = () => {
+      if (graceTimer) clearTimeout(graceTimer)
+      graceTimer = setTimeout(() => finish(readTitle()), RENDER_TITLE_GRACE_MS)
+    }
