+    let stdout = ''
+    let stderr = ''
+    child.stdout.on('data', chunk => {
+      const text = chunk.toString()
+      stdout += text
+      options.onLine?.('stdout', text)
+    })
+    child.stderr.on('data', chunk => {
+      const text = chunk.toString()
+      stderr += text
+      options.onLine?.('stderr', text)
+    })
