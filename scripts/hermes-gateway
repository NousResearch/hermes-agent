#!/usr/bin/env python3
"""Legacy shim for gateway management.

Deprecated: use `hermes gateway ...` directly.
This shim exists only for backward compatibility and forwards all actions
into the canonical Hermes CLI gateway command group.
"""

from __future__ import annotations

import shutil
import subprocess
import sys


def _forward_args(argv: list[str]) -> list[str]:
    # Historic behavior: running the script with no args started foreground run.
    if len(argv) <= 1:
        return ["run"]
    return argv[1:]


def main(argv: list[str] | None = None) -> int:
    argv = argv or sys.argv
    forwarded = _forward_args(argv)

    print(
        "[deprecated] scripts/hermes-gateway is a compatibility shim. "
        "Use `hermes gateway ...`.",
        file=sys.stderr,
    )

    hermes_bin = shutil.which("hermes")
    if hermes_bin:
        cmd = [hermes_bin, "gateway", *forwarded]
    else:
        cmd = [sys.executable, "-m", "hermes_cli.main", "gateway", *forwarded]

    result = subprocess.run(cmd)
    return result.returncode


if __name__ == "__main__":
    raise SystemExit(main())
