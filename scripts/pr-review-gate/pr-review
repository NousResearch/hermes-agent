#!/usr/bin/env bash
# pr-review — ด่านตรวจโค้ด AI ก่อน merge (F2)
# ใช้: pr-review <ลิงก์ PR/MR> [review|describe|improve]   (ค่าเริ่มต้น: review)
# ผล: AI รีวิวโค้ดแล้วโพสต์ความเห็นลงใน PR นั้นเป็นภาษาไทย
set -euo pipefail

if [ "$#" -lt 1 ]; then
  echo "ใช้: pr-review <ลิงก์ PR/MR> [review|describe|improve]"
  exit 2
fi

PR_URL="$1"
CMD="${2:-review}"
case "${CMD}" in
  review|describe|improve|ask|reflect) ;;
  *) echo "คำสั่งย่อยไม่ถูกต้อง: ${CMD} (ใช้ได้: review, describe, improve, ask, reflect)"; exit 2 ;;
esac
HOME_GATE_DIR="${HOME}/.hermes/pr-review-gate"
VENV="${HOME_GATE_DIR}/venv"
CONFIG="${HOME_GATE_DIR}/pr_agent.toml"

if [ ! -x "${VENV}/bin/pr-agent" ]; then
  echo "ยังไม่ได้ติดตั้ง — รัน: bash scripts/pr-review-gate/install-pr-review-gate.sh"
  exit 10
fi

# โหลด key จาก ~/.hermes/.env และ .hermes/.env ของ repo ปัจจุบัน (ไม่พิมพ์ค่าออกจอ)
load_env() {
  local f="$1"
  [ -f "$f" ] || return 0
  while IFS= read -r raw || [ -n "$raw" ]; do
    # ข้ามเฉพาะบรรทัด comment เต็มบรรทัด — ห้ามตัด # กลางค่า (key/URL บางตัวมี #)
    case "$raw" in \#*|"") continue ;; esac
    line="$raw"
    case "$line" in
      *=*)
        key="${line%%=*}"; key="$(echo "$key" | tr -d '[:space:]')"
        val="${line#*=}"; val="${val%\"}"; val="${val#\"}"; val="${val%\'}"; val="${val#\'}"
        if [[ "$key" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]] && [ -z "${!key:-}" ]; then
          export "$key"="$val"
        fi
        ;;
    esac
  done < "$f"
}
load_env "${HOME}/.hermes/.env"
ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
[ -n "${ROOT}" ] && load_env "${ROOT}/.hermes/.env"

# GitHub token: ใช้ของ gh CLI ถ้ายังไม่ได้ตั้งเอง
if [ -z "${GITHUB__USER_TOKEN:-}" ] && command -v gh >/dev/null 2>&1; then
  export GITHUB__USER_TOKEN="$(gh auth token 2>/dev/null || true)"
fi
# GitLab (สำหรับ repo งานทีมบน GitLab): ตั้ง 2 ค่านี้ใน ~/.hermes/.env
#   GITLAB__PERSONAL_ACCESS_TOKEN=<token สิทธิ์ api>
#   GITLAB_URL=https://<gitlab-ของทีม>   (เฉพาะ GitLab แบบติดตั้งเอง)
# เข้าโหมด GitLab เฉพาะเมื่อโดเมนของลิงก์ตรงกับ GitLab ที่รู้จักจริง (จาก Codex review:
# ห้ามเหมาว่า "ไม่ใช่ github.com = GitLab" เพราะลิงก์ผิด/เว็บอื่นจะหลุดเข้าโหมดผิด)
if [ -n "${GITLAB__PERSONAL_ACCESS_TOKEN:-}" ]; then
  pr_host="${PR_URL#*://}"; pr_host="${pr_host%%/*}"
  gitlab_host=""
  if [ -n "${GITLAB_URL:-}" ]; then
    gitlab_host="${GITLAB_URL#*://}"; gitlab_host="${gitlab_host%%/*}"
  fi
  if [ -n "${gitlab_host}" ] && [ "${pr_host}" = "${gitlab_host}" ]; then
    export CONFIG__GIT_PROVIDER="gitlab"
    export GITLAB__URL="${GITLAB_URL}"
  elif [ "${pr_host}" = "gitlab.com" ]; then
    export CONFIG__GIT_PROVIDER="gitlab"
  fi
fi
# ส่งคีย์ Gemini ให้ pr-agent ทั้งสองชื่อที่มันรองรับ
if [ -n "${GEMINI_API_KEY:-}" ]; then
  export GOOGLE_AI_STUDIO__GEMINI_API_KEY="${GEMINI_API_KEY}"
fi

# โหลดค่าจากไฟล์ตั้งค่าประจำเครื่อง (~/.hermes/pr-review-gate/pr_agent.toml)
# เป็นตัวแปรระบบแบบ SECTION__KEY ให้ pr-agent เห็นจริง (จาก Codex review:
# เดิมไฟล์นี้ถูกติดตั้งแต่ไม่ถูกใช้ — เครื่องที่ repo ไม่มี .pr_agent.toml จะเสียกติกาไทยเงียบๆ)
if [ -f "${CONFIG}" ]; then
  toml_exports="$("${VENV}/bin/python" - "$CONFIG" <<'PY'
import shlex, sys, tomllib
with open(sys.argv[1], "rb") as f:
    data = tomllib.load(f)
for section, kv in data.items():
    if not isinstance(kv, dict):
        continue
    for key, val in kv.items():
        name = f"{section}__{key}".upper()
        if isinstance(val, bool):
            val = "true" if val else "false"
        elif isinstance(val, list):
            val = "[" + ",".join(f'"{v}"' for v in val) + "]"
        print(f"[ -n \"${{{name}:-}}\" ] || export {name}={shlex.quote(str(val))}")
PY
)"
  eval "${toml_exports}"
fi

# ตั้งค่ารุ่น AI ผ่านตัวแปรระบบ (override ได้ด้วย PR_REVIEW_MODEL · ชนะค่าในไฟล์)
export CONFIG__MODEL="${PR_REVIEW_MODEL:-${CONFIG__MODEL:-gemini/gemini-2.5-flash}}"
export CONFIG__FALLBACK_MODELS="${CONFIG__FALLBACK_MODELS:-[\"openrouter/anthropic/claude-haiku-4.5\"]}"
# รุ่น AI ใหม่ที่ pr-agent ยังไม่รู้จักเพดาน token — บอกค่าให้ตรงนี้
export CONFIG__CUSTOM_MODEL_MAX_TOKENS="${PR_REVIEW_MAX_TOKENS:-128000}"

if [ "${PR_REVIEW_DRYRUN:-}" = "1" ]; then
  echo "[dry-run] ค่าที่จะส่งให้ pr-agent:"
  env | grep -E "^(CONFIG__|PR_REVIEWER__|PR_DESCRIPTION__)" | cut -d= -f1 | sort
  exit 0
fi
exec "${VENV}/bin/pr-agent" --pr_url "${PR_URL}" "${CMD}"
