{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.NousResearch/hermes-agent",
  "title": "Hermes Agent",
  "description": "Control Hermes Agent conversations, messaging, approvals, and events over MCP.",
  "version": "0.14.0",
  "websiteUrl": "https://hermes-agent.nousresearch.com/docs/guides/hermes-as-an-mcp-server",
  "repository": {
    "url": "https://github.com/NousResearch/hermes-agent",
    "source": "github",
    "id": "1024554267"
  },
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "hermes-agent",
      "version": "0.14.0",
      "transport": {
        "type": "stdio"
      },
      "packageArguments": [
        {
          "type": "positional",
          "value": "mcp"
        },
        {
          "type": "positional",
          "value": "serve"
        }
      ]
    }
  ]
}
