#!/usr/bin/env python3
from __future__ import annotations

import argparse
import getpass
import json
import os
import shutil
import sys
import textwrap
import urllib.error
import urllib.request
from pathlib import Path


DEFAULT_BASE_URL = "__PUBLIC_BASE_URL__"
PLACEHOLDER_BASE_URL = "__PUBLIC" "_BASE_URL__"
if DEFAULT_BASE_URL == PLACEHOLDER_BASE_URL:
    DEFAULT_BASE_URL = "http://localhost:8000"
CONFIG_DIR = Path.home() / ".second-brain"
CONFIG_PATH = CONFIG_DIR / "config.json"


def normalize_token(token: str | None) -> str:
    value = (token or "").strip()
    if value.lower().startswith("bearer "):
        return value.split(None, 1)[1].strip()
    if value.lower().startswith("authorization: bearer "):
        return value.split(None, 2)[2].strip()
    return value


def load_config() -> dict:
    config = {}
    if CONFIG_PATH.exists():
        config = json.loads(CONFIG_PATH.read_text())
    config["base_url"] = os.environ.get("SECOND_BRAIN_BASE_URL", config.get("base_url", DEFAULT_BASE_URL)).rstrip("/")
    config["admin_key"] = os.environ.get("SECOND_BRAIN_ADMIN_KEY", config.get("admin_key", ""))
    config["token"] = normalize_token(os.environ.get("SECOND_BRAIN_TOKEN", config.get("token", "")))
    return config


def save_config(config: dict) -> None:
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    CONFIG_PATH.write_text(json.dumps(config, indent=2) + "\n")
    CONFIG_PATH.chmod(0o600)


def request_json(method: str, url: str, *, headers: dict | None = None, body: dict | None = None, timeout: int = 300) -> dict:
    data = None
    req_headers = {"User-Agent": "second-brain-cli/0.1", **(headers or {})}
    if body is not None:
        data = json.dumps(body).encode()
        req_headers = {"Content-Type": "application/json", **req_headers}
    req = urllib.request.Request(url, data=data, headers=req_headers, method=method)
    try:
        with urllib.request.urlopen(req, timeout=timeout) as response:
            payload = response.read().decode()
    except urllib.error.HTTPError as exc:
        detail = exc.read().decode()
        raise SystemExit(f"HTTP {exc.code}: {detail}") from exc
    except urllib.error.URLError as exc:
        raise SystemExit(f"Connection error: {exc}") from exc
    return json.loads(payload) if payload else {}


def print_json(data: dict) -> None:
    print(json.dumps(data, indent=2, ensure_ascii=False))


def auth_headers(config: dict, *, admin: bool = False) -> dict:
    if admin:
        if not config.get("admin_key"):
            raise SystemExit("Missing admin key. Run `second-brain config --admin-key ...` or set SECOND_BRAIN_ADMIN_KEY.")
        return {"X-API-Key": config["admin_key"]}
    if not config.get("token"):
        raise SystemExit("Missing user token. Run `second-brain connect --token ...` or set SECOND_BRAIN_TOKEN.")
    return {"Authorization": f"Bearer {config['token']}"}


def admin_or_token_headers(config: dict) -> dict:
    if config.get("admin_key"):
        return {"X-API-Key": config["admin_key"]}
    return auth_headers(config)


def prompt_value(value: str | None, label: str, *, secret: bool = False, required: bool = True) -> str:
    if value:
        return value
    prompt = f"{label}: "
    answer = getpass.getpass(prompt) if secret else input(prompt)
    if required and not answer.strip():
        raise SystemExit(f"{label} is required.")
    return answer.strip()


def normalize_cli_source_type(value: str) -> str:
    source_type = value.strip().lower().replace("-", "_")
    if source_type in {"drive", "google_drive", "gdrive"}:
        return "drive_public"
    return source_type


def install_hermes_skill() -> str:
    script_path = Path(__file__).resolve()
    skill_dir = script_path.parents[1]
    source = skill_dir / "SKILL.md"
    if not source.exists():
        return "Hermes skill source not found; CLI config was saved only."
    hermes_home = Path(os.environ.get("HERMES_HOME", Path.home() / ".hermes"))
    dest_dir = hermes_home / "skills" / "productivity" / "company-second-brain"
    if skill_dir.resolve() == dest_dir.resolve():
        return f"Hermes skill already installed at {dest_dir / 'SKILL.md'}"
    dest_scripts = dest_dir / "scripts"
    dest_scripts.mkdir(parents=True, exist_ok=True)
    shutil.copy2(source, dest_dir / "SKILL.md")
    shutil.copy2(script_path, dest_scripts / "second-brain")
    (dest_scripts / "second-brain").chmod(0o755)
    return f"Installed Hermes skill to {dest_dir / 'SKILL.md'}"


def cmd_config(args: argparse.Namespace) -> None:
    config = load_config()
    if args.base_url:
        config["base_url"] = args.base_url.rstrip("/")
    if args.admin_key:
        config["admin_key"] = args.admin_key
    if args.token:
        config["token"] = normalize_token(args.token)
    save_config(config)
    print_json({
        "base_url": config.get("base_url"),
        "admin_key": "set" if config.get("admin_key") else "",
        "token": "set" if config.get("token") else "",
        "path": str(CONFIG_PATH),
    })


def cmd_connect(args: argparse.Namespace) -> None:
    config = load_config()
    if args.base_url:
        config["base_url"] = args.base_url.rstrip("/")
    if args.token:
        config["token"] = normalize_token(args.token)
    if not config.get("token"):
        raise SystemExit("Missing token. Run `second-brain connect --token USER_TOKEN`.")
    save_config(config)
    skill_status = "Skipped Hermes skill install."
    if not args.no_hermes_skill:
        skill_status = install_hermes_skill()
    identity = request_json("GET", f"{config['base_url']}/api/me", headers=auth_headers(config), timeout=30)
    print_json({
        "status": "connected",
        "config": str(CONFIG_PATH),
        "identity": identity,
        "hermes_skill": skill_status,
        "try": "second-brain query \"What documents can I access?\"",
    })


def cmd_admin_token_create(args: argparse.Namespace) -> None:
    config = load_config()
    body = {
        "email": args.email,
        "name": args.name or args.email,
        "groups": args.group or [],
        "expires_days": args.expires_days,
    }
    if args.admin:
        body["role"] = "admin"
        if "role_admin" not in body["groups"]:
            body["groups"].append("role_admin")
    data = request_json("POST", f"{config['base_url']}/api/admin/tokens", headers=auth_headers(config, admin=True), body=body)
    if args.save_user_token:
        config["token"] = data["token"]
        save_config(config)
    print_json(data)


def cmd_me(args: argparse.Namespace) -> None:
    config = load_config()
    print_json(request_json("GET", f"{config['base_url']}/api/me", headers=auth_headers(config)))


def cmd_workspaces(args: argparse.Namespace) -> None:
    config = load_config()
    print_json(request_json("GET", f"{config['base_url']}/api/workspaces", headers=auth_headers(config)))


def cmd_query(args: argparse.Namespace) -> None:
    config = load_config()
    query = args.query or sys.stdin.read().strip()
    if not query:
        raise SystemExit("Missing query. Pass it as an argument or stdin.")
    body = {"query": query, "mode": args.mode, "include_references": not args.no_references}
    data = request_json("POST", f"{config['base_url']}/api/query", headers=auth_headers(config), body=body)
    if args.raw:
        print_json(data)
        return
    print(f"Query: {data.get('query', query)}")
    print(f"Allowed workspaces: {', '.join(data.get('allowed_workspaces', []))}")
    print()
    for answer in data.get("answers", []):
        workspace = answer.get("workspace")
        result = answer.get("result") or {}
        print(f"## {workspace}")
        if answer.get("error"):
            print(f"ERROR: {answer['error']}")
            continue
        print(result.get("response", ""))
        refs = result.get("references") or []
        if refs:
            print("\nReferences:")
            for ref in refs:
                print(f"- [{ref.get('reference_id')}] {ref.get('file_path')}")
        print()


def cmd_ingest_text(args: argparse.Namespace) -> None:
    config = load_config()
    if args.file:
        text = Path(args.file).read_text()
        title = args.title or Path(args.file).name
    else:
        text = sys.stdin.read()
        title = args.title
    if not title:
        raise SystemExit("Missing title. Pass --title or use --file.")
    if not text.strip():
        raise SystemExit("Missing text. Pass --file or pipe text on stdin.")
    target = args.target
    legacy_department = (args.department or "").strip().lower().replace("-", "_")
    if target == "public" and legacy_department in {"c_level", "clevel", "department_c_level"}:
        target = "c_level"
    if target == "public" and args.classification in {"confidential", "restricted"}:
        target = "c_level"
    body = {
        "title": title,
        "target": target,
        "department": args.department or target,
        "visibility": args.visibility,
        "classification": args.classification,
        "text": text,
    }
    print_json(
        request_json(
            "POST",
            f"{config['base_url']}/api/documents/text",
            headers=admin_or_token_headers(config),
            body=body,
        )
    )


def cmd_document_status(args: argparse.Namespace) -> None:
    config = load_config()
    print_json(
        request_json(
            "GET",
            f"{config['base_url']}/api/documents/{args.document_id}",
            headers=auth_headers(config, admin=True),
            timeout=30,
        )
    )


def cmd_queue_status(args: argparse.Namespace) -> None:
    config = load_config()
    print_json(
        request_json(
            "GET",
            f"{config['base_url']}/api/queue/status",
            headers=auth_headers(config, admin=True),
            timeout=30,
        )
    )


def source_config_from_args(args: argparse.Namespace, *, update: bool = False) -> dict:
    source_type = getattr(args, "source_type", None)
    config: dict[str, object] = {}
    if source_type == "notion":
        notion_key = args.notion_api_key
        if not update:
            notion_key = prompt_value(notion_key, "Notion API key", secret=True)
        if notion_key:
            config["notion_api_key"] = notion_key
        if args.notion_page_url:
            config["notion_page_url"] = args.notion_page_url
        if args.notion_page_id:
            config["notion_page_id"] = args.notion_page_id
        if args.notion_data_source_id:
            config["notion_data_source_id"] = args.notion_data_source_id
        if args.notion_search_query:
            config["notion_search_query"] = args.notion_search_query
    elif source_type == "drive_public":
        drive_urls = args.drive_url or []
        if not drive_urls and not update:
            drive_urls = [prompt_value(None, "Public Google Drive/Docs URL")]
        if drive_urls:
            config["drive_urls"] = drive_urls
    return config


def cmd_sources_list(args: argparse.Namespace) -> None:
    config = load_config()
    print_json(request_json("GET", f"{config['base_url']}/api/sources", headers=auth_headers(config, admin=True), timeout=30))


def cmd_source_create(args: argparse.Namespace) -> None:
    config = load_config()
    source_type = args.source_type or prompt_value(None, "Source type (notion or drive_public)")
    args.source_type = normalize_cli_source_type(source_type)
    body = {
        "name": prompt_value(args.name, "Source name"),
        "source_type": args.source_type,
        "target": args.target,
        "classification": args.classification,
        "interval_minutes": args.interval_minutes,
        "enabled": not args.disabled,
        "config": source_config_from_args(args),
    }
    print_json(
        request_json(
            "POST",
            f"{config['base_url']}/api/sources",
            headers=auth_headers(config, admin=True),
            body=body,
            timeout=60,
        )
    )


def cmd_source_update(args: argparse.Namespace) -> None:
    config = load_config()
    if args.source_type:
        args.source_type = normalize_cli_source_type(args.source_type)
    body: dict[str, object] = {}
    for key in ("name", "source_type", "target", "classification", "interval_minutes"):
        value = getattr(args, key, None)
        if value is not None:
            body[key] = value
    if args.enabled:
        body["enabled"] = True
    if args.disabled:
        body["enabled"] = False
    if args.reset_schedule:
        body["reset_schedule"] = True
    config_payload = source_config_from_args(args, update=True)
    if config_payload:
        body["config"] = config_payload
    if not body:
        raise SystemExit("No source updates provided.")
    print_json(
        request_json(
            "PATCH",
            f"{config['base_url']}/api/sources/{args.source_id}",
            headers=auth_headers(config, admin=True),
            body=body,
            timeout=60,
        )
    )


def cmd_source_scan(args: argparse.Namespace) -> None:
    config = load_config()
    print_json(
        request_json(
            "POST",
            f"{config['base_url']}/api/sources/{args.source_id}/scan",
            headers=auth_headers(config, admin=True),
            body={"trigger": "manual"},
            timeout=60,
        )
    )


def cmd_source_runs(args: argparse.Namespace) -> None:
    config = load_config()
    print_json(
        request_json(
            "GET",
            f"{config['base_url']}/api/sources/{args.source_id}/runs",
            headers=auth_headers(config, admin=True),
            timeout=30,
        )
    )


def cmd_snippet(args: argparse.Namespace) -> None:
    config = load_config()
    token = args.token or config.get("token") or "USER_TOKEN"
    print(textwrap.dedent(f"""\
    # Company Second Brain

    Use this API for company RAG / second-brain lookup.

    Base URL: {config["base_url"]}
    Auth: Authorization: Bearer {token}

    Query:
    second-brain query "YOUR QUESTION"
    """))


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="second-brain")
    sub = parser.add_subparsers(dest="command", required=True)

    p = sub.add_parser("connect", help="Save token, install Hermes skill, and verify access")
    p.add_argument("--base-url", default=DEFAULT_BASE_URL)
    p.add_argument("--token")
    p.add_argument("--no-hermes-skill", action="store_true")
    p.set_defaults(func=cmd_connect)

    p = sub.add_parser("config", help="Save local CLI config")
    p.add_argument("--base-url")
    p.add_argument("--admin-key")
    p.add_argument("--token")
    p.set_defaults(func=cmd_config)

    p = sub.add_parser("admin-token-create", help="Admin: create a user/agent/IDE token")
    p.add_argument("--email", required=True)
    p.add_argument("--name")
    p.add_argument("--group", action="append", default=[])
    p.add_argument("--expires-days", type=int, default=30)
    p.add_argument("--admin", action="store_true")
    p.add_argument("--save-user-token", action="store_true")
    p.set_defaults(func=cmd_admin_token_create)

    p = sub.add_parser("me", help="Show current token identity")
    p.set_defaults(func=cmd_me)

    p = sub.add_parser("workspaces", help="List accessible workspaces")
    p.set_defaults(func=cmd_workspaces)

    p = sub.add_parser("query", help="Query RAG")
    p.add_argument("query", nargs="?")
    p.add_argument("--mode", default="mix")
    p.add_argument("--no-references", action="store_true")
    p.add_argument("--raw", action="store_true")
    p.set_defaults(func=cmd_query)

    p = sub.add_parser("ingest-text", help="Admin token only: ingest text into RAG")
    p.add_argument("--title")
    p.add_argument("--file")
    p.add_argument("--target", default="public", choices=["public", "c_level"], help="RAG target workspace")
    p.add_argument("--department", help="Legacy metadata field; use --target for routing")
    p.add_argument("--visibility", default="public")
    p.add_argument("--classification", default="internal", choices=["public", "internal", "confidential", "restricted"])
    p.set_defaults(func=cmd_ingest_text)

    p = sub.add_parser("document-status", help="Admin token only: show queued/indexing/indexed/failed status")
    p.add_argument("document_id")
    p.set_defaults(func=cmd_document_status)

    p = sub.add_parser("queue-status", help="Admin token only: show ingest queue depth and document status counts")
    p.set_defaults(func=cmd_queue_status)

    p = sub.add_parser("sources-list", help="Admin: list Notion/Drive document sources")
    p.set_defaults(func=cmd_sources_list)

    p = sub.add_parser("source-create", help="Admin: create a Notion or public Drive source")
    p.add_argument("--type", dest="source_type", choices=["notion", "drive_public", "drive", "google_drive"])
    p.add_argument("--name")
    p.add_argument("--target", default="public", choices=["public", "c_level"])
    p.add_argument("--classification", default="internal", choices=["public", "internal", "confidential", "restricted"])
    p.add_argument("--interval-minutes", type=int, default=1440)
    p.add_argument("--disabled", action="store_true")
    p.add_argument("--notion-api-key")
    p.add_argument("--notion-page-url")
    p.add_argument("--notion-page-id")
    p.add_argument("--notion-data-source-id")
    p.add_argument("--notion-search-query")
    p.add_argument("--drive-url", action="append")
    p.set_defaults(func=cmd_source_create)

    p = sub.add_parser("source-update", help="Admin: update source config or scan schedule")
    p.add_argument("source_id")
    p.add_argument("--type", dest="source_type", choices=["notion", "drive_public", "drive", "google_drive"])
    p.add_argument("--name")
    p.add_argument("--target", choices=["public", "c_level"])
    p.add_argument("--classification", choices=["public", "internal", "confidential", "restricted"])
    p.add_argument("--interval-minutes", type=int)
    p.add_argument("--enabled", action="store_true")
    p.add_argument("--disabled", action="store_true")
    p.add_argument("--reset-schedule", action="store_true")
    p.add_argument("--notion-api-key")
    p.add_argument("--notion-page-url")
    p.add_argument("--notion-page-id")
    p.add_argument("--notion-data-source-id")
    p.add_argument("--notion-search-query")
    p.add_argument("--drive-url", action="append")
    p.set_defaults(func=cmd_source_update)

    p = sub.add_parser("source-scan", help="Admin: queue a manual source scan")
    p.add_argument("source_id")
    p.set_defaults(func=cmd_source_scan)

    p = sub.add_parser("source-runs", help="Admin: show recent source scan runs")
    p.add_argument("source_id")
    p.set_defaults(func=cmd_source_runs)

    p = sub.add_parser("codex-snippet", help="Print an AGENTS.md/Codex setup snippet")
    p.add_argument("--token")
    p.set_defaults(func=cmd_snippet)

    return parser


def main() -> None:
    args = build_parser().parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
