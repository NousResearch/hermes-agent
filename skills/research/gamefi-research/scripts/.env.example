# Copy this file to .env and fill in your token.
#   cp .env.example .env   (macOS/Linux)
#   Copy-Item .env.example .env   (Windows PowerShell)
#
# A GitHub token is optional but recommended: it raises the API rate limit
# for repository search. Create one at https://github.com/settings/tokens
# (a fine-grained token with read-only public access is enough — no scopes
# beyond public repository read are required).
#
# Do NOT commit your real .env file.

GITHUB_TOKEN=
