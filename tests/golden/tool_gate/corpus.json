      },
      "function_name": "tool_call",
      "function_args": {"name": "golden_lookup", "arguments": {"q": "x"}}
    },
    {
      "name": "tool_call parse error leaves bridge unchanged",
      "kind": "unwrap",
      "agent": {"enabled_toolsets": null, "disabled_toolsets": null},
      "function_name": "tool_call",
      "function_args": {"name": "tool_search", "arguments": {}}
    },
    {
      "name": "scope cache hit returns cached names",
      "kind": "scope",
      "agent": {
