#!/usr/bin/env bash
set -euo pipefail

real_codex="${CODEX_REAL_BIN:-/opt/homebrew/bin/codex}"

is_dev_verification=0
for arg in "$@"; do
  case "$arg" in
    *"DEV_VERIFICATION_RESULTS"*|*"Independent Dev Verification"*)
      is_dev_verification=1
      break
      ;;
  esac
done

copy_codex_auth() {
  local target_home="$1"
  if [[ -n "${HERMES_AO_CODEX_AUTH_HOME:-}" && -f "$HERMES_AO_CODEX_AUTH_HOME/auth.json" ]]; then
    mkdir -p "$target_home"
    cp "$HERMES_AO_CODEX_AUTH_HOME/auth.json" "$target_home/auth.json"
    chmod 600 "$target_home/auth.json" 2>/dev/null || true
  fi
}

if [[ "$is_dev_verification" == "1" && -n "${HERMES_AO_VERIFICATION_CODEX_HOME:-}" ]]; then
  export CODEX_HOME="$HERMES_AO_VERIFICATION_CODEX_HOME"
  copy_codex_auth "$CODEX_HOME"
fi

codex_home="${CODEX_HOME:-${HOME:-}/.codex}"

if [[ "$is_dev_verification" == "1" || ( "${HOME:-}" == *"/.oryn-lab" && "${PWD:-}" == "$HOME"* ) ]]; then
  copy_codex_auth "$codex_home"
  config="$codex_home/config.toml"
  mkdir -p "$(dirname "$config")"
  if ! grep -Fq "[projects.\"$PWD\"]" "$config" 2>/dev/null; then
    {
      [[ -s "$config" ]] && printf '\n'
      printf '[projects."%s"]\ntrust_level = "trusted"\n' "$PWD"
    } >> "$config"
  fi
fi

args=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --approval-mode)
      mode="${2:-}"
      shift 2 || true
      if [[ "$mode" == "full-auto" ]]; then
        args+=(--ask-for-approval never --sandbox danger-full-access)
      elif [[ -n "$mode" ]]; then
        args+=(--ask-for-approval "$mode")
      fi
      ;;
    --approval-mode=full-auto)
      args+=(--ask-for-approval never --sandbox danger-full-access)
      shift
      ;;
    --approval-mode=*)
      args+=(--ask-for-approval "${1#--approval-mode=}")
      shift
      ;;
    *)
      args+=("$1")
      shift
      ;;
  esac
done

exec "$real_codex" "${args[@]}"
