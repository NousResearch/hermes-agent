{
  "name": "@hermes/ink",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "esbuild src/entry-exports.ts --bundle --platform=node --format=esm --packages=external --outdir=dist"
  },
  "sideEffects": true,
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "default": "./index.js"
    },
    "./text-input": {
      "types": "./text-input.d.ts",
      "import": "./text-input.js",
      "default": "./text-input.js"
    },
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "ink-text-input": ">=6.0.0",
    "react": ">=19.0.0"
  },
  "dependencies": {
    "@alcalzone/ansi-tokenize": "^0.3.0",
    "auto-bind": "^5.0.1",
    "bidi-js": "^1.0.3",
    "chalk": "^5.6.2",
    "cli-boxes": "^4.0.1",
    "code-excerpt": "^4.0.0",
    "emoji-regex": "^10.6.0",
    "get-east-asian-width": "^1.6.0",
    "indent-string": "^5.0.0",
    "lodash-es": "^4.18.1",
    "react": ">=19.2.7",
    "react-reconciler": "0.33.0",
    "semver": "^7.8.5",
    "signal-exit": "^4.1.0",
    "stack-utils": "^2.0.6",
    "strip-ansi": "^7.2.0",
    "supports-hyperlinks": "^4.5.0",
    "type-fest": "^5.7.0",
    "usehooks-ts": "^3.1.1",
    "wrap-ansi": "^10.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.1"
  }
}
